<!DOCTYPE html>
<html lang="{{ current_locale }}" class="set-nav-dark">
{# NOTE: data-bs-theme is intentionally NOT hardcoded here.
   saveloadscript.js (loaded in <head>) reads localStorage and sets it
   before any CSS is parsed — this prevents FOUC and respects user preference. #}
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no, maximum-scale=5">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="csrf-token" content="{{ csrf_token }}">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="msapplication-tap-highlight" content="no">
    <title>{% block title %}{{ page_title ?? app_name }}{% endblock %} — {{ app_name }}</title>

    {# Vendor css #}
    <link rel="stylesheet" media="screen, print" href="/themes/smart-tierphysio/plugins/waves/waves.min.css">

    {# Base css — SmartAdmin core (includes Bootstrap 5) #}
    <link rel="stylesheet" media="screen, print" href="/themes/smart-tierphysio/css/smartapp.min.css">

    {# Icons #}
    <link rel="stylesheet" media="screen, print" href="/themes/smart-tierphysio/webfonts/smartadmin/sa-icons.css">

    {# App custom overrides #}
    <link rel="stylesheet" media="screen, print" href="/themes/smart-tierphysio/bridge.css">

    {# Save/Load functionality — MUST be in <head> so theme is applied before CSS renders #}
    <script src="/themes/smart-tierphysio/scripts/core/saveloadscript.js"></script>

    {% block head %}{% endblock %}
</head>
<body>

<div class="app-wrap">

    {# ═══════════════════════════════════════════════════════
       TOP HEADER
       ═══════════════════════════════════════════════════════ #}
    <header class="app-header">
        <div class="d-flex flex-grow-1 w-100 me-auto align-items-center">

            {# Mobile hamburger #}
            <button class="mobile-menu-icon me-2 d-flex d-sm-flex d-md-flex d-lg-none flex-shrink-0"
                    data-action="toggle-swap" data-toggleclass="app-mobile-menu-open"
                    aria-label="Menü öffnen">
                <svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#menu"></use></svg>
            </button>

            {# Desktop sidebar collapse #}
            <button type="button" class="collapse-icon me-3 d-none d-lg-inline-flex d-xl-inline-flex d-xxl-inline-flex"
                    data-action="toggle" data-class="set-nav-minified"
                    aria-label="Navigation minimieren">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 5 8">
                    <polygon fill="#878787" points="4.5,1 3.8,0.2 0,4 3.8,7.8 4.5,7 1.5,4"/>
                </svg>
            </button>

            {# Search #}
            <form class="app-search" role="search" action="/patienten" autocomplete="off">
                <input type="text" class="form-control" placeholder="Suchen…" name="q">
            </form>
        </div>

        {# Settings drawer toggle #}
        <button type="button" class="btn btn-system hidden-mobile"
                data-action="toggle-swap" data-toggleclass="open"
                data-target="aside.js-drawer-settings"
                aria-label="Einstellungen">
            <svg class="sa-icon sa-icon-2x">
                <use href="/themes/smart-tierphysio/icons/sprite.svg#settings"></use>
            </svg>
        </button>

        {# Dark / Light toggle #}
        <button type="button" class="btn btn-system" data-action="toggle-theme"
                aria-label="Dark/Light Mode" aria-pressed="false">
            <svg class="sa-icon sa-icon-2x sa-mode-light">
                <use href="/themes/smart-tierphysio/icons/sprite.svg#sun"></use>
            </svg>
            <svg class="sa-icon sa-icon-2x sa-mode-dark">
                <use href="/themes/smart-tierphysio/icons/sprite.svg#moon"></use>
            </svg>
        </button>

        {# Fullscreen #}
        <button type="button" class="btn btn-system d-none d-sm-block d-sm-none d-md-none d-lg-block"
                data-action="app-fullscreen" aria-label="Vollbild" aria-pressed="false">
            <svg class="sa-icon sa-icon-2x sa-fullscreen-on">
                <use href="/themes/smart-tierphysio/icons/sprite.svg#minimize"></use>
            </svg>
            <svg class="sa-icon sa-icon-2x sa-fullscreen-off">
                <use href="/themes/smart-tierphysio/icons/sprite.svg#maximize"></use>
            </svg>
        </button>

        {# Notifications (intake plugin) #}
        {% if intake_unread_count is defined %}
        <button type="button" class="btn btn-system dropdown-toggle no-arrow"
                data-bs-toggle="dropdown" aria-expanded="false" aria-label="Benachrichtigungen">
            {% if intake_unread_count > 0 %}
            <span class="badge badge-icon pos-top pos-end">{{ intake_unread_count > 9 ? '9+' : intake_unread_count }}</span>
            {% endif %}
            <svg class="sa-icon sa-icon-2x">
                <use href="/themes/smart-tierphysio/icons/sprite.svg#bell"></use>
            </svg>
        </button>
        <div class="dropdown-menu dropdown-menu-animated dropdown-xl dropdown-menu-end p-0">
            <div class="notification-header rounded-top mb-2">
                <h4 class="m-0">
                    {{ intake_unread_count ?? 0 }} Neu
                    <small class="mb-0 opacity-80">Patientenanmeldungen</small>
                </h4>
            </div>
            <div class="custom-scroll" style="max-height:320px;overflow-y:auto;">
                {% if intake_latest is defined and intake_latest|length > 0 %}
                <ul class="notification">
                    {% for item in intake_latest %}
                    <li class="unread alert alert-dismissable">
                        <a href="/eingangsmeldungen/{{ item.id }}" class="d-flex align-items-center text-decoration-none">
                            <span class="d-flex flex-column flex-1 ms-1">
                                <span class="name">🐾 {{ item.patient_name }}</span>
                                <span class="msg-a fs-sm">{{ item.owner_first_name }} {{ item.owner_last_name }}</span>
                                <span class="fs-nano text-muted mt-1">{{ item.created_at|datetime_de }}</span>
                            </span>
                        </a>
                    </li>
                    {% endfor %}
                </ul>
                {% else %}
                <div class="p-4 text-center text-muted fs-sm">Keine neuen Anmeldungen 🎉</div>
                {% endif %}
            </div>
            <div class="py-2 px-3 d-block rounded-bottom text-end border-light border-bottom-0 border-end-0 border-start-0">
                <a href="/eingangsmeldungen" class="fs-xs fw-500">Alle anzeigen →</a>
            </div>
        </div>
        {% endif %}

        {# User avatar + dropdown #}
        <button type="button" data-bs-toggle="dropdown"
                title="{{ current_user.email ?? current_user.name }}"
                class="btn-system bg-transparent d-flex flex-shrink-0 align-items-center justify-content-center"
                style="width:38px;height:38px;border-radius:50%;background:var(--bs-primary)!important;color:#fff;border:none;font-size:.75rem;font-weight:700;"
                aria-label="Benutzermenü">
            {{ current_user.name|initials }}
        </button>
        <div class="dropdown-menu dropdown-menu-animated dropdown-menu-end">
            <div class="notification-header rounded-top mb-2">
                <div class="d-flex flex-row align-items-center mt-1 mb-1 color-white">
                    <div class="info-card-text ms-2">
                        <div class="fs-lg text-truncate text-truncate-lg">{{ current_user.name }}</div>
                        <span class="text-truncate text-truncate-md opacity-80 fs-sm">
                            {{ current_user.role == 'admin' ? 'Administrator' : 'Mitarbeiter' }}
                        </span>
                    </div>
                </div>
            </div>
            <div class="dropdown-divider m-0"></div>
            <a href="/einstellungen" class="dropdown-item" role="button">
                <svg class="sa-icon me-1"><use href="/themes/smart-tierphysio/icons/sprite.svg#settings"></use></svg>
                Einstellungen
            </a>
            <div class="dropdown-divider m-0"></div>
            <form action="/logout" method="POST" style="margin:0;">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <button type="submit" class="dropdown-item d-flex align-items-center py-3 fw-500">
                    <span class="text-danger">Abmelden</span>
                    <span class="d-block text-truncate text-truncate-sm ms-auto text-muted fs-xs">{{ current_user.name }}</span>
                </button>
            </form>
        </div>
    </header>

    {# ═══════════════════════════════════════════════════════
       SIDEBAR
       ═══════════════════════════════════════════════════════ #}
    <aside class="app-sidebar d-flex flex-column">

        {# Logo / Brand #}
        <a href="/dashboard" class="app-logo flex-shrink-0">
            <div class="d-flex align-items-center px-3 py-2 gap-2">
                <div style="width:32px;height:32px;background:var(--bs-primary);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg width="20" height="20" viewBox="0 0 100 100" fill="white">
                        <ellipse cx="20" cy="28" rx="8" ry="11" transform="rotate(-15 20 28)"/>
                        <ellipse cx="40" cy="18" rx="7" ry="10" transform="rotate(-5 40 18)"/>
                        <ellipse cx="60" cy="18" rx="7" ry="10" transform="rotate(5 60 18)"/>
                        <ellipse cx="80" cy="28" rx="8" ry="11" transform="rotate(15 80 28)"/>
                        <path d="M50 42 C30 42 18 55 20 68 C22 80 34 88 50 88 C66 88 78 80 80 68 C82 55 70 42 50 42 Z"/>
                    </svg>
                </div>
                <div class="nav-link-text">
                    <div class="fw-700 fs-md lh-1">{{ app_name }}</div>
                    <div class="fs-nano text-muted">v{{ app_version }}</div>
                </div>
            </div>
        </a>

        {# Nav filter #}
        <form class="app-menu-filter-container px-4">
            <input type="text" class="form-control" id="searchInput"
                   placeholder="Filter" autocomplete="off">
            <div class="js-filter-message nav-filter-msg badge bg-secondary btn"
                 data-bs-toggle="tooltip" data-bs-placement="top"
                 data-bs-original-title="Filter zurücksetzen"></div>
        </form>

        {# Primary Navigation #}
        <nav id="js-primary-nav" class="primary-nav flex-grow-1 custom-scroll">
            <ul id="js-nav-menu" class="nav-menu">

                <li class="nav-title"><span>Tierphysio</span></li>

                <li class="{{ is_active('/dashboard') == 'active' ? 'active' : '' }}">
                    <a href="/dashboard" data-filter-tags="dashboard übersicht">
                        <svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#trello"></use></svg>
                        <span class="nav-link-text">Dashboard</span>
                    </a>
                </li>

                <li class="nav-title"><span>Verwaltung</span></li>

                <li class="{{ is_active('/patienten') == 'active' ? 'active' : '' }}">
                    <a href="/patienten" data-filter-tags="patienten tiere">
                        <svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#heart"></use></svg>
                        <span class="nav-link-text">Patienten</span>
                    </a>
                </li>

                <li class="{{ is_active('/tierhalter') == 'active' ? 'active' : '' }}">
                    <a href="/tierhalter" data-filter-tags="tierhalter besitzer kunden">
                        <svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#users"></use></svg>
                        <span class="nav-link-text">Tierhalter</span>
                    </a>
                </li>

                <li class="{{ is_active('/rechnungen') == 'active' ? 'active' : '' }}">
                    <a href="/rechnungen" data-filter-tags="rechnungen faktura">
                        <svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#file-text"></use></svg>
                        <span class="nav-link-text">Rechnungen</span>
                    </a>
                </li>

                {# Plugin nav items #}
                {% for item in plugin_nav_items ?? [] %}
                {% if not (item.admin_only is defined and item.admin_only) or (current_user and current_user.role == 'admin') %}
                <li class="{{ is_active(item.href) == 'active' ? 'active' : '' }}">
                    <a href="{{ item.href }}" data-filter-tags="{{ item.label|lower }}">
                        {% if item.icon is defined %}{{ item.icon|raw }}{% endif %}
                        <span class="nav-link-text">{{ item.label }}</span>
                    </a>
                </li>
                {% endif %}
                {% endfor %}

                {% if current_user and current_user.role == 'admin' %}
                <li class="nav-title"><span>Administration</span></li>

                <li class="{{ is_active('/einstellungen') == 'active' ? 'active' : '' }}">
                    <a href="/einstellungen" data-filter-tags="einstellungen konfiguration">
                        <svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#settings"></use></svg>
                        <span class="nav-link-text">Einstellungen</span>
                    </a>
                </li>
                {% endif %}

            </ul>
        </nav>

        {# Sidebar footer #}
        <div class="app-sidebar-footer p-3 border-top d-flex align-items-center gap-2">
            <div style="width:32px;height:32px;border-radius:50%;background:var(--bs-primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;flex-shrink:0;">
                {{ current_user.name|initials }}
            </div>
            <div class="nav-link-text overflow-hidden">
                <div class="fw-600 fs-sm text-truncate">{{ current_user.name }}</div>
                <div class="fs-nano text-muted">{{ current_user.role == 'admin' ? 'Administrator' : 'Mitarbeiter' }}</div>
            </div>
        </div>

    </aside>

    {# ═══════════════════════════════════════════════════════
       MAIN CONTENT AREA — exact SmartAdmin CSS structure:
       app-body > app-content > content-wrapper > main-content
       ═══════════════════════════════════════════════════════ #}
    <div class="app-body">
        <div class="app-content">
            <div class="content-wrapper" id="js-page-content" role="main">

            {# Flash messages #}
            {% if flash.success is defined %}
            <div class="alert alert-success alert-dismissible d-flex align-items-center mb-3" role="alert" data-auto-dismiss="5000">
                <svg class="sa-icon sa-icon-success me-2 flex-shrink-0"><use href="/themes/smart-tierphysio/icons/sprite.svg#check-circle"></use></svg>
                <span>{{ flash.success }}</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Schließen"></button>
            </div>
            {% endif %}
            {% if flash.error is defined %}
            <div class="alert alert-danger alert-dismissible d-flex align-items-center mb-3" role="alert" data-auto-dismiss="8000">
                <svg class="sa-icon sa-icon-danger me-2 flex-shrink-0"><use href="/themes/smart-tierphysio/icons/sprite.svg#alert-circle"></use></svg>
                <span>{{ flash.error }}</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Schließen"></button>
            </div>
            {% endif %}
            {% if flash.info is defined %}
            <div class="alert alert-info alert-dismissible d-flex align-items-center mb-3" role="alert" data-auto-dismiss="5000">
                <svg class="sa-icon me-2 flex-shrink-0"><use href="/themes/smart-tierphysio/icons/sprite.svg#info"></use></svg>
                <span>{{ flash.info }}</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Schließen"></button>
            </div>
            {% endif %}

            {# Page content from child templates #}
            {% block content %}{% endblock %}

            </div>{# /content-wrapper / js-page-content #}

            <footer class="app-footer">
                <div class="app-footer-content flex-grow-1">
                    {{ app_name }} &copy; {{ "now"|date("Y") }}
                    <span class="hidden-mobile"> — Alle Rechte vorbehalten.</span>
                </div>
            </footer>

        </div>{# /app-content #}
    </div>{# /app-body #}

    {# ═══════════════════════════════════════════════════════
       SETTINGS DRAWER (SmartAdmin App Builder)
       ═══════════════════════════════════════════════════════ #}
    <aside class="app-drawer js-drawer-settings">
        <div class="app-drawer-header">
            <div class="h4 mb-0">App-Einstellungen</div>
            <button type="button" class="btn btn-system ms-auto"
                    data-action="toggle-swap" data-toggleclass="open"
                    data-target="aside.js-drawer-settings" aria-label="Schließen">
                <svg class="sa-icon sa-icon-2x"><use href="/themes/smart-tierphysio/icons/sprite.svg#x"></use></svg>
            </button>
        </div>

        <div class="custom-scrollbar h-100">

            <div class="mod-status primary-mod" data-prefix="Primäre Einstellungen">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="actionHeaderFixed"
                           data-action="toggle" data-class="set-header-fixed">
                    <label class="form-check-label" for="actionHeaderFixed">Header fixiert</label>
                </div>
                <div class="form-check d-none d-lg-block">
                    <input class="form-check-input" type="checkbox" id="actionNavFull"
                           data-action="toggle" data-class="set-nav-full" data-codependence="set-nav-collapsed">
                    <label class="form-check-label" for="actionNavFull">Navigation volle Höhe</label>
                </div>
            </div>

            <div class="mod-status d-none d-lg-block" data-prefix="Zusätzliche Einstellungen">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="actionNavFixed"
                           data-action="toggle" data-class="set-nav-fixed">
                    <label class="form-check-label" for="actionNavFixed">Navigation fixiert</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="actionNavCollapsed"
                           data-action="toggle" data-class="set-nav-collapsed" data-dependency="set-nav-full">
                    <label class="form-check-label" for="actionNavCollapsed">Navigation eingeklappt</label>
                </div>
            </div>

            <div class="mod-status" data-prefix="Weitere Einstellungen">
                <div class="form-check d-none d-lg-block">
                    <input class="form-check-input" type="checkbox" id="actionNavMinified"
                           data-action="toggle" data-class="set-nav-minified">
                    <label class="form-check-label" for="actionNavMinified">Navigation minimiert</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="darkNavigation"
                           data-action="toggle" data-class="set-nav-dark">
                    <label class="form-check-label" for="darkNavigation">Dunkle Navigation</label>
                </div>
            </div>

            <div class="mod-status app-themes" data-prefix="Farbthema">
                <div class="clickable-boxes">
                    <input type="radio" id="sa-t0" name="options" data-action="theme-style" data-theme-style="" checked>
                    <label for="sa-t0" data-prefix="Standard" style="background:linear-gradient(135deg,#FF6A00,#F6A2D5,#4C91BF,#7A8B92,#AB7C9A);"></label>

                    <input type="radio" id="sa-t1" name="options" data-action="theme-style" data-theme-style="nebula">
                    <label for="sa-t1" data-prefix="Nebula" style="background:linear-gradient(135deg,#2a7dbf,#2a9d8f,#766cbc,#f4a261,#e76f51);"></label>

                    <input type="radio" id="sa-t2" name="options" data-action="theme-style" data-theme-style="olive">
                    <label for="sa-t2" data-prefix="Olive" style="background:linear-gradient(135deg,#556B2F,#6B8E23,#8B9A3D,#A9B83E,#BDB76B);"></label>

                    <input type="radio" id="sa-t3" name="options" data-action="theme-style" data-theme-style="solar">
                    <label for="sa-t3" data-prefix="Solar" style="background:linear-gradient(135deg,#FF8C00,#FFD700,#FF4500,#F1C40F,#F39C12);"></label>

                    <input type="radio" id="sa-t4" name="options" data-action="theme-style" data-theme-style="lunar">
                    <label for="sa-t4" data-prefix="Lunar" style="background:linear-gradient(135deg,#2C3E50,#34495E,#5F6368,#AAB7B8,#E6E6FA,#F1F3F4);"></label>

                    <input type="radio" id="sa-t5" name="options" data-action="theme-style" data-theme-style="night">
                    <label for="sa-t5" data-prefix="Night" style="background:linear-gradient(135deg,#1e2a47,#2b3654,#363d6c,#4f5d79,#717b91,#b6c4d1);"></label>

                    <input type="radio" id="sa-t6" name="options" data-action="theme-style" data-theme-style="aurora">
                    <label for="sa-t6" data-prefix="Aurora" style="background:linear-gradient(135deg,#337e7e,#527a4a,#63279b,#7FFF00,#87CEFA,#B0E0E6);"></label>

                    <input type="radio" id="sa-t7" name="options" data-action="theme-style" data-theme-style="earth">
                    <label for="sa-t7" data-prefix="Earth" style="background:linear-gradient(135deg,#2198f3,#3173a5,#3f6888,#618d48,#52bf11);"></label>

                    <input type="radio" id="sa-t8" name="options" data-action="theme-style" data-theme-style="flare">
                    <label for="sa-t8" data-prefix="Flare" style="background:linear-gradient(135deg,#FF4500,#FF6347,#F44336,#D32F2F,#B71C1C);"></label>

                    <input type="radio" id="sa-t9" name="options" data-action="theme-style" data-theme-style="storm">
                    <label for="sa-t9" data-prefix="Storm" style="background:linear-gradient(135deg,#2F4F4F,#3B5360,#4B6A6E,#5A7980,#A9A9A9,#FFD700);"></label>
                </div>
            </div>

            <div class="d-flex mt-3" style="gap:10px">
                <button type="button" onclick="appDOM.resetStyle();"
                        class="btn reset-button btn-outline-danger flex-grow-1">
                    <i class="sa sa-reload align-base me-1"></i> Factory Reset
                </button>
            </div>

        </div>
    </aside>
    <div class="backdrop" data-action="toggle-swap" data-toggleclass="open"
         data-target="aside.js-drawer-settings"></div>

</div>{# /app-wrap #}

{# ═══════════════════════════════════════════════════════
   SCRIPTS — loaded at bottom like in dist/index.html
   ═══════════════════════════════════════════════════════ #}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script src="/themes/smart-tierphysio/plugins/bootstrap/bootstrap.bundle.min.js"></script>
<script src="/themes/smart-tierphysio/scripts/core/smartNavigation.js"></script>
<script src="/themes/smart-tierphysio/scripts/core/smartFilter.js"></script>
<script src="/themes/smart-tierphysio/scripts/core/smartSlimscroll.js"></script>
<script src="/themes/smart-tierphysio/plugins/sortablejs/Sortable.min.js"></script>
<script src="/themes/smart-tierphysio/plugins/waves/waves.min.js"></script>
<script src="/themes/smart-tierphysio/scripts/core/smartApp.js"></script>

<script>
/* ═══════════════════════════════════════════════════════
   SmartTierphysio — Bridge JS
   ═══════════════════════════════════════════════════════ */
(function () {
    'use strict';

    /* ── 1. Modal System — wraps Bootstrap 5 API ── */
    function openModal(id) {
        var el = document.getElementById(id);
        if (!el) return;
        bootstrap.Modal.getOrCreateInstance(el).show();
    }
    function closeModal(id) {
        if (id) {
            var el = document.getElementById(id);
            if (el) bootstrap.Modal.getOrCreateInstance(el).hide();
        } else {
            document.querySelectorAll('.modal.show').forEach(function (m) {
                bootstrap.Modal.getOrCreateInstance(m).hide();
            });
        }
    }
    window.openModal  = openModal;
    window.closeModal = closeModal;

    /* delegate legacy [data-modal-open/close] */
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-modal-open]');
        if (btn) { e.preventDefault(); openModal(btn.getAttribute('data-modal-open')); return; }
        var cls = e.target.closest('[data-modal-close]');
        if (cls) { e.preventDefault(); closeModal(cls.getAttribute('data-modal-close')); return; }
    });

    /* ── 2. Settings Tabs (delegated) ── */
    document.addEventListener('click', function (e) {
        var tab = e.target.closest('.settings-tab');
        if (!tab) return;
        var tabId = tab.getAttribute('data-tab');
        if (!tabId) return;
        var container = tab.closest('.settings-tabs');
        if (container) container.querySelectorAll('.settings-tab').forEach(function (t) { t.classList.remove('active'); });
        document.querySelectorAll('.settings-tab-content').forEach(function (c) { c.classList.remove('active'); });
        tab.classList.add('active');
        var content = document.getElementById('tab-' + tabId);
        if (content) content.classList.add('active');
        try { sessionStorage.setItem('activeSettingsTab', tabId); } catch (ex) {}
    });
    (function () {
        var tabs = document.querySelectorAll('.settings-tab');
        if (!tabs.length) return;
        try {
            var saved = sessionStorage.getItem('activeSettingsTab');
            var target = saved ? document.querySelector('.settings-tab[data-tab="' + saved + '"]') : null;
            if (!target) target = tabs[0];
            if (target) target.click();
        } catch (e) { if (tabs[0]) tabs[0].click(); }
    })();

    /* ── 3. data-confirm ── */
    document.addEventListener('submit', function (e) {
        var msg = e.target.getAttribute('data-confirm');
        if (msg && !confirm(msg)) e.preventDefault();
    });
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-confirm]:not(form)');
        if (btn) {
            var msg = btn.getAttribute('data-confirm');
            if (msg && !confirm(msg)) e.preventDefault();
        }
    });

    /* ── 4. Auto-dismiss alerts ── */
    document.querySelectorAll('[data-auto-dismiss]').forEach(function (el) {
        var t = parseInt(el.getAttribute('data-auto-dismiss')) || 5000;
        setTimeout(function () {
            el.style.transition = 'opacity .4s';
            el.style.opacity = '0';
            setTimeout(function () { el.remove(); }, 400);
        }, t);
    });

    /* ── 5. Sync colour theme radio from localStorage ── */
    (function () {
        try {
            var cfg = JSON.parse(localStorage.getItem('layoutSettings') || '{}');
            var style = '';
            if (cfg.themeStyle) {
                var m = cfg.themeStyle.match(/\/([^/]+)\.css$/);
                if (m) style = m[1];
            }
            document.querySelectorAll('[data-action="theme-style"]').forEach(function (r) {
                r.checked = (r.getAttribute('data-theme-style') === style);
            });
        } catch (e) {}
    })();

    /* ── 6. Dark/Light toggle button (bridge to saveloadscript.js format) ── */
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-action="toggle-theme"]');
        if (!btn) return;
        var html  = document.documentElement;
        var theme = html.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-bs-theme', theme);
        if (theme === 'dark') html.classList.add('set-nav-dark');
        else html.classList.remove('set-nav-dark');
        try {
            var cfg = JSON.parse(localStorage.getItem('layoutSettings') || '{}');
            cfg.theme = theme;
            localStorage.setItem('layoutSettings', JSON.stringify(cfg));
        } catch (ex) {}
    });

})();
</script>

{% block scripts %}{% endblock %}

{# Notification polling #}
{% if intake_unread_count is defined %}
<script>
(function(){
    function poll(){
        fetch('/api/intake/notifications',{headers:{'X-Requested-With':'XMLHttpRequest'}})
        .then(function(r){return r.json();})
        .then(function(d){
            var c = d.count||0;
            document.querySelectorAll('.badge.badge-icon').forEach(function(b){
                b.textContent = c > 9 ? '9+' : c;
                b.style.display = c > 0 ? '' : 'none';
            });
        }).catch(function(){});
    }
    setInterval(poll, 30000);
})();
</script>
{% endif %}

