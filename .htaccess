Options -Indexes
RewriteEngine On

# ── Path-based multi-tenant support ────────────────────────────────────────
# All tenants are served by the same installation at tp.makeit.uno/{slug}/...
# The TenantResolver reads the first path segment and sets the DB prefix.
# No wildcard DNS or SSL needed — single domain, single certificate.

# Block direct access to sensitive files and directories
RewriteRule ^(\.env|composer\.(json|lock)|\.git) - [F,L]
RewriteRule ^(app|lang|migrations|templates|plugins|saas-platform)/ - [F,L]

# Serve storage/uploads/ and storage/patients/ directly (images, logos)
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -f
RewriteRule ^storage/(uploads|patients)/.+ - [L]

# Serve static files from public/ directly (check both with and without tenant prefix)
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
RewriteRule ^(.*)$ public/$1 [L]

# Serve directories from public/ directly
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
RewriteRule ^(.*)$ public/$1 [L]

# Everything else → public/index.php (PHP router handles tenant slug stripping)
RewriteRule ^(.*)$ public/index.php [QSA,L]
