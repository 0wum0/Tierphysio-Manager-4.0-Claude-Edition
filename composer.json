{
    "name": "tierphysio/manager",
    "description": "Tierphysio Manager 3.0 - Modular Business Web Application",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "twig/twig": "^3.8",
        "symfony/http-foundation": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^6.9",
        "tecnickcom/tcpdf": "^6.7",
        "erusev/parsedown": "^1.7",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Plugins\\": "plugins/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    }
}
