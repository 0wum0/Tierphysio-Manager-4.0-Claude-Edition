APP_NAME="Tierphysio SaaS"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://saas.tierphysio.de
APP_KEY=

# SaaS-Plattform Datenbank
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=tierphysio_saas
DB_USERNAME=dein_datenbankbenutzer
DB_PASSWORD=dein_datenbankpasswort

# Tenant-Datenbank (gemeinsame DB, Tabellen werden per Präfix getrennt)
# Kann dieselbe DB wie oben sein — alle Tenant-Tabellen landen dort
TENANT_DB_HOST=localhost
TENANT_DB_PORT=3306
TENANT_DB_DATABASE=deine_hauptdatenbank
TENANT_DB_USERNAME=dein_datenbankbenutzer
TENANT_DB_PASSWORD=dein_datenbankpasswort
# Basis-Präfix für Tenant-Tabellen: tpm1_users, tpm2_users, ...
TENANT_TABLE_PREFIX=tpm

# Stripe (Marketplace Zahlungen)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal (Marketplace Zahlungen)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# URL der Praxissoftware (wird auf der Landingpage als Demo-Link verwendet)
# Beispiel: https://tp.makeit.uno
PRACTICE_SOFTWARE_PATH=/var/www/praxis
PRACTICE_SOFTWARE_URL=https://tp.makeit.uno

# Demo-Zugangsdaten (werden auf der Landingpage angezeigt)
DEMO_EMAIL=info@demo.de
DEMO_PASSWORD=admin123456

# Cron Secret (für automatischen Demo-Cleanup via /api/demo/cleanup?secret=...)
CRON_SECRET=change_this_to_a_random_secret

# Session
SESSION_LIFETIME=120
SESSION_SECURE=true

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@tierphysio.de
MAIL_FROM_NAME="Tierphysio SaaS"

# Lizenz-Token Signierungsgeheimnis (mind. 32 Zeichen)
LICENSE_SECRET=aendere_mich_zu_einem_langen_geheimnis_32chars

APP_LOCALE=de
INSTALLED=false
