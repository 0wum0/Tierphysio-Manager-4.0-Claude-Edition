{% extends 'layouts/base.twig' %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1 fw-bold">Plugin-Marktplatz</h4>
        <p class="text-secondary mb-0" style="font-size:.875rem;">Erweitern Sie Ihre Praxissoftware mit zusätzlichen Modulen.</p>
    </div>
</div>

{% if plugins is empty %}
<div class="card text-center py-5">
    <div class="card-body">
        <i class="bi bi-shop" style="font-size:3rem;color:#334155;"></i>
        <h5 class="mt-3 text-secondary">Noch keine Plugins verfügbar</h5>
        <p class="text-secondary" style="font-size:.875rem;">Der Marktplatz wird bald mit Plugins befüllt.</p>
    </div>
</div>
{% else %}

{# Stats bar #}
<div class="row g-3 mb-4">
    <div class="col-auto">
        <span class="badge bg-primary bg-opacity-25 text-primary px-3 py-2" style="font-size:.875rem;">
            <i class="bi bi-puzzle me-1"></i>{{ plugins|length }} Plugins verfügbar
        </span>
    </div>
    {% set purchased_count = 0 %}
    {% for p in plugins %}{% if p.purchased %}{% set purchased_count = purchased_count + 1 %}{% endif %}{% endfor %}
    {% if purchased_count > 0 %}
    <div class="col-auto">
        <span class="badge bg-success bg-opacity-25 text-success px-3 py-2" style="font-size:.875rem;">
            <i class="bi bi-check-circle me-1"></i>{{ purchased_count }} aktiviert
        </span>
    </div>
    {% endif %}
</div>

{# Plugin grid #}
<div class="row g-4">
    {% for plugin in plugins %}
    <div class="col-md-6 col-xl-4">
        <div class="card h-100 position-relative" style="{% if plugin.is_featured %}border-color:#2563eb;{% endif %}">
            {% if plugin.is_featured %}
            <div class="position-absolute top-0 end-0 m-2">
                <span class="badge bg-primary"><i class="bi bi-star-fill me-1"></i>Featured</span>
            </div>
            {% endif %}
            {% if plugin.purchased %}
            <div class="position-absolute top-0 start-0 m-2">
                <span class="badge bg-success"><i class="bi bi-check-circle-fill me-1"></i>Aktiviert</span>
            </div>
            {% endif %}

            <div class="card-body p-4 d-flex flex-column">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-3 d-flex align-items-center justify-content-center"
                         style="width:52px;height:52px;background:rgba(37,99,235,.15);flex-shrink:0;">
                        <i class="{{ plugin.icon }} text-primary" style="font-size:1.5rem;"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold">{{ plugin.name }}</h6>
                        <span class="badge bg-secondary bg-opacity-25 text-secondary" style="font-size:.7rem;">{{ plugin.category }}</span>
                    </div>
                </div>

                <p class="text-secondary flex-grow-1" style="font-size:.875rem;">{{ plugin.description }}</p>

                <div class="d-flex align-items-center justify-content-between mt-3 pt-3" style="border-top:1px solid #334155;">
                    <div>
                        {% if plugin.price_type == 'free' or plugin.price == 0 %}
                            <span class="fw-bold text-success fs-5">Kostenlos</span>
                        {% elseif plugin.price_type == 'monthly' %}
                            <span class="fw-bold fs-5">{{ plugin.price|number_format(2,',','.') }} €</span>
                            <span class="text-secondary" style="font-size:.75rem;">/Monat</span>
                        {% else %}
                            <span class="fw-bold fs-5">{{ plugin.price|number_format(2,',','.') }} €</span>
                            <span class="text-secondary" style="font-size:.75rem;">einmalig</span>
                        {% endif %}
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/marketplace/{{ plugin.id }}" class="btn btn-sm btn-outline-secondary">Details</a>
                        {% if plugin.purchased %}
                            <span class="btn btn-sm btn-success disabled"><i class="bi bi-check-lg"></i></span>
                        {% elseif plugin.price_type == 'free' or plugin.price == 0 %}
                            <form method="POST" action="/marketplace/{{ plugin.id }}/activate" class="d-inline">
                                <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                                <button class="btn btn-sm btn-primary">Aktivieren</button>
                            </form>
                        {% else %}
                            <a href="/marketplace/{{ plugin.id }}" class="btn btn-sm btn-primary">Kaufen</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
