{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}

{# ── Page Header ─────────────────────────────────────────── #}
<div class="page-header">
    <div>
        <h1 class="page-title">
            🐾 {{ t('dashboard.welcome') }}, {{ current_user.name|split(' ')|first }}!
        </h1>
        <p class="page-subtitle">{{ 'now'|date('l, d. F Y') }}</p>
    </div>
    <div class="d-flex gap-2 flex-wrap align-items-center">
        <a href="{{ base_path }}/patienten" class="btn btn-outline-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            {{ t('dashboard.new_patient') }}
        </a>
        <a href="{{ base_path }}/rechnungen/erstellen" class="btn btn-primary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            {{ t('dashboard.new_invoice') }}
        </a>
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="resetPanelState()" title="Dashboard-Layout zurücksetzen">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="1 4 1 10 7 10"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M3.51 15a9 9 0 1 0 .49-4.95"/></svg>
        </button>
    </div>
</div>

{# ════════════════════════════════════════════════════════════════
   MODULAR DASHBOARD — server-persisted panel order per user
   saved_layout = array of panel IDs in saved order (from DB)
   Panels are sorted server-side via Twig, then Sortable.js enables
   drag & drop. onEnd → POST /api/dashboard/layout → DB save.
   Same order on every device because it's stored server-side.
   ════════════════════════════════════════════════════════════════ #}

{# Build ordered panel list: saved order first, then any new panels appended #}
{% set all_panels = ['panel-appointments', 'panel-birthdays', 'panel-kpi-revenue', 'panel-revenue-chart', 'panel-activity-kpis', 'panel-mini-charts', 'panel-quick-actions'] %}
{% for w in plugin_widgets %}{% set all_panels = all_panels|merge([w.id]) %}{% endfor %}
{% set ordered_panels = saved_layout ?? all_panels %}
{% for id in all_panels %}{% if id not in ordered_panels %}{% set ordered_panels = ordered_panels|merge([id]) %}{% endif %}{% endfor %}
{% set widget_map = {} %}
{% for w in plugin_widgets %}{% set widget_map = widget_map|merge({(w.id): w}) %}{% endfor %}

<div class="main-content" id="js-dashboard">
    <div id="dashboard-grid" class="row g-3">

    {% for panel_id in ordered_panels %}

        {# ── Panel: Upcoming Appointments ── #}
        {% if panel_id == 'panel-appointments' %}
        <div class="col-12" data-panel-id="panel-appointments">
            <div class="panel" id="panel-appointments">
                <div class="panel-hdr">
                    <h2>
                        <svg class="sa-icon sa-icon-primary me-2"><use href="/themes/smart-tierphysio/icons/sprite.svg#calendar"></use></svg>
                        Nächste Termine
                        <small class="text-muted fw-normal ms-2" style="font-size:.75rem;">kommende Termine</small>
                    </h2>
                    <div class="panel-toolbar ms-auto d-flex align-items-center gap-2">
                        <a href="{{ base_path }}/kalender" class="btn btn-outline-primary btn-sm">Kalender öffnen</a>
                        <button class="btn btn-panel" data-action="panel-collapse" title="Einklappen"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#minus"></use></svg></button>
                    </div>
                </div>
                <div class="panel-container">
                    <div class="panel-content p-0">
                        {% if upcoming_appointments is empty %}
                            <div class="d-flex align-items-center justify-content-center gap-2 py-4 text-muted">
                                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" class="opacity-50"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.5"/></svg>
                                <span class="fs-sm">Keine anstehenden Termine</span>
                            </div>
                        {% else %}
                        <div class="row g-0">
                            {% for appt in upcoming_appointments %}
                            {% set appt_date = appt.start_at|date('Y-m-d') %}
                            {% set today_str = 'now'|date('Y-m-d') %}
                            {% set is_today = appt_date == today_str %}
                            {% set appt_color = appt.treatment_color ?? '#4f7cff' %}
                            <div class="col-12 col-sm-6 col-xl-3">
                                <a href="{{ base_path }}/kalender" class="d-flex align-items-center gap-3 px-3 py-2 text-decoration-none border-bottom border-end"
                                   style="{% if is_today %}background:rgba(79,124,255,0.05);{% endif %}min-height:64px;">
                                    <div class="flex-shrink-0 d-flex flex-column align-items-center justify-content-center rounded-2"
                                         style="width:44px;height:44px;background:{{ appt_color }}18;border:1px solid {{ appt_color }}40;">
                                        <div style="font-size:.65rem;font-weight:700;color:{{ appt_color }};line-height:1;text-transform:uppercase;">{{ appt.start_at|date('M') }}</div>
                                        <div style="font-size:1.1rem;font-weight:800;color:{{ appt_color }};line-height:1.1;">{{ appt.start_at|date('d') }}</div>
                                    </div>
                                    <div class="flex-grow-1 min-width-0">
                                        <div class="d-flex align-items-center gap-1 mb-1">
                                            <span class="fw-600 fs-sm text-truncate">{{ appt.patient_name ?? appt.title ?? 'Termin' }}</span>
                                            {% if is_today %}<span class="badge ms-1" style="background:#4f7cff;font-size:.6rem;">Heute</span>{% endif %}
                                        </div>
                                        <div class="d-flex align-items-center gap-2" style="font-size:.72rem;color:var(--bs-secondary-color);">
                                            <span>{{ appt.start_at|date('H:i') }} Uhr</span>
                                            {% if appt.treatment_type_name %}<span>· {{ appt.treatment_type_name }}</span>{% endif %}
                                            {% if appt.owner_name %}<span class="text-truncate">· {{ appt.owner_name }}</span>{% endif %}
                                        </div>
                                    </div>
                                </a>
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# ── Panel: KPI Revenue ── #}
        {% if panel_id == 'panel-kpi-revenue' %}
        <div class="col-12" data-panel-id="panel-kpi-revenue">
            <div class="panel" id="panel-kpi-revenue">
                <div class="panel-hdr">
                    <h2>
                        <svg class="sa-icon sa-icon-primary me-2"><use href="/themes/smart-tierphysio/icons/sprite.svg#dollar-sign"></use></svg>
                        Umsatz-Übersicht
                    </h2>
                    <div class="panel-toolbar">
                        <button class="btn btn-panel" data-action="panel-collapse" title="Einklappen"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#minus"></use></svg></button>
                        <button class="btn btn-panel" data-action="panel-fullscreen" title="Vollbild"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#maximize-2"></use></svg></button>
                    </div>
                </div>
                <div class="panel-container">
                    <div class="panel-content p-3">
                        <div class="row g-3">
                            <div class="col-6 col-sm-3">
                                <div class="d-flex flex-column p-3 rounded-3" style="border-left:3px solid #4f7cff;background:rgba(79,124,255,0.06);">
                                    <span class="stat-card-label mb-1">{{ t('dashboard.revenue_week') }}</span>
                                    <span class="stat-card-value fs-4">{{ stats.revenue_week|money }}</span>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="d-flex flex-column p-3 rounded-3" style="border-left:3px solid #a855f7;background:rgba(168,85,247,0.06);">
                                    <span class="stat-card-label mb-1">{{ t('dashboard.revenue_month') }}</span>
                                    <span class="stat-card-value fs-4">{{ stats.revenue_month|money }}</span>
                                    <span class="fs-nano mt-1">
                                        {% if stats.month_change > 0 %}<span class="trend-up">▲ {{ stats.month_change }}%</span>
                                        {% elseif stats.month_change < 0 %}<span class="trend-down">▼ {{ stats.month_change|abs }}%</span>
                                        {% else %}<span class="trend-flat">—</span>{% endif %}
                                        <span class="text-muted">{{ t('dashboard.vs_last_month') }}</span>
                                    </span>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="d-flex flex-column p-3 rounded-3" style="border-left:3px solid #06b6d4;background:rgba(6,182,212,0.06);">
                                    <span class="stat-card-label mb-1">{{ t('dashboard.revenue_year') }}</span>
                                    <span class="stat-card-value fs-4">{{ stats.revenue_year|money }}</span>
                                    <span class="fs-nano mt-1">
                                        {% if stats.year_change > 0 %}<span class="trend-up">▲ {{ stats.year_change }}%</span>
                                        {% elseif stats.year_change < 0 %}<span class="trend-down">▼ {{ stats.year_change|abs }}%</span>
                                        {% else %}<span class="trend-flat">—</span>{% endif %}
                                        <span class="text-muted">{{ t('dashboard.vs_last_year') }}</span>
                                    </span>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="d-flex flex-column p-3 rounded-3" style="border-left:3px solid #22c55e;background:rgba(34,197,94,0.06);">
                                    <span class="stat-card-label mb-1">{{ t('dashboard.revenue_total') }}</span>
                                    <span class="stat-card-value fs-4">{{ stats.revenue_total|money }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# ── Panel: Revenue Chart ── #}
        {% if panel_id == 'panel-revenue-chart' %}
        <div class="col-xl-8 col-lg-7 col-12" data-panel-id="panel-revenue-chart">
            <div class="panel h-100" id="panel-revenue-chart">
                <div class="panel-hdr">
                    <h2>
                        <svg class="sa-icon sa-icon-primary me-2"><use href="/themes/smart-tierphysio/icons/sprite.svg#bar-chart-2"></use></svg>
                        {{ t('dashboard.chart_title') }}
                    </h2>
                    <div class="panel-toolbar ms-auto d-flex align-items-center gap-2">
                        <div class="btn-group btn-group-sm" role="group">
                            <button class="btn btn-outline-secondary active" id="btn-weekly">{{ t('dashboard.weekly') }}</button>
                            <button class="btn btn-outline-secondary" id="btn-monthly">{{ t('dashboard.monthly') }}</button>
                        </div>
                        <button class="btn btn-panel" data-action="panel-collapse" title="Einklappen"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#minus"></use></svg></button>
                        <button class="btn btn-panel" data-action="panel-fullscreen" title="Vollbild"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#maximize-2"></use></svg></button>
                    </div>
                </div>
                <div class="panel-container">
                    <div class="panel-content p-2">
                        <div id="dash-revenue-chart" style="min-height:270px;"></div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# ── Panel: Activity KPIs ── #}
        {% if panel_id == 'panel-activity-kpis' %}
        <div class="col-xl-4 col-lg-5 col-12" data-panel-id="panel-activity-kpis">
            <div class="panel h-100" id="panel-activity-kpis">
                <div class="panel-hdr">
                    <h2>
                        <svg class="sa-icon sa-icon-info me-2"><use href="/themes/smart-tierphysio/icons/sprite.svg#activity"></use></svg>
                        Aktivität
                    </h2>
                    <div class="panel-toolbar">
                        <button class="btn btn-panel" data-action="panel-collapse" title="Einklappen"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#minus"></use></svg></button>
                        <button class="btn btn-panel" data-action="panel-fullscreen" title="Vollbild"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#maximize-2"></use></svg></button>
                    </div>
                </div>
                <div class="panel-container">
                    <div class="panel-content p-0">
                        <div class="list-group list-group-flush rounded-0">
                            <div class="list-group-item d-flex align-items-center justify-content-between px-3 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="stat-card-icon" style="--stat-color:#06b6d4;"><svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg></div>
                                    <span class="stat-card-label">{{ t('dashboard.open_invoices') }}</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="fw-800 fs-4" style="color:#06b6d4;">{{ stats.open_count }}</span>
                                    <a href="{{ base_path }}/rechnungen?status=open" class="btn btn-outline-info btn-sm">→</a>
                                </div>
                            </div>
                            <div class="list-group-item d-flex align-items-center justify-content-between px-3 py-3{% if stats.overdue_count > 0 %} border-start border-danger border-3{% endif %}">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="stat-card-icon" style="--stat-color:{% if stats.overdue_count > 0 %}#ef4444{% else %}var(--bs-secondary-color){% endif %};"><svg width="15" height="15" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></div>
                                    <span class="stat-card-label">{{ t('dashboard.overdue_invoices') }}</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="fw-800 fs-4" style="color:{% if stats.overdue_count > 0 %}#ef4444{% else %}var(--bs-secondary-color){% endif %};">{{ stats.overdue_count }}</span>
                                    <a href="{{ base_path }}/rechnungen?status=overdue" class="btn btn-outline-danger btn-sm">→</a>
                                </div>
                            </div>
                            <div class="list-group-item d-flex align-items-center justify-content-between px-3 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="stat-card-icon" style="--stat-color:#f59e0b;"><svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
                                    <div>
                                        <span class="stat-card-label d-block">{{ t('dashboard.new_patients') }}</span>
                                        <span class="fs-nano text-muted">letzte 30 Tage</span>
                                    </div>
                                </div>
                                <span class="fw-800 fs-4" style="color:#f59e0b;">{{ stats.new_patients }}</span>
                            </div>
                            <div class="list-group-item d-flex align-items-center justify-content-between px-3 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="stat-card-icon" style="--stat-color:#4f7cff;"><svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
                                    <span class="stat-card-label">{{ t('dashboard.total_patients') }}</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="fw-800 fs-4" style="color:#4f7cff;">{{ stats.total_patients }}</span>
                                    <a href="{{ base_path }}/patienten" class="btn btn-outline-primary btn-sm">→</a>
                                </div>
                            </div>
                            <div class="list-group-item d-flex align-items-center justify-content-between px-3 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="stat-card-icon" style="--stat-color:#a855f7;"><svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/></svg></div>
                                    <span class="stat-card-label">{{ t('dashboard.total_owners') }}</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="fw-800 fs-4" style="color:#a855f7;">{{ stats.total_owners }}</span>
                                    <a href="{{ base_path }}/tierhalter" class="btn btn-sm" style="background:rgba(168,85,247,0.12);color:#a855f7;border:1px solid rgba(168,85,247,0.25);">→</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# ── Panel: Mini Charts ── #}
        {% if panel_id == 'panel-mini-charts' %}
        <div class="col-12" data-panel-id="panel-mini-charts">
            <div class="panel" id="panel-mini-charts">
                <div class="panel-hdr">
                    <h2>
                        <svg class="sa-icon sa-icon-success me-2"><use href="/themes/smart-tierphysio/icons/sprite.svg#pie-chart"></use></svg>
                        Kennzahlen
                    </h2>
                    <div class="panel-toolbar">
                        <button class="btn btn-panel" data-action="panel-collapse" title="Einklappen"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#minus"></use></svg></button>
                    </div>
                </div>
                <div class="panel-container">
                    <div class="panel-content p-3">
                        <div class="row g-3">

                            {# Neue Patienten Trend #}
                            <div class="col-12 col-md-6 col-xl-4">
                                <div class="d-flex flex-column p-3 rounded-3 h-100" style="background:rgba(79,124,255,0.05);border:1px solid rgba(79,124,255,0.12);">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <div class="stat-card-label">Neue Patienten</div>
                                            <div class="fw-800 fs-3" style="color:#4f7cff;">{{ stats.new_patients }}</div>
                                            <div class="fs-nano text-muted">letzte 30 Tage</div>
                                        </div>
                                        <div class="stat-card-icon" style="--stat-color:#4f7cff;">
                                            <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                                        </div>
                                    </div>
                                    <div id="dash-patient-sparkline" style="height:60px;margin:0 -4px;"></div>
                                    <div class="fs-nano text-muted mt-1">Trend 6 Monate</div>
                                </div>
                            </div>

                            {# Rechnungsstatus Radialbar #}
                            <div class="col-12 col-md-6 col-xl-4">
                                <div class="d-flex flex-column align-items-center p-3 rounded-3 h-100" style="background:rgba(34,197,94,0.05);border:1px solid rgba(34,197,94,0.12);">
                                    <div class="stat-card-label mb-1 align-self-start">Bezahlungsrate</div>
                                    <div id="dash-paid-radial" style="height:120px;width:120px;"></div>
                                    <div class="d-flex gap-3 mt-1" style="font-size:.72rem;color:var(--bs-secondary-color);">
                                        <span><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#22c55e;margin-right:3px;"></span>Bezahlt</span>
                                        <span><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#ef4444;margin-right:3px;"></span>Offen/Überfällig</span>
                                    </div>
                                </div>
                            </div>

                            {# Gesamtpatienten vs. letzte 30 Tage #}
                            <div class="col-12 col-md-6 col-xl-4">
                                <div class="d-flex flex-column p-3 rounded-3 h-100" style="background:rgba(168,85,247,0.05);border:1px solid rgba(168,85,247,0.12);">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <div class="stat-card-label">Patienten gesamt</div>
                                            <div class="fw-800 fs-3" style="color:#a855f7;">{{ stats.total_patients }}</div>
                                            <div class="fs-nano text-muted">{{ stats.total_owners }} Tierhalter</div>
                                        </div>
                                        <div class="stat-card-icon" style="--stat-color:#a855f7;">
                                            <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/></svg>
                                        </div>
                                    </div>
                                    <div id="dash-owners-bar" style="height:60px;margin:0 -4px;"></div>
                                    <div class="fs-nano text-muted mt-1">Patienten (blau) · Tierhalter (lila)</div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# ── Panel: Quick Actions ── #}
        {% if panel_id == 'panel-quick-actions' %}
        <div class="col-xl-4 col-lg-5 col-12" data-panel-id="panel-quick-actions">
            <div class="panel" id="panel-quick-actions">
                <div class="panel-hdr">
                    <h2>
                        <svg class="sa-icon sa-icon-warning me-2"><use href="/themes/smart-tierphysio/icons/sprite.svg#zap"></use></svg>
                        {{ t('dashboard.quick_actions') }}
                    </h2>
                    <div class="panel-toolbar">
                        <button class="btn btn-panel" data-action="panel-collapse" title="Einklappen"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#minus"></use></svg></button>
                    </div>
                </div>
                <div class="panel-container">
                    <div class="panel-content d-flex flex-column gap-2">
                        <a href="{{ base_path }}/patienten" class="btn btn-light d-flex align-items-center gap-2 text-start">
                            <span class="d-inline-flex align-items-center justify-content-center rounded-circle" style="width:32px;height:32px;background:rgba(239,68,68,0.12);color:#ef4444;flex-shrink:0;"><svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></span>
                            <span class="fw-500 fs-sm">{{ t('dashboard.new_patient') }}</span>
                        </a>
                        <a href="{{ base_path }}/tierhalter" class="btn btn-light d-flex align-items-center gap-2 text-start">
                            <span class="d-inline-flex align-items-center justify-content-center rounded-circle" style="width:32px;height:32px;background:rgba(168,85,247,0.12);color:#a855f7;flex-shrink:0;"><svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/></svg></span>
                            <span class="fw-500 fs-sm">{{ t('dashboard.new_owner') }}</span>
                        </a>
                        <a href="{{ base_path }}/rechnungen/erstellen" class="btn btn-light d-flex align-items-center gap-2 text-start">
                            <span class="d-inline-flex align-items-center justify-content-center rounded-circle" style="width:32px;height:32px;background:rgba(79,124,255,0.12);color:#4f7cff;flex-shrink:0;"><svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg></span>
                            <span class="fw-500 fs-sm">{{ t('dashboard.new_invoice') }}</span>
                        </a>
                        {% if stats.overdue_count > 0 %}
                        <a href="{{ base_path }}/rechnungen?status=overdue" class="btn btn-danger d-flex align-items-center gap-2">
                            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            <span>{{ stats.overdue_count }} {{ t('dashboard.overdue_invoices') }}</span>
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# ── Panel: Upcoming Birthdays ── #}
        {% if panel_id == 'panel-birthdays' %}
        <div class="col-xl-4 col-lg-5 col-12" data-panel-id="panel-birthdays">
            <div class="panel" id="panel-birthdays">
                <div class="panel-hdr">
                    <h2>
                        <svg class="sa-icon sa-icon-warning me-2" width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path stroke="currentColor" stroke-width="2" d="M16 3v4M8 3v4M3 11h18"/></svg>
                        Geburtstage <small class="text-muted fw-normal ms-1" style="font-size:.75rem;">nächste 14 Tage</small>
                    </h2>
                    <div class="panel-toolbar">
                        <button class="btn btn-panel" data-action="panel-collapse" title="Einklappen"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#minus"></use></svg></button>
                        <button class="btn btn-panel" data-action="panel-fullscreen" title="Vollbild"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#maximize-2"></use></svg></button>
                    </div>
                </div>
                <div class="panel-container">
                    <div class="panel-content p-0">
                        {% if upcoming_birthdays is empty %}
                            <div class="d-flex flex-column align-items-center justify-content-center py-4 text-muted">
                                <svg width="28" height="28" fill="none" viewBox="0 0 24 24" class="mb-2 opacity-50"><path stroke="currentColor" stroke-width="1.5" d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path stroke="currentColor" stroke-width="1.5" d="M16 3v4M8 3v4M3 11h18"/></svg>
                                <span class="fs-sm">Keine Geburtstage in den nächsten 14 Tagen</span>
                            </div>
                        {% else %}
                        <div class="list-group list-group-flush rounded-0">
                            {% for b in upcoming_birthdays %}
                            <a href="{{ b.link }}" class="list-group-item list-group-item-action d-flex align-items-center gap-3 px-3 py-2 text-decoration-none">
                                <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                                     style="width:36px;height:36px;background:{% if b.diff_days == 0 %}rgba(245,158,11,0.15){% elseif b.diff_days <= 3 %}rgba(239,68,68,0.1){% else %}rgba(79,124,255,0.1){% endif %};">
                                    {% if b.type == 'patient' %}
                                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" style="color:{% if b.diff_days == 0 %}#f59e0b{% elseif b.diff_days <= 3 %}#ef4444{% else %}#4f7cff{% endif %};"><path stroke="currentColor" stroke-width="2" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                                    {% else %}
                                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" style="color:{% if b.diff_days == 0 %}#f59e0b{% elseif b.diff_days <= 3 %}#ef4444{% else %}#a855f7{% endif %};"><path stroke="currentColor" stroke-width="2" d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/></svg>
                                    {% endif %}
                                </div>
                                <div class="flex-grow-1 min-width-0">
                                    <div class="fw-600 fs-sm text-truncate">{{ b.name }}</div>
                                    {% if b.sub %}<div class="text-muted" style="font-size:.72rem;">{{ b.sub }}</div>{% endif %}
                                </div>
                                <div class="text-end flex-shrink-0">
                                    {% if b.diff_days == 0 %}
                                        <span class="badge bg-warning text-dark">Heute 🎂</span>
                                    {% elseif b.diff_days == 1 %}
                                        <span class="badge bg-danger">Morgen</span>
                                    {% else %}
                                        <span class="badge bg-light text-muted border">in {{ b.diff_days }}d</span>
                                    {% endif %}
                                    <div class="text-muted mt-1" style="font-size:.68rem;">wird {{ b.age_next }}</div>
                                </div>
                            </a>
                            {% endfor %}
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# ── Plugin Widget Panels (one panel per plugin) ── #}
        {% if panel_id in widget_map|keys %}
        {% set w = widget_map[panel_id] %}
        <div class="{{ w.col ?? 'col-xl-4 col-lg-5 col-12' }}" data-panel-id="{{ w.id }}">
            <div class="panel" id="{{ w.id }}">
                <div class="panel-hdr">
                    <h2>
                        {% if w.icon %}<span class="me-2">{{ w.icon|raw }}</span>{% endif %}
                        {{ w.title }}
                    </h2>
                    <div class="panel-toolbar">
                        <button class="btn btn-panel" data-action="panel-collapse" title="Einklappen"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#minus"></use></svg></button>
                        <button class="btn btn-panel" data-action="panel-fullscreen" title="Vollbild"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#maximize-2"></use></svg></button>
                    </div>
                </div>
                <div class="panel-container">
                    <div class="panel-content">
                        {{ w.content|raw }}
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

    {% endfor %}

    </div>{# /dashboard-grid #}
</div>{# /main-content #}

{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/apexcharts@3/dist/apexcharts.min.js"></script>
<script>
(function(){
    'use strict';

    var isDark     = document.documentElement.getAttribute('data-bs-theme') === 'dark';
    var textColor  = isDark ? '#94a3b8' : '#6b7280';
    var gridColor  = isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';
    var bgCard     = isDark ? '#1e2a3a' : '#ffffff';

    /* ── Revenue Area Chart ─────────────────────────────────── */
    var revenueEl = document.getElementById('dash-revenue-chart');

    var weeklyData    = {{ stats.chart_weekly|default([])|json_encode|raw }};
    var monthlyData   = {{ stats.chart_monthly|default([])|json_encode|raw }};
    var weeklyLabels  = weeklyData.map(function(d){ return d.label; });
    var weeklyValues  = weeklyData.map(function(d){ return parseFloat(d.value) || 0; });
    var monthlyLabels = monthlyData.map(function(d){ return d.label; });
    var monthlyValues = monthlyData.map(function(d){ return parseFloat(d.value) || 0; });

    var revenueChart = null;
    if (revenueEl) {
        revenueChart = new ApexCharts(revenueEl, {
            chart: {
                type: 'area',
                height: 280,
                toolbar: { show: false },
                background: 'transparent',
                fontFamily: 'inherit',
                animations: { enabled: true, easing: 'easeinout', speed: 500 },
                zoom: { enabled: false }
            },
            series: [{ name: 'Umsatz', data: weeklyValues }],
            xaxis: {
                categories: weeklyLabels,
                labels: { style: { colors: textColor, fontSize: '11px' } },
                axisBorder: { show: false },
                axisTicks: { show: false }
            },
            yaxis: {
                labels: {
                    style: { colors: textColor, fontSize: '11px' },
                    formatter: function(v) {
                        return v >= 1000 ? (v/1000).toFixed(1)+'k €' : v.toFixed(0)+' €';
                    }
                }
            },
            colors: ['#4f7cff'],
            fill: {
                type: 'gradient',
                gradient: {
                    shadeIntensity: 1,
                    opacityFrom: 0.45,
                    opacityTo: 0.02,
                    stops: [0, 95]
                }
            },
            stroke: { curve: 'smooth', width: 2.5 },
            markers: { size: 3, colors: ['#4f7cff'], strokeColors: bgCard, strokeWidth: 2 },
            grid: { borderColor: gridColor, strokeDashArray: 4, padding: { left: 4, right: 4 } },
            dataLabels: { enabled: false },
            tooltip: {
                theme: isDark ? 'dark' : 'light',
                x: { show: true },
                y: { formatter: function(v) { return v.toFixed(2).replace('.',',') + ' €'; } }
            },
            legend: { show: false }
        });
        revenueChart.render();
    }

    document.getElementById('btn-weekly')?.addEventListener('click', function(){
        if (!revenueChart) return;
        revenueChart.updateOptions({ xaxis: { categories: weeklyLabels } });
        revenueChart.updateSeries([{ name: 'Umsatz', data: weeklyValues }]);
        this.classList.add('active');
        document.getElementById('btn-monthly').classList.remove('active');
    });
    document.getElementById('btn-monthly')?.addEventListener('click', function(){
        if (!revenueChart) return;
        revenueChart.updateOptions({ xaxis: { categories: monthlyLabels } });
        revenueChart.updateSeries([{ name: 'Umsatz', data: monthlyValues }]);
        this.classList.add('active');
        document.getElementById('btn-weekly').classList.remove('active');
    });

    /* ── Patient Sparkline ──────────────────────────────────── */
    var sparkEl = document.getElementById('dash-patient-sparkline');
    if (sparkEl) {
        var pLabels = {{ patient_trend.labels|json_encode|raw }};
        var pData   = {{ patient_trend.data|json_encode|raw }};
        new ApexCharts(sparkEl, {
            chart: {
                type: 'area',
                height: 60,
                sparkline: { enabled: true },
                background: 'transparent',
                animations: { enabled: true, speed: 400 }
            },
            series: [{ data: pData }],
            xaxis: { categories: pLabels },
            colors: ['#4f7cff'],
            fill: {
                type: 'gradient',
                gradient: { opacityFrom: 0.4, opacityTo: 0.0 }
            },
            stroke: { curve: 'smooth', width: 2 },
            tooltip: {
                theme: isDark ? 'dark' : 'light',
                x: { show: true },
                y: { formatter: function(v) { return v + ' Patient' + (v !== 1 ? 'en' : ''); } }
            }
        }).render();
    }

    /* ── Bezahlungsrate Radialbar ───────────────────────────── */
    var radialEl = document.getElementById('dash-paid-radial');
    if (radialEl) {
        var paidCount  = {{ stats.paid_count ?? 0 }};
        var openCount  = {{ stats.open_count ?? 0 }};
        var ovdCount   = {{ stats.overdue_count ?? 0 }};
        var totalInv   = paidCount + openCount + ovdCount;
        var paidPct    = totalInv > 0 ? Math.round((paidCount / totalInv) * 100) : 0;
        new ApexCharts(radialEl, {
            chart: {
                type: 'radialBar',
                height: 120,
                background: 'transparent',
                sparkline: { enabled: true },
                animations: { enabled: true, speed: 500 }
            },
            series: [paidPct],
            colors: ['#22c55e'],
            plotOptions: {
                radialBar: {
                    startAngle: -135,
                    endAngle: 135,
                    hollow: { size: '55%' },
                    track: { background: isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)', strokeWidth: '100%' },
                    dataLabels: {
                        name: { show: false },
                        value: {
                            fontSize: '18px',
                            fontWeight: 700,
                            color: '#22c55e',
                            offsetY: 6,
                            formatter: function(v) { return v + '%'; }
                        }
                    }
                }
            },
            stroke: { lineCap: 'round' },
            tooltip: { enabled: false }
        }).render();
    }

    /* ── Patienten + Tierhalter Bar ─────────────────────────── */
    var ownersEl = document.getElementById('dash-owners-bar');
    if (ownersEl) {
        var pLabels2 = {{ patient_trend.labels|json_encode|raw }};
        var pData2   = {{ patient_trend.data|json_encode|raw }};
        new ApexCharts(ownersEl, {
            chart: {
                type: 'bar',
                height: 60,
                sparkline: { enabled: true },
                background: 'transparent',
                animations: { enabled: true, speed: 400 }
            },
            series: [{ name: 'Neue Patienten', data: pData2 }],
            xaxis: { categories: pLabels2 },
            colors: ['#a855f7'],
            plotOptions: { bar: { borderRadius: 2, columnWidth: '60%' } },
            tooltip: {
                theme: isDark ? 'dark' : 'light',
                y: { formatter: function(v) { return v + ' neu'; } }
            }
        }).render();
    }

})();

/* ── Sortable drag & drop with server-side persistence ── */
(function() {
    var grid = document.getElementById('dashboard-grid');
    if (!grid || typeof Sortable === 'undefined') return;

    Sortable.create(grid, {
        handle: '.panel-hdr h2',
        animation: 200,
        ghostClass: 'panel-selected',
        onEnd: function() {
            var order = Array.from(grid.querySelectorAll('[data-panel-id]'))
                            .map(function(el) { return el.getAttribute('data-panel-id'); });
            fetch('/api/dashboard/layout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ layout: order })
            });
        }
    });
})();

/* ── Dashboard panel position reset ── */
function resetPanelState() {
    if (!confirm('Dashboard-Layout zurücksetzen?')) return;
    fetch('/api/dashboard/layout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ layout: null })
    }).then(function() { location.reload(); });
}
</script>
{% endblock %}
