{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}
<div class="page-header">
    <h1 class="page-title">{{ t('profile.title') }}</h1>
</div>

<div class="flex gap-4" style="align-items:flex-start;flex-wrap:wrap;">

    {# Profile Info #}
    <div style="flex:1;min-width:280px;display:flex;flex-direction:column;gap:1rem;">
        <div class="glass-card">
            <div class="flex items-center gap-4 mb-6">
                <div class="avatar-placeholder" style="width:64px;height:64px;font-size:1.5rem;border-radius:50%;">{{ current_user.name|initials }}</div>
                <div>
                    <div class="font-bold" style="font-size:1.15rem;">{{ current_user.name }}</div>
                    <div class="text-sm text-muted">{{ current_user.email }}</div>
                    <span class="badge {{ current_user.role == 'admin' ? 'badge-admin' : 'badge-primary' }} mt-1">
                        {{ current_user.role == 'admin' ? t('common.role_admin') : t('common.role_mita') }}
                    </span>
                </div>
            </div>

            <h3 class="font-semibold mb-4" style="font-size:0.9rem;color:var(--accent);">Persönliche Daten</h3>

            <form action="{{ base_path }}/profil" method="POST">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <input type="hidden" name="action" value="profile">
                <div class="form-group mb-3">
                    <label class="form-label">{{ t('profile.name') }} *</label>
                    <input type="text" name="name" class="form-control" value="{{ current_user.name }}" required>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">{{ t('profile.email') }} *</label>
                    <input type="email" name="email" class="form-control" value="{{ current_user.email }}" required>
                </div>
                <div class="form-grid form-grid-2 mb-4">
                    <div class="form-group">
                        <label class="form-label">{{ t('profile.theme') }}</label>
                        <select name="theme" class="form-control">
                            <option value="dark"  {{ theme == 'dark'  ? 'selected' : '' }}>{{ t('profile.dark_theme') }}</option>
                            <option value="light" {{ theme == 'light' ? 'selected' : '' }}>{{ t('profile.light_theme') }}</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('profile.language') }}</label>
                        <select name="locale" class="form-control">
                            <option value="de" {{ current_locale == 'de' ? 'selected' : '' }}>{{ t('profile.german') }}</option>
                            <option value="en" {{ current_locale == 'en' ? 'selected' : '' }}>{{ t('profile.english') }}</option>
                        </select>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 3 7 8 15 8"/></svg>
                    {{ t('common.save') }}
                </button>
            </form>
        </div>
    </div>

    {# Password Change #}
    <div style="width:320px;flex-shrink:0;">
        <div class="glass-card">
            <h3 class="font-semibold mb-4" style="font-size:0.9rem;color:var(--accent);">{{ t('profile.change_password') }}</h3>
            <form action="{{ base_path }}/profil" method="POST">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <input type="hidden" name="action" value="password">
                <div class="form-group mb-3">
                    <label class="form-label">{{ t('profile.current_password') }}</label>
                    <input type="password" name="current_password" class="form-control" autocomplete="current-password" required>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">{{ t('profile.new_password') }}</label>
                    <input type="password" name="new_password" class="form-control" autocomplete="new-password" minlength="8" required>
                    <div class="form-hint">Mindestens 8 Zeichen</div>
                </div>
                <div class="form-group mb-4">
                    <label class="form-label">{{ t('profile.confirm_password') }}</label>
                    <input type="password" name="confirm_password" class="form-control" autocomplete="new-password" minlength="8" required>
                </div>
                <button type="submit" class="btn btn-secondary w-full">
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="2"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    {{ t('profile.change_password') }}
                </button>
            </form>
        </div>

        <div class="glass-card mt-4">
            <h3 class="font-semibold mb-3" style="font-size:0.9rem;color:var(--text-muted);">Kontoinformationen</h3>
            <div style="display:flex;flex-direction:column;gap:0.5rem;">
                <div class="flex justify-between text-sm">
                    <span class="text-muted">Konto-ID</span>
                    <span class="font-medium" style="font-family:monospace;">#{{ current_user.id }}</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-muted">Rolle</span>
                    <span class="badge {{ current_user.role == 'admin' ? 'badge-admin' : 'badge-primary' }}">{{ current_user.role }}</span>
                </div>
                {% if current_user.last_login %}
                <div class="flex justify-between text-sm">
                    <span class="text-muted">Letzter Login</span>
                    <span class="font-medium">{{ current_user.last_login|datetime_de }}</span>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
