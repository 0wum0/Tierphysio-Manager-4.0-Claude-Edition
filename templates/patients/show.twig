{% extends 'layouts/base.twig' %}

{% block content %}
<div class="page-header">
    <div class="flex items-center gap-3">
        <a href="/patienten" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            {{ t('patients.back_to_list') }}
        </a>
        <h1 class="page-title">{{ patient.name }}</h1>
        <span class="badge badge-{{ patient.status|lower|replace({' ':'_', 'ä':'ae','ü':'ue','ö':'oe'}) }}">{{ patient.status }}</span>
    </div>
    <div class="flex gap-2">
        <a href="/rechnungen/erstellen?patient_id={{ patient.id }}" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
            {{ t('patients.create_invoice') }}
        </a>
        <button class="btn btn-primary btn-sm" data-modal-open="modal-edit-patient">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            {{ t('common.edit') }}
        </button>
    </div>
</div>

<div class="flex gap-4" style="align-items:flex-start;flex-wrap:wrap;">

    {# Left: Patient Info #}
    <div style="width:280px;flex-shrink:0;display:flex;flex-direction:column;gap:1rem;">

        {# Photo Card #}
        <div class="glass-card" style="padding:0;overflow:hidden;">
            <div style="height:200px;background:linear-gradient(135deg,var(--bg-elevated),var(--bg-surface));display:flex;align-items:center;justify-content:center;position:relative;">
                {% if patient.photo %}
                    <img src="/storage/patients/{{ patient.id }}/{{ patient.photo }}" alt="{{ patient.name }}" style="width:100%;height:100%;object-fit:cover;">
                {% else %}
                    <svg width="48" height="48" fill="none" viewBox="0 0 24 24" style="color:var(--text-muted);opacity:0.4;"><path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                {% endif %}
            </div>
            <div style="padding:1rem;">
                <form action="/patienten/{{ patient.id }}/foto" method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                    <label class="form-label">{{ t('patients.photo') }}</label>
                    <div class="flex gap-2 mt-1">
                        <input type="file" name="photo" accept="image/*" class="form-control" style="font-size:0.8rem;padding:0.4rem;">
                        <button type="submit" class="btn btn-secondary btn-sm" style="flex-shrink:0;">
                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        {# Patient Details #}
        <div class="glass-card">
            <h3 class="font-semibold mb-3" style="font-size:0.9rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">Details</h3>
            <div style="display:flex;flex-direction:column;gap:0.75rem;">
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.species') }}</div>
                    <div class="text-sm font-medium">{{ patient.species ?: '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.breed') }}</div>
                    <div class="text-sm font-medium">{{ patient.breed ?: '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.gender') }}</div>
                    <div class="text-sm font-medium">{{ patient.gender ?: '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.birth_date') }}</div>
                    <div class="text-sm font-medium">{{ patient.birth_date ? patient.birth_date|date_de : '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.color') }}</div>
                    <div class="text-sm font-medium">{{ patient.color ?: '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.chip_number') }}</div>
                    <div class="text-sm font-medium" style="font-family:monospace;">{{ patient.chip_number ?: '—' }}</div>
                </div>
                {% if patient.notes %}
                <div style="border-top:1px solid var(--glass-border);padding-top:0.75rem;">
                    <div class="text-xs text-muted mb-1">{{ t('patients.notes') }}</div>
                    <div class="text-sm" style="line-height:1.5;color:var(--text-secondary);">{{ patient.notes }}</div>
                </div>
                {% endif %}
            </div>
        </div>

        {# Owner Card #}
        {% if owner %}
        <div class="glass-card">
            <h3 class="font-semibold mb-3" style="font-size:0.9rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">{{ t('patients.owner') }}</h3>
            <a href="/tierhalter/{{ owner.id }}" style="text-decoration:none;">
                <div class="flex items-center gap-3">
                    <div class="avatar-placeholder avatar-md" style="font-size:0.875rem;">{{ owner.first_name|first ~ owner.last_name|first }}</div>
                    <div>
                        <div class="font-semibold text-sm">{{ owner.first_name }} {{ owner.last_name }}</div>
                        {% if owner.phone %}<div class="text-xs text-muted">{{ owner.phone }}</div>{% endif %}
                        {% if owner.email %}<div class="text-xs text-muted">{{ owner.email }}</div>{% endif %}
                    </div>
                </div>
            </a>
        </div>
        {% endif %}

        {# Delete #}
        <form action="/patienten/{{ patient.id }}/loeschen" method="POST">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="btn btn-danger w-full" data-confirm="Patient wirklich löschen? Alle Daten werden entfernt.">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m5 0V4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2"/></svg>
                {{ t('common.delete') }}
            </button>
        </form>
    </div>

    {# Right: Timeline #}
    <div style="flex:1;min-width:0;display:flex;flex-direction:column;gap:1rem;">

        {# Add Timeline Entry #}
        <div class="glass-card">
            <h3 class="font-semibold mb-3" style="font-size:0.95rem;">{{ t('patients.add_entry') }}</h3>
            <form action="/patienten/{{ patient.id }}/timeline" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <div class="form-grid form-grid-2" style="margin-bottom:0.75rem;">
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.entry_type') }}</label>
                        <select name="type" class="form-control">
                            <option value="note">📝 Notiz</option>
                            <option value="treatment">💊 Behandlung</option>
                            <option value="photo">📷 Foto</option>
                            <option value="document">📄 Dokument</option>
                            <option value="other">📌 Sonstiges</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.entry_date') }}</label>
                        <input type="datetime-local" name="entry_date" class="form-control" value="{{ 'now'|date('Y-m-d\\TH:i') }}">
                    </div>
                </div>
                <div class="form-group mb-2">
                    <label class="form-label">{{ t('patients.entry_title') }}</label>
                    <input type="text" name="title" class="form-control" placeholder="Kurzer Titel...">
                </div>
                <div class="form-grid form-grid-2" style="margin-bottom:0.75rem;">
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.status_badge') }}</label>
                        <select name="status_badge" class="form-control">
                            <option value="">— Kein Badge —</option>
                            <option value="Schmerzfrei">Schmerzfrei</option>
                            <option value="In Behandlung">In Behandlung</option>
                            <option value="Kontrolltermin">Kontrolltermin</option>
                            <option value="Notfall">Notfall</option>
                            <option value="Gebessert">Gebessert</option>
                            <option value="Entlassen">Entlassen</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.attachment') }}</label>
                        <input type="file" name="attachment" class="form-control" style="font-size:0.8rem;padding:0.4rem;">
                    </div>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">{{ t('patients.entry_content') }} (Markdown)</label>
                    <textarea name="content" class="form-control" rows="3" placeholder="Notizen, Befunde, Behandlungsschritte..."></textarea>
                </div>
                <button type="submit" class="btn btn-primary btn-sm">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    {{ t('patients.add_entry') }}
                </button>
            </form>
        </div>

        {# Timeline #}
        <div class="glass-card">
            <h3 class="font-semibold mb-4" style="font-size:0.95rem;">{{ t('patients.timeline') }}</h3>

            {% if timeline %}
                <div class="timeline">
                    {% for entry in timeline %}
                        <div class="timeline-item">
                            <div class="timeline-dot timeline-dot-{{ entry.type }}"></div>
                            <div class="timeline-card">
                                <div class="timeline-meta">
                                    <div class="flex items-center gap-2">
                                        <span class="text-xs" style="color:var(--text-muted);">
                                            {% if entry.type == 'note' %}📝{% elseif entry.type == 'treatment' %}💊{% elseif entry.type == 'photo' %}📷{% elseif entry.type == 'document' %}📄{% else %}📌{% endif %}
                                        </span>
                                        {% if entry.status_badge %}
                                            <span class="badge badge-primary" style="font-size:0.65rem;">{{ entry.status_badge }}</span>
                                        {% endif %}
                                        <span class="timeline-date">{{ entry.entry_date|datetime_de }}</span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        {% if entry.user_name %}
                                            <span class="timeline-author">{{ entry.user_name }}</span>
                                        {% endif %}
                                        <form action="/patienten/{{ patient.id }}/timeline/{{ entry.id }}/loeschen" method="POST" style="margin:0;">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                            <button type="submit" class="btn btn-sm" style="width:24px;height:24px;padding:0;color:var(--text-muted);border:none;background:none;" data-confirm="Eintrag wirklich löschen?">
                                                <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                                {% if entry.title %}
                                    <div class="timeline-title">{{ entry.title }}</div>
                                {% endif %}
                                {% if entry.content %}
                                    <div class="timeline-content">{{ entry.content }}</div>
                                {% endif %}
                                {% if entry.attachment %}
                                    <div class="mt-2">
                                        <a href="/patienten/{{ patient.id }}/dokumente/{{ entry.attachment }}" class="btn btn-secondary btn-sm">
                                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                            {{ entry.attachment }}
                                        </a>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="empty-state" style="padding:2rem 1rem;">
                    <div class="empty-state-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/></svg></div>
                    <div class="empty-state-title">Noch keine Einträge</div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

{# Edit Patient Modal #}
<div class="modal-overlay" id="modal-edit-patient">
    <div class="modal modal-lg">
        <div class="modal-header">
            <h3 class="modal-title">{{ t('common.edit') }}: {{ patient.name }}</h3>
            <button class="modal-close" data-modal-close="modal-edit-patient" type="button">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
        </div>
        <form action="/patienten/{{ patient.id }}" method="POST" class="modal-body">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="form-grid form-grid-2">
                <div class="form-group">
                    <label class="form-label">{{ t('patients.name') }} *</label>
                    <input type="text" name="name" class="form-control" value="{{ patient.name }}" required>
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('patients.species') }}</label>
                    <input type="text" name="species" class="form-control" value="{{ patient.species }}">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('patients.breed') }}</label>
                    <input type="text" name="breed" class="form-control" value="{{ patient.breed }}">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('patients.birth_date') }}</label>
                    <input type="date" name="birth_date" class="form-control" value="{{ patient.birth_date }}">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('patients.gender') }}</label>
                    <select name="gender" class="form-control">
                        <option value="unbekannt" {{ patient.gender == 'unbekannt' ? 'selected' : '' }}>{{ t('patients.unknown') }}</option>
                        <option value="männlich" {{ patient.gender == 'männlich' ? 'selected' : '' }}>{{ t('patients.male') }}</option>
                        <option value="weiblich" {{ patient.gender == 'weiblich' ? 'selected' : '' }}>{{ t('patients.female') }}</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('patients.color') }}</label>
                    <input type="text" name="color" class="form-control" value="{{ patient.color }}">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('patients.chip_number') }}</label>
                    <input type="text" name="chip_number" class="form-control" value="{{ patient.chip_number }}">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('patients.status') }}</label>
                    <select name="status" class="form-control">
                        <option value="aktiv" {{ patient.status == 'aktiv' ? 'selected' : '' }}>Aktiv</option>
                        <option value="in_behandlung" {{ patient.status == 'in_behandlung' ? 'selected' : '' }}>In Behandlung</option>
                        <option value="schmerzfrei" {{ patient.status == 'schmerzfrei' ? 'selected' : '' }}>Schmerzfrei</option>
                        <option value="kontrolltermin" {{ patient.status == 'kontrolltermin' ? 'selected' : '' }}>Kontrolltermin</option>
                        <option value="inaktiv" {{ patient.status == 'inaktiv' ? 'selected' : '' }}>Inaktiv</option>
                    </select>
                </div>
            </div>
            <div class="form-group mt-3">
                <label class="form-label">{{ t('patients.owner') }} *</label>
                <select name="owner_id" class="form-control" required>
                    {% for o in owners %}
                        <option value="{{ o.id }}" {{ patient.owner_id == o.id ? 'selected' : '' }}>
                            {{ o.last_name }}, {{ o.first_name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="form-group mt-3">
                <label class="form-label">{{ t('patients.notes') }}</label>
                <textarea name="notes" class="form-control" rows="3">{{ patient.notes }}</textarea>
            </div>
            <div class="modal-footer" style="padding:1rem 0 0;margin-top:1rem;border-top:1px solid var(--glass-border);">
                <button type="button" class="btn btn-secondary" data-modal-close="modal-edit-patient">{{ t('common.cancel') }}</button>
                <button type="submit" class="btn btn-primary">{{ t('common.save') }}</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
