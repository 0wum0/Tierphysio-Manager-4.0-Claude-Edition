{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}
<div class="page-header">
    <div class="flex items-center gap-3">
        <a href="/patienten" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            {{ t('patients.back_to_list') }}
        </a>
        <h1 class="page-title">{{ patient.name }}</h1>
        <span class="badge badge-{{ patient.status|lower|replace({' ':'_', 'ä':'ae','ü':'ue','ö':'oe'}) }}">{{ patient.status }}</span>
    </div>
    <div class="flex gap-2">
        <button class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-create-invoice">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
            {{ t('patients.create_invoice') }}
        </button>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-edit-patient">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            {{ t('common.edit') }}
        </button>
    </div>
</div>

<div class="flex gap-4" style="align-items:flex-start;flex-wrap:wrap;">

    {# Left: Patient Info #}
    <div style="width:280px;flex-shrink:0;display:flex;flex-direction:column;gap:1rem;">

        {# Photo Card #}
        <div class="glass-card" style="padding:0;overflow:hidden;">
            <div style="height:200px;background:linear-gradient(135deg,var(--bg-elevated),var(--bg-surface));display:flex;align-items:center;justify-content:center;position:relative;">
                {% if patient.photo %}
                    <img src="/patienten/{{ patient.id }}/foto/{{ patient.photo }}" alt="{{ patient.name }}" style="width:100%;height:100%;object-fit:cover;">
                {% else %}
                    <svg width="48" height="48" fill="none" viewBox="0 0 24 24" style="color:var(--text-muted);opacity:0.4;"><path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                {% endif %}
            </div>
            <div style="padding:1rem;">
                <form action="/patienten/{{ patient.id }}/foto" method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                    <label class="form-label">{{ t('patients.photo') }}</label>
                    <div class="flex gap-2 mt-1">
                        <input type="file" name="photo" accept="image/*" class="form-control" style="font-size:0.8rem;padding:0.4rem;">
                        <button type="submit" class="btn btn-secondary btn-sm" style="flex-shrink:0;">
                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        {# Patient Details #}
        <div class="glass-card">
            <h3 class="font-semibold mb-3" style="font-size:0.9rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">Details</h3>
            <div style="display:flex;flex-direction:column;gap:0.75rem;">
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.species') }}</div>
                    <div class="text-sm font-medium">{{ patient.species ?: '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.breed') }}</div>
                    <div class="text-sm font-medium">{{ patient.breed ?: '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.gender') }}</div>
                    <div class="text-sm font-medium">{{ patient.gender ?: '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.birth_date') }}</div>
                    <div class="text-sm font-medium">{{ patient.birth_date ? patient.birth_date|date_de : '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.color') }}</div>
                    <div class="text-sm font-medium">{{ patient.color ?: '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.chip_number') }}</div>
                    <div class="text-sm font-medium" style="font-family:monospace;">{{ patient.chip_number ?: '—' }}</div>
                </div>
                {% if patient.notes %}
                <div style="border-top:1px solid var(--glass-border);padding-top:0.75rem;">
                    <div class="text-xs text-muted mb-1">{{ t('patients.notes') }}</div>
                    <div class="text-sm" style="line-height:1.5;color:var(--text-secondary);">{{ patient.notes }}</div>
                </div>
                {% endif %}
            </div>
        </div>

        {# Owner Card #}
        {% if owner %}
        <div class="glass-card">
            <h3 class="font-semibold mb-3" style="font-size:0.9rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">{{ t('patients.owner') }}</h3>
            <a href="/tierhalter/{{ owner.id }}" style="text-decoration:none;">
                <div class="flex items-center gap-3">
                    <div class="avatar-placeholder avatar-md" style="font-size:0.875rem;">{{ owner.first_name|first ~ owner.last_name|first }}</div>
                    <div>
                        <div class="font-semibold text-sm">{{ owner.first_name }} {{ owner.last_name }}</div>
                        {% if owner.phone %}<div class="text-xs text-muted">{{ owner.phone }}</div>{% endif %}
                        {% if owner.email %}<div class="text-xs text-muted">{{ owner.email }}</div>{% endif %}
                    </div>
                </div>
            </a>
        </div>
        {% endif %}

        {# Delete #}
        <form action="/patienten/{{ patient.id }}/loeschen" method="POST">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="btn btn-danger w-full" data-confirm="Patient wirklich löschen? Alle Daten werden entfernt.">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m5 0V4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2"/></svg>
                {{ t('common.delete') }}
            </button>
        </form>
    </div>

    {# Right: Timeline #}
    <div style="flex:1;min-width:0;display:flex;flex-direction:column;gap:1rem;">

        {# Add Timeline Entry #}
        <div class="glass-card">
            <h3 class="font-semibold mb-3" style="font-size:0.95rem;">{{ t('patients.add_entry') }}</h3>
            <form action="/patienten/{{ patient.id }}/timeline" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <div class="form-grid form-grid-2" style="margin-bottom:0.75rem;">
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.entry_type') }}</label>
                        <select name="type" class="form-control">
                            <option value="note">📝 Notiz</option>
                            <option value="treatment">💊 Behandlung</option>
                            <option value="photo">📷 Foto</option>
                            <option value="document">📄 Dokument</option>
                            <option value="other">📌 Sonstiges</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.entry_date') }}</label>
                        <input type="datetime-local" name="entry_date" class="form-control" value="{{ 'now'|date('Y-m-d\\TH:i') }}">
                    </div>
                </div>
                <div class="form-group mb-2">
                    <label class="form-label">{{ t('patients.entry_title') }}</label>
                    <input type="text" name="title" class="form-control" placeholder="Kurzer Titel...">
                </div>
                <div class="form-grid form-grid-2" style="margin-bottom:0.75rem;">
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.status_badge') }}</label>
                        <select name="status_badge" class="form-control">
                            <option value="">— Kein Badge —</option>
                            <option value="Schmerzfrei">Schmerzfrei</option>
                            <option value="In Behandlung">In Behandlung</option>
                            <option value="Kontrolltermin">Kontrolltermin</option>
                            <option value="Notfall">Notfall</option>
                            <option value="Gebessert">Gebessert</option>
                            <option value="Entlassen">Entlassen</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.attachment') }}</label>
                        <input type="file" name="attachment" class="form-control" style="font-size:0.8rem;padding:0.4rem;">
                    </div>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">{{ t('patients.entry_content') }} (Markdown)</label>
                    <textarea name="content" class="form-control" rows="3" placeholder="Notizen, Befunde, Behandlungsschritte..."></textarea>
                </div>
                <button type="submit" class="btn btn-primary btn-sm">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    {{ t('patients.add_entry') }}
                </button>
            </form>
        </div>

        {# Timeline #}
        <div class="glass-card">
            <h3 class="font-semibold mb-4" style="font-size:0.95rem;">{{ t('patients.timeline') }}</h3>

            {% if timeline %}
                <div class="timeline">
                    {% for entry in timeline %}
                        <div class="timeline-item">
                            <div class="timeline-dot timeline-dot-{{ entry.type }}"></div>
                            <div class="timeline-card">
                                <div class="timeline-meta">
                                    <div class="flex items-center gap-2">
                                        <span class="text-xs" style="color:var(--text-muted);">
                                            {% if entry.type == 'note' %}📝{% elseif entry.type == 'treatment' %}💊{% elseif entry.type == 'photo' %}📷{% elseif entry.type == 'document' %}📄{% else %}📌{% endif %}
                                        </span>
                                        {% if entry.status_badge %}
                                            <span class="badge badge-primary" style="font-size:0.65rem;">{{ entry.status_badge }}</span>
                                        {% endif %}
                                        <span class="timeline-date">{{ entry.entry_date|datetime_de }}</span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        {% if entry.user_name %}
                                            <span class="timeline-author">{{ entry.user_name }}</span>
                                        {% endif %}
                                        <form action="/patienten/{{ patient.id }}/timeline/{{ entry.id }}/loeschen" method="POST" style="margin:0;">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                            <button type="submit" class="btn btn-sm" style="width:24px;height:24px;padding:0;color:var(--text-muted);border:none;background:none;" data-confirm="Eintrag wirklich löschen?">
                                                <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                                {% if entry.title %}
                                    <div class="timeline-title">{{ entry.title }}</div>
                                {% endif %}
                                {% if entry.content %}
                                    <div class="timeline-content">{{ entry.content }}</div>
                                {% endif %}
                                {% if entry.attachment %}
                                    {% set ext = entry.attachment|split('.')|last|lower %}
                                    {% set isImage = ext in ['jpg','jpeg','png','gif','webp'] %}
                                    <div class="mt-2">
                                        {% if isImage %}
                                            <a href="/patienten/{{ patient.id }}/dokumente/{{ entry.attachment }}"
                                               class="timeline-attachment-preview"
                                               data-lightbox="/patienten/{{ patient.id }}/dokumente/{{ entry.attachment }}"
                                               data-filename="{{ entry.attachment }}">
                                                <img src="/patienten/{{ patient.id }}/dokumente/{{ entry.attachment }}"
                                                     alt="{{ entry.attachment }}"
                                                     style="max-height:120px;max-width:100%;border-radius:6px;cursor:pointer;border:1px solid var(--glass-border);display:block;">
                                            </a>
                                        {% else %}
                                            <a href="/patienten/{{ patient.id }}/dokumente/{{ entry.attachment }}"
                                               class="btn btn-secondary btn-sm"
                                               data-lightbox="/patienten/{{ patient.id }}/dokumente/{{ entry.attachment }}"
                                               data-filename="{{ entry.attachment }}">
                                                <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="1.5" stroke-linecap="round" points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="16" y1="17" x2="8" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                                                {{ entry.attachment }}
                                            </a>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="empty-state" style="padding:2rem 1rem;">
                    <div class="empty-state-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/></svg></div>
                    <div class="empty-state-title">Noch keine Einträge</div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

{# Edit Patient Modal #}
<div class="modal fade" id="modal-edit-patient" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">{{ t('common.edit') }}: {{ patient.name }}</h3>
            <button class="modal-close" data-bs-dismiss="modal" type="button">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
        </div>
        <form action="/patienten/{{ patient.id }}" method="POST" style="display:contents;">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="modal-body">
                <div class="form-grid form-grid-2">
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.name') }} *</label>
                        <input type="text" name="name" class="form-control" value="{{ patient.name }}" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.species') }}</label>
                        <input type="text" name="species" class="form-control" value="{{ patient.species }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.breed') }}</label>
                        <input type="text" name="breed" class="form-control" value="{{ patient.breed }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.birth_date') }}</label>
                        <input type="date" name="birth_date" class="form-control" value="{{ patient.birth_date }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.gender') }}</label>
                        <select name="gender" class="form-control">
                            <option value="unbekannt" {{ patient.gender == 'unbekannt' ? 'selected' : '' }}>{{ t('patients.unknown') }}</option>
                            <option value="männlich" {{ patient.gender == 'männlich' ? 'selected' : '' }}>{{ t('patients.male') }}</option>
                            <option value="weiblich" {{ patient.gender == 'weiblich' ? 'selected' : '' }}>{{ t('patients.female') }}</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.color') }}</label>
                        <input type="text" name="color" class="form-control" value="{{ patient.color }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.chip_number') }}</label>
                        <input type="text" name="chip_number" class="form-control" value="{{ patient.chip_number }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('patients.status') }}</label>
                        <select name="status" class="form-control">
                            <option value="aktiv" {{ patient.status == 'aktiv' ? 'selected' : '' }}>Aktiv</option>
                            <option value="in_behandlung" {{ patient.status == 'in_behandlung' ? 'selected' : '' }}>In Behandlung</option>
                            <option value="schmerzfrei" {{ patient.status == 'schmerzfrei' ? 'selected' : '' }}>Schmerzfrei</option>
                            <option value="kontrolltermin" {{ patient.status == 'kontrolltermin' ? 'selected' : '' }}>Kontrolltermin</option>
                            <option value="inaktiv" {{ patient.status == 'inaktiv' ? 'selected' : '' }}>Inaktiv</option>
                        </select>
                    </div>
                </div>
                <div class="form-group mt-3">
                    <label class="form-label">{{ t('patients.owner') }} *</label>
                    <select name="owner_id" class="form-control" required>
                        {% for o in owners %}
                            <option value="{{ o.id }}" {{ patient.owner_id == o.id ? 'selected' : '' }}>
                                {{ o.last_name }}, {{ o.first_name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-group mt-3">
                    <label class="form-label">{{ t('patients.notes') }}</label>
                    <textarea name="notes" class="form-control" rows="3">{{ patient.notes }}</textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ t('common.cancel') }}</button>
                <button type="submit" class="btn btn-primary">{{ t('common.save') }}</button>
            </div>
        </form>
    </div></div>
</div>

{# ── Rechnung erstellen Modal ────────────────────────────────────── #}
<div class="modal fade" id="modal-create-invoice" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header" style="flex-shrink:0;">
            <div class="flex items-center gap-3">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
                <span class="font-bold" style="font-size:1rem;">Rechnung erstellen</span>
            </div>
            <button class="modal-close" data-bs-dismiss="modal" type="button">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
        </div>

        <form action="/rechnungen" method="POST" id="invoice-create-modal-form">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <input type="hidden" name="patient_id" value="{{ patient.id }}">
        <input type="hidden" name="owner_id" value="{{ owner.id ?? '' }}">

        <div class="modal-body" style="overflow-y:auto;flex:1;">
            <div class="flex gap-4" style="flex-wrap:wrap;align-items:flex-start;">

                {# Left: invoice meta #}
                <div style="flex:1;min-width:260px;display:flex;flex-direction:column;gap:1rem;">

                    <div class="form-grid form-grid-2">
                        <div class="form-group">
                            <label class="form-label">{{ t('invoices.invoice_number') }}</label>
                            <input type="text" name="invoice_number" class="form-control" value="{{ next_number }}" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">{{ t('invoices.status') }}</label>
                            <select name="status" class="form-control">
                                <option value="draft">{{ t('invoices.status_draft') }}</option>
                                <option value="open">{{ t('invoices.status_open') }}</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">{{ t('invoices.issue_date') }}</label>
                            <input type="date" name="issue_date" class="form-control" value="{{ 'now'|date('Y-m-d') }}">
                        </div>
                        <div class="form-group">
                            <label class="form-label">{{ t('invoices.due_date') }}</label>
                            <input type="date" name="due_date" class="form-control" value="{{ 'now'|date_modify('+14 days')|date('Y-m-d') }}">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">{{ t('invoices.notes') }}</label>
                        <textarea name="notes" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('invoices.payment_terms') }}</label>
                        <textarea name="payment_terms" class="form-control" rows="2"></textarea>
                    </div>

                </div>

                {# Right: positions #}
                <div style="flex:1.4;min-width:300px;display:flex;flex-direction:column;gap:0.75rem;">

                    {% if kleinunternehmer %}
                    <div class="flex items-center gap-2" style="background:rgba(255,193,7,0.12);border:1px solid rgba(255,193,7,0.3);border-radius:var(--radius-sm);padding:0.5rem 0.75rem;">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" style="color:#f59e0b;flex-shrink:0;"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        <span class="text-xs"><strong>Kleinunternehmer §19 UStG</strong> — MwSt. 0%</span>
                    </div>
                    {% endif %}

                    {# Column headers #}
                    <div style="display:grid;grid-template-columns:1fr 70px 100px {{ kleinunternehmer ? '0px' : '65px' }} auto;gap:0.4rem;">
                        <span class="text-xs text-muted">Beschreibung</span>
                        <span class="text-xs text-muted" style="text-align:right;">Menge</span>
                        <span class="text-xs text-muted" style="text-align:right;">Einzelpreis</span>
                        {% if not kleinunternehmer %}<span class="text-xs text-muted" style="text-align:right;">MwSt.%</span>{% endif %}
                        <span></span>
                    </div>

                    <div id="modal-positions-container">
                        <div class="modal-position-row" style="display:grid;grid-template-columns:1fr 70px 100px {{ kleinunternehmer ? '0px' : '65px' }} auto;gap:0.4rem;margin-bottom:0.4rem;align-items:center;">
                            <input type="text" name="position_description[]" class="form-control" placeholder="Leistung..." required>
                            <input type="number" name="position_quantity[]" class="form-control pos-qty" value="1" min="0.01" step="0.01" style="text-align:right;">
                            <input type="number" name="position_price[]" class="form-control pos-price" value="0.00" min="0" step="0.01" style="text-align:right;">
                            <input type="number" name="position_tax_rate[]" class="form-control pos-tax" value="{{ kleinunternehmer ? '0' : default_tax_rate }}" min="0" step="0.01" style="text-align:right;{{ kleinunternehmer ? 'display:none;' : '' }}">
                            <button type="button" class="btn btn-danger btn-icon btn-sm remove-modal-position" title="Entfernen" style="visibility:hidden;">
                                <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            </button>
                        </div>
                    </div>

                    <button type="button" id="modal-add-position" class="btn btn-secondary btn-sm" style="align-self:flex-start;">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        Position hinzufügen
                    </button>

                    {# Running total #}
                    <div style="border-top:1px solid var(--glass-border);padding-top:0.75rem;margin-top:0.25rem;">
                        <div class="flex justify-between text-sm">
                            <span class="text-muted">Gesamt (brutto)</span>
                            <span id="modal-total-gross" class="font-bold" style="color:var(--accent);font-size:1rem;">0,00 €</span>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="modal-footer" style="flex-shrink:0;">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ t('common.cancel') }}</button>
            <button type="submit" class="btn btn-primary">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 3 7 8 15 8"/></svg>
                Rechnung speichern
            </button>
        </div>
        </form>
    </div></div>
</div>

{# Position Row Template for modal #}
<template id="modal-position-row-template">
    <div class="modal-position-row" style="display:grid;grid-template-columns:1fr 70px 100px {{ kleinunternehmer ? '0px' : '65px' }} auto;gap:0.4rem;margin-bottom:0.4rem;align-items:center;">
        <input type="text" name="position_description[]" class="form-control" placeholder="Leistung..." required>
        <input type="number" name="position_quantity[]" class="form-control pos-qty" value="1" min="0.01" step="0.01" style="text-align:right;">
        <input type="number" name="position_price[]" class="form-control pos-price" value="0.00" min="0" step="0.01" style="text-align:right;">
        <input type="number" name="position_tax_rate[]" class="form-control pos-tax" value="{{ kleinunternehmer ? '0' : default_tax_rate }}" min="0" step="0.01" style="text-align:right;{{ kleinunternehmer ? 'display:none;' : '' }}">
        <button type="button" class="btn btn-danger btn-icon btn-sm remove-modal-position" title="Entfernen">
            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
    </div>
</template>

{# Datei-Viewer (Bilder + PDFs) #}
<div id="fileviewer-overlay" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.88);align-items:center;justify-content:center;padding:1rem;box-sizing:border-box;">
    <div style="position:relative;width:100%;max-width:960px;height:min(88vh,100%);display:flex;flex-direction:column;background:var(--bg-surface,#1a1a2e);border-radius:12px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.7);">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:0.75rem 1rem;border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;gap:0.5rem;">
            <span id="fv-filename" style="font-size:0.875rem;font-weight:600;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;min-width:0;flex:1;"></span>
            <div style="display:flex;gap:0.5rem;align-items:center;flex-shrink:0;">
                <a id="fv-download" href="" download style="background:rgba(255,255,255,0.12);color:#fff;border:none;padding:0.35rem 0.75rem;border-radius:6px;font-size:0.8rem;text-decoration:none;display:flex;align-items:center;gap:0.4rem;white-space:nowrap;">
                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    Herunterladen
                </a>
                <button id="fv-close" style="background:rgba(255,255,255,0.12);border:none;color:#fff;width:32px;height:32px;border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                </button>
            </div>
        </div>
        <div id="fv-body" style="flex:1;overflow:hidden;display:flex;align-items:center;justify-content:center;background:#111;min-height:0;"></div>
    </div>
</div>

<script>
/* ── Invoice creation modal: positions + total ── */
(function () {
    var container  = document.getElementById('modal-positions-container');
    var addBtn     = document.getElementById('modal-add-position');
    var totalEl    = document.getElementById('modal-total-gross');
    var tmpl       = document.getElementById('modal-position-row-template');

    function calcTotal() {
        var total = 0;
        container.querySelectorAll('.modal-position-row').forEach(function (row) {
            var qty   = parseFloat(row.querySelector('.pos-qty').value)   || 0;
            var price = parseFloat(row.querySelector('.pos-price').value) || 0;
            var tax   = parseFloat(row.querySelector('.pos-tax').value)   || 0;
            total += qty * price * (1 + tax / 100);
        });
        totalEl.textContent = total.toFixed(2).replace('.', ',') + ' €';
    }

    function updateRemoveButtons() {
        var rows = container.querySelectorAll('.modal-position-row');
        rows.forEach(function (row) {
            row.querySelector('.remove-modal-position').style.visibility = rows.length > 1 ? 'visible' : 'hidden';
        });
    }

    function bindRow(row) {
        row.querySelectorAll('input').forEach(function (inp) {
            inp.addEventListener('input', calcTotal);
        });
        row.querySelector('.remove-modal-position').addEventListener('click', function () {
            row.remove();
            updateRemoveButtons();
            calcTotal();
        });
    }

    if (container && addBtn && tmpl) {
        bindRow(container.querySelector('.modal-position-row'));
        calcTotal();

        addBtn.addEventListener('click', function () {
            var clone = tmpl.content.cloneNode(true);
            var row   = clone.querySelector('.modal-position-row');
            bindRow(row);
            container.appendChild(row);
            updateRemoveButtons();
            calcTotal();
            row.querySelector('input[type="text"]').focus();
        });
    }
})();

/* ── Modal open/close — use global window.openModal/closeModal from layout.twig ── */
(function () {
    /* Auto-open modal from ?open= query param */
    var openParam = new URLSearchParams(window.location.search).get('open');
    if (openParam === 'invoice') { window.openModal('modal-create-invoice'); }
    else if (openParam === 'edit') { window.openModal('modal-edit-patient'); }
    /* Clean URL without reload */
    if (openParam) { history.replaceState(null, '', window.location.pathname); }
})();

/* ── Datei-Viewer ── */
(function () {
    var overlay = document.getElementById('fileviewer-overlay');
    var fvBody  = document.getElementById('fv-body');
    var fvName  = document.getElementById('fv-filename');
    var fvDl    = document.getElementById('fv-download');
    var fvClose = document.getElementById('fv-close');
    var imgExts = ['jpg','jpeg','png','gif','webp'];

    function ext(f) { return (f.split('.').pop() || '').toLowerCase(); }

    function openViewer(src, filename) {
        fvName.textContent = filename;
        fvDl.href = src; fvDl.download = filename;
        fvBody.innerHTML = '';
        var e = ext(filename);
        if (imgExts.includes(e)) {
            var img = document.createElement('img');
            img.src = src; img.alt = filename;
            img.style.cssText = 'max-width:100%;max-height:100%;object-fit:contain;border-radius:4px;';
            fvBody.appendChild(img);
        } else if (e === 'pdf') {
            var frame = document.createElement('iframe');
            frame.src = src + '#toolbar=1&view=FitH';
            frame.style.cssText = 'width:100%;height:100%;border:none;';
            frame.setAttribute('title', filename);
            fvBody.appendChild(frame);
        } else {
            fvBody.innerHTML = '<div style="text-align:center;color:rgba(255,255,255,0.7);padding:3rem;">' +
                '<svg width="48" height="48" fill="none" viewBox="0 0 24 24" style="margin:0 auto 1rem;display:block;opacity:0.5;"><path stroke="currentColor" stroke-width="1.5" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>' +
                '<div style="font-size:1rem;font-weight:600;margin-bottom:0.5rem;">' + filename + '</div>' +
                '<div style="font-size:0.85rem;margin-bottom:1.5rem;opacity:0.6;">Dieser Dateityp kann nicht direkt angezeigt werden.</div>' +
                '<a href="' + src + '" download="' + filename + '" style="background:var(--accent,#4f7cff);color:#fff;padding:0.6rem 1.4rem;border-radius:8px;text-decoration:none;font-size:0.875rem;">Herunterladen</a>' +
                '</div>';
        }
        overlay.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeViewer() {
        overlay.style.display = 'none';
        fvBody.innerHTML = '';
        document.body.style.overflow = '';
    }

    document.querySelectorAll('[data-lightbox]').forEach(function (el) {
        el.addEventListener('click', function (e) {
            e.preventDefault();
            openViewer(el.dataset.lightbox, el.dataset.filename);
        });
    });

    fvClose.addEventListener('click', closeViewer);
    overlay.addEventListener('click', function (e) { if (e.target === overlay) closeViewer(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeViewer(); });
})();
</script>
{% endblock %}
