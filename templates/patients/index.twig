{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block head %}
<link href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css" rel="stylesheet">
{% endblock %}


{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">{{ t('patients.title') }}</h1>
        <p class="page-subtitle">{{ pagination.total }} {{ t('common.entries') }}</p>
    </div>
    <a href="{{ base_path }}/patienten/neu" class="btn btn-primary">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        {{ t('patients.new_patient') }}
    </a>
</div>


{# Patient detail, timeline-edit, edit-patient-inline, fileviewer modals are global — see partials/patient-modal-global.twig #}

{# Search & Filter #}
<form method="GET" action="{{ base_path }}/patienten">
    <div class="glass-card" style="padding:1rem;">
        <div class="search-bar">
            <div class="search-input-wrapper" style="flex:1;">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/><line x1="21" y1="21" x2="16.65" y2="16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                <input type="text" name="search" class="form-control" placeholder="{{ t('patients.search_placeholder') }}" value="{{ search }}">
            </div>
            <select name="filter" class="form-control" style="width:180px;flex:none;" data-cs-width="180px">
                <option value="">{{ t('patients.all_status') }}</option>
                <option value="aktiv" {{ filter == 'aktiv' ? 'selected' : '' }}>Aktiv</option>
                <option value="inaktiv" {{ filter == 'inaktiv' ? 'selected' : '' }}>Inaktiv</option>
                <option value="in_behandlung" {{ filter == 'in_behandlung' ? 'selected' : '' }}>In Behandlung</option>
                <option value="schmerzfrei" {{ filter == 'schmerzfrei' ? 'selected' : '' }}>Schmerzfrei</option>
                <option value="kontrolltermin" {{ filter == 'kontrolltermin' ? 'selected' : '' }}>Kontrolltermin</option>
            </select>
            <button type="submit" class="btn btn-secondary">
                <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/><line x1="21" y1="21" x2="16.65" y2="16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                {{ t('common.search') }}
            </button>
            {% if search or filter %}
                <a href="{{ base_path }}/patienten" class="btn btn-secondary">{{ t('common.reset') }}</a>
            {% endif %}
        </div>
    </div>
</form>

{# Patient Grid #}
{% if patients %}
    <div class="patient-grid">
        {% for patient in patients %}
            <div class="patient-card" style="cursor:pointer;" data-patient-id="{{ patient.id }}" role="button" tabindex="0">
                <div class="patient-card-image">
                    {% if patient.photo %}
                        <img src="/patienten/{{ patient.id }}/foto/{{ patient.photo }}" alt="{{ patient.name }}">
                    {% else %}
                        <div class="patient-card-image-placeholder">
                            <svg width="28" height="28" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        </div>
                    {% endif %}
                    <div style="position:absolute;top:0.5rem;right:0.5rem;display:flex;flex-direction:column;align-items:flex-end;gap:0.25rem;">
                        <span class="badge badge-{{ patient.status|lower|replace({' ':'_'}) }}">{{ patient.status }}</span>
                        {% set stats = invoice_stats_map[patient.id] ?? null %}
                        {% if stats and stats.open_count > 0 %}
                            <span class="invoice-badge-pulse" style="background:rgba(220,53,69,0.18);color:#ff6b6b;border:1.5px solid #dc3545;border-radius:5px;font-size:0.62rem;font-weight:700;padding:0.15rem 0.4rem;white-space:nowrap;">
                                {{ stats.open_count }} offen
                            </span>
                        {% elseif stats and stats.paid_count > 0 %}
                            <span style="background:rgba(25,135,84,0.15);color:#2dbe6c;border:1.5px solid #198754;border-radius:5px;font-size:0.62rem;font-weight:700;padding:0.15rem 0.4rem;white-space:nowrap;">
                                ? bezahlt
                            </span>
                        {% endif %}
                    </div>
                </div>
                <div class="patient-card-body">
                    <div class="patient-card-name">{{ patient.name }}</div>
                    <div class="patient-card-species">
                        {{ patient.species }}{% if patient.breed %} · {{ patient.breed }}{% endif %}
                    </div>
                    <div class="patient-card-meta">
                        <div class="patient-card-owner">
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2"/></svg>
                            {{ patient.owner_name ?? '—' }}
                        </div>
                        {% if patient.birth_date %}
                            <span class="text-muted text-xs">{{ patient.birth_date|date_de }}</span>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% if pagination.last_page > 1 %}
        <div class="pagination">
            {% if pagination.has_prev %}
                <a href="?page={{ pagination.page - 1 }}&search={{ search }}&filter={{ filter }}" class="page-link">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
                </a>
            {% endif %}
            {% for p in 1..pagination.last_page %}
                {% if p == pagination.page %}
                    <span class="page-link active">{{ p }}</span>
                {% elseif p == 1 or p == pagination.last_page or (p >= pagination.page - 2 and p <= pagination.page + 2) %}
                    <a href="?page={{ p }}&search={{ search }}&filter={{ filter }}" class="page-link">{{ p }}</a>
                {% elseif p == pagination.page - 3 or p == pagination.page + 3 %}
                    <span class="page-link disabled">…</span>
                {% endif %}
            {% endfor %}
            {% if pagination.has_next %}
                <a href="?page={{ pagination.page + 1 }}&search={{ search }}&filter={{ filter }}" class="page-link">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="9 18 15 12 9 6"/></svg>
                </a>
            {% endif %}
        </div>
    {% endif %}

{% else %}
    <div class="empty-state">
        <div class="empty-state-icon">
            <svg width="28" height="28" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </div>
        <div class="empty-state-title">{{ t('patients.no_patients') }}</div>
        <div class="empty-state-text mb-4">{{ search ? 'Keine Ergebnisse für "' ~ search ~ '"' : 'Noch keine Patienten angelegt.' }}</div>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modal-new-patient">{{ t('patients.new_patient') }}</button>
    </div>
{% endif %}

{# New Patient Modal #}
<div class="modal fade" id="modal-new-patient" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">{{ t('patients.new_patient') }}</h3>
            <button class="modal-close" data-bs-dismiss="modal" type="button">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
        </div>
        <form action="{{ base_path }}/patienten" method="POST" class="modal-body">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="form-grid form-grid-2">
                <div class="form-group">
                    <label class="form-label" for="p-name">{{ t('patients.name') }} *</label>
                    <input type="text" id="p-name" name="name" class="form-control" required placeholder="z.B. Bello">
                </div>
                <div class="form-group">
                    <label class="form-label" for="p-species">{{ t('patients.species') }}</label>
                    <input type="text" id="p-species" name="species" class="form-control" placeholder="z.B. Hund">
                </div>
                <div class="form-group">
                    <label class="form-label" for="p-breed">{{ t('patients.breed') }}</label>
                    <input type="text" id="p-breed" name="breed" class="form-control" placeholder="z.B. Labrador">
                </div>
                <div class="form-group">
                    <label class="form-label" for="p-birth">{{ t('patients.birth_date') }}</label>
                    <input type="date" id="p-birth" name="birth_date" class="form-control">
                </div>
                <div class="form-group">
                    <label class="form-label" for="p-gender">{{ t('patients.gender') }}</label>
                    <select id="p-gender" name="gender" class="form-control">
                        <option value="unbekannt">{{ t('patients.unknown') }}</option>
                        <option value="männlich">{{ t('patients.male') }}</option>
                        <option value="weiblich">{{ t('patients.female') }}</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="p-color">{{ t('patients.color') }}</label>
                    <input type="text" id="p-color" name="color" class="form-control" placeholder="z.B. Schwarz">
                </div>
                <div class="form-group">
                    <label class="form-label" for="p-chip">{{ t('patients.chip_number') }}</label>
                    <input type="text" id="p-chip" name="chip_number" class="form-control">
                </div>
                <div class="form-group">
                    <label class="form-label" for="p-status">{{ t('patients.status') }}</label>
                    <select id="p-status" name="status" class="form-control">
                        <option value="aktiv">Aktiv</option>
                        <option value="in_behandlung">In Behandlung</option>
                        <option value="schmerzfrei">Schmerzfrei</option>
                        <option value="kontrolltermin">Kontrolltermin</option>
                        <option value="inaktiv">Inaktiv</option>
                    </select>
                </div>
            </div>
            <div class="form-group mt-3">
                <label class="form-label" for="p-owner">{{ t('patients.owner') }} *</label>
                <select id="p-owner" name="owner_id" class="form-control" required>
                    <option value="">— Tierhalter wählen —</option>
                </select>
                <div class="form-hint">
                    <a href="{{ base_path }}/tierhalter" target="_blank" style="color:var(--accent)">Neuen Tierhalter anlegen</a>
                </div>
            </div>
            <div class="form-group mt-3">
                <label class="form-label" for="p-notes">{{ t('patients.notes') }}</label>
                <textarea id="p-notes" name="notes" class="form-control" rows="3" placeholder="Notizen..."></textarea>
            </div>
            <div class="modal-footer" style="padding:1rem 0 0;margin-top:1rem;border-top:1px solid var(--glass-border);">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ t('common.cancel') }}</button>
                <button type="submit" class="btn btn-primary">{{ t('common.create') }}</button>
            </div>
        </form>
    </div></div>
</div>

{# edit-patient-inline modal is global #}
<div class="modal fade" id="modal-edit-patient-inline-DISABLED-MOVED" tabindex="-1" aria-hidden="true" style="display:none!important">
    <div class="modal-dialog modal-lg modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title" id="edit-modal-title">Patient bearbeiten</h3>
            <button class="modal-close" data-bs-dismiss="modal" type="button">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
        </div>
        <form id="edit-patient-form" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="modal-body" style="overflow-y:auto;max-height:72vh;">

                {# Photo upload #}
                <div class="form-group mb-4">
                    <label class="form-label">Profilbild</label>
                    <div class="flex items-center gap-3">
                        <div id="edit-photo-preview" style="width:64px;height:64px;border-radius:50%;overflow:hidden;background:var(--bg-elevated);display:flex;align-items:center;justify-content:center;flex-shrink:0;border:2px solid var(--glass-border);">
                            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" style="opacity:0.3;"><path stroke="currentColor" stroke-width="1.5" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/></svg>
                        </div>
                        <div style="flex:1;">
                            <input type="file" name="photo" id="edit-photo-input" accept="image/*" class="form-control" style="font-size:0.8rem;padding:0.4rem;">
                            <div class="form-hint">JPG, PNG, WEBP — max. 5 MB</div>
                        </div>
                    </div>
                </div>

                <div class="form-grid form-grid-2">
                    <div class="form-group">
                        <label class="form-label">Name *</label>
                        <input type="text" name="name" id="edit-name" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Tierart</label>
                        <input type="text" name="species" id="edit-species" class="form-control">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Rasse</label>
                        <input type="text" name="breed" id="edit-breed" class="form-control">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Geburtsdatum</label>
                        <input type="date" name="birth_date" id="edit-birth" class="form-control">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Geschlecht</label>
                        <select name="gender" id="edit-gender" class="form-control">
                            <option value="unbekannt">Unbekannt</option>
                            <option value="männlich">Männlich</option>
                            <option value="weiblich">Weiblich</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Farbe</label>
                        <input type="text" name="color" id="edit-color" class="form-control">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Chip-Nummer</label>
                        <input type="text" name="chip_number" id="edit-chip" class="form-control">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <select name="status" id="edit-status" class="form-control">
                            <option value="aktiv">Aktiv</option>
                            <option value="in_behandlung">In Behandlung</option>
                            <option value="schmerzfrei">Schmerzfrei</option>
                            <option value="kontrolltermin">Kontrolltermin</option>
                            <option value="inaktiv">Inaktiv</option>
                        </select>
                    </div>
                </div>
                <div class="form-group mt-3">
                    <label class="form-label">Tierhalter *</label>
                    <select name="owner_id" id="edit-owner" class="form-control" required>
                        {% for o in owners %}
                            <option value="{{ o.id }}">{{ o.last_name }}, {{ o.first_name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-group mt-3">
                    <label class="form-label">Notizen</label>
                    <textarea name="notes" id="edit-notes" class="form-control" rows="3"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <button type="submit" class="btn btn-primary">Speichern</button>
            </div>
        </form>
    </div></div>
</div>

{# -- Create Invoice Modal (inline, no navigation) ------------------- #}
<div class="modal fade" id="modal-invoice-inline" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header" style="flex-shrink:0;">
            <div class="flex items-center gap-3">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
                <span class="font-bold" style="font-size:1rem;">Rechnung erstellen</span>
            </div>
            <button class="modal-close" data-bs-dismiss="modal" type="button">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
        </div>
        <form action="{{ base_path }}/rechnungen" method="POST" id="invoice-inline-form">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <input type="hidden" name="patient_id" id="inv-patient-id" value="">
        <input type="hidden" name="owner_id"   id="inv-owner-id"   value="">
        <div class="modal-body" style="overflow-y:auto;flex:1;">
            <div class="flex gap-4" style="flex-wrap:wrap;align-items:flex-start;">
                {# Left: meta #}
                <div style="flex:1;min-width:240px;display:flex;flex-direction:column;gap:1rem;">
                    <div class="form-grid form-grid-2">
                        <div class="form-group">
                            <label class="form-label">Rechnungsnummer</label>
                            <input type="text" name="invoice_number" id="inv-number" class="form-control" value="{{ next_number }}" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Status</label>
                            <select name="status" class="form-control">
                                <option value="draft">Entwurf</option>
                                <option value="open">Offen</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Rechnungsdatum</label>
                            <input type="date" name="issue_date" class="form-control" value="{{ 'now'|date('Y-m-d') }}">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Fälligkeitsdatum</label>
                            <input type="date" name="due_date" class="form-control" value="{{ 'now'|date_modify('+14 days')|date('Y-m-d') }}">
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Notizen</label>
                        <textarea name="notes" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Zahlungsbedingungen</label>
                        <textarea name="payment_terms" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                {# Right: positions #}
                <div style="flex:1.4;min-width:300px;display:flex;flex-direction:column;gap:0.75rem;">
                    {% if kleinunternehmer %}
                    <div class="flex items-center gap-2" style="background:rgba(255,193,7,0.12);border:1px solid rgba(255,193,7,0.3);border-radius:var(--radius-sm);padding:0.5rem 0.75rem;">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" style="color:#f59e0b;flex-shrink:0;"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        <span class="text-xs"><strong>Kleinunternehmer §19 UStG</strong> — MwSt. 0%</span>
                    </div>
                    {% endif %}
                    <div style="display:grid;grid-template-columns:1fr 70px 100px {{ kleinunternehmer ? '0px' : '65px' }} auto;gap:0.4rem;">
                        <span class="text-xs text-muted">Beschreibung</span>
                        <span class="text-xs text-muted" style="text-align:right;">Menge</span>
                        <span class="text-xs text-muted" style="text-align:right;">Einzelpreis</span>
                        {% if not kleinunternehmer %}<span class="text-xs text-muted" style="text-align:right;">MwSt.%</span>{% endif %}
                        <span></span>
                    </div>
                    <div id="inv-positions-container">
                        <div class="inv-pos-row" style="display:grid;grid-template-columns:1fr 70px 100px {{ kleinunternehmer ? '0px' : '65px' }} auto;gap:0.4rem;margin-bottom:0.4rem;align-items:center;">
                            <input type="text" name="position_description[]" class="form-control" placeholder="Leistung..." required>
                            <input type="number" name="position_quantity[]"    class="form-control inv-qty"   value="1"    min="0.01" step="0.01" style="text-align:right;">
                            <input type="number" name="position_price[]"       class="form-control inv-price" value="0.00" min="0"    step="0.01" style="text-align:right;">
                            <input type="number" name="position_tax_rate[]"    class="form-control inv-tax"   value="{{ kleinunternehmer ? '0' : default_tax_rate }}" min="0" step="0.01" style="text-align:right;{{ kleinunternehmer ? 'display:none;' : '' }}">
                            <button type="button" class="btn btn-danger btn-icon btn-sm inv-remove-pos" style="visibility:hidden;">
                                <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            </button>
                        </div>
                    </div>
                    <button type="button" id="inv-add-pos" class="btn btn-secondary btn-sm" style="align-self:flex-start;">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        Position hinzufügen
                    </button>
                    <div style="border-top:1px solid var(--glass-border);padding-top:0.75rem;margin-top:0.25rem;">
                        <div class="flex justify-between text-sm">
                            <span class="text-muted">Gesamt (brutto)</span>
                            <span id="inv-total" class="font-bold" style="color:var(--accent);font-size:1rem;">0,00 €</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-footer" style="flex-shrink:0;">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
            <button type="submit" class="btn btn-primary">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 3 7 8 15 8"/></svg>
                Rechnung speichern
            </button>
        </div>
        </form>
    </div></div>
</div>

<template id="inv-pos-row-template">
    <div class="inv-pos-row" style="display:grid;grid-template-columns:1fr 70px 100px {{ kleinunternehmer ? '0px' : '65px' }} auto;gap:0.4rem;margin-bottom:0.4rem;align-items:center;">
        <input type="text" name="position_description[]" class="form-control" placeholder="Leistung..." required>
        <input type="number" name="position_quantity[]"    class="form-control inv-qty"   value="1"    min="0.01" step="0.01" style="text-align:right;">
        <input type="number" name="position_price[]"       class="form-control inv-price" value="0.00" min="0"    step="0.01" style="text-align:right;">
        <input type="number" name="position_tax_rate[]"    class="form-control inv-tax"   value="{{ kleinunternehmer ? '0' : default_tax_rate }}" min="0" step="0.01" style="text-align:right;{{ kleinunternehmer ? 'display:none;' : '' }}">
        <button type="button" class="btn btn-danger btn-icon btn-sm inv-remove-pos">
            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
    </div>
</template>

{% endblock %}

{% block scripts %}
<script>
(function () {
'use strict';

/* -- Owner dropdown for new-patient modal ------------------- */
var ownerSelect = document.getElementById('p-owner');
if (ownerSelect) {
    var owners = {{ owners is defined ? owners|json_encode|raw : '[]' }};
    owners.forEach(function (o) {
        var opt = document.createElement('option');
        opt.value = o.id;
        opt.textContent = o.last_name + ', ' + o.first_name;
        ownerSelect.appendChild(opt);
    });
}

/* -- Invoice modal: positions + total -- */
(function(){
    var cont  = document.getElementById('inv-positions-container');
    var addB  = document.getElementById('inv-add-pos');
    var totEl = document.getElementById('inv-total');
    var tmpl  = document.getElementById('inv-pos-row-template');
    function calcTotal(){
        var t=0;
        if (!cont) return;
        cont.querySelectorAll('.inv-pos-row').forEach(function(r){
            var qty=parseFloat(r.querySelector('.inv-qty').value)||0;
            var pr=parseFloat(r.querySelector('.inv-price').value)||0;
            var tx=parseFloat(r.querySelector('.inv-tax')?.value)||0;
            t+=qty*pr*(1+tx/100);
        });
        if (totEl) totEl.textContent=t.toFixed(2).replace('.',',')+' €';
    }
    function updRemove(){
        if (!cont) return;
        var rows=cont.querySelectorAll('.inv-pos-row');
        rows.forEach(function(r){ r.querySelector('.inv-remove-pos').style.visibility=rows.length>1?'visible':'hidden'; });
    }
    function bindRow(row){
        row.querySelectorAll('input').forEach(function(i){ i.addEventListener('input',calcTotal); });
        row.querySelector('.inv-remove-pos').addEventListener('click',function(){ row.remove(); updRemove(); calcTotal(); });
    }
    if(cont&&addB&&tmpl){
        bindRow(cont.querySelector('.inv-pos-row'));
        calcTotal();
        addB.addEventListener('click',function(){
            var clone=tmpl.content.cloneNode(true);
            var row=clone.querySelector('.inv-pos-row');
            bindRow(row);
            cont.appendChild(row);
            updRemove();
            calcTotal();
            row.querySelector('input[type="text"]').focus();
        });
    }
})();

/* -- Card click listeners ? global patient modal ----------- */
document.querySelectorAll('[data-patient-id]').forEach(function (card) {
    card.addEventListener('click', function () {
        if (window._gsOpenPatient) window._gsOpenPatient(card.dataset.patientId);
    });
    card.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            if (window._gsOpenPatient) window._gsOpenPatient(card.dataset.patientId);
        }
    });
});

/* -- Escape closes file viewer ------------------------------ */
document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
        var fv = document.getElementById('fileviewer-overlay');
        if (fv && fv.style.display !== 'none') {
            fv.style.display = 'none';
            document.body.style.overflow = '';
        }
    }
});

})();
</script>
{% endblock %}
