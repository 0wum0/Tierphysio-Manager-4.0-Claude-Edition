/* ── Timeline live search ─────────────────────────────────── */
if (pdSearchInput) {
    pdSearchInput.addEventListener('input', function () {
        const q = pdSearchInput.value.trim().toLowerCase();
        pdTimeline.querySelectorAll('.timeline-item').forEach(function (item) {
            const text = item.textContent.toLowerCase();
            item.style.display = (!q || text.includes(q)) ? '' : 'none';
        });
    });
}

function detail(label, value) {
    if (!value) return '';
    return `<div><span>${esc(label)}</span><div>${esc(value)}</div></div>`;
}

function renderTimeline(timeline, patientId) {
    if (!timeline || !timeline.length) {
        pdTimeline.innerHTML = '<div style="text-align:center;padding:2rem 1rem;color:var(--text-muted);font-size:0.85rem;">Noch keine Einträge</div>';
        return;
    }
    const csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';
    let html = '<div class="timeline">';
    timeline.forEach(function (e) {
        const hasAttach = e.attachment;
        const ext = hasAttach ? (e.attachment.split('.').pop() || '').toLowerCase() : '';
        const isImg = imgExts.includes(ext);
        const src = hasAttach ? `/patienten/${patientId}/dokumente/${encodeURIComponent(e.attachment)}` : '';

        let attachHtml = '';
        if (hasAttach) {
            if (isImg) {
                attachHtml = `<div class="mt-2">
                    <a href="${src}" data-lightbox-modal="${src}" data-filename="${esc(e.attachment)}" style="cursor:pointer;display:inline-block;">
                        <img src="${src}" alt="${esc(e.attachment)}" style="max-height:100px;max-width:100%;border-radius:6px;border:1px solid var(--glass-border);display:block;">
                    </a></div>`;
            } else {
                attachHtml = `<div class="mt-2">
                    <a href="${src}" data-lightbox-modal="${src}" data-filename="${esc(e.attachment)}" class="btn btn-secondary btn-sm" style="font-size:0.78rem;">
                        <svg width="11" height="11" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
                        ${esc(e.attachment)}
                    </a></div>`;
            }
        }

        html += `<div class="timeline-item" data-entry-id="${e.id}">
            <div class="timeline-dot timeline-dot-${esc(e.type)}"></div>
            <div class="timeline-card">
                <div class="timeline-meta">
                    <div style="display:flex;align-items:center;gap:0.4rem;flex-wrap:wrap;">
                        <span class="text-xs">${typeIcon(e.type)}</span>
                        ${e.status_badge ? `<span class="badge badge-primary" style="font-size:0.62rem;">${esc(e.status_badge)}</span>` : ''}
                        <span class="timeline-date">${fmtDateTime(e.entry_date)}</span>
                        ${e.treatment_type_name ? `<span style="display:inline-block;padding:0.12rem 0.5rem;border-radius:999px;font-size:0.62rem;font-weight:600;background:${esc(e.treatment_type_color)}22;color:${esc(e.treatment_type_color)};border:1px solid ${esc(e.treatment_type_color)}44;">${esc(e.treatment_type_name)}</span>` : ''}
                    </div>
                    <div style="display:flex;align-items:center;gap:0.25rem;">
                        ${e.user_name ? `<span class="timeline-author">${esc(e.user_name)}</span>` : ''}
                        <button type="button" class="tl-edit-btn" data-entry='${JSON.stringify(e)}' style="width:24px;height:24px;padding:0;color:var(--text-muted);border:none;background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;border-radius:4px;" title="Bearbeiten">
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        </button>
                        <button type="button" class="tl-del-btn" data-entry-id="${e.id}" style="width:24px;height:24px;padding:0;color:var(--text-muted);border:none;background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;border-radius:4px;" title="Löschen">
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10 11v6M14 11v6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 6V4h6v2"/></svg>
                        </button>
                    </div>
                </div>
                ${e.title ? `<div class="timeline-title">${esc(e.title)}</div>` : ''}
                ${e.content ? `<div class="timeline-content ql-view">${e.content}</div>` : ''}
                ${attachHtml}
            </div>
        </div>`;
    });
    html += '</div>';
    pdTimeline.innerHTML = html;

    /* Attach file-viewer listeners */
    pdTimeline.querySelectorAll('[data-lightbox-modal]').forEach(function (el) {
        el.addEventListener('click', function (e) {
            e.preventDefault();
            openViewer(el.dataset.lightboxModal, el.dataset.filename);
        });
    });

    /* Edit buttons */
    pdTimeline.querySelectorAll('.tl-edit-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            const entry = JSON.parse(btn.dataset.entry);
            openTimelineEditModal(entry, patientId);
        });
    });

    /* Delete buttons — AJAX */
    pdTimeline.querySelectorAll('.tl-del-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            if (!confirm('Eintrag wirklich löschen?')) return;
            const entryId = btn.dataset.entryId;
            const csrf = document.getElementById('te-csrf')?.value || '';
            const fd = new FormData();
            fd.append('_csrf_token', csrf);
            fetch('/patienten/' + patientId + '/timeline/' + entryId + '/delete-json', {
                method: 'POST', body: fd
            })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.ok) renderTimeline(data.timeline, patientId);
            })
            .catch(function () { alert('Fehler beim Löschen.'); });
        });
    });
}

function openPatientModal(patientId) {
    resetModal();
    window.openModal('modal-patient-detail');
    initQuill();
    if (quillEditor) quillEditor.setContents([]);

    fetch('/patienten/' + patientId + '/json')
        .then(function (r) { return r.json(); })
        .then(function (data) {
            const p = data.patient;
            const o = data.owner;

            /* Header */
            pdName.textContent = p.name || '';
            if (p.status) {
                const slug = p.status.toLowerCase().replace(/ /g,'_');
                pdBadge.textContent = p.status;
                pdBadge.className = 'badge badge-' + slug;
                pdBadge.style.display = '';
            }
            pdSpecies.textContent = [p.species, p.breed].filter(Boolean).join(' · ');
            pdInvoiceBtn.dataset.patientId = patientId;
            pdEditBtn.dataset.patientId    = patientId;

            /* Thumbnail photo in header */
            if (p.photo) {
                const imgH = document.createElement('img');
                imgH.src = '/patienten/' + patientId + '/foto/' + p.photo;
                imgH.style.cssText = 'width:100%;height:100%;object-fit:cover;';
                pdPhoto.innerHTML = '';
                pdPhoto.appendChild(imgH);
            }

            /* Full photo left panel */
            if (p.photo) {
                const imgF = document.createElement('img');
                imgF.src = '/patienten/' + patientId + '/foto/' + p.photo;
                imgF.alt = p.name || '';
                pdPhotoFull.innerHTML = '';
                pdPhotoFull.appendChild(imgF);
            }

            /* Details */
            pdDetails.innerHTML =
                detail('Tierart', p.species) +
                detail('Rasse', p.breed) +
                detail('Geschlecht', p.gender) +
                detail('Geburtsdatum', p.birth_date ? fmtDate(p.birth_date) : null) +
                detail('Farbe', p.color) +
                detail('Chip-Nr.', p.chip_number) +
                (p.notes ? `<div style="grid-column:1/-1;border-top:1px solid var(--glass-border);padding-top:0.5rem;margin-top:0.1rem;"><span>Notizen</span><div style="line-height:1.5;">${esc(p.notes)}</div></div>` : '');

            /* Owner */
            if (o) {
                const kundenNr = 'Kunden-Nr. ' + String(o.id).padStart(4, '0');
                pdOwner.innerHTML = `<a href="/tierhalter/${o.id}" class="pd-owner-link">
                    <div class="pd-owner-avatar">${esc((o.first_name||'').charAt(0)+(o.last_name||'').charAt(0))}</div>
                    <div class="pd-owner-info">
                        <div class="pd-owner-name">${esc(o.first_name+' '+o.last_name)} <span style="font-size:0.7rem;font-weight:600;color:var(--accent);background:var(--accent-soft,rgba(99,102,241,0.1));padding:0.1rem 0.45rem;border-radius:999px;margin-left:4px;">${kundenNr}</span></div>
                        ${o.phone ? `<div class="pd-owner-meta">${esc(o.phone)}</div>` : ''}
                        ${o.email ? `<div class="pd-owner-meta">${esc(o.email)}</div>` : ''}
                        ${o.street ? `<div class="pd-owner-meta">${esc(o.street)}${o.zip||o.city ? ', '+esc((o.zip||'')+' '+(o.city||'')).trim() : ''}</div>` : ''}
                    </div>
                </a>`;
            } else {
                pdOwner.innerHTML = '<span style="color:var(--text-muted);font-size:0.82rem;">Kein Besitzer</span>';
            }

            /* Timeline form — action + data-patient-id for AJAX */
            if (pdForm) {
                pdForm.action = '/patienten/' + patientId + '/timeline';
                pdForm.dataset.patientId = patientId;
            }

            /* Populate treatment type dropdown (native select — no CustomSelect) */
            var ttSel = document.getElementById('pd-treatment-type');
            if (ttSel && data.treatment_types) {
                ttSel.innerHTML = '<option value="">— keine —</option>';
                data.treatment_types.forEach(function(tt) {
                    var opt = document.createElement('option');
                    opt.value = tt.id;
                    opt.textContent = tt.name;
                    opt.dataset.color = tt.color;
                    ttSel.appendChild(opt);
                });
            }

            /* Store for PDF / delete */
            currentPatientData = data;

            /* Timeline */
            renderTimeline(data.timeline, patientId);

            /* Show body */
            pdLoading.style.display = 'none';
            pdBody.style.display = 'block';
            if (typeof CustomSelect !== 'undefined') CustomSelect.refresh(pdBody);
        })
        .catch(function () {
            pdLoading.innerHTML = '<div style="color:var(--text-muted);font-size:0.85rem;">Fehler beim Laden.</div>';
        });
}

