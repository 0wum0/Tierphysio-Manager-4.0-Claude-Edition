{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
<script>
(function () {
'use strict';

/* ── Quill Rich-Text-Editor ───────────────────────────────── */
let quillEditor = null;
function initQuill() {
    if (quillEditor) return;
    const el = document.getElementById('pd-quill-editor');
    if (!el) return;
    quillEditor = new Quill(el, {
        theme: 'snow',
        placeholder: 'Notizen, Befunde, Behandlungsschritte...',
        modules: {
            toolbar: [
                ['bold', 'italic', 'underline', 'strike'],
                [{ list: 'ordered' }, { list: 'bullet' }],
                ['blockquote'],
                [{ color: [] }],
                ['clean']
            ]
        }
    });
}
/* Intercept form submit — AJAX, Modal bleibt offen */
document.addEventListener('submit', function (e) {
    const form = e.target;
    if (form.id !== 'pd-timeline-form') return;
    e.preventDefault();

    /* Fill hidden content input from Quill */
    const hidden = document.getElementById('pd-content-input');
    if (hidden && quillEditor) hidden.value = quillEditor.root.innerHTML;

    const patientId = form.dataset.patientId;
    if (!patientId) return;

    const btn = form.querySelector('[type=submit]');
    const origText = btn ? btn.innerHTML : '';
    if (btn) { btn.disabled = true; btn.innerHTML = '…'; }

    const fd = new FormData(form);
    fetch('/patienten/' + patientId + '/timeline-json', {
        method: 'POST',
        body: fd
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
        if (data.ok) {
            renderTimeline(data.timeline, patientId);
            form.reset();
            if (quillEditor) quillEditor.setContents([]);
        }
    })
    .catch(function () {})
    .finally(function () {
        if (btn) { btn.disabled = false; btn.innerHTML = origText; }
    });
}, true);

/* ── Owner dropdown for new-patient modal ─────────────────── */
const ownerSelect = document.getElementById('p-owner');
if (ownerSelect) {
    const owners = {{ owners is defined ? owners|json_encode|raw : '[]' }};
    owners.forEach(function (o) {
        const opt = document.createElement('option');
        opt.value = o.id;
        opt.textContent = o.last_name + ', ' + o.first_name;
        ownerSelect.appendChild(opt);
    });
}

/* ── Helpers ──────────────────────────────────────────────── */
function esc(str) {
    return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function fmtDate(str) {
    if (!str) return '—';
    const d = new Date(str.replace(' ', 'T'));
    return d.toLocaleDateString('de-DE', {day:'2-digit',month:'2-digit',year:'numeric'});
}
function fmtDateTime(str) {
    if (!str) return '—';
    const d = new Date(str.replace(' ', 'T'));
    return d.toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit',year:'numeric'}) + ' ' +
           d.toLocaleTimeString('de-DE',{hour:'2-digit',minute:'2-digit'});
}
function typeIcon(t) {
    return {note:'📝', treatment:'💊', photo:'📷', document:'📄', other:'📌'}[t] || '📌';
}

/* ── Spin animation ───────────────────────────────────────── */
if (!document.getElementById('pd-spin-style')) {
    const s = document.createElement('style');
    s.id = 'pd-spin-style';
    s.textContent = '@keyframes spin{to{transform:rotate(360deg)}}';
    document.head.appendChild(s);
}

/* ── File viewer ──────────────────────────────────────────── */
const fvOverlay = document.getElementById('fileviewer-overlay');
const fvBody    = document.getElementById('fv-body');
const fvName    = document.getElementById('fv-filename');
const fvDl      = document.getElementById('fv-download');
const fvOpen    = document.getElementById('fv-open');
const fvClose   = document.getElementById('fv-close');
const imgExts   = ['jpg','jpeg','png','gif','webp'];

function isMobile() {
    return /Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent);
}

function openViewer(src, filename) {
    fvName.textContent = filename;
    fvDl.href = src; fvDl.download = filename;
    if (fvOpen) { fvOpen.href = src; }
    fvBody.innerHTML = '';
    const ext = (filename.split('.').pop() || '').toLowerCase();
    if (imgExts.includes(ext)) {
        const img = document.createElement('img');
        img.src = src; img.alt = filename;
        img.style.cssText = 'max-width:100%;max-height:100%;object-fit:contain;border-radius:4px;';
        fvBody.appendChild(img);
    } else if (ext === 'pdf') {
        if (isMobile()) {
            /* Mobile: iframe PDF rendering unreliable — show open/download buttons */
            fvBody.innerHTML = `<div style="text-align:center;color:rgba(255,255,255,0.85);padding:2rem 1.5rem;">
                <svg width="56" height="56" fill="none" viewBox="0 0 24 24" style="margin:0 auto 1rem;display:block;opacity:0.6;"><path stroke="#ff6b6b" stroke-width="1.5" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="#ff6b6b" stroke-width="1.5" stroke-linecap="round" points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13" stroke="#ff6b6b" stroke-width="1.5" stroke-linecap="round"/><line x1="9" y1="17" x2="13" y2="17" stroke="#ff6b6b" stroke-width="1.5" stroke-linecap="round"/></svg>
                <div style="font-size:1rem;font-weight:600;margin-bottom:0.4rem;">${esc(filename)}</div>
                <div style="font-size:0.82rem;opacity:0.6;margin-bottom:1.5rem;">PDF-Dateien öffne direkt im Browser oder lade sie herunter.</div>
                <div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap;">
                    <a href="${src}" target="_blank" rel="noopener" style="background:var(--accent,#4f7cff);color:#fff;padding:0.65rem 1.4rem;border-radius:8px;text-decoration:none;font-size:0.9rem;font-weight:600;">Im Browser öffnen</a>
                    <a href="${src}" download="${esc(filename)}" style="background:rgba(255,255,255,0.15);color:#fff;padding:0.65rem 1.4rem;border-radius:8px;text-decoration:none;font-size:0.9rem;">Herunterladen</a>
                </div>
            </div>`;
        } else {
            const fr = document.createElement('iframe');
            fr.src = src; fr.style.cssText = 'width:100%;height:100%;border:none;';
            fr.title = filename; fvBody.appendChild(fr);
        }
    } else {
        fvBody.innerHTML = `<div style="text-align:center;color:rgba(255,255,255,0.7);padding:3rem 1.5rem;">
            <svg width="48" height="48" fill="none" viewBox="0 0 24 24" style="margin:0 auto 1rem;display:block;opacity:0.5;"><path stroke="currentColor" stroke-width="1.5" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="1.5" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
            <div style="font-size:1rem;font-weight:600;margin-bottom:0.5rem;">${esc(filename)}</div>
            <div style="font-size:0.85rem;margin-bottom:1.5rem;opacity:0.6;">Dieser Dateityp kann nicht direkt angezeigt werden.</div>
            <a href="${src}" download="${esc(filename)}" style="background:var(--accent,#4f7cff);color:#fff;padding:0.6rem 1.4rem;border-radius:8px;text-decoration:none;">Herunterladen</a>
        </div>`;
    }
    fvOverlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';
}
function closeViewer() {
    fvOverlay.style.display = 'none';
    fvBody.innerHTML = '';
    document.body.style.overflow = '';
}
if (fvClose) fvClose.addEventListener('click', closeViewer);
if (fvOverlay) fvOverlay.addEventListener('click', function(e){ if(e.target===fvOverlay) closeViewer(); });

/* ── Timeline Entry Edit Modal ───────────────────────────── */
let teQuill = null;

function initTeQuill() {
    if (teQuill) return;
    const el = document.getElementById('te-quill-editor');
    if (!el) return;
    teQuill = new Quill(el, {
        theme: 'snow',
        placeholder: 'Inhalt...',
        modules: {
            toolbar: [
                ['bold', 'italic', 'underline', 'strike'],
                [{ list: 'ordered' }, { list: 'bullet' }],
                ['blockquote'],
                [{ color: [] }],
                ['clean']
            ]
        }
    });
}

function openTimelineEditModal(entry, patientId) {
    initTeQuill();
    document.getElementById('te-entry-id').value   = entry.id;
    document.getElementById('te-patient-id').value = patientId;
    /* Typ */
    const tySel = document.getElementById('te-type');
    for (let i = 0; i < tySel.options.length; i++) {
        tySel.options[i].selected = tySel.options[i].value === (entry.type || 'note');
    }
    /* Behandlungsart */
    const ttSel = document.getElementById('te-treatment-type');
    ttSel.innerHTML = '<option value="">— keine —</option>';
    if (currentPatientData && currentPatientData.treatment_types) {
        currentPatientData.treatment_types.forEach(function (tt) {
            const o = document.createElement('option');
            o.value = tt.id; o.textContent = tt.name;
            o.selected = parseInt(entry.treatment_type_id) === parseInt(tt.id);
            ttSel.appendChild(o);
        });
    }
    /* Datum */
    if (entry.entry_date) {
        const d = new Date(entry.entry_date.replace(' ', 'T'));
        const pad = n => String(n).padStart(2, '0');
        document.getElementById('te-date').value =
            d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate()) +
            'T' + pad(d.getHours()) + ':' + pad(d.getMinutes());
    }
    /* Status */
    const stSel = document.getElementById('te-status');
    for (let i = 0; i < stSel.options.length; i++) {
        stSel.options[i].selected = stSel.options[i].value === (entry.status_badge || '');
    }
    /* Titel */
    document.getElementById('te-title').value = entry.title || '';
    /* Inhalt */
    if (teQuill) {
        if (entry.content) {
            teQuill.clipboard.dangerouslyPasteHTML(entry.content);
        } else {
            teQuill.setContents([]);
        }
    }
    window.openModal('modal-timeline-edit');
}

/* Save button in edit modal */
const teSaveBtn = document.getElementById('te-save-btn');
if (teSaveBtn) {
    teSaveBtn.addEventListener('click', function () {
        initTeQuill();
        const entryId   = document.getElementById('te-entry-id').value;
        const patientId = document.getElementById('te-patient-id').value;
        const csrf      = document.getElementById('te-csrf').value;
        if (!entryId || !patientId) return;

        /* Write Quill HTML to hidden input */
        if (teQuill) document.getElementById('te-content').value = teQuill.root.innerHTML;

        const fd = new FormData();
        fd.append('_csrf_token', csrf);
        fd.append('type',              document.getElementById('te-type').value);
        fd.append('treatment_type_id', document.getElementById('te-treatment-type').value);
        fd.append('title',             document.getElementById('te-title').value);
        fd.append('content',           document.getElementById('te-content').value);
        fd.append('status_badge',      document.getElementById('te-status').value);
        fd.append('entry_date',        document.getElementById('te-date').value);

        teSaveBtn.disabled = true;
        teSaveBtn.textContent = 'Speichern…';

        fetch('/patienten/' + patientId + '/timeline/' + entryId + '/update-json', {
            method: 'POST', body: fd
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.ok) {
                window.closeModal('modal-timeline-edit');
                renderTimeline(data.timeline, patientId);
            }
        })
        .catch(function () { alert('Fehler beim Speichern.'); })
        .finally(function () {
            teSaveBtn.disabled = false;
            teSaveBtn.innerHTML = '<svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/></svg> Speichern';
        });
    });
}

/* ── Patient Detail Modal ─────────────────────────────────── */
const pdModal      = document.getElementById('modal-patient-detail');
const pdLoading    = document.getElementById('pd-loading');
const pdBody       = document.getElementById('pd-body');
const pdName       = document.getElementById('pd-name');
const pdBadge      = document.getElementById('pd-badge');
const pdSpecies    = document.getElementById('pd-species');
const pdPhoto      = document.getElementById('pd-photo');
const pdPhotoFull  = document.getElementById('pd-photo-full');
const pdDetails    = document.getElementById('pd-details');
const pdOwner      = document.getElementById('pd-owner');
const pdTimeline   = document.getElementById('pd-timeline');
const pdInvoiceBtn = document.getElementById('pd-invoice-btn');
const pdEditBtn    = document.getElementById('pd-edit-btn');
const pdForm         = document.getElementById('pd-timeline-form');
const pdSearchInput  = document.getElementById('pd-timeline-search');
let currentPatientData = null;

/* ── Invoice button: open inline invoice modal ── */
if (pdInvoiceBtn) {
    pdInvoiceBtn.addEventListener('click', function () {
        if (!currentPatientData) return;
        const p = currentPatientData.patient;
        const o = currentPatientData.owner;
        document.getElementById('inv-patient-id').value = p.id || '';
        document.getElementById('inv-owner-id').value   = (o && o.id) ? o.id : '';
        var invoiceOverlay = document.getElementById('modal-invoice-inline');
        if (invoiceOverlay) { window.openModal('modal-invoice-inline'); }
    });
}

/* ── Edit button: open inline edit modal and pre-fill ── */
if (pdEditBtn) {
    pdEditBtn.addEventListener('click', function () {
        if (!currentPatientData) return;
        const p = currentPatientData.patient;
        const o = currentPatientData.owner;
        /* Set form action to correct patient update URL */
        const form = document.getElementById('edit-patient-form');
        form.action = '/patienten/' + p.id;
        /* Pre-fill title */
        document.getElementById('edit-modal-title').textContent = (p.name || 'Patient') + ' bearbeiten';
        /* Pre-fill fields */
        document.getElementById('edit-name').value    = p.name    || '';
        document.getElementById('edit-species').value = p.species || '';
        document.getElementById('edit-breed').value   = p.breed   || '';
        document.getElementById('edit-birth').value   = p.birth_date ? p.birth_date.slice(0,10) : '';
        document.getElementById('edit-color').value   = p.color   || '';
        document.getElementById('edit-chip').value    = p.chip_number || '';
        document.getElementById('edit-notes').value   = p.notes   || '';
        /* Gender */
        var gSel = document.getElementById('edit-gender');
        for (var i = 0; i < gSel.options.length; i++) {
            gSel.options[i].selected = (gSel.options[i].value === (p.gender || 'unbekannt'));
        }
        /* Status */
        var sSel = document.getElementById('edit-status');
        for (var i = 0; i < sSel.options.length; i++) {
            sSel.options[i].selected = (sSel.options[i].value === (p.status || 'aktiv'));
        }
        /* Owner */
        var oSel = document.getElementById('edit-owner');
        for (var i = 0; i < oSel.options.length; i++) {
            oSel.options[i].selected = (parseInt(oSel.options[i].value) === parseInt(p.owner_id || (o && o.id)));
        }
        /* Photo preview */
        var prev = document.getElementById('edit-photo-preview');
        if (p.photo) {
            prev.innerHTML = '<img src="/patienten/'+p.id+'/foto/'+encodeURIComponent(p.photo)+'" style="width:100%;height:100%;object-fit:cover;">';
        } else {
            prev.innerHTML = '<svg width="28" height="28" fill="none" viewBox="0 0 24 24" style="opacity:0.3;"><path stroke="currentColor" stroke-width="1.5" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/></svg>';
        }
        var editOverlay2 = document.getElementById('modal-edit-patient-inline');
        if (editOverlay2) { window.openModal('modal-edit-patient-inline'); }
    });
}

/* ── Edit form: AJAX submit — stay on page ── */
var editForm = document.getElementById('edit-patient-form');
if (editForm) {
    editForm.addEventListener('submit', function (e) {
        e.preventDefault();
        var btn = editForm.querySelector('button[type="submit"]');
        if (btn) { btn.disabled = true; btn.textContent = 'Speichern…'; }

        var fd = new FormData(editForm);
        fetch(editForm.action, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: fd
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.ok) {
                /* Update currentPatientData so the detail modal reflects changes */
                if (currentPatientData && data.patient) {
                    currentPatientData.patient = data.patient;
                    /* Refresh header in detail modal */
                    pdName.textContent = data.patient.name || '';
                    pdSpecies.textContent = [data.patient.species, data.patient.breed].filter(Boolean).join(' · ');
                }
                var editOverlay = document.getElementById('modal-edit-patient-inline');
                if (editOverlay) { window.closeModal('modal-edit-patient-inline'); }
                /* Re-open patient detail modal */
                var detailOverlay = document.getElementById('modal-patient-detail');
                if (detailOverlay) { window.openModal('modal-patient-detail'); }
            }
        })
        .catch(function () { alert('Fehler beim Speichern.'); })
        .finally(function () {
            if (btn) { btn.disabled = false; btn.textContent = 'Speichern'; }
        });
    });
}

/* ── Edit photo live preview ── */
var editPhotoInput = document.getElementById('edit-photo-input');
if (editPhotoInput) {
    editPhotoInput.addEventListener('change', function () {
        var file = this.files && this.files[0];
        if (!file) return;
        var reader = new FileReader();
        reader.onload = function(e) {
            var prev = document.getElementById('edit-photo-preview');
            prev.innerHTML = '<img src="'+e.target.result+'" style="width:100%;height:100%;object-fit:cover;">';
        };
        reader.readAsDataURL(file);
    });
}

/* ── Invoice modal: positions + total ── */
(function(){
    var cont  = document.getElementById('inv-positions-container');
    var addB  = document.getElementById('inv-add-pos');
    var totEl = document.getElementById('inv-total');
    var tmpl  = document.getElementById('inv-pos-row-template');
    function calcTotal(){
        var t=0;
        cont.querySelectorAll('.inv-pos-row').forEach(function(r){
            var qty=parseFloat(r.querySelector('.inv-qty').value)||0;
            var pr=parseFloat(r.querySelector('.inv-price').value)||0;
            var tx=parseFloat(r.querySelector('.inv-tax').value)||0;
            t+=qty*pr*(1+tx/100);
        });
        totEl.textContent=t.toFixed(2).replace('.',',')+' €';
    }
    function updRemove(){
        var rows=cont.querySelectorAll('.inv-pos-row');
        rows.forEach(function(r){ r.querySelector('.inv-remove-pos').style.visibility=rows.length>1?'visible':'hidden'; });
    }
    function bindRow(row){
        row.querySelectorAll('input').forEach(function(i){ i.addEventListener('input',calcTotal); });
        row.querySelector('.inv-remove-pos').addEventListener('click',function(){ row.remove(); updRemove(); calcTotal(); });
    }
    if(cont&&addB&&tmpl){
        bindRow(cont.querySelector('.inv-pos-row'));
        calcTotal();
        addB.addEventListener('click',function(){
            var clone=tmpl.content.cloneNode(true);
            var row=clone.querySelector('.inv-pos-row');
            bindRow(row);
            cont.appendChild(row);
            updRemove();
            calcTotal();
            row.querySelector('input[type="text"]').focus();
        });
    }
})();

