<!DOCTYPE html>
<html lang="de" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Installation — Tierphysio Manager 3.0</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/installer.css">
</head>
<body class="inst-body">

<div class="inst-bg"></div>

<div class="inst-wrap">

    {# ── Sidebar / Brand ── #}
    <aside class="inst-sidebar">
        <div class="inst-brand">
            <div class="inst-brand-icon">
                <svg width="28" height="28" fill="none" viewBox="0 0 24 24"><path stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </div>
            <div>
                <div class="inst-brand-name">Tierphysio Manager</div>
                <div class="inst-brand-version">Version 3.0</div>
            </div>
        </div>

        <nav class="inst-steps-nav">
            {% set steps_info = [
                {num: 1, label: 'Systemcheck',    icon: '<path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 0 0 1.946-.806 3.42 3.42 0 0 1 4.438 0 3.42 3.42 0 0 0 1.946.806 3.42 3.42 0 0 1 3.138 3.138 3.42 3.42 0 0 0 .806 1.946 3.42 3.42 0 0 1 0 4.438 3.42 3.42 0 0 0-.806 1.946 3.42 3.42 0 0 1-3.138 3.138 3.42 3.42 0 0 0-1.946.806 3.42 3.42 0 0 1-4.438 0 3.42 3.42 0 0 0-1.946-.806 3.42 3.42 0 0 1-3.138-3.138 3.42 3.42 0 0 0-.806-1.946 3.42 3.42 0 0 1 0-4.438 3.42 3.42 0 0 0 .806-1.946 3.42 3.42 0 0 1 3.138-3.138z"/>'},
                {num: 2, label: 'Datenbank',      icon: '<ellipse cx="12" cy="5" rx="9" ry="3" stroke="currentColor" stroke-width="2"/><path stroke="currentColor" stroke-width="2" d="M21 12c0 1.657-4.03 3-9 3S3 13.657 3 12"/><path stroke="currentColor" stroke-width="2" d="M3 5v14c0 1.657 4.03 3 9 3s9-1.343 9-3V5"/>'},
                {num: 3, label: 'Administrator',  icon: '<path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2"/>'},
                {num: 4, label: 'Fertigstellung', icon: '<path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="22 4 12 14.01 9 11.01"/>'}
            ] %}
            {% for s in steps_info %}
                <div class="inst-step-item {{ step == s.num ? 'active' : (step > s.num ? 'done' : '') }}">
                    <div class="inst-step-bullet">
                        {% if step > s.num %}
                            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M20 6 9 17l-5-5"/></svg>
                        {% else %}
                            {{ s.num }}
                        {% endif %}
                    </div>
                    <div class="inst-step-label">{{ s.label }}</div>
                </div>
            {% endfor %}
        </nav>

        <div class="inst-sidebar-footer">
            <div class="inst-progress-bar">
                <div class="inst-progress-fill" style="width:{{ ((step - 1) / 3 * 100)|round }}%"></div>
            </div>
            <div class="inst-progress-label">Schritt {{ step }} von 4</div>
        </div>
    </aside>

    {# ── Main Content ── #}
    <main class="inst-main">

        {# Flash messages #}
        {% if flash.error is defined %}
            <div class="inst-alert inst-alert-error">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" style="flex-shrink:0"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                <span>{{ flash.error }}</span>
            </div>
        {% endif %}
        {% if flash.success is defined %}
            <div class="inst-alert inst-alert-success">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" style="flex-shrink:0"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20 6 9 17l-5-5"/></svg>
                <span>{{ flash.success }}</span>
            </div>
        {% endif %}

        {# ══════════════════════════════════
           STEP 1 — Requirements
           ══════════════════════════════════ #}
        {% if step == 1 %}

            <div class="inst-step-header">
                <h1 class="inst-step-title">Systemvoraussetzungen</h1>
                <p class="inst-step-desc">Der Assistent überprüft, ob Ihr Server alle notwendigen Komponenten für den Betrieb von Tierphysio Manager bereitstellt.</p>
            </div>

            {% set all_ok = true %}
            <div class="inst-req-list">
                {% for req in requirements %}
                    <div class="inst-req-item">
                        <div class="inst-req-left">
                            {% if req.ok %}
                                <span class="inst-req-icon inst-req-ok">
                                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M20 6 9 17l-5-5"/></svg>
                                </span>
                            {% else %}
                                {% set all_ok = false %}
                                <span class="inst-req-icon inst-req-fail">
                                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                                </span>
                            {% endif %}
                            <span class="inst-req-name">{{ req.label }}</span>
                        </div>
                        <span class="inst-req-status {{ req.ok ? 'inst-req-status-ok' : 'inst-req-status-fail' }}">
                            {{ req.ok ? 'OK' : 'Fehlgeschlagen' }}
                        </span>
                    </div>
                {% endfor %}
            </div>

            {% if not all_ok %}
                <div class="inst-alert inst-alert-warning" style="margin-top:1.5rem;">
                    <svg width="18" height="18" fill="none" viewBox="0 0 24 24" style="flex-shrink:0"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="17" x2="12.01" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    <div>
                        <strong>Einige Voraussetzungen sind nicht erfüllt.</strong><br>
                        <span style="font-size:0.85rem;opacity:0.85;">Bitte kontaktieren Sie Ihren Hosting-Anbieter und installieren Sie die fehlenden PHP-Erweiterungen.</span>
                    </div>
                </div>
            {% endif %}

            <div class="inst-actions">
                {% if all_ok %}
                    <a href="/install/schritt/2" class="inst-btn inst-btn-primary">
                        Weiter
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" points="9 18 15 12 9 6"/></svg>
                    </a>
                {% else %}
                    <button class="inst-btn inst-btn-primary" disabled>
                        Voraussetzungen nicht erfüllt
                    </button>
                    <a href="/install" class="inst-btn inst-btn-ghost">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="1 4 1 10 7 10"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M3.51 15a9 9 0 1 0 .49-3.63"/></svg>
                        Erneut prüfen
                    </a>
                {% endif %}
            </div>

        {# ══════════════════════════════════
           STEP 2 — Database
           ══════════════════════════════════ #}
        {% elseif step == 2 %}

            <div class="inst-step-header">
                <h1 class="inst-step-title">Datenbankverbindung</h1>
                <p class="inst-step-desc">Geben Sie die Zugangsdaten Ihrer MySQL/MariaDB-Datenbank ein. Die Datenbank muss bereits vorhanden sein oder der Benutzer muss die Berechtigung haben, sie anzulegen.</p>
            </div>

            <form action="/install/schritt/2" method="POST" id="install-form" novalidate>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                <div class="inst-field">
                    <label class="inst-label">
                        Datenbank-Host
                        <span class="inst-hint">Meistens <code>localhost</code></span>
                    </label>
                    <input type="text" name="db_host" class="inst-input" value="localhost" required autocomplete="off">
                </div>

                <div class="inst-grid-2">
                    <div class="inst-field">
                        <label class="inst-label">Port</label>
                        <input type="number" name="db_port" class="inst-input" value="3306" min="1" max="65535">
                    </div>
                    <div class="inst-field">
                        <label class="inst-label">
                            Datenbankname
                            <span class="inst-hint">Wird angelegt falls nicht vorhanden</span>
                        </label>
                        <input type="text" name="db_name" class="inst-input" value="tierphysio" required autocomplete="off">
                    </div>
                </div>

                <div class="inst-grid-2">
                    <div class="inst-field">
                        <label class="inst-label">Datenbankbenutzer</label>
                        <input type="text" name="db_user" class="inst-input" value="root" required autocomplete="off">
                    </div>
                    <div class="inst-field">
                        <label class="inst-label">Passwort</label>
                        <div class="inst-input-wrap">
                            <input type="password" name="db_password" id="db_password" class="inst-input inst-input-pw" autocomplete="new-password">
                            <button type="button" class="inst-pw-toggle" data-target="db_password" aria-label="Passwort anzeigen">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/></svg>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="inst-db-test-bar">
                    <button type="button" id="test-db-btn" class="inst-btn inst-btn-ghost inst-btn-sm">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" id="test-db-icon"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                        <span id="test-db-label">Verbindung testen</span>
                    </button>
                    <div id="db-test-result" class="inst-db-result"></div>
                </div>

                <div class="inst-actions">
                    <a href="/install/schritt/1" class="inst-btn inst-btn-ghost">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
                        Zurück
                    </a>
                    <button type="submit" class="inst-btn inst-btn-primary" id="db-submit-btn">
                        Datenbank einrichten &amp; Weiter
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" points="9 18 15 12 9 6"/></svg>
                    </button>
                </div>
            </form>

        {# ══════════════════════════════════
           STEP 3 — Admin Account + App Config
           ══════════════════════════════════ #}
        {% elseif step == 3 %}

            <div class="inst-step-header">
                <h1 class="inst-step-title">Administrator &amp; Anwendung</h1>
                <p class="inst-step-desc">Erstellen Sie Ihr Administrator-Konto und konfigurieren Sie die grundlegenden Einstellungen der Anwendung.</p>
            </div>

            <form action="/install/schritt/3" method="POST" id="admin-form" novalidate>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                <div class="inst-section-title">Administrator-Konto</div>

                <div class="inst-grid-2">
                    <div class="inst-field">
                        <label class="inst-label">Vollständiger Name</label>
                        <input type="text" name="admin_name" class="inst-input" value="Administrator" required>
                    </div>
                    <div class="inst-field">
                        <label class="inst-label">E-Mail-Adresse</label>
                        <input type="email" name="admin_email" class="inst-input" id="admin_email" placeholder="admin@praxis.de" required autocomplete="email">
                    </div>
                </div>

                <div class="inst-grid-2">
                    <div class="inst-field">
                        <label class="inst-label">
                            Passwort
                            <span class="inst-hint">min. 8 Zeichen</span>
                        </label>
                        <div class="inst-input-wrap">
                            <input type="password" name="admin_password" id="admin_password" class="inst-input inst-input-pw" minlength="8" required autocomplete="new-password">
                            <button type="button" class="inst-pw-toggle" data-target="admin_password" aria-label="Passwort anzeigen">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/></svg>
                            </button>
                        </div>
                        <div class="inst-strength-bar" id="pw-strength-bar">
                            <div class="inst-strength-fill" id="pw-strength-fill"></div>
                        </div>
                        <div class="inst-strength-label" id="pw-strength-label"></div>
                    </div>
                    <div class="inst-field">
                        <label class="inst-label">Passwort bestätigen</label>
                        <div class="inst-input-wrap">
                            <input type="password" name="admin_password_confirm" id="admin_password_confirm" class="inst-input inst-input-pw" minlength="8" required autocomplete="new-password">
                            <button type="button" class="inst-pw-toggle" data-target="admin_password_confirm" aria-label="Passwort anzeigen">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/></svg>
                            </button>
                        </div>
                        <div class="inst-pw-match" id="pw-match-label"></div>
                    </div>
                </div>

                <div class="inst-section-title" style="margin-top:1.75rem;">Anwendungseinstellungen</div>

                <div class="inst-grid-2">
                    <div class="inst-field">
                        <label class="inst-label">
                            Anwendungs-URL
                            <span class="inst-hint">z.B. https://praxis.de</span>
                        </label>
                        <input type="url" name="app_url" class="inst-input" value="http://localhost" required>
                    </div>
                    <div class="inst-field">
                        <label class="inst-label">Standardsprache</label>
                        <select name="app_locale" class="inst-input inst-select">
                            <option value="de" selected>Deutsch</option>
                            <option value="en">English</option>
                        </select>
                    </div>
                </div>

                <div class="inst-actions">
                    <a href="/install/schritt/2" class="inst-btn inst-btn-ghost">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
                        Zurück
                    </a>
                    <button type="submit" class="inst-btn inst-btn-primary" id="admin-submit-btn">
                        Installation abschließen
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" points="9 18 15 12 9 6"/></svg>
                    </button>
                </div>
            </form>

        {# ══════════════════════════════════
           STEP 4 — Success
           ══════════════════════════════════ #}
        {% elseif step == 4 %}

            <div class="inst-success">
                <div class="inst-success-icon">
                    <svg width="40" height="40" fill="none" viewBox="0 0 24 24"><path stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M20 6 9 17l-5-5"/></svg>
                </div>
                <h1 class="inst-success-title">Installation erfolgreich!</h1>
                <p class="inst-success-desc">
                    Tierphysio Manager 3.0 wurde vollständig installiert und ist einsatzbereit.
                    Melden Sie sich jetzt mit Ihrem Administrator-Konto an.
                </p>

                <div class="inst-success-checklist">
                    <div class="inst-check-item">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M20 6 9 17l-5-5"/></svg>
                        Datenbank eingerichtet &amp; Migrationen ausgeführt
                    </div>
                    <div class="inst-check-item">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M20 6 9 17l-5-5"/></svg>
                        Administrator-Konto erstellt
                    </div>
                    <div class="inst-check-item">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M20 6 9 17l-5-5"/></svg>
                        Konfigurationsdatei <code>.env</code> gespeichert
                    </div>
                </div>

                <div class="inst-success-note">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;color:#f59e0b"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="17" x2="12.01" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    <span>Aus Sicherheitsgründen empfehlen wir, den <code>/install</code>-Pfad nach der Installation zu sperren oder den Installer-Ordner zu löschen.</span>
                </div>

                <a href="/login" class="inst-btn inst-btn-primary inst-btn-lg" style="width:100%;justify-content:center;margin-top:2rem;">
                    <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M10 17l5-5-5-5M15 12H3"/></svg>
                    Jetzt anmelden
                </a>
            </div>

        {% endif %}

    </main>
</div>

<script src="/assets/js/installer.js"></script>
</body>
</html>
