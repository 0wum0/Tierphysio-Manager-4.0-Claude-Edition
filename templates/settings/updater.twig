{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}
<div class="page-header">
    <div class="flex items-center gap-3">
        <a href="{{ base_path }}/einstellungen" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            {{ t('common.back') }}
        </a>
        <h1 class="page-title">{{ t('settings.updater') }}</h1>
    </div>
</div>

<div class="flex gap-4" style="align-items:flex-start;flex-wrap:wrap;">

    <div class="glass-card" style="flex:1;min-width:280px;">
        <h3 class="font-semibold mb-4" style="font-size:0.95rem;">Datenbankversionen</h3>

        <div style="display:flex;flex-direction:column;gap:1rem;">
            <div class="flex justify-between items-center">
                <span class="text-sm text-muted">{{ t('settings.current_version') }}</span>
                <span class="badge badge-primary">v{{ current_version }}</span>
            </div>
            <div class="flex justify-between items-center">
                <span class="text-sm text-muted">{{ t('settings.latest_version') }}</span>
                <span class="badge {{ latest_version > current_version ? 'badge-warning' : 'badge-aktiv' }}">v{{ latest_version }}</span>
            </div>
        </div>

        {% if latest_version > current_version %}
            <div class="alert alert-warning mt-4">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="17" x2="12.01" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                <span>{{ pending|length }} ausstehende Migration(en) verfügbar.</span>
            </div>

            {% if pending %}
                <div class="mt-4">
                    <div class="text-xs text-muted mb-2 font-semibold">Ausstehende Migrationen:</div>
                    {% for m in pending %}
                        <div class="flex items-center gap-2 text-sm mb-1">
                            <span class="badge badge-warning" style="font-size:0.65rem;">v{{ m.version }}</span>
                            <span class="text-muted">{{ m.file }}</span>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            <form action="{{ base_path }}/einstellungen/migrationen" method="POST" class="mt-4">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <button type="submit" class="btn btn-warning w-full" data-confirm="Migrationen wirklich ausführen? Erstellen Sie vorher ein Datenbankbackup.">
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="23 4 23 10 17 10"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="1 20 1 14 7 14"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                    {{ t('settings.run_migrations') }}
                </button>
            </form>
        {% else %}
            <div class="alert alert-success mt-4">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20 6 9 17l-5-5"/></svg>
                <span>{{ t('settings.up_to_date') }}</span>
            </div>
        {% endif %}
    </div>

    <div class="glass-card" style="flex:1;min-width:280px;">
        <h3 class="font-semibold mb-4" style="font-size:0.95rem;">Systeminfo</h3>
        <div style="display:flex;flex-direction:column;gap:0.625rem;">
            <div class="flex justify-between text-sm">
                <span class="text-muted">PHP Version</span>
                <span class="font-medium">{{ php_version }}</span>
            </div>
            <div class="flex justify-between text-sm">
                <span class="text-muted">App Version</span>
                <span class="font-medium">{{ app_version }}</span>
            </div>
            <div class="flex justify-between text-sm">
                <span class="text-muted">Umgebung</span>
                <span class="badge {{ app_env == 'production' ? 'badge-aktiv' : 'badge-warning' }}">{{ app_env }}</span>
            </div>
            <div class="flex justify-between text-sm">
                <span class="text-muted">DB-Version</span>
                <span class="font-medium">v{{ current_version }}</span>
            </div>
        </div>
    </div>
</div>
{% endblock %}
