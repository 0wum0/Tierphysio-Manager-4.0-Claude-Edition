{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}
<div class="page-header">
    <div class="flex items-center gap-3">
        <a href="{{ base_path }}/einstellungen" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            {{ t('common.back') }}
        </a>
        <h1 class="page-title">{{ t('settings.users') }}</h1>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modal-new-user">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        {{ t('settings.new_user') }}
    </button>
</div>

<div class="table-container">
    <table class="data-table">
        <thead>
            <tr>
                <th>{{ t('settings.user_name') }}</th>
                <th>{{ t('settings.user_email') }}</th>
                <th>{{ t('settings.user_role') }}</th>
                <th>{{ t('settings.user_active') }}</th>
                <th>{{ t('settings.user_last_login') }}</th>
                <th style="text-align:right;">{{ t('common.actions') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
            <tr>
                <td>
                    <div class="flex items-center gap-3">
                        <div class="avatar-placeholder" style="width:32px;height:32px;font-size:0.75rem;">{{ user.name|initials }}</div>
                        <div class="font-semibold">{{ user.name }}</div>
                    </div>
                </td>
                <td>{{ user.email }}</td>
                <td>
                    <span class="badge {{ user.role == 'admin' ? 'badge-admin' : 'badge-primary' }}">
                        {{ user.role == 'admin' ? t('common.role_admin') : t('common.role_mita') }}
                    </span>
                </td>
                <td>
                    {% if user.active %}
                        <span class="badge badge-aktiv">Aktiv</span>
                    {% else %}
                        <span class="badge badge-inaktiv">Inaktiv</span>
                    {% endif %}
                </td>
                <td class="text-sm text-muted">{{ user.last_login ? user.last_login|datetime_de : '—' }}</td>
                <td>
                    <div class="flex gap-2" style="justify-content:flex-end;">
                        <button type="button" class="btn btn-secondary btn-sm"
                            data-bs-toggle="modal" data-bs-target="#modal-edit-user-{{ user.id }}">
                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            {{ t('common.edit') }}
                        </button>
                        {% if user.id != current_user.id %}
                        <form action="{{ base_path }}/einstellungen/benutzer/{{ user.id }}/loeschen" method="POST" style="margin:0;">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-danger btn-sm" data-confirm="{{ t('common.confirm_delete') }}">
                                <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                                {{ t('common.delete') }}
                            </button>
                        </form>
                        {% else %}
                        <span class="text-xs text-muted">(Eigenes Konto)</span>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{# New User Modal #}
<div class="modal fade" id="modal-new-user" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">{{ t('settings.new_user') }}</h3>
            <button class="modal-close" data-bs-dismiss="modal" type="button">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
        </div>
        <form action="{{ base_path }}/einstellungen/benutzer" method="POST" class="modal-body">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="form-group mb-3">
                <label class="form-label">{{ t('settings.user_name') }} *</label>
                <input type="text" name="name" class="form-control" required placeholder="Vollständiger Name">
            </div>
            <div class="form-group mb-3">
                <label class="form-label">{{ t('settings.user_email') }} *</label>
                <input type="email" name="email" class="form-control" required placeholder="name@praxis.de">
            </div>
            <div class="form-group mb-3">
                <label class="form-label">{{ t('settings.user_password') }} * <span class="form-hint">(min. 8 Zeichen)</span></label>
                <input type="password" name="password" class="form-control" required minlength="8" autocomplete="new-password">
            </div>
            <div class="form-group mb-3">
                <label class="form-label">{{ t('settings.user_role') }}</label>
                <select name="role" class="form-control">
                    <option value="mitarbeiter">{{ t('common.role_mita') }}</option>
                    <option value="admin">{{ t('common.role_admin') }}</option>
                </select>
            </div>
            <div class="modal-footer" style="padding:1rem 0 0;margin-top:1rem;border-top:1px solid var(--glass-border);">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ t('common.cancel') }}</button>
                <button type="submit" class="btn btn-primary">{{ t('common.create') }}</button>
            </div>
        </form>
    </div></div>
</div>
{# Edit User Modals (one per user) #}
{% for user in users %}
<div class="modal fade" id="modal-edit-user-{{ user.id }}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">Benutzer bearbeiten</h3>
            <button class="modal-close" data-bs-dismiss="modal" type="button">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
        </div>
        <form action="{{ base_path }}/einstellungen/benutzer/{{ user.id }}" method="POST" class="modal-body">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="form-group mb-3">
                <label class="form-label">{{ t('settings.user_name') }} *</label>
                <input type="text" name="name" class="form-control" required value="{{ user.name }}">
            </div>
            <div class="form-group mb-3">
                <label class="form-label">{{ t('settings.user_email') }} *</label>
                <input type="email" name="email" class="form-control" required value="{{ user.email }}">
            </div>
            <div class="form-group mb-3">
                <label class="form-label">
                    {{ t('settings.user_password') }}
                    <span class="form-hint">(leer lassen = unverändert, min. 8 Zeichen)</span>
                </label>
                <input type="password" name="password" class="form-control" minlength="8" autocomplete="new-password" placeholder="Neues Passwort (optional)">
            </div>
            <div class="form-group mb-3">
                <label class="form-label">{{ t('settings.user_role') }}</label>
                <select name="role" class="form-control">
                    <option value="mitarbeiter" {{ user.role == 'mitarbeiter' ? 'selected' : '' }}>{{ t('common.role_mita') }}</option>
                    <option value="admin" {{ user.role == 'admin' ? 'selected' : '' }}>{{ t('common.role_admin') }}</option>
                </select>
            </div>
            <div class="modal-footer" style="padding:1rem 0 0;margin-top:1rem;border-top:1px solid var(--glass-border);">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ t('common.cancel') }}</button>
                <button type="submit" class="btn btn-primary">{{ t('common.save') }}</button>
            </div>
        </form>
    </div></div>
</div>
{% endfor %}

{% endblock %}
