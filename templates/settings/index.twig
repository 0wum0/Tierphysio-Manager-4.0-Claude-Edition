{% extends 'layouts/base.twig' %}

{% block content %}
<div class="page-header">
    <h1 class="page-title">{{ t('settings.title') }}</h1>
    <div class="flex gap-2">
        <a href="/einstellungen/benutzer" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            {{ t('settings.users') }}
        </a>
        <a href="/einstellungen/plugins" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="17.5" y1="15" x2="9" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            {{ t('settings.plugins') }}
        </a>
        <a href="/einstellungen/updater" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="23 4 23 10 17 10"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="1 20 1 14 7 14"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
            {{ t('settings.updater') }}
        </a>
    </div>
</div>

{# ── Logo Upload (standalone form, MUST be outside main settings form) ── #}
<div class="flex gap-4 mb-4" style="align-items:flex-start;flex-wrap:wrap;">
    <div style="flex:1;min-width:300px;">
        <div class="glass-card">
            <h3 class="font-semibold mb-3" style="font-size:0.95rem;color:var(--accent);">{{ t('settings.company_logo') }}</h3>
            {% if settings.company_logo %}
                <div class="mb-3">
                    <img src="/storage/uploads/{{ settings.company_logo }}" alt="Logo" style="max-height:60px;border-radius:var(--radius-sm);">
                </div>
            {% endif %}
            <form action="/einstellungen/logo" method="POST" enctype="multipart/form-data" style="display:flex;gap:0.5rem;align-items:center;">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <input type="file" name="logo" class="form-control" accept="image/*" style="font-size:0.8rem;padding:0.4rem;">
                <button type="submit" class="btn btn-secondary btn-sm" style="flex-shrink:0;">{{ t('settings.upload_logo') }}</button>
            </form>
        </div>
    </div>
    <div style="flex:1;min-width:300px;"></div>
</div>

{# ── Main Settings Form ── #}
<form action="/einstellungen" method="POST">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

    <div class="flex gap-4" style="align-items:flex-start;flex-wrap:wrap;">

        {# Left Column #}
        <div style="flex:1;min-width:300px;display:flex;flex-direction:column;gap:1rem;">

            {# Company Info #}
            <div class="glass-card">
                <h3 class="font-semibold mb-4" style="font-size:0.95rem;color:var(--accent);">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="display:inline;margin-right:0.4rem;"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2"/><line x1="8" y1="21" x2="16" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="17" x2="12" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    {{ t('settings.company') }}
                </h3>
                <div class="form-grid form-grid-2">
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">{{ t('settings.company_name') }}</label>
                        <input type="text" name="company_name" class="form-control" value="{{ settings.company_name ?? '' }}">
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">{{ t('settings.company_street') }}</label>
                        <input type="text" name="company_street" class="form-control" value="{{ settings.company_street ?? '' }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.company_zip') }}</label>
                        <input type="text" name="company_zip" class="form-control" value="{{ settings.company_zip ?? '' }}" maxlength="10">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.company_city') }}</label>
                        <input type="text" name="company_city" class="form-control" value="{{ settings.company_city ?? '' }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.company_phone') }}</label>
                        <input type="tel" name="company_phone" class="form-control" value="{{ settings.company_phone ?? '' }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.company_email') }}</label>
                        <input type="email" name="company_email" class="form-control" value="{{ settings.company_email ?? '' }}">
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">{{ t('settings.company_website') }}</label>
                        <input type="text" name="company_website" class="form-control" value="{{ settings.company_website ?? '' }}" placeholder="https://...">
                    </div>
                </div>
            </div>

            {# Tax #}
            <div class="glass-card">
                <h3 class="font-semibold mb-4" style="font-size:0.95rem;color:var(--accent);">
                    {{ t('settings.tax') }}
                </h3>
                <div class="form-grid form-grid-2">
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.tax_number') }}</label>
                        <input type="text" name="tax_number" class="form-control" value="{{ settings.tax_number ?? '' }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.vat_number') }}</label>
                        <input type="text" name="vat_number" class="form-control" value="{{ settings.vat_number ?? '' }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.default_tax_rate') }}</label>
                        <input type="number" name="default_tax_rate" class="form-control" value="{{ settings.default_tax_rate ?? '19' }}" min="0" max="100" step="0.01">
                    </div>
                </div>
            </div>

            {# Appearance #}
            <div class="glass-card">
                <h3 class="font-semibold mb-4" style="font-size:0.95rem;color:var(--accent);">
                    {{ t('settings.appearance') }}
                </h3>
                <div class="form-grid form-grid-2">
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.default_language') }}</label>
                        <select name="default_language" class="form-control">
                            <option value="de" {{ (settings.default_language ?? 'de') == 'de' ? 'selected' : '' }}>{{ t('common.de') }}</option>
                            <option value="en" {{ (settings.default_language ?? 'de') == 'en' ? 'selected' : '' }}>{{ t('common.en') }}</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.default_theme') }}</label>
                        <select name="default_theme" class="form-control">
                            <option value="dark"  {{ (settings.default_theme ?? 'dark') == 'dark'  ? 'selected' : '' }}>{{ t('common.dark') }}</option>
                            <option value="light" {{ (settings.default_theme ?? 'dark') == 'light' ? 'selected' : '' }}>{{ t('common.light') }}</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        {# Right Column #}
        <div style="flex:1;min-width:300px;display:flex;flex-direction:column;gap:1rem;">

            {# Bank #}
            <div class="glass-card">
                <h3 class="font-semibold mb-4" style="font-size:0.95rem;color:var(--accent);">
                    {{ t('settings.bank') }}
                </h3>
                <div class="form-grid form-grid-1" style="grid-template-columns:1fr;">
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.bank_name') }}</label>
                        <input type="text" name="bank_name" class="form-control" value="{{ settings.bank_name ?? '' }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.bank_iban') }}</label>
                        <input type="text" name="bank_iban" class="form-control" value="{{ settings.bank_iban ?? '' }}" placeholder="DE00 0000 0000 0000 0000 00">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.bank_bic') }}</label>
                        <input type="text" name="bank_bic" class="form-control" value="{{ settings.bank_bic ?? '' }}">
                    </div>
                </div>
            </div>

            {# Invoice Settings #}
            <div class="glass-card">
                <h3 class="font-semibold mb-4" style="font-size:0.95rem;color:var(--accent);">
                    {{ t('settings.invoices') }}
                </h3>
                <div class="form-grid form-grid-2">
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.invoice_prefix') }}</label>
                        <input type="text" name="invoice_prefix" class="form-control" value="{{ settings.invoice_prefix ?? 'RE' }}" maxlength="10">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.invoice_start_number') }}</label>
                        <input type="number" name="invoice_start_number" class="form-control" value="{{ settings.invoice_start_number ?? '1000' }}" min="1">
                    </div>
                </div>
                <div class="form-group mt-3">
                    <label class="form-label">{{ t('settings.payment_terms') }}</label>
                    <textarea name="payment_terms" class="form-control" rows="3">{{ settings.payment_terms ?? '' }}</textarea>
                </div>
            </div>

            {# SMTP #}
            <div class="glass-card">
                <h3 class="font-semibold mb-4" style="font-size:0.95rem;color:var(--accent);">
                    {{ t('settings.smtp') }}
                </h3>
                <div class="form-grid form-grid-2">
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.smtp_host') }}</label>
                        <input type="text" name="smtp_host" class="form-control" value="{{ settings.smtp_host ?? '' }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.smtp_port') }}</label>
                        <input type="number" name="smtp_port" class="form-control" value="{{ settings.smtp_port ?? '587' }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.smtp_username') }}</label>
                        <input type="text" name="smtp_username" class="form-control" value="{{ settings.smtp_username ?? '' }}" autocomplete="off">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.smtp_password') }}</label>
                        <input type="password" name="smtp_password" class="form-control" value="{{ settings.smtp_password ?? '' }}" autocomplete="new-password">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.smtp_encryption') }}</label>
                        <select name="smtp_encryption" class="form-control">
                            <option value="tls" {{ (settings.smtp_encryption ?? 'tls') == 'tls' ? 'selected' : '' }}>TLS (STARTTLS)</option>
                            <option value="ssl" {{ (settings.smtp_encryption ?? 'tls') == 'ssl' ? 'selected' : '' }}>SSL</option>
                            <option value="none" {{ (settings.smtp_encryption ?? 'tls') == 'none' ? 'selected' : '' }}>Keine</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.mail_from_name') }}</label>
                        <input type="text" name="mail_from_name" class="form-control" value="{{ settings.mail_from_name ?? '' }}">
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">{{ t('settings.mail_from_address') }}</label>
                        <input type="email" name="mail_from_address" class="form-control" value="{{ settings.mail_from_address ?? '' }}">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="flex justify-end gap-3 mt-4">
        <button type="submit" class="btn btn-primary">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 3 7 8 15 8"/></svg>
            {{ t('common.save') }}
        </button>
    </div>
</form>
{% endblock %}
