<style>
.settings-tabs {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--glass-border);
    margin-bottom: 1.5rem;
    overflow-x: auto;
    padding-bottom: 0;
}
.settings-tab {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    border: none;
    background: transparent;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
}
.settings-tab:hover { color: var(--text-primary); }
.settings-tab.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
}
.tab-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    margin-left: 0.2rem;
}
.settings-tab-content { display: none; }
.settings-tab-content.active { display: block; }
.section-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 1rem;
}
</style>

<script>
(function() {
    // ── Tab Navigation ──────────────────────────────
    const tabs   = document.querySelectorAll('#settingsTabs .settings-tab');
    const panels = document.querySelectorAll('.settings-tab-content');

    function activate(tabId) {
        tabs.forEach(t => t.classList.toggle('active', t.dataset.tab === tabId));
        panels.forEach(p => p.classList.toggle('active', p.id === 'tab-' + tabId));
        try { localStorage.setItem('settingsTab', tabId); } catch(e) {}
    }

    tabs.forEach(tab => tab.addEventListener('click', () => activate(tab.dataset.tab)));

    const hash    = location.hash.replace('#', '');
    const saved   = (function(){ try { return localStorage.getItem('settingsTab'); } catch(e) { return null; } })();
    activate(hash || saved || 'firma');

    // ── PDF Design Live Preview ──────────────────────
    function syncColorPicker(pickerId, textId) {
        const picker = document.getElementById(pickerId);
        const text   = document.getElementById(textId);
        if (!picker || !text) return;
        picker.addEventListener('input', () => { text.value = picker.value; updatePreview(); });
        text.addEventListener('input', () => {
            if (/^#[0-9a-fA-F]{6}$/.test(text.value)) {
                picker.value = text.value;
                updatePreview();
            }
        });
    }

    function updatePreview() {
        const primary = document.getElementById('pdf_primary_color')?.value || '#2962FF';
        const accent  = document.getElementById('pdf_accent_color')?.value  || '#2962FF';
        const font    = document.getElementById('pdf_font_select')?.value   || 'helvetica';
        const hStyle  = document.querySelector('[name="pdf_header_style"]')?.value || 'line';
        const showLogo    = document.querySelector('[name="pdf_show_logo"]:not([type=hidden])')?.checked ?? true;
        const showPatient = document.querySelector('[name="pdf_show_patient"]:not([type=hidden])')?.checked ?? true;

        const fontMap = { helvetica:'Helvetica,Arial,sans-serif', times:'Georgia,"Times New Roman",serif', courier:'"Courier New",Courier,monospace', dejavusans:'Helvetica,Arial,sans-serif' };
        const fontCss = fontMap[font] || fontMap.helvetica;

        const preview = document.getElementById('pdf-preview');
        if (preview) preview.style.fontFamily = fontCss;

        const divider = document.getElementById('preview-divider');
        if (divider) {
            if (hStyle === 'band') {
                divider.style.height = '6px';
                divider.style.borderRadius = '0';
            } else {
                divider.style.height = '2px';
                divider.style.borderRadius = '1px';
            }
            divider.style.background = primary;
        }

        const tableHeader = document.getElementById('preview-table-header');
        if (tableHeader) tableHeader.style.background = primary;

        const title = document.getElementById('preview-title');
        if (title) title.style.color = accent;

        const total = document.getElementById('preview-total');
        if (total) total.style.color = accent;

        const logoEl = document.getElementById('preview-logo');
        if (logoEl) logoEl.style.display = showLogo ? '' : 'none';
    }

    syncColorPicker('pdf_primary_color_picker', 'pdf_primary_color');
    syncColorPicker('pdf_accent_color_picker',  'pdf_accent_color');

    document.getElementById('pdf_font_select')?.addEventListener('change', updatePreview);
    document.querySelector('[name="pdf_header_style"]')?.addEventListener('change', updatePreview);
    document.querySelector('[name="pdf_show_logo"]:not([type=hidden])')?.addEventListener('change', updatePreview);
    document.querySelector('[name="pdf_show_patient"]:not([type=hidden])')?.addEventListener('change', updatePreview);

    updatePreview();
})();
</script>

<script>
function openEditTT(tt) {
    document.getElementById('form-edit-tt').action = '/einstellungen/behandlungsarten/' + tt.id;
    document.getElementById('ett-name').value   = tt.name  || '';
    document.getElementById('ett-color').value  = tt.color || '#4f7cff';
    document.getElementById('ett-price').value  = tt.price || '';
    document.getElementById('ett-sort').value   = tt.sort_order || 0;
    document.getElementById('ett-desc').value   = tt.description || '';
    document.getElementById('ett-active').checked = tt.active == 1;
    document.getElementById('modal-edit-tt').style.display = 'flex';
}
</script>

