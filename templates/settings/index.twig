{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}
<div class="page-header">
    <h1 class="page-title">{{ t('settings.title') }}</h1>
</div>

{# ── Tab Navigation ── #}
<div class="settings-tabs" id="settingsTabs">
    <button class="settings-tab" data-tab="firma">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2"/><line x1="8" y1="21" x2="16" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="17" x2="12" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        Firma
    </button>
    <button class="settings-tab" data-tab="finanzen">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        Finanzen & Rechnungen
    </button>
    <button class="settings-tab" data-tab="smtp">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="22,6 12,13 2,6"/></svg>
        E-Mail / SMTP
    </button>
    <button class="settings-tab" data-tab="darstellung">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        Darstellung
    </button>
    <button class="settings-tab" data-tab="pdf">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="16" y1="17" x2="8" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="10 9 9 9 8 9"/></svg>
        PDF-Design
    </button>
    <button class="settings-tab" data-tab="benutzer">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Benutzer
    </button>
    <button class="settings-tab" data-tab="plugins">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="17.5" y1="15" x2="9" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        Plugins
    </button>
    <button class="settings-tab" data-tab="behandlungsarten">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Behandlungsarten
    </button>
    <button class="settings-tab" data-tab="updates">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="23 4 23 10 17 10"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="1 20 1 14 7 14"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
        Updates
        {% if not up_to_date %}<span class="tab-badge">{{ pending|length }}</span>{% endif %}
    </button>
</div>

{# ════════════════════════════════════════════════════
   TAB: FIRMA
════════════════════════════════════════════════════ #}
<div class="settings-tab-content" id="tab-firma">

    {# Logo Upload — own form, completely separate #}
    <div class="glass-card mb-4">
        <h3 class="section-title">{{ t('settings.company_logo') }}</h3>
        <div class="flex gap-4 items-center flex-wrap">
            {% if settings.company_logo %}
                <img src="/storage/uploads/{{ settings.company_logo }}" alt="Logo" style="max-height:64px;border-radius:var(--radius-sm);border:1px solid var(--glass-border);">
            {% endif %}
            <form action="/einstellungen/logo" method="POST" enctype="multipart/form-data" class="flex gap-2 items-center">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <input type="file" name="logo" class="form-control" accept="image/*" style="font-size:0.8rem;padding:0.4rem;max-width:280px;">
                <button type="submit" class="btn btn-secondary btn-sm" style="flex-shrink:0;">{{ t('settings.upload_logo') }}</button>
            </form>
        </div>
    </div>

    {# Company Info — main settings form #}
    <form action="/einstellungen" method="POST">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <div class="glass-card">
            <h3 class="section-title">{{ t('settings.company') }}</h3>
            <div class="form-grid form-grid-2">
                <div class="form-group" style="grid-column:1/-1;">
                    <label class="form-label">{{ t('settings.company_name') }}</label>
                    <input type="text" name="company_name" class="form-control" value="{{ settings.company_name ?? '' }}">
                </div>
                <div class="form-group" style="grid-column:1/-1;">
                    <label class="form-label">{{ t('settings.company_street') }}</label>
                    <input type="text" name="company_street" class="form-control" value="{{ settings.company_street ?? '' }}">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('settings.company_zip') }}</label>
                    <input type="text" name="company_zip" class="form-control" value="{{ settings.company_zip ?? '' }}" maxlength="10">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('settings.company_city') }}</label>
                    <input type="text" name="company_city" class="form-control" value="{{ settings.company_city ?? '' }}">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('settings.company_phone') }}</label>
                    <input type="tel" name="company_phone" class="form-control" value="{{ settings.company_phone ?? '' }}">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('settings.company_email') }}</label>
                    <input type="email" name="company_email" class="form-control" value="{{ settings.company_email ?? '' }}">
                </div>
                <div class="form-group" style="grid-column:1/-1;">
                    <label class="form-label">{{ t('settings.company_website') }}</label>
                    <input type="text" name="company_website" class="form-control" value="{{ settings.company_website ?? '' }}" placeholder="https://...">
                </div>
            </div>
        </div>
        <div class="flex justify-end mt-3">
            <button type="submit" class="btn btn-primary">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 3 7 8 15 8"/></svg>
                {{ t('common.save') }}
            </button>
        </div>
    </form>
</div>

{# ════════════════════════════════════════════════════
   TAB: FINANZEN & RECHNUNGEN
════════════════════════════════════════════════════ #}
<div class="settings-tab-content" id="tab-finanzen">
    <form action="/einstellungen" method="POST">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <div class="flex gap-4" style="align-items:flex-start;flex-wrap:wrap;">

            <div style="flex:1;min-width:280px;display:flex;flex-direction:column;gap:1rem;">
                <div class="glass-card">
                    <h3 class="section-title">{{ t('settings.bank') }}</h3>
                    <div class="form-group">
                        <label class="form-label">{{ t('settings.bank_name') }}</label>
                        <input type="text" name="bank_name" class="form-control" value="{{ settings.bank_name ?? '' }}">
                    </div>
                    <div class="form-group mt-3">
                        <label class="form-label">{{ t('settings.bank_iban') }}</label>
                        <input type="text" name="bank_iban" class="form-control" value="{{ settings.bank_iban ?? '' }}" placeholder="DE00 0000 0000 0000 0000 00">
                    </div>
                    <div class="form-group mt-3">
                        <label class="form-label">{{ t('settings.bank_bic') }}</label>
                        <input type="text" name="bank_bic" class="form-control" value="{{ settings.bank_bic ?? '' }}">
                    </div>
                </div>

                <div class="glass-card">
                    <h3 class="section-title">{{ t('settings.tax') }}</h3>
                    <div class="form-grid form-grid-2">
                        <div class="form-group">
                            <label class="form-label">{{ t('settings.tax_number') }}</label>
                            <input type="text" name="tax_number" class="form-control" value="{{ settings.tax_number ?? '' }}">
                        </div>
                        <div class="form-group">
                            <label class="form-label">{{ t('settings.vat_number') }}</label>
                            <input type="text" name="vat_number" class="form-control" value="{{ settings.vat_number ?? '' }}">
                        </div>
                        <div class="form-group">
                            <label class="form-label">{{ t('settings.default_tax_rate') }} (%)</label>
                            <input type="number" name="default_tax_rate" class="form-control" value="{{ settings.default_tax_rate ?? '19' }}" min="0" max="100" step="0.01">
                        </div>
                        <div class="form-group" style="grid-column:1/-1;">
                            <label class="form-label">Kleinunternehmerregelung</label>
                            <label class="flex items-center gap-2 mt-1" style="cursor:pointer;">
                                <input type="hidden" name="kleinunternehmer" value="0">
                                <input type="checkbox" name="kleinunternehmer" value="1" {{ (settings.kleinunternehmer ?? '0') == '1' ? 'checked' : '' }} style="width:16px;height:16px;accent-color:var(--accent);">
                                <span class="text-sm">Kleinunternehmer §19 UStG — MwSt. wird automatisch auf 0% gesetzt und im PDF als steuerbefreit ausgewiesen</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div style="flex:1;min-width:280px;">
                <div class="glass-card">
                    <h3 class="section-title">{{ t('settings.invoices') }}</h3>
                    <div class="form-grid form-grid-2">
                        <div class="form-group">
                            <label class="form-label">{{ t('settings.invoice_prefix') }}</label>
                            <input type="text" name="invoice_prefix" class="form-control" value="{{ settings.invoice_prefix ?? 'RE' }}" maxlength="10">
                        </div>
                        <div class="form-group">
                            <label class="form-label">{{ t('settings.invoice_start_number') }}</label>
                            <input type="number" name="invoice_start_number" class="form-control" value="{{ settings.invoice_start_number ?? '1000' }}" min="1">
                        </div>
                    </div>
                    <div class="form-group mt-3">
                        <label class="form-label">{{ t('settings.payment_terms') }}</label>
                        <textarea name="payment_terms" class="form-control" rows="4">{{ settings.payment_terms ?? '' }}</textarea>
                    </div>
                </div>
            </div>
        </div>
        <div class="flex justify-end mt-3">
            <button type="submit" class="btn btn-primary">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 3 7 8 15 8"/></svg>
                {{ t('common.save') }}
            </button>
        </div>
    </form>
</div>

{# ════════════════════════════════════════════════════
   TAB: E-MAIL / SMTP
════════════════════════════════════════════════════ #}
<div class="settings-tab-content" id="tab-smtp">
    <form action="/einstellungen" method="POST">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <div class="glass-card">
            <h3 class="section-title">{{ t('settings.smtp') }}</h3>
            <div class="form-grid form-grid-2">
                <div class="form-group">
                    <label class="form-label">{{ t('settings.smtp_host') }}</label>
                    <input type="text" name="smtp_host" class="form-control" value="{{ settings.smtp_host ?? '' }}" placeholder="smtp.example.com">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('settings.smtp_port') }}</label>
                    <input type="number" name="smtp_port" class="form-control" value="{{ settings.smtp_port ?? '587' }}">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('settings.smtp_username') }}</label>
                    <input type="text" name="smtp_username" class="form-control" value="{{ settings.smtp_username ?? '' }}" autocomplete="off">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('settings.smtp_password') }}</label>
                    <input type="password" name="smtp_password" class="form-control" value="{{ settings.smtp_password ?? '' }}" autocomplete="new-password">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('settings.smtp_encryption') }}</label>
                    <select name="smtp_encryption" class="form-control">
                        <option value="tls"  {{ (settings.smtp_encryption ?? 'tls') == 'tls'  ? 'selected' : '' }}>TLS (STARTTLS) — Port 587</option>
                        <option value="ssl"  {{ (settings.smtp_encryption ?? 'tls') == 'ssl'  ? 'selected' : '' }}>SSL — Port 465</option>
                        <option value="none" {{ (settings.smtp_encryption ?? 'tls') == 'none' ? 'selected' : '' }}>Keine Verschlüsselung</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('settings.mail_from_name') }}</label>
                    <input type="text" name="mail_from_name" class="form-control" value="{{ settings.mail_from_name ?? '' }}" placeholder="Tierphysio Praxis">
                </div>
                <div class="form-group" style="grid-column:1/-1;">
                    <label class="form-label">{{ t('settings.mail_from_address') }}</label>
                    <input type="email" name="mail_from_address" class="form-control" value="{{ settings.mail_from_address ?? '' }}" placeholder="noreply@praxis.de">
                </div>
            </div>
        </div>
        <div class="flex justify-end mt-3">
            <button type="submit" class="btn btn-primary">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 3 7 8 15 8"/></svg>
                {{ t('common.save') }}
            </button>
        </div>
    </form>
</div>

{# ════════════════════════════════════════════════════
   TAB: DARSTELLUNG
════════════════════════════════════════════════════ #}
<div class="settings-tab-content" id="tab-darstellung">
    <form action="/einstellungen" method="POST">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <div class="glass-card" style="max-width:480px;">
            <h3 class="section-title">{{ t('settings.appearance') }}</h3>
            <div class="form-group">
                <label class="form-label">{{ t('settings.default_language') }}</label>
                <select name="default_language" class="form-control">
                    <option value="de" {{ (settings.default_language ?? 'de') == 'de' ? 'selected' : '' }}>{{ t('common.de') }}</option>
                    <option value="en" {{ (settings.default_language ?? 'de') == 'en' ? 'selected' : '' }}>{{ t('common.en') }}</option>
                </select>
            </div>
            <div class="form-group mt-3">
                <label class="form-label">{{ t('settings.default_theme') }}</label>
                <select name="default_theme" class="form-control">
                    <option value="dark"  {{ (settings.default_theme ?? 'dark') == 'dark'  ? 'selected' : '' }}>{{ t('common.dark') }}</option>
                    <option value="light" {{ (settings.default_theme ?? 'dark') == 'light' ? 'selected' : '' }}>{{ t('common.light') }}</option>
                </select>
            </div>
        </div>
        <div class="flex justify-end mt-3">
            <button type="submit" class="btn btn-primary">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 3 7 8 15 8"/></svg>
                {{ t('common.save') }}
            </button>
        </div>
    </form>
</div>

{# ════════════════════════════════════════════════════
   TAB: PDF-DESIGN
════════════════════════════════════════════════════ #}
<div class="settings-tab-content" id="tab-pdf">
    <form action="/einstellungen" method="POST" id="pdf-settings-form">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

        <div class="flex gap-4" style="align-items:flex-start;flex-wrap:wrap;">

            {# ── LEFT COLUMN ── #}
            <div style="flex:1.2;min-width:300px;display:flex;flex-direction:column;gap:1rem;">

                {# 1. Farben #}
                <div class="glass-card">
                    <h3 class="section-title">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="margin-right:6px;vertical-align:-2px;"><circle cx="13.5" cy="6.5" r="2.5" stroke="currentColor" stroke-width="2"/><circle cx="17.5" cy="10.5" r="2.5" stroke="currentColor" stroke-width="2"/><circle cx="8.5" cy="7.5" r="2.5" stroke="currentColor" stroke-width="2"/><circle cx="6.5" cy="12.5" r="2.5" stroke="currentColor" stroke-width="2"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M20.488 9c.328.93.512 1.944.512 3a9 9 0 0 1-9 9 3 3 0 0 1 0-6c1.657 0 3-1.343 3-3 0-.552.448-1 1-1h4.5"/></svg>
                        Farben
                    </h3>
                    <div class="form-grid form-grid-2">
                        <div class="form-group">
                            <label class="form-label">Primärfarbe</label>
                            <p class="form-hint" style="margin-bottom:6px;">Tabellenheader, Trennlinie</p>
                            <div class="flex gap-2 items-center">
                                <input type="color" id="pdf_primary_color_picker" value="{{ settings.pdf_primary_color ?? '#2962FF' }}"
                                    style="width:44px;height:38px;padding:2px;border:1px solid var(--glass-border);border-radius:var(--radius-sm);background:transparent;cursor:pointer;flex-shrink:0;">
                                <input type="text" name="pdf_primary_color" id="pdf_primary_color" class="form-control" value="{{ settings.pdf_primary_color ?? '#2962FF' }}" maxlength="7" style="font-family:monospace;">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Akzentfarbe</label>
                            <p class="form-hint" style="margin-bottom:6px;">Gesamtsumme, Rechnungstitel</p>
                            <div class="flex gap-2 items-center">
                                <input type="color" id="pdf_accent_color_picker" value="{{ settings.pdf_accent_color ?? '#2962FF' }}"
                                    style="width:44px;height:38px;padding:2px;border:1px solid var(--glass-border);border-radius:var(--radius-sm);background:transparent;cursor:pointer;flex-shrink:0;">
                                <input type="text" name="pdf_accent_color" id="pdf_accent_color" class="form-control" value="{{ settings.pdf_accent_color ?? '#2962FF' }}" maxlength="7" style="font-family:monospace;">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Hintergrundfarbe Zeilen</label>
                            <p class="form-hint" style="margin-bottom:6px;">Zebra-Streifen (gerade Zeilen)</p>
                            <div class="flex gap-2 items-center">
                                <input type="color" id="pdf_row_color_picker" value="{{ settings.pdf_row_color ?? '#F5F5FA' }}"
                                    style="width:44px;height:38px;padding:2px;border:1px solid var(--glass-border);border-radius:var(--radius-sm);background:transparent;cursor:pointer;flex-shrink:0;">
                                <input type="text" name="pdf_row_color" id="pdf_row_color" class="form-control" value="{{ settings.pdf_row_color ?? '#F5F5FA' }}" maxlength="7" style="font-family:monospace;">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Wasserzeichen-Text</label>
                            <p class="form-hint" style="margin-bottom:6px;">Diagonal auf jeder Seite (leer = kein Wasserzeichen)</p>
                            <input type="text" name="pdf_watermark" class="form-control" value="{{ settings.pdf_watermark ?? '' }}" placeholder="z.B. ENTWURF oder BEZAHLT" maxlength="30">
                        </div>
                    </div>

                    {# ── Erweiterte Farbeinstellungen ── #}
                    <h4 style="font-size:0.8rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);margin:1.2rem 0 0.6rem;">Textelemente</h4>
                    <div class="form-grid form-grid-2">
                        {% set colorFields = [
                            {key: 'pdf_color_company_name',       label: 'Firmenname',             hint: 'Fetter Name oben rechts',         default: '#1E1E1E'},
                            {key: 'pdf_color_company_info',       label: 'Firmenadresse / Grautexte', hint: 'Adresse, Kunden-Nr., Patient',  default: '#6E6E6E'},
                            {key: 'pdf_color_recipient',          label: 'Empfänger',              hint: 'Name und Adresse des Kunden',      default: '#1E1E1E'},
                            {key: 'pdf_color_table_header_bg',    label: 'Tabellenkopf Hintergrund', hint: 'Hintergrundfarbe der Kopfzeile', default: '#8B9E8B'},
                            {key: 'pdf_color_table_header_text',  label: 'Tabellenkopf Text',      hint: 'Beschriftung Anzahl, Preis usw.',  default: '#FFFFFF'},
                            {key: 'pdf_color_table_text',         label: 'Tabellenzeilen Text',    hint: 'Positionen / Beschreibungen',      default: '#1E1E1E'},
                            {key: 'pdf_color_line',               label: 'Trennlinien',            hint: 'Alle Linien im PDF',               default: '#B4B4B4'},
                            {key: 'pdf_color_total_label',        label: 'Summen-Bezeichnungen',   hint: 'Netto, MwSt. Beschriftungen',      default: '#1E1E1E'},
                            {key: 'pdf_color_total_gross',        label: 'Gesamtbetrag',           hint: 'Fett gedruckte Endsumme',          default: '#1E1E1E'},
                            {key: 'pdf_color_footer',             label: 'Footer-Text',            hint: 'Bankdaten, Kontakt unten',         default: '#6E6E6E'}
                        ] %}
                        {% for f in colorFields %}
                        <div class="form-group">
                            <label class="form-label">{{ f.label }}</label>
                            <p class="form-hint" style="margin-bottom:6px;">{{ f.hint }}</p>
                            <div class="flex gap-2 items-center">
                                <input type="color" id="{{ f.key }}_picker" value="{{ attribute(settings, f.key) ?? f.default }}"
                                    style="width:44px;height:38px;padding:2px;border:1px solid var(--glass-border);border-radius:var(--radius-sm);background:transparent;cursor:pointer;flex-shrink:0;">
                                <input type="text" name="{{ f.key }}" id="{{ f.key }}" class="form-control pdf-color-field" value="{{ attribute(settings, f.key) ?? f.default }}" maxlength="7" style="font-family:monospace;">
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>

                {# 2. Schrift & Layout #}
                {# ── Script-Bilder Upload ── #}
                <div class="glass-card">
                    <h3 class="section-title">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="margin-right:6px;vertical-align:-2px;"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/><path d="M3 9l4-4 4 4 4-4 4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Script-Bilder (Rechnung &amp; Vielen Dank!)
                    </h3>
                    <p class="form-hint" style="margin-bottom:1rem;">Diese Bilder ersetzen die Schriftzüge im PDF. PNG mit transparentem Hintergrund empfohlen.</p>

                    <div class="form-grid form-grid-2">
                        <div class="form-group">
                            <label class="form-label">"Rechnung"-Schriftzug</label>
                            {% if settings.pdf_rechnung_bild %}
                                <img src="/assets/img/{{ settings.pdf_rechnung_bild }}" alt="Rechnung" style="max-height:50px;max-width:100%;margin-bottom:8px;border-radius:4px;background:#f5f5f5;padding:4px;">
                            {% else %}
                                <img src="/assets/img/rechnung-script.png" alt="Rechnung" style="max-height:50px;max-width:100%;margin-bottom:8px;border-radius:4px;background:#f5f5f5;padding:4px;" onerror="this.style.display='none'">
                            {% endif %}
                            <div class="flex gap-2 items-center">
                                <input type="file" name="pdf_rechnung_bild" accept="image/*" form="form-upload-rechnung" class="form-control" style="flex:1;">
                                <button type="submit" form="form-upload-rechnung" class="btn btn-sm btn-primary">Hochladen</button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">"Vielen Dank!"-Schriftzug</label>
                            {% if settings.pdf_vielen_dank_bild %}
                                <img src="/assets/img/{{ settings.pdf_vielen_dank_bild }}" alt="Vielen Dank" style="max-height:50px;max-width:100%;margin-bottom:8px;border-radius:4px;background:#f5f5f5;padding:4px;">
                            {% else %}
                                <img src="/assets/img/vielen-dank-script.png" alt="Vielen Dank" style="max-height:50px;max-width:100%;margin-bottom:8px;border-radius:4px;background:#f5f5f5;padding:4px;" onerror="this.style.display='none'">
                            {% endif %}
                            <div class="flex gap-2 items-center">
                                <input type="file" name="pdf_vielen_dank_bild" accept="image/*" form="form-upload-vielen-dank" class="form-control" style="flex:1;">
                                <button type="submit" form="form-upload-vielen-dank" class="btn btn-sm btn-primary">Hochladen</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="glass-card">
                    <h3 class="section-title">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="margin-right:6px;vertical-align:-2px;"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="4" x2="12" y2="20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        Schrift &amp; Layout
                    </h3>
                    <div class="form-grid form-grid-2">
                        <div class="form-group">
                            <label class="form-label">Schriftart</label>
                            <select name="pdf_font" class="form-control" id="pdf_font_select">
                                <option value="helvetica"  {{ (settings.pdf_font ?? 'helvetica') == 'helvetica'  ? 'selected' : '' }}>Helvetica (Standard)</option>
                                <option value="times"      {{ (settings.pdf_font ?? 'helvetica') == 'times'      ? 'selected' : '' }}>Times New Roman (Klassisch)</option>
                                <option value="courier"    {{ (settings.pdf_font ?? 'helvetica') == 'courier'    ? 'selected' : '' }}>Courier (Monospace)</option>
                                <option value="dejavusans" {{ (settings.pdf_font ?? 'helvetica') == 'dejavusans' ? 'selected' : '' }}>DejaVu Sans (Modern)</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Basis-Schriftgröße (pt)</label>
                            <input type="number" name="pdf_font_size" class="form-control" value="{{ settings.pdf_font_size ?? '9' }}" min="7" max="14" step="0.5">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Kopfzeilen-Stil</label>
                            <select name="pdf_header_style" class="form-control" id="pdf_header_style_select">
                                <option value="line"    {{ (settings.pdf_header_style ?? 'line') == 'line'    ? 'selected' : '' }}>Dünne Linie</option>
                                <option value="band"    {{ (settings.pdf_header_style ?? 'line') == 'band'    ? 'selected' : '' }}>Farbband (kräftig)</option>
                                <option value="none"    {{ (settings.pdf_header_style ?? 'line') == 'none'    ? 'selected' : '' }}>Keiner</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Logo-Position</label>
                            <select name="pdf_logo_position" class="form-control">
                                <option value="left"   {{ (settings.pdf_logo_position ?? 'left') == 'left'   ? 'selected' : '' }}>Links</option>
                                <option value="center" {{ (settings.pdf_logo_position ?? 'left') == 'center' ? 'selected' : '' }}>Mitte</option>
                                <option value="right"  {{ (settings.pdf_logo_position ?? 'left') == 'right'  ? 'selected' : '' }}>Rechts</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Logo-Breite (mm)</label>
                            <input type="number" name="pdf_logo_width" class="form-control" value="{{ settings.pdf_logo_width ?? '35' }}" min="10" max="80">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Seitenränder (mm)</label>
                            <input type="number" name="pdf_margin" class="form-control" value="{{ settings.pdf_margin ?? '20' }}" min="5" max="40">
                        </div>
                    </div>
                </div>

                {# 3. Inhaltsoptionen #}
                <div class="glass-card">
                    <h3 class="section-title">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="margin-right:6px;vertical-align:-2px;"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 11l3 3L22 4"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                        Inhaltsoptionen
                    </h3>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem 1.5rem;">
                        <label class="flex items-center gap-2" style="cursor:pointer;">
                            <input type="hidden" name="pdf_show_logo" value="0">
                            <input type="checkbox" name="pdf_show_logo" value="1" {{ (settings.pdf_show_logo ?? '1') == '1' ? 'checked' : '' }} style="width:16px;height:16px;accent-color:var(--accent);">
                            <span class="text-sm">Firmenlogo anzeigen</span>
                        </label>
                        <label class="flex items-center gap-2" style="cursor:pointer;">
                            <input type="hidden" name="pdf_show_patient" value="0">
                            <input type="checkbox" name="pdf_show_patient" value="1" {{ (settings.pdf_show_patient ?? '1') == '1' ? 'checked' : '' }} style="width:16px;height:16px;accent-color:var(--accent);">
                            <span class="text-sm">Patientenname anzeigen</span>
                        </label>
                        <label class="flex items-center gap-2" style="cursor:pointer;">
                            <input type="hidden" name="pdf_show_chip" value="0">
                            <input type="checkbox" name="pdf_show_chip" value="1" {{ (settings.pdf_show_chip ?? '1') == '1' ? 'checked' : '' }} style="width:16px;height:16px;accent-color:var(--accent);">
                            <span class="text-sm">Chip-Nummer anzeigen</span>
                        </label>
                        <label class="flex items-center gap-2" style="cursor:pointer;">
                            <input type="hidden" name="pdf_zebra_rows" value="0">
                            <input type="checkbox" name="pdf_zebra_rows" value="1" {{ (settings.pdf_zebra_rows ?? '1') == '1' ? 'checked' : '' }} style="width:16px;height:16px;accent-color:var(--accent);">
                            <span class="text-sm">Zebra-Streifen in Tabelle</span>
                        </label>
                        <label class="flex items-center gap-2" style="cursor:pointer;">
                            <input type="hidden" name="pdf_show_page_numbers" value="0">
                            <input type="checkbox" name="pdf_show_page_numbers" value="1" {{ (settings.pdf_show_page_numbers ?? '1') == '1' ? 'checked' : '' }} style="width:16px;height:16px;accent-color:var(--accent);">
                            <span class="text-sm">Seitenzahlen anzeigen</span>
                        </label>
                        <label class="flex items-center gap-2" style="cursor:pointer;">
                            <input type="hidden" name="pdf_show_iban" value="0">
                            <input type="checkbox" name="pdf_show_iban" value="1" {{ (settings.pdf_show_iban ?? '1') == '1' ? 'checked' : '' }} style="width:16px;height:16px;accent-color:var(--accent);">
                            <span class="text-sm">IBAN in Fußzeile anzeigen</span>
                        </label>
                        <label class="flex items-center gap-2" style="cursor:pointer;">
                            <input type="hidden" name="pdf_show_tax_number" value="0">
                            <input type="checkbox" name="pdf_show_tax_number" value="1" {{ (settings.pdf_show_tax_number ?? '1') == '1' ? 'checked' : '' }} style="width:16px;height:16px;accent-color:var(--accent);">
                            <span class="text-sm">Steuernummer in Fußzeile</span>
                        </label>
                        <label class="flex items-center gap-2" style="cursor:pointer;">
                            <input type="hidden" name="pdf_show_website" value="0">
                            <input type="checkbox" name="pdf_show_website" value="1" {{ (settings.pdf_show_website ?? '0') == '1' ? 'checked' : '' }} style="width:16px;height:16px;accent-color:var(--accent);">
                            <span class="text-sm">Website im Kopf anzeigen</span>
                        </label>
                    </div>
                </div>

                {# 4. Texte #}
                <div class="glass-card">
                    <h3 class="section-title">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="margin-right:6px;vertical-align:-2px;"><line x1="17" y1="10" x2="3" y2="10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="21" y1="6" x2="3" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="21" y1="14" x2="3" y2="14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="17" y1="18" x2="3" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        Texte &amp; Inhalte
                    </h3>
                    <div class="form-group">
                        <label class="form-label">Einleitungstext (unter Empfängeradresse)</label>
                        <textarea name="pdf_intro_text" class="form-control" rows="2" placeholder="z.B. Sehr geehrte Damen und Herren, hiermit stellen wir Ihnen folgende Leistungen in Rechnung:">{{ settings.pdf_intro_text ?? '' }}</textarea>
                        <span class="form-hint">Erscheint vor der Positionstabelle.</span>
                    </div>
                    <div class="form-group mt-3">
                        <label class="form-label">Schlusstext (unter den Summen)</label>
                        <textarea name="pdf_closing_text" class="form-control" rows="2" placeholder="z.B. Vielen Dank für Ihr Vertrauen. Bei Fragen stehen wir Ihnen gerne zur Verfügung.">{{ settings.pdf_closing_text ?? '' }}</textarea>
                        <span class="form-hint">Erscheint nach den Summen, vor den Zahlungsbedingungen.</span>
                    </div>
                    <div class="form-group mt-3">
                        <label class="form-label">Zusätzlicher Fußzeilentext</label>
                        <input type="text" name="pdf_footer_text" class="form-control" value="{{ settings.pdf_footer_text ?? '' }}" placeholder="z.B. Umsatzsteuer nicht ausgewiesen (Kleinunternehmer §19 UStG)">
                        <span class="form-hint">Wird unter den Bankdaten in der Fußzeile angezeigt.</span>
                    </div>
                </div>

            </div>

            {# ── RIGHT COLUMN: Live Preview ── #}
            <div style="flex:1;min-width:310px;position:sticky;top:1rem;">
                <div class="glass-card">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="section-title" style="margin-bottom:0;">Live-Vorschau</h3>
                        <a href="/rechnungen/1/pdf" target="_blank" class="btn btn-secondary btn-sm" style="font-size:0.75rem;">
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            Echte Vorschau öffnen
                        </a>
                    </div>

                    {# PDF Mock Preview — Sidebar Layout #}
                    <div id="pdf-preview" style="background:#fff;border-radius:6px;font-family:Helvetica,sans-serif;font-size:10px;color:#0f0f1a;min-height:440px;border:1px solid var(--glass-border);position:relative;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,0.08);display:flex;">

                        {# Watermark #}
                        <div id="preview-watermark" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-35deg);font-size:28px;font-weight:900;color:rgba(0,0,0,0.06);pointer-events:none;white-space:nowrap;z-index:10;letter-spacing:0.05em;display:none;"></div>

                        {# LEFT SIDEBAR #}
                        <div id="preview-sidebar" style="width:22%;background:#8B9E8B;display:flex;flex-direction:column;align-items:center;padding:10px 4px;flex-shrink:0;">
                            {# Logo #}
                            <div id="preview-logo-wrap" style="margin-bottom:8px;width:100%;display:flex;justify-content:center;">
                                {% if settings.company_logo %}
                                    <img src="/storage/uploads/{{ settings.company_logo }}" alt="Logo" style="max-width:80%;max-height:30px;object-fit:contain;">
                                {% else %}
                                    <div style="width:36px;height:36px;border-radius:50%;border:1.5px solid rgba(255,255,255,0.6);display:flex;align-items:center;justify-content:center;font-size:6px;color:rgba(255,255,255,0.8);">LOGO</div>
                                {% endif %}
                            </div>
                            <div style="font-size:6px;color:rgba(220,235,220,0.9);margin-bottom:1px;text-align:center;">Rechnungsnummer</div>
                            <div style="font-size:7px;font-weight:700;color:#fff;margin-bottom:6px;text-align:center;">RE-2025-0042</div>
                            <div style="font-size:6px;color:rgba(220,235,220,0.9);margin-bottom:1px;text-align:center;">Rechnungsdatum</div>
                            <div style="font-size:7px;font-weight:700;color:#fff;margin-bottom:6px;text-align:center;">01.01.2025</div>
                            <div style="font-size:6px;color:rgba(220,235,220,0.9);margin-bottom:1px;text-align:center;">Fällig am</div>
                            <div style="font-size:7px;font-weight:700;color:#fff;text-align:center;">15.01.2025</div>
                        </div>

                        {# MAIN CONTENT #}
                        <div style="flex:1;padding:8px 10px;display:flex;flex-direction:column;overflow:hidden;">

                            {# Company info top right #}
                            <div style="text-align:right;margin-bottom:4px;">
                                <div id="preview-company" style="font-weight:700;font-size:9px;color:#1E1E1E;">{{ settings.company_name ?? 'Tierphysio GmbH' }}</div>
                                <div id="preview-company-info" style="font-size:7px;color:#6E6E6E;">{{ settings.company_street ?? 'Musterstraße 1' }}</div>
                                <div style="font-size:7px;color:#6E6E6E;">{{ (settings.company_zip ?? '12345') ~ ' ' ~ (settings.company_city ?? 'Musterstadt') }}</div>
                                {% if settings.company_phone %}<div style="font-size:7px;color:#6E6E6E;">Tel: {{ settings.company_phone }}</div>{% endif %}
                                {% if settings.company_email %}<div style="font-size:7px;color:#6E6E6E;">{{ settings.company_email }}</div>{% endif %}
                            </div>

                            {# Rechnung script text placeholder #}
                            <div style="text-align:right;margin-bottom:4px;">
                                <span style="font-size:16px;font-style:italic;font-family:Georgia,serif;color:#1E1E1E;">Rechnung</span>
                            </div>

                            {# Recipient #}
                            <div style="margin-bottom:8px;">
                                <div id="preview-recipient" style="font-size:8px;font-weight:700;color:#1E1E1E;">Max Mustermann</div>
                                <div style="font-size:7px;color:#1E1E1E;">Beispielstraße 5</div>
                                <div style="font-size:7px;color:#1E1E1E;">12345 Musterstadt</div>
                                <div style="font-size:7px;color:#6E6E6E;margin-top:2px;">Kunden-Nr. 0001</div>
                                <div id="preview-patient-row" style="font-size:7px;color:#6E6E6E;">Patient: Bello (Hund)</div>
                            </div>

                            {# Table #}
                            <div style="margin-bottom:6px;">
                                <div id="preview-table-header" style="display:flex;background:#8B9E8B;color:#fff;font-size:7px;padding:2px 4px;">
                                    <span style="width:18px;">Anz.</span>
                                    <span style="flex:1;">Leistung</span>
                                    <span style="width:36px;text-align:right;">Preis</span>
                                    <span style="width:36px;text-align:right;">Total</span>
                                </div>
                                <div style="display:flex;font-size:7px;padding:2px 4px;border-bottom:1px solid #e0e0e0;">
                                    <span id="preview-row-text" style="width:18px;">1</span>
                                    <span style="flex:1;">Physiotherapie</span>
                                    <span style="width:36px;text-align:right;">65,00 €</span>
                                    <span style="width:36px;text-align:right;">65,00 €</span>
                                </div>
                                <div style="display:flex;font-size:7px;padding:2px 4px;border-bottom:1px solid #e0e0e0;">
                                    <span style="width:18px;">2</span>
                                    <span style="flex:1;">Massage</span>
                                    <span style="width:36px;text-align:right;">45,00 €</span>
                                    <span style="width:36px;text-align:right;">90,00 €</span>
                                </div>
                            </div>

                            {# Totals #}
                            <div style="display:flex;justify-content:flex-end;margin-bottom:6px;">
                                <div style="font-size:7px;min-width:120px;">
                                    <div style="display:flex;justify-content:space-between;"><span id="preview-total-label">Total exkl. MwSt.</span><span>155,00 €</span></div>
                                    <div style="display:flex;justify-content:space-between;"><span id="preview-mwst-label">MwSt. 19%</span><span>29,45 €</span></div>
                                    <div style="display:flex;justify-content:space-between;font-weight:700;border-top:1px solid #ccc;margin-top:2px;padding-top:2px;">
                                        <span>Total</span>
                                        <span id="preview-total">184,45 €</span>
                                    </div>
                                </div>
                            </div>

                            {# Vielen Dank #}
                            <div style="font-size:13px;font-style:italic;font-family:Georgia,serif;color:#1E1E1E;margin-bottom:4px;">Vielen Dank!</div>

                            {# Footer #}
                            <div id="preview-footer" style="margin-top:auto;padding-top:4px;border-top:1px solid #e0e0e0;font-size:6.5px;color:#6E6E6E;">
                                {{ settings.bank_name ?? 'Musterbank' }} &nbsp;|&nbsp; IBAN: {{ settings.bank_iban ?? 'DE00 1234 5678' }} &nbsp;|&nbsp; {{ settings.company_email ?? 'info@beispiel.de' }}
                            </div>
                        </div>
                    </div>
                    <p class="form-hint mt-2">Die Vorschau zeigt das ungefähre Layout. Das endgültige PDF wird mit TCPDF erzeugt und kann minimal abweichen.</p>
                </div>

                {# PDF test download info #}
                <div class="glass-card mt-3" style="background:rgba(79,124,255,0.05);border-color:rgba(79,124,255,0.15);">
                    <div style="display:flex;gap:10px;align-items:flex-start;">
                        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" style="color:var(--accent);flex-shrink:0;margin-top:1px;"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        <div>
                            <div style="font-size:0.82rem;font-weight:600;color:var(--text-primary);margin-bottom:3px;">Tipp: Echte PDF-Vorschau</div>
                            <p class="form-hint">Speichere die Einstellungen und öffne dann eine bestehende Rechnung → <strong>PDF herunterladen</strong>, um das finale Ergebnis zu sehen.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex justify-end mt-4">
            <button type="submit" class="btn btn-primary">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 3 7 8 15 8"/></svg>
                {{ t('common.save') }}
            </button>
        </div>
    </form>

    <script>
    (function() {
        function syncColor(pickerId, inputId) {
            const picker = document.getElementById(pickerId);
            const input  = document.getElementById(inputId);
            if (!picker || !input) return;
            picker.addEventListener('input', function() {
                input.value = picker.value.toUpperCase();
                updatePreview();
            });
            input.addEventListener('input', function() {
                if (/^#[0-9A-Fa-f]{6}$/.test(input.value)) {
                    picker.value = input.value;
                    updatePreview();
                }
            });
        }
        syncColor('pdf_primary_color_picker', 'pdf_primary_color');
        syncColor('pdf_accent_color_picker',  'pdf_accent_color');
        syncColor('pdf_row_color_picker',      'pdf_row_color');
        // Auto-sync all extended color pickers (pattern: id + '_picker' <-> id)
        document.querySelectorAll('.pdf-color-field').forEach(function(input) {
            syncColor(input.id + '_picker', input.id);
        });

        function val(name) {
            const el = document.querySelector('[name="' + name + '"]:not([type="hidden"])') ||
                       document.querySelector('[name="' + name + '"]');
            return el ? el.value : '';
        }
        function checked(name) {
            const el = document.querySelector('input[name="' + name + '"][type="checkbox"]');
            return el ? el.checked : false;
        }

        function updatePreview() {
            const primary       = val('pdf_primary_color')             || '#8B9E8B';
            const cCompanyName  = val('pdf_color_company_name')        || '#1E1E1E';
            const cCompanyInfo  = val('pdf_color_company_info')        || '#6E6E6E';
            const cRecipient    = val('pdf_color_recipient')           || '#1E1E1E';
            const cTblHdrBg     = val('pdf_color_table_header_bg')     || '#8B9E8B';
            const cTblHdrTxt    = val('pdf_color_table_header_text')   || '#FFFFFF';
            const cTblText      = val('pdf_color_table_text')          || '#1E1E1E';
            const cLine         = val('pdf_color_line')                || '#B4B4B4';
            const cTotalLbl     = val('pdf_color_total_label')         || '#1E1E1E';
            const cTotalGross   = val('pdf_color_total_gross')         || '#1E1E1E';
            const cFooter       = val('pdf_color_footer')              || '#6E6E6E';
            const watermark     = val('pdf_watermark');
            const showPatient   = checked('pdf_show_patient');
            const showLogo      = checked('pdf_show_logo');

            /* Sidebar */
            const sidebar = document.getElementById('preview-sidebar');
            if (sidebar) sidebar.style.background = primary;

            /* Logo visibility */
            const logoWrap = document.getElementById('preview-logo-wrap');
            if (logoWrap) logoWrap.style.display = showLogo ? '' : 'none';

            /* Company name */
            const comp = document.getElementById('preview-company');
            if (comp) comp.style.color = cCompanyName;

            /* Company info */
            const compInfo = document.getElementById('preview-company-info');
            if (compInfo) compInfo.style.color = cCompanyInfo;

            /* Recipient */
            const rec = document.getElementById('preview-recipient');
            if (rec) rec.style.color = cRecipient;

            /* Table header */
            const th = document.getElementById('preview-table-header');
            if (th) { th.style.background = cTblHdrBg; th.style.color = cTblHdrTxt; }

            /* Table row text */
            const rt = document.getElementById('preview-row-text');
            if (rt) rt.style.color = cTblText;

            /* Totals */
            const tl = document.getElementById('preview-total-label');
            if (tl) tl.style.color = cTotalLbl;
            const ml = document.getElementById('preview-mwst-label');
            if (ml) ml.style.color = cTotalLbl;
            const tot = document.getElementById('preview-total');
            if (tot) tot.style.color = cTotalGross;

            /* Footer */
            const footer = document.getElementById('preview-footer');
            if (footer) { footer.style.color = cFooter; footer.style.borderTopColor = cLine; }

            /* Patient row */
            const patRow = document.getElementById('preview-patient-row');
            if (patRow) patRow.style.display = showPatient ? '' : 'none';

            /* Watermark */
            const wm = document.getElementById('preview-watermark');
            if (wm) {
                if (watermark) { wm.textContent = watermark.toUpperCase(); wm.style.display = ''; }
                else { wm.style.display = 'none'; }
            }
        }

        /* Attach listeners to all form inputs */
        document.getElementById('pdf-settings-form').querySelectorAll('input,select,textarea').forEach(function(el) {
            el.addEventListener('input', updatePreview);
            el.addEventListener('change', updatePreview);
        });

        updatePreview();
    })();
    </script>
</div>

{# ════════════════════════════════════════════════════
   TAB: BENUTZER
════════════════════════════════════════════════════ #}
<div class="settings-tab-content" id="tab-benutzer">
    <div class="flex justify-between items-center mb-4">
        <p class="text-sm text-muted">Verwalte Benutzer und ihre Zugriffsrechte.</p>
        <button class="btn btn-primary btn-sm" data-modal-open="modal-new-user">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            {{ t('settings.new_user') }}
        </button>
    </div>
    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>{{ t('settings.user_name') }}</th>
                    <th>{{ t('settings.user_email') }}</th>
                    <th>{{ t('settings.user_role') }}</th>
                    <th>{{ t('settings.user_active') }}</th>
                    <th>{{ t('settings.user_last_login') }}</th>
                    <th style="text-align:right;">{{ t('common.actions') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr>
                    <td>
                        <div class="flex items-center gap-3">
                            <div class="avatar-placeholder" style="width:32px;height:32px;font-size:0.75rem;">{{ user.name|initials }}</div>
                            <div class="font-semibold">{{ user.name }}</div>
                        </div>
                    </td>
                    <td>{{ user.email }}</td>
                    <td><span class="badge {{ user.role == 'admin' ? 'badge-admin' : 'badge-primary' }}">{{ user.role == 'admin' ? t('common.role_admin') : t('common.role_mita') }}</span></td>
                    <td>
                        {% if user.active %}<span class="badge badge-aktiv">Aktiv</span>
                        {% else %}<span class="badge badge-inaktiv">Inaktiv</span>{% endif %}
                    </td>
                    <td class="text-sm text-muted">{{ user.last_login ? user.last_login|datetime_de : '—' }}</td>
                    <td>
                        <div class="flex gap-2" style="justify-content:flex-end;">
                            <button type="button" class="btn btn-secondary btn-sm" data-modal-open="modal-edit-user-{{ user.id }}">
                                <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                {{ t('common.edit') }}
                            </button>
                            {% if user.id != current_user.id %}
                            <form action="/einstellungen/benutzer/{{ user.id }}/loeschen" method="POST" style="margin:0;">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn-danger btn-sm" data-confirm="{{ t('common.confirm_delete') }}">
                                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                                    {{ t('common.delete') }}
                                </button>
                            </form>
                            {% else %}
                            <span class="text-xs text-muted">(Du)</span>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# ════════════════════════════════════════════════════
   TAB: PLUGINS
════════════════════════════════════════════════════ #}
<div class="settings-tab-content" id="tab-plugins">
    {% if plugins %}
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>{{ t('settings.plugin_name') }}</th>
                        <th>{{ t('settings.plugin_version') }}</th>
                        <th>{{ t('settings.plugin_author') }}</th>
                        <th>Status</th>
                        <th style="text-align:right;">{{ t('common.actions') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for slug, plugin in plugins %}
                    <tr>
                        <td>
                            <div class="font-semibold">{{ plugin.manifest.name }}</div>
                            {% if plugin.manifest.description %}<div class="text-xs text-muted">{{ plugin.manifest.description }}</div>{% endif %}
                        </td>
                        <td><span class="badge badge-primary">v{{ plugin.manifest.version ?? '1.0.0' }}</span></td>
                        <td class="text-sm text-muted">{{ plugin.manifest.author ?? '—' }}</td>
                        <td>{% if plugin.enabled %}<span class="badge badge-aktiv">Aktiv</span>{% else %}<span class="badge badge-inaktiv">Inaktiv</span>{% endif %}</td>
                        <td>
                            <div class="flex gap-2" style="justify-content:flex-end;">
                                {% if plugin.enabled %}
                                    <form action="/einstellungen/plugins/{{ slug }}/deaktivieren" method="POST" style="margin:0;">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                        <button type="submit" class="btn btn-warning btn-sm">{{ t('settings.plugin_deactivate') }}</button>
                                    </form>
                                {% else %}
                                    <form action="/einstellungen/plugins/{{ slug }}/aktivieren" method="POST" style="margin:0;">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                        <button type="submit" class="btn btn-success btn-sm">{{ t('settings.plugin_activate') }}</button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="empty-state">
            <div class="empty-state-icon"><svg width="28" height="28" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
            <div class="empty-state-title">Keine Plugins installiert</div>
            <div class="empty-state-text">Plugin-Ordner unter <code>/plugins/</code> ablegen.</div>
        </div>
    {% endif %}
    <div class="glass-card mt-4">
        <h3 class="font-semibold mb-2" style="font-size:0.9rem;">Plugin-Entwicklung</h3>
        <p class="text-sm text-muted" style="line-height:1.6;">
            Plugins werden als Unterordner in <code style="color:var(--accent);">/plugins/[slug]/</code> abgelegt.<br>
            Jedes Plugin benötigt eine <code style="color:var(--accent);">manifest.json</code> sowie eine optionale <code style="color:var(--accent);">ServiceProvider.php</code>.
        </p>
    </div>

    {# ── Kalender Plugin: Cron-Konfiguration ── #}
    {% if plugins['calendar'] is defined and plugins['calendar'].enabled %}
    <div class="glass-card mt-4">
        <h3 class="section-title" style="display:flex;align-items:center;gap:0.5rem;">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/></svg>
            Terminkalender – Erinnerungen (Cron)
        </h3>
        <p class="text-sm text-muted mb-3" style="line-height:1.6;">
            Automatische E-Mail-Erinnerungen werden über einen Cron-Job getriggert.<br>
            Trage das Secret unten ein und richte dann den Cron-Job auf deinem Server ein.
        </p>
        <form action="/einstellungen" method="POST">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="flex gap-3 items-end" style="flex-wrap:wrap;">
                <div class="form-group" style="flex:1;min-width:240px;margin:0;">
                    <label class="form-label">Cron-Secret (Token)</label>
                    <div class="flex gap-2">
                        <input type="text" name="calendar_cron_secret" class="form-control"
                               value="{{ settings.calendar_cron_secret ?? '' }}"
                               placeholder="Zufälliges Secret eingeben..."
                               style="font-family:monospace;font-size:0.82rem;">
                        <button type="button" class="btn btn-secondary btn-sm" onclick="
                            const chars='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
                            let r='';
                            for(let i=0;i<40;i++) r+=chars[Math.floor(Math.random()*chars.length)];
                            this.closest('.flex').querySelector('input').value=r;
                        " title="Zufälliges Secret generieren">
                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="23 4 23 10 17 10"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="1 20 1 14 7 14"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                        </button>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary btn-sm" style="margin-bottom:1px;">Speichern</button>
            </div>
        </form>

        {# Standalone upload forms — outside main form to avoid nesting #}
        <form id="form-upload-rechnung" action="/einstellungen/pdf-rechnung-bild" method="POST" enctype="multipart/form-data" style="display:none;">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        </form>
        <form id="form-upload-vielen-dank" action="/einstellungen/pdf-vielen-dank-bild" method="POST" enctype="multipart/form-data" style="display:none;">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        </form>

        {% if settings.calendar_cron_secret ?? '' %}
        <div class="mt-4">
            <label class="form-label">Cron-Job Befehl (alle 15 Minuten)</label>
            <div class="flex gap-2 items-center">
                <code id="cron-cmd" style="display:block;background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:var(--radius-sm);padding:0.6rem 0.75rem;font-size:0.78rem;flex:1;overflow-x:auto;white-space:nowrap;">
                    */15 * * * * curl -s "{{ app_url ?? '' }}/kalender/cron/erinnerungen?token={{ settings.calendar_cron_secret }}" > /dev/null 2>&1
                </code>
                <button class="btn btn-secondary btn-sm" onclick="navigator.clipboard.writeText(document.getElementById('cron-cmd').textContent.trim()).then(()=>this.textContent='✓ Kopiert').catch(()=>{}); setTimeout(()=>this.textContent='Kopieren',2000);">Kopieren</button>
            </div>
            <p class="text-xs text-muted mt-2">
                Auf dem Server unter <code>crontab -e</code> eintragen. Der Endpunkt prüft ob Erinnerungen fällig sind und sendet E-Mails automatisch.
            </p>
        </div>
        {% endif %}
    </div>
    {% endif %}
</div>

{# ════════════════════════════════════════════════════
   TAB: BEHANDLUNGSARTEN
════════════════════════════════════════════════════ #}
<div class="settings-tab-content" id="tab-behandlungsarten">

    {# Neue Behandlungsart #}
    <div class="glass-card mb-4">
        <h3 class="section-title">Neue Behandlungsart</h3>
        <form action="/einstellungen/behandlungsarten" method="POST">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="form-grid-2 mb-3">
                <div class="form-group">
                    <label class="form-label">Name *</label>
                    <input type="text" name="name" class="form-control" required placeholder="z.B. Physiotherapie">
                </div>
                <div class="form-group">
                    <label class="form-label">Farbe</label>
                    <div class="flex gap-2 items-center">
                        <input type="color" name="color" value="#4f7cff" class="form-control" style="width:56px;height:40px;padding:0.2rem;cursor:pointer;">
                        <span style="font-size:0.8rem;color:var(--text-muted);">Badge-Farbe</span>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Standardpreis (€)</label>
                    <input type="number" name="price" class="form-control" step="0.01" min="0" placeholder="0.00">
                </div>
                <div class="form-group">
                    <label class="form-label">Reihenfolge</label>
                    <input type="number" name="sort_order" class="form-control" value="0" min="0">
                </div>
            </div>
            <div class="form-group mb-3">
                <label class="form-label">Beschreibung</label>
                <textarea name="description" class="form-control" rows="2" placeholder="Optionale Beschreibung..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                Behandlungsart hinzufügen
            </button>
        </form>
    </div>

    {# Liste der Behandlungsarten #}
    <div class="glass-card">
        <h3 class="section-title">Vorhandene Behandlungsarten</h3>
        {% if treatment_types is empty %}
            <p style="color:var(--text-muted);font-size:0.875rem;">Noch keine Behandlungsarten vorhanden. Migration ausführen falls nötig.</p>
        {% else %}
            <div style="display:flex;flex-direction:column;gap:0.75rem;">
                {% for tt in treatment_types %}
                <div class="glass-card" style="padding:1rem;background:var(--glass-bg);">
                    <div class="flex gap-3 items-start" style="flex-wrap:wrap;">
                        {# Farbvorschau + Badge #}
                        <div style="flex-shrink:0;margin-top:0.2rem;">
                            <span style="display:inline-block;padding:0.25rem 0.75rem;border-radius:999px;background:{{ tt.color }}22;color:{{ tt.color }};font-size:0.75rem;font-weight:600;border:1px solid {{ tt.color }}44;">
                                {{ tt.name }}
                            </span>
                        </div>
                        {# Infos #}
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:0.75rem;color:var(--text-muted);">
                                {% if tt.price %}Preis: {{ tt.price|number_format(2, ',', '.') }} €{% else %}Kein Standardpreis{% endif %}
                                &nbsp;·&nbsp;
                                {% if tt.active %}
                                    <span style="color:var(--success);">Aktiv</span>
                                {% else %}
                                    <span style="color:var(--text-muted);">Inaktiv</span>
                                {% endif %}
                                &nbsp;·&nbsp; Reihenfolge: {{ tt.sort_order }}
                            </div>
                            {% if tt.description %}
                                <div style="font-size:0.78rem;color:var(--text-secondary);margin-top:0.2rem;">{{ tt.description }}</div>
                            {% endif %}
                        </div>
                        {# Aktionen #}
                        <div class="flex gap-2" style="flex-shrink:0;">
                            <button class="btn btn-secondary btn-sm" onclick="openEditTT({{ tt|json_encode|e('html_attr') }})">
                                <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                Bearbeiten
                            </button>
                            <form action="/einstellungen/behandlungsarten/{{ tt.id }}/loeschen" method="POST" style="margin:0;" onsubmit="return confirm('Behandlungsart wirklich löschen?');">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn-sm" style="background:var(--danger-glow);color:var(--danger);border:1px solid var(--danger);">
                                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10 11v6M14 11v6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                    Löschen
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

{# Edit Modal für Behandlungsart #}
<div class="tp-overlay" hidden id="modal-edit-tt" onclick="if(event.target===this)this.classList.remove('open')">
    <div class="tp-modal">
        <div class="modal-header">
            <h2 class="modal-title">Behandlungsart bearbeiten</h2>
            <button class="modal-close" onclick="document.getElementById('modal-edit-tt').classList.remove('open')" type="button"><svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></button>
        </div>
        <div class="modal-body">
            <form id="form-edit-tt" action="" method="POST">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <div class="form-grid-2 mb-3">
                    <div class="form-group">
                        <label class="form-label">Name *</label>
                        <input type="text" id="ett-name" name="name" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Farbe</label>
                        <input type="color" id="ett-color" name="color" class="form-control" style="height:40px;padding:0.2rem;cursor:pointer;">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Standardpreis (€)</label>
                        <input type="number" id="ett-price" name="price" class="form-control" step="0.01" min="0">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Reihenfolge</label>
                        <input type="number" id="ett-sort" name="sort_order" class="form-control" min="0">
                    </div>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">Beschreibung</label>
                    <textarea id="ett-desc" name="description" class="form-control" rows="2"></textarea>
                </div>
                <div class="form-group mb-3">
                    <label class="flex items-center gap-2" style="cursor:pointer;font-size:0.875rem;">
                        <input type="checkbox" id="ett-active" name="active" value="1" style="width:16px;height:16px;">
                        Aktiv (im Dropdown sichtbar)
                    </label>
                </div>
                <div class="flex gap-2 justify-end">
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('modal-edit-tt').classList.remove('open')">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Speichern</button>
                </div>
            </form>
        </div>
    </div>
</div>

{# ════════════════════════════════════════════════════
   TAB: UPDATES
════════════════════════════════════════════════════ #}
<div class="settings-tab-content" id="tab-updates">
    <div class="flex gap-4" style="align-items:flex-start;flex-wrap:wrap;">
        <div class="glass-card" style="flex:1;min-width:280px;">
            <h3 class="section-title">Datenbankversionen</h3>
            <div style="display:flex;flex-direction:column;gap:0.75rem;">
                <div class="flex justify-between items-center">
                    <span class="text-sm text-muted">{{ t('settings.current_version') }}</span>
                    <span class="badge badge-primary">v{{ current_version }}</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-sm text-muted">{{ t('settings.latest_version') }}</span>
                    <span class="badge {{ latest_version > current_version ? 'badge-warning' : 'badge-aktiv' }}">v{{ latest_version }}</span>
                </div>
            </div>
            {% if not up_to_date %}
                <div class="alert alert-warning mt-4">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    <span>{{ pending|length }} ausstehende Migration(en).</span>
                </div>
                <form action="/einstellungen/migrationen" method="POST" class="mt-3">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                    <button type="submit" class="btn btn-warning" style="width:100%;" data-confirm="Migrationen wirklich ausführen? Erstellen Sie vorher ein Datenbankbackup.">
                        {{ t('settings.run_migrations') }}
                    </button>
                </form>
            {% else %}
                <div class="alert alert-success mt-4">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20 6 9 17l-5-5"/></svg>
                    <span>{{ t('settings.up_to_date') }}</span>
                </div>
            {% endif %}
        </div>
        <div class="glass-card" style="flex:1;min-width:280px;">
            <h3 class="section-title">Systeminfo</h3>
            <div style="display:flex;flex-direction:column;gap:0.625rem;">
                <div class="flex justify-between text-sm"><span class="text-muted">PHP Version</span><span class="font-medium">{{ php_version }}</span></div>
                <div class="flex justify-between text-sm"><span class="text-muted">App Version</span><span class="font-medium">{{ app_version }}</span></div>
                <div class="flex justify-between text-sm"><span class="text-muted">Umgebung</span><span class="badge {{ app_env == 'production' ? 'badge-aktiv' : 'badge-warning' }}">{{ app_env }}</span></div>
                <div class="flex justify-between text-sm"><span class="text-muted">DB-Version</span><span class="font-medium">v{{ current_version }}</span></div>
            </div>
        </div>
    </div>
</div>

{# ════════════════════════════════════════════════════
   MODALS: Benutzer anlegen / bearbeiten
