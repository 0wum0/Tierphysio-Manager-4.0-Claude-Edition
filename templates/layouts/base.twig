<!DOCTYPE html>
<html lang="{{ current_locale }}" data-theme="{{ theme }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token }}">
    <title>{% block title %}{{ page_title ?? app_name }}{% endblock %} — {{ app_name }}</title>
    {# Theme FOUC prevention — MUST be before any stylesheet, runs synchronously #}
    <script>!function(){try{var t=localStorage.getItem('theme');document.documentElement.setAttribute('data-theme',t==='light'?'light':'dark');}catch(e){}}();</script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400;1,500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/app.css">
    <link rel="stylesheet" href="/assets/css/liquid-glass.css">
    {% if active_theme_css is defined and active_theme_css %}
    <link rel="stylesheet" href="{{ active_theme_css }}?v={{ 'now'|date('YmdHi') }}">
    {% endif %}
    {% block head %}{% endblock %}
</head>
<body>

<div class="app-grid-overlay"></div>
<div class="app-layout">

    {# Mobile overlay - visibility controlled by CSS .open class; click handled by Sidebar.init() #}
    <div id="sidebar-overlay"></div>

    {# Sidebar #}
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-logo">
                <div class="sidebar-brand-icon">
                    <svg width="20" height="20" viewBox="0 0 100 100" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <ellipse cx="20" cy="28" rx="8" ry="11" transform="rotate(-15 20 28)"/>
                        <ellipse cx="40" cy="18" rx="7" ry="10" transform="rotate(-5 40 18)"/>
                        <ellipse cx="60" cy="18" rx="7" ry="10" transform="rotate(5 60 18)"/>
                        <ellipse cx="80" cy="28" rx="8" ry="11" transform="rotate(15 80 28)"/>
                        <path d="M50 42 C30 42 18 55 20 68 C22 80 34 88 50 88 C66 88 78 80 80 68 C82 55 70 42 50 42 Z"/>
                    </svg>
                </div>
                <div class="sidebar-brand-text">
                    <div class="sidebar-brand-name">{{ app_name }}</div>
                    <div class="sidebar-brand-version">v{{ app_version }}</div>
                </div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <a href="{{ base_path }}/dashboard" class="nav-item {{ is_active('/dashboard') }}">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
                    <rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                    <rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                    <rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                    <rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                </svg>
                {{ t('nav.dashboard') }}
            </a>

            <div class="sidebar-nav-section">{{ t('common.entries') }}</div>

            <a href="{{ base_path }}/patienten" class="nav-item {{ is_active('/patienten') }}">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
                    <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                          d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
                {{ t('nav.patients') }}
            </a>

            <a href="{{ base_path }}/tierhalter" class="nav-item {{ is_active('/tierhalter') }}">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
                    <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                          d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/>
                    <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                          d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                {{ t('nav.owners') }}
            </a>

            <a href="{{ base_path }}/rechnungen" class="nav-item {{ is_active('/rechnungen') }}">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
                    <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                          d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                              points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <line x1="16" y1="17" x2="8" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="10 9 9 9 8 9"/>
                </svg>
                {{ t('nav.invoices') }}
            </a>

            {% for item in plugin_nav_items ?? [] %}
            {% if not (item.admin_only is defined and item.admin_only) or (current_user and current_user.role == 'admin') %}
            <a href="{{ item.href }}" class="nav-item {{ is_active(item.href) }}">
                {% if item.icon is defined %}{{ item.icon|raw }}{% endif %}
                {{ item.label }}
            </a>
            {% endif %}
            {% endfor %}

            {% if current_user and current_user.role == 'admin' %}
            <div class="sidebar-nav-section">{{ t('nav.admin') }}</div>
            <a href="{{ base_path }}/einstellungen" class="nav-item {{ is_active('/einstellungen') }}">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
                    <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                          d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
                {{ t('nav.settings') }}
            </a>
            {% endif %}
        </nav>

        <div class="sidebar-footer">
            <a href="{{ base_path }}/profil" class="sidebar-user">
                <div class="user-avatar">{{ current_user.name|initials }}</div>
                <div class="user-info">
                    <div class="user-name">{{ current_user.name }}</div>
                    <div class="user-role">{{ current_user.role == 'admin' ? t('common.role_admin') : t('common.role_mita') }}</div>
                </div>
            </a>
        </div>
    </aside>

    {# Main content #}
    <div class="main-content">
        <header class="top-header">
            <button class="header-btn" id="sidebar-toggle" style="display:none;" aria-label="Menü">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
                    <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <line x1="3" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <line x1="3" y1="18" x2="21" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </button>

            <div class="header-title">{% block header_title %}{{ page_title ?? app_name }}{% endblock %}</div>

            <div class="header-actions">

                {# ── Notification Bell (patient-intake plugin) ── #}
                {% if intake_unread_count is defined %}
                <div class="dropdown" id="notif-dropdown-wrap">
                    <button class="header-btn notif-bell-btn" data-dropdown="notif-menu" aria-label="Benachrichtigungen"
                            style="position:relative;">
                        <svg width="17" height="17" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                  d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                            <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                  d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        <span class="notif-badge" id="notif-badge"
                              style="display:{% if intake_unread_count > 0 %}flex{% else %}none{% endif %};">
                            {{ intake_unread_count > 9 ? '9+' : intake_unread_count }}
                        </span>
                    </button>
                    <div class="dropdown-menu notif-menu" id="notif-menu" style="width:320px;right:0;left:auto;">
                        <div style="padding:0.75rem 1rem 0.5rem;border-bottom:1px solid var(--glass-border);display:flex;align-items:center;justify-content:space-between;">
                            <span style="font-size:0.82rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-muted);">Neue Anmeldungen</span>
                            {% if intake_unread_count > 0 %}
                            <span style="background:rgba(239,68,68,0.15);color:#ef4444;border:1px solid rgba(239,68,68,0.3);border-radius:100px;padding:0.1rem 0.5rem;font-size:0.72rem;font-weight:700;">{{ intake_unread_count }}</span>
                            {% endif %}
                        </div>
                        <div id="notif-list">
                        {% if intake_latest is defined and intake_latest|length > 0 %}
                            {% for item in intake_latest %}
                            <a href="{{ base_path }}/eingangsmeldungen/{{ item.id }}" class="dropdown-item" style="flex-direction:column;align-items:flex-start;gap:0.15rem;padding:0.65rem 1rem;">
                                <div style="display:flex;align-items:center;gap:0.5rem;width:100%;">
                                    <span style="width:7px;height:7px;border-radius:50%;background:#ef4444;flex-shrink:0;animation:notif-pulse 2s infinite;"></span>
                                    <strong style="font-size:0.85rem;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">🐾 {{ item.patient_name }}</strong>
                                    <span style="font-size:0.72rem;color:var(--text-muted);flex-shrink:0;">{{ item.created_at|datetime_de }}</span>
                                </div>
                                <span style="font-size:0.78rem;color:var(--text-muted);padding-left:1.1rem;">{{ item.owner_first_name }} {{ item.owner_last_name }} · hat eine Terminanfrage</span>
                            </a>
                            {% endfor %}
                        {% else %}
                            <div style="padding:1.25rem 1rem;text-align:center;font-size:0.85rem;color:var(--text-muted);">
                                Keine neuen Anmeldungen 🎉
                            </div>
                        {% endif %}
                        </div>
                        <div style="padding:0.5rem 0.75rem;border-top:1px solid var(--glass-border);">
                            <a href="{{ base_path }}/eingangsmeldungen" class="dropdown-item" style="justify-content:center;color:var(--accent);font-size:0.82rem;font-weight:600;">
                                Alle Eingangsmeldungen →
                            </a>
                        </div>
                    </div>
                </div>
                {% endif %}

                <button class="header-btn" id="theme-toggle" title="Design wechseln" aria-label="Design wechseln">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24">
                        <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                              d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"/>
                    </svg>
                </button>

                <div class="dropdown">
                    <button class="header-btn" data-dropdown="user-menu" aria-label="Benutzermenü">
                        <div class="user-avatar" style="width:28px;height:28px;font-size:0.7rem;">{{ current_user.name|initials }}</div>
                    </button>
                    <div class="dropdown-menu" id="user-menu">
                        <a href="{{ base_path }}/profil" class="dropdown-item">
                            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                            {{ t('nav.profile') }}
                        </a>
                        <div class="dropdown-divider"></div>
                        <form action="{{ base_path }}/logout" method="POST" style="margin:0;">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                            <button type="submit" class="dropdown-item danger">
                                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
                                {{ t('nav.logout') }}
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </header>

        <main class="page-content">
            {# Flash messages #}
            {% if flash.success is defined %}
                <div class="alert alert-success" data-auto-dismiss="5000">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" style="flex-shrink:0"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20 6 9 17l-5-5"/></svg>
                    <span>{{ flash.success }}</span>
                </div>
            {% endif %}
            {% if flash.error is defined %}
                <div class="alert alert-error" data-auto-dismiss="8000">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" style="flex-shrink:0"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    <span>{{ flash.error }}</span>
                </div>
            {% endif %}
            {% if flash.info is defined %}
                <div class="alert alert-info" data-auto-dismiss="5000">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" style="flex-shrink:0"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="16" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="8" x2="12.01" y2="8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    <span>{{ flash.info }}</span>
                </div>
            {% endif %}

            {% block content %}{% endblock %}
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script src="/assets/js/app.js?v={{ 'now'|date('YmdHi') }}"></script>

{% block scripts %}{% endblock %}

{% if intake_unread_count is defined %}
<style>
/* Notification Bell */
.notif-bell-btn { position: relative; }
.notif-badge {
    position: absolute;
    top: 2px; right: 2px;
    min-width: 17px; height: 17px;
    background: #ef4444;
    color: #fff;
    font-size: 0.6rem;
    font-weight: 800;
    border-radius: 100px;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    border: 2px solid var(--bg-primary, #0f0f1a);
    line-height: 1;
    pointer-events: none;
    animation: badge-pop 0.4s cubic-bezier(.34,1.56,.64,1);
}
@keyframes badge-pop { from { transform: scale(0); } to { transform: scale(1); } }
@keyframes notif-pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(1.3)} }
.notif-menu { max-height: 400px; overflow-y: auto; }
.notif-bell-btn.has-new svg { animation: bell-ring 0.6s ease 0.2s both; }
@keyframes bell-ring {
    0%  { transform: rotate(0); }
    20% { transform: rotate(15deg); }
    40% { transform: rotate(-12deg); }
    60% { transform: rotate(8deg); }
    80% { transform: rotate(-5deg); }
    100%{ transform: rotate(0); }
}
</style>

<script>
/* ── Notification Polling (every 30s) ── */
(function () {
    const badge    = document.getElementById('notif-badge');
    const bellBtn  = document.querySelector('.notif-bell-btn');
    const listEl   = document.getElementById('notif-list');
    if (!badge || !bellBtn) return;

    let lastCount = parseInt(badge.textContent) || 0;

    function formatDe(str) {
        if (!str) return '';
        const d = new Date(str.replace(' ', 'T'));
        if (isNaN(d)) return str;
        return d.toLocaleDateString('de-DE', {day:'2-digit',month:'2-digit',year:'numeric'})
             + ' ' + d.toLocaleTimeString('de-DE', {hour:'2-digit',minute:'2-digit'});
    }

    function poll() {
        fetch('{{ base_path }}/api/intake/notifications', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            const count = data.count || 0;

            /* Update badge */
            if (count > 0) {
                badge.textContent = count > 9 ? '9+' : count;
                badge.style.display = 'flex';
                bellBtn.classList.add('has-new');
            } else {
                badge.style.display = 'none';
                bellBtn.classList.remove('has-new');
            }

            /* Ring bell animation if new items arrived since last poll */
            if (count > lastCount && lastCount >= 0) {
                bellBtn.querySelector('svg').style.animation = 'none';
                /* force reflow */
                void bellBtn.querySelector('svg').offsetWidth;
                bellBtn.querySelector('svg').style.animation = '';
            }
            lastCount = count;

            /* Update dropdown list */
            if (listEl) {
                if (data.items && data.items.length > 0) {
                    listEl.innerHTML = data.items.map(function (item) {
                        return '<a href="{{ base_path }}/eingangsmeldungen/' + item.id + '" class="dropdown-item" style="flex-direction:column;align-items:flex-start;gap:0.15rem;padding:0.65rem 1rem;">'
                            + '<div style="display:flex;align-items:center;gap:0.5rem;width:100%;">'
                            + '<span style="width:7px;height:7px;border-radius:50%;background:#ef4444;flex-shrink:0;animation:notif-pulse 2s infinite;"></span>'
                            + '<strong style="font-size:0.85rem;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">🐾 ' + (item.patient_name || '') + '</strong>'
                            + '<span style="font-size:0.72rem;color:var(--text-muted);flex-shrink:0;">' + formatDe(item.created_at) + '</span>'
                            + '</div>'
                            + '<span style="font-size:0.78rem;color:var(--text-muted);padding-left:1.1rem;">' + (item.owner_first_name || '') + ' ' + (item.owner_last_name || '') + ' · hat eine Terminanfrage</span>'
                            + '</a>';
                    }).join('');
                } else {
                    listEl.innerHTML = '<div style="padding:1.25rem 1rem;text-align:center;font-size:0.85rem;color:var(--text-muted);">Keine neuen Anmeldungen 🎉</div>';
                }
            }
        })
        .catch(function () { /* silently ignore network errors */ });
    }

    /* Poll every 30 seconds */
    setInterval(poll, 30000);

    /* Ring bell once on page load if there are new notifications */
    if (lastCount > 0) {
        setTimeout(function () {
            bellBtn.classList.add('has-new');
        }, 800);
    }
})();
</script>
{% endif %}

<script>
// Show sidebar toggle on mobile - NEVER show overlay here, that's Sidebar.open()'s job
function updateSidebarToggle() {
    const t = document.getElementById('sidebar-toggle');
    if (!t) return;
    t.style.display = window.innerWidth <= 768 ? 'flex' : 'none';
}
updateSidebarToggle();
window.addEventListener('resize', updateSidebarToggle);

/* ── Apple-style Pulse + Ripple ── */
(function() {
    const BTN_SEL  = '.btn, .lg-btn, .cal-nav-btn, .cal-view-btn, .header-btn, .modal-close, .dropdown-item';
    const NAV_SEL  = '.nav-item';
    const ALL_SEL  = BTN_SEL + ', ' + NAV_SEL;

    function triggerPulse(el) {
        const cls = el.matches(NAV_SEL) ? 'lg-pulsing-sm' : 'lg-pulsing';
        el.classList.remove('lg-pulsing', 'lg-pulsing-sm');
        /* force reflow so animation restarts if clicked again quickly */
        void el.offsetWidth;
        el.classList.add(cls);
        el.addEventListener('animationend', () => el.classList.remove(cls), { once: true });
    }

    function spawnRipple(el, e) {
        if (!el.matches(BTN_SEL)) return;
        const rect = el.getBoundingClientRect();
        const x    = e.clientX - rect.left;
        const y    = e.clientY - rect.top;
        const wave = document.createElement('span');
        wave.className = 'lg-ripple-wave';
        wave.style.left = x + 'px';
        wave.style.top  = y + 'px';
        el.appendChild(wave);
        wave.addEventListener('animationend', () => wave.remove(), { once: true });
    }

    document.addEventListener('pointerdown', function(e) {
        const el = e.target.closest(ALL_SEL);
        if (!el || el.disabled || el.hasAttribute('data-no-ripple')) return;
        triggerPulse(el);
        spawnRipple(el, e);
    }, { passive: true });
})();
</script>
</body>
</html>
