{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}

{# ── INVOICE DETAIL MODALS ─────────────────────────────────────────── #}
{% for invoice in invoices %}
<div class="modal fade" id="modal-invoice-{{ invoice.id }}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header" style="flex-shrink:0;">
            <div class="flex items-center gap-3">
                <span class="font-bold" style="font-size:1rem;">{{ invoice.invoice_number }}</span>
                <span class="badge badge-{{ invoice.status }}">{{ t('invoices.status_' ~ invoice.status) }}</span>
            </div>
            <button class="modal-close" data-bs-dismiss="modal" type="button">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
        </div>
        <div class="modal-body" style="overflow-y:auto;flex:1;">
            <div class="flex gap-4" style="flex-wrap:wrap;align-items:flex-start;">

                {# Left: meta + positions #}
                <div style="flex:1;min-width:260px;display:flex;flex-direction:column;gap:1rem;">

                    <div class="form-grid form-grid-2" style="gap:0.75rem;">
                        <div>
                            <div class="text-xs text-muted mb-1">{{ t('invoices.issue_date') }}</div>
                            <div class="font-semibold text-sm">{{ invoice.issue_date|date_de }}</div>
                        </div>
                        <div>
                            <div class="text-xs text-muted mb-1">{{ t('invoices.due_date') }}</div>
                            <div class="font-semibold text-sm {{ invoice.status == 'overdue' ? 'text-danger' : '' }}">{{ invoice.due_date ? invoice.due_date|date_de : '—' }}</div>
                        </div>
                        <div>
                            <div class="text-xs text-muted mb-1">{{ t('invoices.owner') }}</div>
                            <div class="font-semibold text-sm">{{ invoice.owner_name ?? '—' }}</div>
                        </div>
                        <div>
                            <div class="text-xs text-muted mb-1">{{ t('invoices.patient') }}</div>
                            <div class="font-semibold text-sm">{{ invoice.patient_name ?? '—' }}</div>
                        </div>
                    </div>

                    {# Positions laden wir per AJAX #}
                    <div id="positions-{{ invoice.id }}" data-invoice-id="{{ invoice.id }}">
                        <div style="text-align:center;padding:1rem;color:var(--text-muted);font-size:0.85rem;">Lade Positionen…</div>
                    </div>

                    <div class="flex justify-between items-center" style="border-top:1px solid var(--glass-border);padding-top:0.75rem;">
                        <span class="text-xs text-muted">Gesamt (brutto)</span>
                        <span class="font-bold" style="font-size:1.1rem;color:var(--accent);">{{ invoice.total_gross|money }}</span>
                    </div>

                    {# Status ändern #}
                    <form action="/rechnungen/{{ invoice.id }}/status" method="POST" class="flex gap-2 items-center">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                        <select name="status" class="form-control" style="flex:1;font-size:0.85rem;">
                            <option value="draft"   {{ invoice.status == 'draft'   ? 'selected' : '' }}>{{ t('invoices.status_draft') }}</option>
                            <option value="open"    {{ invoice.status == 'open'    ? 'selected' : '' }}>{{ t('invoices.status_open') }}</option>
                            <option value="paid"    {{ invoice.status == 'paid'    ? 'selected' : '' }}>{{ t('invoices.status_paid') }}</option>
                            <option value="overdue" {{ invoice.status == 'overdue' ? 'selected' : '' }}>{{ t('invoices.status_overdue') }}</option>
                        </select>
                        <button type="submit" class="btn btn-primary btn-sm" style="flex-shrink:0;">Status speichern</button>
                    </form>

                    <div class="flex gap-2" style="flex-wrap:wrap;">
                        <a href="/rechnungen/{{ invoice.id }}" class="btn btn-secondary btn-sm">
                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            Bearbeiten
                        </a>
                        <button class="btn btn-secondary btn-sm" onclick="openPdfPreview('/rechnungen/{{ invoice.id }}/pdf', '{{ invoice.invoice_number }}.pdf')">
                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="1.5" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
                            PDF Vorschau
                        </button>
                        <a href="/rechnungen/{{ invoice.id }}/pdf" class="btn btn-secondary btn-sm" download>
                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            Download
                        </a>
                        <form action="/rechnungen/{{ invoice.id }}/loeschen" method="POST" style="margin:0;">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-danger btn-sm" data-confirm="{{ t('common.confirm_delete') }}">
                                <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                                Löschen
                            </button>
                        </form>
                    </div>
                </div>

                {# Right: PDF preview iframe #}
                <div style="flex:1;min-width:280px;height:420px;background:#111;border-radius:8px;overflow:hidden;border:1px solid var(--glass-border);" id="pdf-frame-wrap-{{ invoice.id }}">
                    <div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--text-muted);font-size:0.85rem;flex-direction:column;gap:0.5rem;" id="pdf-placeholder-{{ invoice.id }}">
                        <svg width="32" height="32" fill="none" viewBox="0 0 24 24" style="opacity:0.3;"><path stroke="currentColor" stroke-width="1.5" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="1.5" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
                        <span>PDF-Vorschau wird geladen…</span>
                    </div>
                </div>

            </div>
        </div>
    </div></div>
</div>
{% endfor %}
<div class="page-header">
    <div>
        <h1 class="page-title">{{ t('invoices.title') }}</h1>
        <p class="page-subtitle">{{ pagination.total }} {{ t('common.entries') }}</p>
    </div>
    <a href="/rechnungen/erstellen" class="btn btn-primary">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        {{ t('invoices.new_invoice') }}
    </a>
</div>

{# Stats #}
<div class="stats-grid">
    <div class="stat-card" style="--stat-color:#4f7cff;">
        <div class="stat-card-header"><span class="stat-card-label">{{ t('invoices.revenue_week') }}</span></div>
        <div class="stat-card-value">{{ stats.revenue_week|money }}</div>
    </div>
    <div class="stat-card" style="--stat-color:#a855f7;">
        <div class="stat-card-header"><span class="stat-card-label">{{ t('invoices.revenue_month') }}</span></div>
        <div class="stat-card-value">{{ stats.revenue_month|money }}</div>
        <div class="stat-card-meta">
            {% if stats.month_change > 0 %}<span class="trend-up">▲ {{ stats.month_change }}%</span>
            {% elseif stats.month_change < 0 %}<span class="trend-down">▼ {{ stats.month_change|abs }}%</span>
            {% else %}<span class="trend-flat">—</span>{% endif %}
            <span>{{ t('dashboard.vs_last_month') }}</span>
        </div>
    </div>
    <div class="stat-card" style="--stat-color:#06b6d4;">
        <div class="stat-card-header"><span class="stat-card-label">{{ t('invoices.revenue_year') }}</span></div>
        <div class="stat-card-value">{{ stats.revenue_year|money }}</div>
    </div>
    <div class="stat-card" style="--stat-color:#22c55e;">
        <div class="stat-card-header"><span class="stat-card-label">{{ t('invoices.revenue_total') }}</span></div>
        <div class="stat-card-value">{{ stats.revenue_total|money }}</div>
    </div>
    <div class="stat-card" style="--stat-color:#06b6d4;">
        <div class="stat-card-header"><span class="stat-card-label">{{ t('dashboard.open_invoices') }}</span></div>
        <div class="stat-card-value">{{ stats.open_count }}</div>
    </div>
    <div class="stat-card" style="--stat-color:#ef4444;">
        <div class="stat-card-header"><span class="stat-card-label">{{ t('dashboard.overdue_invoices') }}</span></div>
        <div class="stat-card-value">{{ stats.overdue_count }}</div>
    </div>
</div>

{# Filter #}
<form method="GET" action="/rechnungen">
    <div class="glass-card" style="padding:1rem;">
        <div class="search-bar">
            <div class="search-input-wrapper" style="flex:1;">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/><line x1="21" y1="21" x2="16.65" y2="16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                <input type="text" name="search" class="form-control" placeholder="Suche nach Rechnungsnummer, Tierhalter..." value="{{ search }}">
            </div>
            <select name="status" class="form-control" style="flex:none;min-width:140px;" data-cs-width="160px">
                <option value="">{{ t('invoices.all_status') }}</option>
                <option value="draft"   {{ status == 'draft'   ? 'selected' : '' }}>{{ t('invoices.status_draft') }}</option>
                <option value="open"    {{ status == 'open'    ? 'selected' : '' }}>{{ t('invoices.status_open') }}</option>
                <option value="paid"    {{ status == 'paid'    ? 'selected' : '' }}>{{ t('invoices.status_paid') }}</option>
                <option value="overdue" {{ status == 'overdue' ? 'selected' : '' }}>{{ t('invoices.status_overdue') }}</option>
            </select>
            <button type="submit" class="btn btn-secondary">{{ t('common.filter') }}</button>
            {% if search or status %}<a href="/rechnungen" class="btn btn-secondary">{{ t('common.reset') }}</a>{% endif %}
        </div>
    </div>
</form>

{% if invoices %}
<div class="mob-hide-table">

    {# ── Desktop: Tabelle ── #}
    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>{{ t('invoices.invoice_number') }}</th>
                    <th>{{ t('invoices.owner') }}</th>
                    <th>{{ t('invoices.patient') }}</th>
                    <th>{{ t('invoices.issue_date') }}</th>
                    <th>{{ t('invoices.due_date') }}</th>
                    <th>{{ t('invoices.total_gross') }}</th>
                    <th>{{ t('invoices.status') }}</th>
                    <th style="text-align:right;">{{ t('common.actions') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for invoice in invoices %}
                <tr class="invoice-row" data-bs-toggle="modal" data-bs-target="#modal-invoice-{{ invoice.id }}" data-invoice-id="{{ invoice.id }}" style="cursor:pointer;">
                    <td><span class="font-semibold" style="color:var(--accent);">{{ invoice.invoice_number }}</span></td>
                    <td>{{ invoice.owner_name ?? '—' }}</td>
                    <td>{{ invoice.patient_name ?? '—' }}</td>
                    <td>{{ invoice.issue_date|date_de }}</td>
                    <td>
                        {% if invoice.due_date %}
                            <span class="{{ invoice.status == 'overdue' ? 'text-danger' : '' }}">{{ invoice.due_date|date_de }}</span>
                        {% else %}—{% endif %}
                    </td>
                    <td class="font-semibold">{{ invoice.total_gross|money }}</td>
                    <td><span class="badge badge-{{ invoice.status }}">{{ t('invoices.status_' ~ invoice.status) }}</span></td>
                    <td>
                        <div class="flex gap-2" style="justify-content:flex-end;">
                            <span class="btn btn-secondary btn-sm" title="Details">
                                <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/></svg>
                            </span>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# ── Mobile: Card List ── #}
    <div class="mob-card-list">
        {% for invoice in invoices %}
        <div class="mob-card invoice-row" data-bs-toggle="modal" data-bs-target="#modal-invoice-{{ invoice.id }}" data-invoice-id="{{ invoice.id }}">
            <div class="mob-card-header">
                <span class="mob-card-title" style="color:var(--accent);">{{ invoice.invoice_number }}</span>
                <span class="badge badge-{{ invoice.status }}">{{ t('invoices.status_' ~ invoice.status) }}</span>
            </div>
            <div class="mob-card-meta">
                <span class="mob-card-meta-item" style="font-weight:600;color:var(--text-primary);font-size:0.9rem;">{{ invoice.total_gross|money }}</span>
                <span class="mob-card-meta-item">👤 {{ invoice.owner_name ?? '—' }}</span>
                {% if invoice.patient_name %}<span class="mob-card-meta-item">🐾 {{ invoice.patient_name }}</span>{% endif %}
                <span class="mob-card-meta-item">📅 {{ invoice.issue_date|date_de }}</span>
                {% if invoice.due_date %}
                <span class="mob-card-meta-item {{ invoice.status == 'overdue' ? 'text-danger' : '' }}">
                    Fällig: {{ invoice.due_date|date_de }}
                </span>
                {% endif %}
            </div>
        </div>
        {% endfor %}
    </div>

</div>{# /mob-hide-table #}

    {% if pagination.last_page > 1 %}
        <div class="pagination">
            {% if pagination.has_prev %}<a href="?page={{ pagination.page - 1 }}&status={{ status }}&search={{ search }}" class="page-link"><svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg></a>{% endif %}
            {% for p in 1..pagination.last_page %}
                {% if p == pagination.page %}<span class="page-link active">{{ p }}</span>
                {% elseif p == 1 or p == pagination.last_page or (p >= pagination.page - 2 and p <= pagination.page + 2) %}<a href="?page={{ p }}&status={{ status }}&search={{ search }}" class="page-link">{{ p }}</a>
                {% elseif p == pagination.page - 3 or p == pagination.page + 3 %}<span class="page-link disabled">…</span>{% endif %}
            {% endfor %}
            {% if pagination.has_next %}<a href="?page={{ pagination.page + 1 }}&status={{ status }}&search={{ search }}" class="page-link"><svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="9 18 15 12 9 6"/></svg></a>{% endif %}
        </div>
    {% endif %}
{% else %}
    <div class="empty-state">
        <div class="empty-state-icon"><svg width="28" height="28" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="1.5" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="1.5" stroke-linecap="round" points="14 2 14 8 20 8"/></svg></div>
        <div class="empty-state-title">{{ t('invoices.no_invoices') }}</div>
        <div class="empty-state-text mb-4">{{ search or status ? 'Keine Ergebnisse für diese Filtereinstellungen.' : 'Noch keine Rechnungen erstellt.' }}</div>
        <a href="/rechnungen/erstellen" class="btn btn-primary">{{ t('invoices.new_invoice') }}</a>
    </div>
{% endif %}
{# PDF Viewer Modal (global, reused) #}
<div id="pdf-viewer-overlay" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.9);align-items:center;justify-content:center;flex-direction:column;">
    <div style="position:relative;width:92vw;max-width:1000px;height:90vh;display:flex;flex-direction:column;background:var(--bg-surface,#1a1a2e);border-radius:12px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.7);">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:0.75rem 1rem;border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;">
            <span id="pv-filename" style="font-size:0.875rem;font-weight:600;color:#fff;"></span>
            <div style="display:flex;gap:0.5rem;">
                <a id="pv-download" href="" download style="background:rgba(255,255,255,0.12);color:#fff;padding:0.35rem 0.75rem;border-radius:6px;font-size:0.8rem;text-decoration:none;">Herunterladen</a>
                <button id="pv-close" style="background:rgba(255,255,255,0.12);border:none;color:#fff;width:32px;height:32px;border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                </button>
            </div>
        </div>
        <iframe id="pv-frame" src="" style="flex:1;border:none;width:100%;" title="PDF Vorschau"></iframe>
    </div>
</div>

<script>
(function () {
    // ── Invoice row click → open modal + lazy load PDF preview ──────
    document.querySelectorAll('.invoice-row').forEach(function (row) {
        row.addEventListener('click', function (e) {
            if (e.target.closest('button, a, form')) return;
            const invoiceId = row.dataset.invoiceId;
            const modalId   = 'modal-invoice-' + invoiceId;

            // Open modal via existing modal system
            window.openModal(modalId);

            // Lazy-load positions
            const posBox = document.getElementById('positions-' + invoiceId);
            if (posBox && posBox.dataset.loaded !== '1') {
                posBox.dataset.loaded = '1';
                fetch('/rechnungen/' + invoiceId + '/positionen-json')
                    .then(r => r.json())
                    .then(function (data) {
                        if (!data.positions || !data.positions.length) {
                            posBox.innerHTML = '<p class="text-sm text-muted">Keine Positionen.</p>';
                            return;
                        }
                        let html = '<table style="width:100%;border-collapse:collapse;font-size:0.82rem;">';
                        html += '<thead><tr style="border-bottom:1px solid var(--glass-border);">';
                        html += '<th style="text-align:left;padding:4px 6px;color:var(--text-muted);font-weight:500;">Beschreibung</th>';
                        html += '<th style="text-align:right;padding:4px 6px;color:var(--text-muted);font-weight:500;">Menge</th>';
                        html += '<th style="text-align:right;padding:4px 6px;color:var(--text-muted);font-weight:500;">Einzelpreis</th>';
                        html += '<th style="text-align:right;padding:4px 6px;color:var(--text-muted);font-weight:500;">MwSt.</th>';
                        html += '<th style="text-align:right;padding:4px 6px;color:var(--text-muted);font-weight:500;">Gesamt</th>';
                        html += '</tr></thead><tbody>';
                        data.positions.forEach(function (p, i) {
                            const bg = i % 2 === 0 ? 'background:rgba(255,255,255,0.02);' : '';
                            const total = (parseFloat(p.quantity) * parseFloat(p.unit_price)).toFixed(2).replace('.', ',');
                            const price = parseFloat(p.unit_price).toFixed(2).replace('.', ',');
                            const qty   = parseFloat(p.quantity).toFixed(2).replace('.', ',');
                            html += `<tr style="${bg}"><td style="padding:5px 6px;">${p.description}</td><td style="text-align:right;padding:5px 6px;">${qty}</td><td style="text-align:right;padding:5px 6px;">${price} €</td><td style="text-align:right;padding:5px 6px;">${p.tax_rate}%</td><td style="text-align:right;padding:5px 6px;font-weight:600;">${total} €</td></tr>`;
                        });
                        html += '</tbody></table>';
                        posBox.innerHTML = html;
                    })
                    .catch(function () {
                        posBox.innerHTML = '<p class="text-sm text-muted">Positionen konnten nicht geladen werden.</p>';
                    });
            }

            // Lazy-load HTML preview in iframe
            const pdfWrap = document.getElementById('pdf-frame-wrap-' + invoiceId);
            const pdfPlaceholder = document.getElementById('pdf-placeholder-' + invoiceId);
            if (pdfWrap && pdfPlaceholder && !pdfWrap.dataset.loaded) {
                pdfWrap.dataset.loaded = '1';
                const frame = document.createElement('iframe');
                frame.src   = '/rechnungen/' + invoiceId + '/vorschau';
                frame.style.cssText = 'width:100%;height:100%;border:none;display:block;';
                frame.title = 'Rechnungs-Vorschau';
                pdfPlaceholder.remove();
                pdfWrap.appendChild(frame);
            }
        });
    });

    // ── Global PDF preview modal ─────────────────────────────────────
    window.openPdfPreview = function (src, filename) {
        document.getElementById('pv-filename').textContent = filename;
        document.getElementById('pv-download').href = src;
        document.getElementById('pv-download').download = filename;
        document.getElementById('pv-frame').src = src;
        document.getElementById('pdf-viewer-overlay').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    };

    document.getElementById('pv-close').addEventListener('click', function () {
        document.getElementById('pdf-viewer-overlay').style.display = 'none';
        document.getElementById('pv-frame').src = '';
        document.body.style.overflow = '';
    });
    document.getElementById('pdf-viewer-overlay').addEventListener('click', function (e) {
        if (e.target === this) {
            this.style.display = 'none';
            document.getElementById('pv-frame').src = '';
            document.body.style.overflow = '';
        }
    });
})();
</script>
{% endblock %}
