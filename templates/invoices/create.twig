{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}
<div class="page-header">
    <div class="flex items-center gap-3">
        <a href="/rechnungen" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            {{ t('invoices.back_to_list') }}
        </a>
        <h1 class="page-title">{{ t('invoices.create') }}</h1>
    </div>
</div>

<form action="/rechnungen" method="POST" id="invoice-form">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
    <input type="hidden" name="_send_email" id="invoice-send-email-flag" value="0">

    <div class="flex gap-4" style="align-items:flex-start;flex-wrap:wrap;">

        {# Left: Main Form #}
        <div style="flex:1;min-width:300px;display:flex;flex-direction:column;gap:1rem;">

            {# Header Info #}
            <div class="glass-card">
                <h3 class="font-semibold mb-4" style="font-size:0.95rem;">{{ t('invoices.invoice') }}</h3>

                {# Zahlungsart Toggle #}
                <div class="form-group mb-4">
                    <label class="form-label">Zahlungsart</label>
                    <div class="flex gap-2" id="payment-method-toggle">
                        <label class="flex items-center gap-2 px-3 py-2 rounded" style="cursor:pointer;border:2px solid var(--accent);background:rgba(var(--accent-rgb,99,102,241),0.08);flex:1;justify-content:center;" id="lbl-rechnung">
                            <input type="radio" name="payment_method" value="rechnung" checked style="display:none;">
                            <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg>
                            <span class="font-semibold text-sm">Rechnung</span>
                        </label>
                        <label class="flex items-center gap-2 px-3 py-2 rounded" style="cursor:pointer;border:2px solid var(--glass-border);flex:1;justify-content:center;" id="lbl-bar">
                            <input type="radio" name="payment_method" value="bar" style="display:none;">
                            <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2"/><line x1="2" y1="10" x2="22" y2="10" stroke="currentColor" stroke-width="2"/></svg>
                            <span class="font-semibold text-sm">Barzahlung / Quittung</span>
                        </label>
                    </div>
                </div>

                <div class="form-grid form-grid-2">
                    <div class="form-group">
                        <label class="form-label">{{ t('invoices.invoice_number') }}</label>
                        <input type="text" name="invoice_number" class="form-control" value="{{ next_number }}" required>
                    </div>
                    <div class="form-group" id="field-status">
                        <label class="form-label">{{ t('invoices.status') }}</label>
                        <select name="status" class="form-control">
                            <option value="draft">{{ t('invoices.status_draft') }}</option>
                            <option value="open">{{ t('invoices.status_open') }}</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('invoices.issue_date') }}</label>
                        <input type="date" name="issue_date" class="form-control" value="{{ 'now'|date('Y-m-d') }}">
                    </div>
                    <div class="form-group" id="field-due-date">
                        <label class="form-label">{{ t('invoices.due_date') }}</label>
                        <input type="date" name="due_date" class="form-control" value="{{ 'now'|date_modify('+14 days')|date('Y-m-d') }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('invoices.owner') }} *</label>
                        <select name="owner_id" class="form-control" required>
                            <option value="">— Tierhalter wählen —</option>
                            {% for owner in owners %}
                                <option value="{{ owner.id }}" {{ preselected_owner == owner.id ? 'selected' : '' }}>
                                    {{ owner.last_name }}, {{ owner.first_name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('invoices.patient') }}</label>
                        <select name="patient_id" class="form-control">
                            <option value="">— Kein Patient —</option>
                            {% for patient in patients %}
                                <option value="{{ patient.id }}" {{ preselected_patient == patient.id ? 'selected' : '' }}>
                                    {{ patient.name }} ({{ patient.species }})
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
            </div>

            {# Positions #}
            <div class="glass-card">
                <h3 class="font-semibold mb-4" style="font-size:0.95rem;">{{ t('invoices.positions') }}</h3>

                {% if kleinunternehmer %}
                <div class="flex items-center gap-2 mb-3" style="background:rgba(255,193,7,0.12);border:1px solid rgba(255,193,7,0.3);border-radius:var(--radius-sm);padding:0.5rem 0.75rem;">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="color:#f59e0b;flex-shrink:0;"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    <span class="text-sm"><strong>Kleinunternehmer §19 UStG</strong> — MwSt. wird automatisch auf 0% gesetzt.</span>
                </div>
                {% endif %}

                {# Column headers #}
                <div style="display:grid;grid-template-columns:1fr 140px 80px 110px {{ kleinunternehmer ? '0px' : '80px' }} auto;gap:0.5rem;margin-bottom:0.25rem;">
                    <span class="text-xs text-muted">{{ t('invoices.description') }}</span>
                    <span class="text-xs text-muted">Behandlungsart</span>
                    <span class="text-xs text-muted" style="text-align:right;">{{ t('invoices.quantity') }}</span>
                    <span class="text-xs text-muted" style="text-align:right;">{{ t('invoices.unit_price') }}</span>
                    {% if not kleinunternehmer %}<span class="text-xs text-muted" style="text-align:right;">{{ t('invoices.tax_rate') }}</span>{% endif %}
                    <span></span>
                </div>

                <div id="positions-container">
                    {# Row template clone target #}
                    <div class="position-row" style="display:grid;grid-template-columns:1fr 140px 80px 110px {{ kleinunternehmer ? '0px' : '80px' }} auto;gap:0.5rem;margin-bottom:0.5rem;align-items:center;">
                        <input type="text" name="position_description[]" class="form-control" placeholder="{{ t('invoices.description') }}" required>
                        <select name="position_treatment_type[]" class="form-control" style="font-size:0.85rem;" data-cs-width="140px">
                            <option value="" selected>— keine —</option>
                            {% for tt in treatment_types %}
                                <option value="{{ tt.id }}" data-price="{{ tt.price }}" data-color="{{ tt.color }}">{{ tt.name }}</option>
                            {% endfor %}
                        </select>
                        <input type="number" name="position_quantity[]" class="form-control pos-qty" value="1" min="0.01" step="0.01" style="text-align:right;">
                        <input type="number" name="position_price[]" class="form-control pos-price" value="0.00" min="0" step="0.01" style="text-align:right;" placeholder="{{ t('invoices.unit_price') }}">
                        <input type="number" name="position_tax_rate[]" class="form-control pos-tax" value="{{ kleinunternehmer ? '0' : default_tax_rate }}" min="0" step="0.01" style="text-align:right;{{ kleinunternehmer ? 'display:none;' : '' }}">
                        <button type="button" class="btn btn-danger btn-icon btn-sm remove-position" title="Entfernen">
                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        </button>
                    </div>
                </div>

                <button type="button" id="add-position" class="btn btn-secondary btn-sm mt-3">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    {{ t('invoices.add_position') }}
                </button>
            </div>

            {# Notes #}
            <div class="glass-card">
                <div class="form-group">
                    <label class="form-label">{{ t('invoices.notes') }}</label>
                    <textarea name="notes" class="form-control" rows="3" placeholder="Interne Notizen oder Anmerkungen..."></textarea>
                </div>
                <div class="form-group mt-3">
                    <label class="form-label">{{ t('invoices.payment_terms') }}</label>
                    <textarea name="payment_terms" class="form-control" rows="2" placeholder="z.B. Zahlbar innerhalb von 14 Tagen..."></textarea>
                </div>
            </div>
        </div>

        {# Right: Totals #}
        <div style="width:260px;flex-shrink:0;position:sticky;top:calc(var(--header-height) + 1rem);">
            <div class="glass-card">
                <h3 class="font-semibold mb-4" style="font-size:0.95rem;">Zusammenfassung</h3>

                <div style="display:flex;flex-direction:column;gap:0.75rem;">
                    <div class="flex justify-between text-sm">
                        <span class="text-muted">{{ t('invoices.total_net') }}</span>
                        <span id="total-net" class="font-medium">0,00 €</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-muted">{{ t('invoices.total_tax') }}</span>
                        <span id="total-tax" class="font-medium">0,00 €</span>
                    </div>
                    <div class="divider"></div>
                    <div class="flex justify-between">
                        <span class="font-bold" style="color:var(--accent);">{{ t('invoices.total_gross') }}</span>
                        <span id="total-gross" class="font-bold" style="font-size:1.2rem;color:var(--accent);">0,00 €</span>
                    </div>
                </div>

                <div class="divider mt-4 mb-4"></div>

                <div class="btn-group w-full" id="invoice-split-group">
                    <button type="submit" id="invoice-save-btn" class="btn btn-primary" style="flex:1;">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 3 7 8 15 8"/></svg>
                        {{ t('common.save') }}
                    </button>
                    <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="visually-hidden">Optionen</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <button type="button" id="invoice-save-send-btn" class="dropdown-item">
                                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" class="me-2"><line x1="22" y1="2" x2="11" y2="13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><polygon points="22 2 15 22 11 13 2 9 22 2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                                Speichern &amp; E-Mail senden
                            </button>
                        </li>
                    </ul>
                </div>
                <a href="/rechnungen" class="btn btn-secondary w-full mt-2">{{ t('common.cancel') }}</a>
            </div>
        </div>
    </div>
</form>

<script>
(function () {
    /* ── Data from PHP ── */
    const patientsByOwner = {};
    {% for patient in patients %}
    {% if patient.owner_id %}
    (patientsByOwner['{{ patient.owner_id }}'] = patientsByOwner['{{ patient.owner_id }}'] || [])
        .push({ id: '{{ patient.id }}', label: '{{ patient.name|e('js') }} ({{ patient.species|e('js') }})' });
    {% endif %}
    {% endfor %}

    /* ── Owner → Patient filter ── */
    const ownerSel   = document.querySelector('[name="owner_id"]');
    const patientSel = document.querySelector('[name="patient_id"]');
    const allPatientOptions = Array.from(patientSel.options).map(o => ({
        value: o.value, text: o.textContent, ownerId: o.dataset.owner || ''
    }));

    function filterPatients(ownerId) {
        const animals = patientsByOwner[ownerId] || [];
        patientSel.innerHTML = '<option value="">— Kein Patient —</option>';
        if (animals.length) {
            animals.forEach(a => {
                const opt = new Option(a.label, a.id);
                patientSel.appendChild(opt);
            });
            if (animals.length === 1) patientSel.value = animals[0].id;
        } else {
            /* no animals for this owner — show all */
            allPatientOptions.forEach(p => {
                if (p.value) patientSel.appendChild(new Option(p.text, p.value));
            });
        }
    }

    ownerSel.addEventListener('change', function () {
        filterPatients(this.value);
    });

    /* pre-select on page load if owner already selected */
    if (ownerSel.value) filterPatients(ownerSel.value);

    /* ── Treatment type → description + price ── */
    function bindTreatmentSelect(row) {
        const ttSel  = row.querySelector('[name="position_treatment_type[]"]');
        const desc   = row.querySelector('[name="position_description[]"]');
        const price  = row.querySelector('[name="position_price[]"]');
        if (!ttSel) return;
        ttSel.addEventListener('change', function () {
            const opt = this.options[this.selectedIndex];
            if (!opt || !opt.value) return;
            const ttPrice = opt.dataset.price;
            const ttName  = opt.textContent.trim();
            if (desc && !desc.value) desc.value = ttName;
            if (price && ttPrice && parseFloat(ttPrice) > 0) {
                price.value = parseFloat(ttPrice).toFixed(2);
                recalc();
            }
        });
    }

    /* ── Totals recalc ── */
    function recalc() {
        let net = 0, tax = 0;
        document.querySelectorAll('.position-row').forEach(row => {
            const qty   = parseFloat(row.querySelector('.pos-qty')?.value  || 0);
            const price = parseFloat(row.querySelector('.pos-price')?.value || 0);
            const taxR  = parseFloat(row.querySelector('.pos-tax')?.value  || 0);
            const lineNet = qty * price;
            net += lineNet;
            tax += lineNet * (taxR / 100);
        });
        const fmt = v => v.toFixed(2).replace('.', ',') + ' €';
        document.getElementById('total-net').textContent   = fmt(net);
        document.getElementById('total-tax').textContent   = fmt(tax);
        document.getElementById('total-gross').textContent = fmt(net + tax);
    }

    /* bind existing rows */
    document.querySelectorAll('.position-row').forEach(row => {
        bindTreatmentSelect(row);
        row.querySelector('.pos-qty')?.addEventListener('input', recalc);
        row.querySelector('.pos-price')?.addEventListener('input', recalc);
        row.querySelector('.pos-tax')?.addEventListener('input', recalc);
        row.querySelector('.remove-position')?.addEventListener('click', function () {
            this.closest('.position-row').remove();
            recalc();
        });
    });

    /* ── Add position ── */
    document.getElementById('add-position').addEventListener('click', function () {
        const tpl  = document.getElementById('position-row-template');
        const node = tpl.content.cloneNode(true);
        const row  = node.querySelector('.position-row');
        document.getElementById('positions-container').appendChild(node);
        bindTreatmentSelect(row);
        row.querySelector('.pos-qty')?.addEventListener('input', recalc);
        row.querySelector('.pos-price')?.addEventListener('input', recalc);
        row.querySelector('.pos-tax')?.addEventListener('input', recalc);
        row.querySelector('.remove-position')?.addEventListener('click', function () {
            this.closest('.position-row').remove();
            recalc();
        });
    });

    recalc();

    /* ── Zahlungsart Toggle ── */
    const lblRechnung  = document.getElementById('lbl-rechnung');
    const lblBar       = document.getElementById('lbl-bar');
    const fieldStatus  = document.getElementById('field-status');
    const fieldDueDate = document.getElementById('field-due-date');
    const submitBtn      = document.getElementById('invoice-save-btn');
    const splitToggle    = document.querySelector('#invoice-split-group .dropdown-toggle-split');

    function updatePaymentUI() {
        const isCash = document.querySelector('[name="payment_method"]:checked')?.value === 'bar';
        const accentBorder = '2px solid var(--accent)';
        const normalBorder = '2px solid var(--glass-border)';
        const accentBg     = 'rgba(99,102,241,0.08)';

        lblRechnung.style.border     = isCash ? normalBorder : accentBorder;
        lblRechnung.style.background = isCash ? '' : accentBg;
        lblBar.style.border          = isCash ? accentBorder : normalBorder;
        lblBar.style.background      = isCash ? accentBg : '';

        fieldStatus.style.display  = isCash ? 'none' : '';
        fieldDueDate.style.display = isCash ? 'none' : '';

        if (submitBtn) {
            submitBtn.innerHTML = isCash
                ? '<svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg> Quittung erstellen'
                : '<svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 3 7 8 15 8"/></svg> Speichern';
        }
        /* Hide split-dropdown for cash payments (no email option) */
        if (splitToggle) splitToggle.style.display = isCash ? 'none' : '';
    }

    document.querySelectorAll('[name="payment_method"]').forEach(r => {
        r.addEventListener('change', updatePaymentUI);
    });
    updatePaymentUI();

    /* ── Speichern & Per E-Mail senden ── */
    const saveSendBtn  = document.getElementById('invoice-save-send-btn');
    const sendFlag     = document.getElementById('invoice-send-email-flag');
    if (saveSendBtn && sendFlag) {
        saveSendBtn.addEventListener('click', function () {
            sendFlag.value = '1';
            document.getElementById('invoice-form').requestSubmit();
        });
    }
})();
</script>

{# Position Row Template #}
<template id="position-row-template">
    <div class="position-row" style="display:grid;grid-template-columns:1fr 140px 80px 110px {{ kleinunternehmer ? '0px' : '80px' }} auto;gap:0.5rem;margin-bottom:0.5rem;align-items:center;">
        <input type="text" name="position_description[]" class="form-control" placeholder="{{ t('invoices.description') }}" required>
        <select name="position_treatment_type[]" class="form-control" style="font-size:0.85rem;" data-cs-width="140px">
            <option value="" selected>— keine —</option>
            {% for tt in treatment_types %}
                <option value="{{ tt.id }}" data-price="{{ tt.price }}" data-color="{{ tt.color }}">{{ tt.name }}</option>
            {% endfor %}
        </select>
        <input type="number" name="position_quantity[]" class="form-control pos-qty" value="1" min="0.01" step="0.01" style="text-align:right;">
        <input type="number" name="position_price[]" class="form-control pos-price" value="0.00" min="0" step="0.01" style="text-align:right;">
        <input type="number" name="position_tax_rate[]" class="form-control pos-tax" value="{{ kleinunternehmer ? '0' : default_tax_rate }}" min="0" step="0.01" style="text-align:right;{{ kleinunternehmer ? 'display:none;' : '' }}">
        <button type="button" class="btn btn-danger btn-icon btn-sm remove-position" title="Entfernen">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
    </div>
</template>
{% endblock %}
