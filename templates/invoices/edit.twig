{% extends 'layouts/base.twig' %}

{% block content %}
<div class="page-header">
    <div class="flex items-center gap-3">
        <a href="/rechnungen/{{ invoice.id }}" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            {{ t('common.back') }}
        </a>
        <h1 class="page-title">{{ t('invoices.edit') }}: {{ invoice.invoice_number }}</h1>
    </div>
</div>

<form action="/rechnungen/{{ invoice.id }}" method="POST" id="invoice-form">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

    <div class="flex gap-4" style="align-items:flex-start;flex-wrap:wrap;">
        <div style="flex:1;min-width:300px;display:flex;flex-direction:column;gap:1rem;">

            <div class="glass-card">
                <h3 class="font-semibold mb-4" style="font-size:0.95rem;">{{ t('invoices.invoice') }}</h3>
                <div class="form-grid form-grid-2">
                    <div class="form-group">
                        <label class="form-label">{{ t('invoices.invoice_number') }}</label>
                        <input type="text" name="invoice_number" class="form-control" value="{{ invoice.invoice_number }}" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('invoices.status') }}</label>
                        <select name="status" class="form-control">
                            <option value="draft"   {{ invoice.status == 'draft'   ? 'selected' : '' }}>{{ t('invoices.status_draft') }}</option>
                            <option value="open"    {{ invoice.status == 'open'    ? 'selected' : '' }}>{{ t('invoices.status_open') }}</option>
                            <option value="paid"    {{ invoice.status == 'paid'    ? 'selected' : '' }}>{{ t('invoices.status_paid') }}</option>
                            <option value="overdue" {{ invoice.status == 'overdue' ? 'selected' : '' }}>{{ t('invoices.status_overdue') }}</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('invoices.issue_date') }}</label>
                        <input type="date" name="issue_date" class="form-control" value="{{ invoice.issue_date }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('invoices.due_date') }}</label>
                        <input type="date" name="due_date" class="form-control" value="{{ invoice.due_date }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('invoices.owner') }} *</label>
                        <select name="owner_id" class="form-control" required>
                            {% for owner in owners %}
                                <option value="{{ owner.id }}" {{ invoice.owner_id == owner.id ? 'selected' : '' }}>
                                    {{ owner.last_name }}, {{ owner.first_name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('invoices.patient') }}</label>
                        <select name="patient_id" class="form-control">
                            <option value="">— Kein Patient —</option>
                            {% for patient in patients %}
                                <option value="{{ patient.id }}" {{ invoice.patient_id == patient.id ? 'selected' : '' }}>
                                    {{ patient.name }} ({{ patient.species }})
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
            </div>

            <div class="glass-card">
                <h3 class="font-semibold mb-3" style="font-size:0.95rem;">{{ t('invoices.positions') }}</h3>
                <div style="display:grid;grid-template-columns:1fr 80px 110px 80px auto;gap:0.375rem;margin-bottom:0.375rem;">
                    <span class="text-xs text-muted">{{ t('invoices.description') }}</span>
                    <span class="text-xs text-muted" style="text-align:right;">{{ t('invoices.quantity') }}</span>
                    <span class="text-xs text-muted" style="text-align:right;">{{ t('invoices.unit_price') }}</span>
                    <span class="text-xs text-muted" style="text-align:right;">{{ t('invoices.tax_rate') }}</span>
                    <span></span>
                </div>
                <div id="positions-container">
                    {% for pos in positions %}
                    <div class="position-row" style="display:grid;grid-template-columns:1fr 80px 110px 80px auto;gap:0.5rem;margin-bottom:0.5rem;align-items:center;">
                        <input type="text" name="position_description[]" class="form-control" value="{{ pos.description }}" required>
                        <input type="number" name="position_quantity[]" class="form-control pos-qty" value="{{ pos.quantity }}" min="0.01" step="0.01" style="text-align:right;">
                        <input type="number" name="position_price[]" class="form-control pos-price" value="{{ pos.unit_price }}" min="0" step="0.01" style="text-align:right;">
                        <input type="number" name="position_tax_rate[]" class="form-control pos-tax" value="{{ pos.tax_rate }}" min="0" step="0.01" style="text-align:right;">
                        <button type="button" class="btn btn-danger btn-icon btn-sm remove-position">
                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        </button>
                    </div>
                    {% endfor %}
                </div>
                <button type="button" id="add-position" class="btn btn-secondary btn-sm mt-2">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    {{ t('invoices.add_position') }}
                </button>
            </div>

            <div class="glass-card">
                <div class="form-group">
                    <label class="form-label">{{ t('invoices.notes') }}</label>
                    <textarea name="notes" class="form-control" rows="3">{{ invoice.notes }}</textarea>
                </div>
                <div class="form-group mt-3">
                    <label class="form-label">{{ t('invoices.payment_terms') }}</label>
                    <textarea name="payment_terms" class="form-control" rows="2">{{ invoice.payment_terms }}</textarea>
                </div>
            </div>
        </div>

        <div style="width:240px;flex-shrink:0;position:sticky;top:calc(var(--header-height) + 1rem);">
            <div class="glass-card">
                <h3 class="font-semibold mb-4" style="font-size:0.95rem;">Zusammenfassung</h3>
                <div style="display:flex;flex-direction:column;gap:0.75rem;">
                    <div class="flex justify-between text-sm">
                        <span class="text-muted">{{ t('invoices.total_net') }}</span>
                        <span id="total-net" class="font-medium">{{ invoice.total_net|money }}</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-muted">{{ t('invoices.total_tax') }}</span>
                        <span id="total-tax" class="font-medium">{{ invoice.total_tax|money }}</span>
                    </div>
                    <div class="divider"></div>
                    <div class="flex justify-between">
                        <span class="font-bold" style="color:var(--accent);">{{ t('invoices.total_gross') }}</span>
                        <span id="total-gross" class="font-bold" style="font-size:1.1rem;color:var(--accent);">{{ invoice.total_gross|money }}</span>
                    </div>
                </div>
                <div class="divider mt-4 mb-4"></div>
                <button type="submit" class="btn btn-primary w-full">
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 3 7 8 15 8"/></svg>
                    {{ t('common.save') }}
                </button>
                <a href="/rechnungen/{{ invoice.id }}" class="btn btn-secondary w-full mt-2">{{ t('common.cancel') }}</a>
            </div>
        </div>
    </div>
</form>

<template id="position-row-template">
    <div class="position-row" style="display:grid;grid-template-columns:1fr 80px 110px 80px auto;gap:0.5rem;margin-bottom:0.5rem;align-items:center;">
        <input type="text" name="position_description[]" class="form-control" placeholder="{{ t('invoices.description') }}" required>
        <input type="number" name="position_quantity[]" class="form-control pos-qty" value="1" min="0.01" step="0.01" style="text-align:right;">
        <input type="number" name="position_price[]" class="form-control pos-price" value="0.00" min="0" step="0.01" style="text-align:right;">
        <input type="number" name="position_tax_rate[]" class="form-control pos-tax" value="19" min="0" step="0.01" style="text-align:right;">
        <button type="button" class="btn btn-danger btn-icon btn-sm remove-position">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
    </div>
</template>
{% endblock %}
