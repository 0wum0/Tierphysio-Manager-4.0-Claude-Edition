<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rechnung {{ invoice.invoice_number }}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --sidebar-color: {{ settings.pdf_primary_color ?? '#8B9E8B' }};
    --c-company-name: {{ settings.pdf_color_company_name ?? '#1E1E1E' }};
    --c-company-info: {{ settings.pdf_color_company_info ?? '#6E6E6E' }};
    --c-recipient: {{ settings.pdf_color_recipient ?? '#1E1E1E' }};
    --c-tbl-hdr-bg: {{ settings.pdf_color_table_header_bg ?? '#8B9E8B' }};
    --c-tbl-hdr-txt: {{ settings.pdf_color_table_header_text ?? '#FFFFFF' }};
    --c-tbl-text: {{ settings.pdf_color_table_text ?? '#1E1E1E' }};
    --c-line: {{ settings.pdf_color_line ?? '#B4B4B4' }};
    --c-total-lbl: {{ settings.pdf_color_total_label ?? '#1E1E1E' }};
    --c-total-gross: {{ settings.pdf_color_total_gross ?? '#1E1E1E' }};
    --c-footer: {{ settings.pdf_color_footer ?? '#6E6E6E' }};
  }

  body {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 9.5pt;
    color: #1a1a2e;
    background: #f0f2f5;
    min-height: 100vh;
  }

  /* ── Toolbar ─────────────────────────────────────── */
  .toolbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(20, 20, 40, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1.5rem;
    color: #fff;
    font-size: 0.8rem;
  }
  .toolbar-title {
    font-weight: 600;
    letter-spacing: 0.02em;
    flex: 1;
  }
  .tb-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.9rem;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: background 0.15s;
  }
  .tb-btn-primary { background: #4f7cff; color: #fff; }
  .tb-btn-primary:hover { background: #3a6aee; }
  .tb-btn-secondary { background: rgba(255,255,255,0.12); color: #fff; }
  .tb-btn-secondary:hover { background: rgba(255,255,255,0.2); }

  /* ── Paper wrapper ───────────────────────────────── */
  .paper-wrap {
    margin: 80px auto 60px;
    max-width: 820px;
    padding: 0 20px;
  }

  /* ── A4 Page — sidebar layout ────────────────────── */
  .a4 {
    background: #fff;
    width: 100%;
    min-height: 1122px;
    box-shadow: 0 4px 40px rgba(0,0,0,0.18);
    border-radius: 3px;
    display: flex;
    position: relative;
    overflow: hidden;
  }

  /* ── Left sidebar ────────────────────────────────── */
  .inv-sidebar {
    width: 160px;
    flex-shrink: 0;
    background: var(--sidebar-color);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 36px 12px 36px;
    min-height: 100%;
  }
  .inv-sidebar .sb-logo {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-bottom: 28px;
  }
  .inv-sidebar .sb-logo img {
    max-width: 110px;
    max-height: 90px;
    object-fit: contain;
  }
  .inv-sidebar .sb-logo-placeholder {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8pt;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.05em;
  }
  .inv-sidebar .sb-divider {
    width: 60%;
    height: 1px;
    background: rgba(255,255,255,0.25);
    margin: 14px 0;
  }
  .inv-sidebar .sb-label {
    font-size: 7pt;
    color: rgba(220,240,220,0.85);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 3px;
    text-align: center;
  }
  .inv-sidebar .sb-value {
    font-size: 9pt;
    font-weight: 700;
    color: #fff;
    text-align: center;
    margin-bottom: 16px;
    word-break: break-all;
  }

  /* ── Main content ────────────────────────────────── */
  .inv-main {
    flex: 1;
    padding: 36px 44px 120px;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  /* Company info top-right */
  .inv-company-block {
    text-align: right;
    margin-bottom: 10px;
  }
  .inv-company-name {
    font-size: 12pt;
    font-weight: 700;
    color: var(--c-company-name);
    margin-bottom: 2px;
  }
  .inv-company-info {
    font-size: 8pt;
    color: var(--c-company-info);
    line-height: 1.55;
  }

  /* Rechnung script */
  .inv-script {
    text-align: right;
    font-size: 36pt;
    font-style: italic;
    font-family: Georgia, 'Times New Roman', serif;
    color: var(--c-company-name);
    line-height: 1;
    margin-bottom: 18px;
  }

  /* Recipient block */
  .inv-recipient {
    margin-bottom: 22px;
  }
  .inv-return-addr {
    font-size: 7pt;
    color: var(--c-company-info);
    border-bottom: 1px solid var(--c-line);
    padding-bottom: 3px;
    margin-bottom: 7px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .inv-recipient-name {
    font-size: 11pt;
    font-weight: 700;
    color: var(--c-recipient);
    margin-bottom: 3px;
  }
  .inv-recipient-addr {
    font-size: 9pt;
    color: var(--c-recipient);
    line-height: 1.55;
  }
  .inv-recipient-meta {
    margin-top: 6px;
    font-size: 8pt;
    color: var(--c-company-info);
    line-height: 1.55;
  }

  /* Intro */
  .inv-intro {
    font-size: 9pt;
    color: #444;
    margin-bottom: 16px;
    line-height: 1.5;
  }

  /* ── Positions table ─────────────────────────────── */
  .pos-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 6px;
    font-size: 9pt;
  }
  .pos-table thead tr {
    background: var(--c-tbl-hdr-bg);
    color: var(--c-tbl-hdr-txt);
  }
  .pos-table thead th {
    padding: 7px 10px;
    font-weight: 600;
    font-size: 8pt;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .pos-table thead th:not(:first-child) { text-align: right; }
  .pos-table tbody tr {
    border-bottom: 1px solid var(--c-line);
  }
  .pos-table tbody td {
    padding: 7px 10px;
    vertical-align: top;
    color: var(--c-tbl-text);
  }
  .pos-table tbody td:not(:first-child) {
    text-align: right;
    white-space: nowrap;
  }

  /* ── Totals block ─────────────────────────────────── */
  .totals-wrap {
    display: flex;
    justify-content: flex-end;
    margin-top: 10px;
    margin-bottom: 24px;
  }
  .totals-table {
    min-width: 240px;
    border-collapse: collapse;
    font-size: 9pt;
  }
  .totals-table td {
    padding: 4px 10px;
  }
  .totals-table td:first-child {
    color: var(--c-total-lbl);
    white-space: nowrap;
  }
  .totals-table td:last-child {
    text-align: right;
    font-weight: 600;
    white-space: nowrap;
    color: var(--c-total-lbl);
  }
  .totals-table .total-divider td {
    border-top: 1px solid var(--c-line);
    padding-top: 6px;
  }
  .totals-table .total-gross td {
    font-size: 11pt;
    font-weight: 800;
    color: var(--c-total-gross);
    padding-top: 4px;
  }

  /* ── Closing / Thank-you ─────────────────────────── */
  .inv-closing {
    font-size: 9pt;
    color: #444;
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .inv-thankyou {
    font-size: 22pt;
    font-style: italic;
    font-family: Georgia, 'Times New Roman', serif;
    color: var(--c-company-name);
    margin-bottom: 0;
  }

  /* ── Notes ───────────────────────────────────────── */
  .inv-notes {
    font-size: 8.5pt;
    color: #555;
    line-height: 1.55;
    margin-bottom: 16px;
    padding: 10px 12px;
    background: #f8f8fc;
    border-left: 3px solid var(--c-line);
    border-radius: 3px;
  }

  /* ── Footer ──────────────────────────────────────── */
  .inv-footer {
    position: absolute;
    bottom: 0;
    left: 160px;
    right: 0;
    border-top: 1px solid var(--c-line);
    padding: 10px 44px;
    display: flex;
    gap: 24px;
    justify-content: space-between;
    align-items: flex-start;
    background: #fff;
  }
  .inv-footer .footer-col-label {
    font-size: 7pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-footer);
    margin-bottom: 2px;
  }
  .inv-footer .footer-col-value {
    font-size: 8pt;
    color: var(--c-footer);
    line-height: 1.5;
  }
  .inv-ku-notice {
    font-size: 7.5pt;
    font-style: italic;
    color: var(--c-footer);
    text-align: center;
    margin-top: 4px;
  }

  /* ── Embedded (iframe) mode ────────────────────────── */
  body.embedded .toolbar { display: none; }
  body.embedded .paper-wrap { margin: 10px auto 20px; }
  body.embedded .a4 { box-shadow: 0 2px 12px rgba(0,0,0,0.12); }

  /* ── Print styles ─────────────────────────────────── */
  @media print {
    body { background: #fff; }
    .toolbar { display: none; }
    .paper-wrap { margin: 0; padding: 0; max-width: 100%; }
    .a4 { box-shadow: none; border-radius: 0; min-height: 100vh; }
  }
</style>
</head>
<body>
<script>
  if (window.self !== window.top) { document.documentElement.classList.add('embedded'); document.addEventListener('DOMContentLoaded', function(){ document.body.classList.add('embedded'); }); }
</script>

{# ── Toolbar ───────────────────────────────────────── #}
<div class="toolbar">
  <span class="toolbar-title">
    Rechnung {{ invoice.invoice_number }}
    <span style="opacity:0.5;font-weight:400;margin-left:8px;">{{ invoice.issue_date|date_de }}</span>
  </span>
  <a href="{{ base_path }}/rechnungen/{{ invoice.id }}" class="tb-btn tb-btn-secondary">
    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
    Zurück
  </a>
  {% if invoice.status != 'paid' %}
  <a href="{{ base_path }}/rechnungen/{{ invoice.id }}/bearbeiten" class="tb-btn tb-btn-secondary">
    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
    Bearbeiten
  </a>
  {% endif %}
  <a href="{{ base_path }}/rechnungen/{{ invoice.id }}/pdf" class="tb-btn tb-btn-secondary" target="_blank">
    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    PDF
  </a>
  <button class="tb-btn tb-btn-primary" onclick="window.print()">
    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="6 9 6 2 18 2 18 9"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8" rx="1" stroke="currentColor" stroke-width="2"/></svg>
    Drucken
  </button>
</div>

{# ── A4 Paper ──────────────────────────────────────── #}
<div class="paper-wrap">
<div class="a4">

  {# ── LEFT SIDEBAR ─────────────────────────────────── #}
  <div class="inv-sidebar">

    {# Logo #}
    <div class="sb-logo">
      {% if settings.company_logo %}
        <img src="/storage/uploads/{{ settings.company_logo }}" alt="Logo">
      {% else %}
        <div class="sb-logo-placeholder">LOGO</div>
      {% endif %}
    </div>

    <div class="sb-divider"></div>

    {# Rechnungsnummer #}
    <div class="sb-label">Rechnungsnummer</div>
    <div class="sb-value">{{ invoice.invoice_number }}</div>

    {# Rechnungsdatum #}
    <div class="sb-label">Rechnungsdatum</div>
    <div class="sb-value">{{ invoice.issue_date|date_de }}</div>

    {# Fällig #}
    {% if invoice.due_date %}
    <div class="sb-divider"></div>
    <div class="sb-label">Fällig am</div>
    <div class="sb-value" style="{{ invoice.status == 'overdue' ? 'color:#ffcccc;' : '' }}">{{ invoice.due_date|date_de }}</div>
    {% endif %}

  </div>

  {# ── MAIN CONTENT ─────────────────────────────────── #}
  <div class="inv-main">

    {# Company info — top right #}
    <div class="inv-company-block">
      <div class="inv-company-name">{{ settings.company_name ?? '' }}</div>
      <div class="inv-company-info">
        {% if settings.company_street %}{{ settings.company_street }}<br>{% endif %}
        {% if settings.company_zip or settings.company_city %}{{ settings.company_zip }} {{ settings.company_city }}<br>{% endif %}
        {% if settings.company_phone %}Tel: {{ settings.company_phone }}<br>{% endif %}
        {% if settings.company_email %}{{ settings.company_email }}{% endif %}
      </div>
    </div>

    {# "Rechnung" script heading #}
    {% set rechnungImg = settings.pdf_rechnung_bild ?? 'rechnung-script.png' %}
    <div class="inv-script" style="text-align:right;margin-bottom:12px;">
      <img src="/assets/img/{{ rechnungImg }}" alt="Rechnung" style="max-height:60px;max-width:220px;object-fit:contain;" onerror="this.style.display='none';this.nextElementSibling.style.display='block';">
      <span style="display:none;font-size:36pt;font-style:italic;font-family:Georgia,'Times New Roman',serif;color:var(--c-company-name);">Rechnung</span>
    </div>

    {# Recipient #}
    <div class="inv-recipient">
      <div class="inv-return-addr">
        {{ settings.company_name ?? '' }} &nbsp;·&nbsp; {{ settings.company_street ?? '' }} &nbsp;·&nbsp; {{ settings.company_zip ?? '' }} {{ settings.company_city ?? '' }}
      </div>
      {% if owner %}
      <div class="inv-recipient-name">{{ owner.first_name }} {{ owner.last_name }}</div>
      <div class="inv-recipient-addr">
        {% if owner.street %}{{ owner.street }}<br>{% endif %}
        {% if owner.zip or owner.city %}{{ owner.zip }} {{ owner.city }}{% endif %}
      </div>
      <div class="inv-recipient-meta">
        {% if patient %}Patient: {{ patient.name }}{% if patient.species %} ({{ patient.species }}){% endif %}{% endif %}
      </div>
      {% endif %}
    </div>

    {# Intro text #}
    {% if settings.pdf_intro_text %}
    <div class="inv-intro">{{ settings.pdf_intro_text }}</div>
    {% else %}
    <div class="inv-intro">für folgende erbrachten Leistungen erlauben wir uns, Ihnen folgenden Betrag in Rechnung zu stellen:</div>
    {% endif %}

    {# ── Positions table ─────────────────────────────── #}
    {% set kleinunternehmer = (settings.kleinunternehmer ?? '0') == '1' %}
    <table class="pos-table">
      <thead>
        <tr>
          <th style="width:10%;text-align:left;">Anz.</th>
          <th style="width:45%;text-align:left;">Leistung / Beschreibung</th>
          <th style="width:15%;">Einzelpreis</th>
          {% if not kleinunternehmer %}<th style="width:10%;">MwSt.</th>{% endif %}
          <th style="width:15%;">Betrag</th>
        </tr>
      </thead>
      <tbody>
        {% for pos in positions %}
        <tr>
          <td>{{ pos.quantity|number_format(2, ',', '.') }}</td>
          <td style="text-align:left;">{{ pos.description }}</td>
          <td>{{ pos.unit_price|money }}</td>
          {% if not kleinunternehmer %}<td>{{ pos.tax_rate }}%</td>{% endif %}
          <td>{{ (pos.quantity * pos.unit_price)|money }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>

    {# ── Totals ───────────────────────────────────────── #}
    <div class="totals-wrap">
      <table class="totals-table">
        {% if kleinunternehmer %}
        <tr class="total-divider">
          <td>Gesamtbetrag (netto)</td>
          <td>{{ invoice.total_net|money }}</td>
        </tr>
        {% else %}
        <tr>
          <td>Total exkl. MwSt.</td>
          <td>{{ invoice.total_net|money }}</td>
        </tr>
        {% set taxGroups = {} %}
        {% for pos in positions %}
          {% set rate = pos.tax_rate %}
          {% set prev = attribute(taxGroups, rate) ?? 0 %}
          {% set taxGroups = taxGroups|merge({(rate): prev + pos.quantity * pos.unit_price * rate / 100}) %}
        {% endfor %}
        {% for rate, amt in taxGroups %}
        <tr>
          <td>MwSt. {{ rate }}%</td>
          <td>{{ amt|number_format(2, ',', '.') }} €</td>
        </tr>
        {% endfor %}
        <tr class="total-divider">
          <td></td><td></td>
        </tr>
        {% endif %}
        <tr class="total-gross">
          <td>Total</td>
          <td>{{ invoice.total_gross|money }}</td>
        </tr>
      </table>
    </div>

    {# Notes #}
    {% if invoice.notes %}
    <div class="inv-notes">{{ invoice.notes }}</div>
    {% endif %}

    {# Closing #}
    {% if settings.pdf_closing_text %}
    <div class="inv-closing">{{ settings.pdf_closing_text }}</div>
    {% elseif invoice.payment_terms %}
    <div class="inv-closing"><em>{{ invoice.payment_terms }}</em></div>
    {% endif %}

    {# "Vielen Dank!" #}
    {% set vielenDankImg = settings.pdf_vielen_dank_bild ?? 'vielen-dank-script.png' %}
    <div class="inv-thankyou" style="margin-bottom:8px;">
      <img src="/assets/img/{{ vielenDankImg }}" alt="Vielen Dank!" style="max-height:70px;max-width:260px;object-fit:contain;" onerror="this.style.display='none';this.nextElementSibling.style.display='block';">
      <span style="display:none;">Vielen Dank!</span>
    </div>

    {# ── Footer ───────────────────────────────────────── #}
    <div class="inv-footer">
      {% if settings.bank_name or settings.bank_iban %}
      <div>
        <div class="footer-col-label">Bankverbindung</div>
        <div class="footer-col-value">
          {% if settings.bank_name %}{{ settings.bank_name }}<br>{% endif %}
          {% if settings.bank_iban %}IBAN: {{ settings.bank_iban }}<br>{% endif %}
          {% if settings.bank_bic %}BIC: {{ settings.bank_bic }}{% endif %}
        </div>
      </div>
      {% endif %}
      {% if settings.company_email or settings.company_phone %}
      <div>
        <div class="footer-col-label">Kontakt</div>
        <div class="footer-col-value">
          {% if settings.company_email %}{{ settings.company_email }}<br>{% endif %}
          {% if settings.company_phone %}Tel: {{ settings.company_phone }}{% endif %}
        </div>
      </div>
      {% endif %}
      {% if settings.tax_number %}
      <div>
        <div class="footer-col-label">Steuernummer</div>
        <div class="footer-col-value">{{ settings.tax_number }}</div>
      </div>
      {% endif %}
    </div>
    {% if kleinunternehmer %}
    <div class="inv-ku-notice" style="position:absolute;bottom:4px;left:160px;right:0;text-align:center;">Gemäß §19 UStG wird keine Umsatzsteuer berechnet.</div>
    {% endif %}

  </div>{# .inv-main #}

</div>{# .a4 #}
</div>{# .paper-wrap #}

</body>
</html>
