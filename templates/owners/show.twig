{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}
<div class="page-header">
    <div class="flex items-center gap-3">
        <a href="/tierhalter" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            {{ t('owners.back_to_list') }}
        </a>
        <h1 class="page-title">{{ owner.first_name }} {{ owner.last_name }}</h1>
    </div>
    <div class="flex gap-2">
        <a href="/rechnungen/erstellen?owner_id={{ owner.id }}" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
            {{ t('owners.create_invoice') }}
        </a>
        {% if owner.email %}
        <a href="mailto:{{ owner.email }}" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="22,6 12,13 2,6"/></svg>
            {{ t('owners.send_email') }}
        </a>
        {% endif %}
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-edit-owner">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            {{ t('common.edit') }}
        </button>
    </div>
</div>

<div class="flex gap-4" style="align-items:flex-start;flex-wrap:wrap;">

    {# Left: Owner Info #}
    <div style="width:300px;flex-shrink:0;display:flex;flex-direction:column;gap:1rem;">
        <div class="glass-card">
            <div class="flex items-center gap-3 mb-4">
                <div class="avatar-placeholder" style="width:56px;height:56px;font-size:1.25rem;border-radius:50%;">{{ owner.first_name|first ~ owner.last_name|first }}</div>
                <div>
                    <div class="font-bold" style="font-size:1.1rem;">{{ owner.first_name }} {{ owner.last_name }}</div>
                    <div class="text-sm text-muted" style="display:flex;align-items:center;gap:0.4rem;">
                        <span style="font-size:0.72rem;font-weight:700;color:var(--accent,#6366f1);background:rgba(99,102,241,0.1);padding:0.1rem 0.5rem;border-radius:999px;border:1px solid rgba(99,102,241,0.2);">Kunden-Nr. {{ '%04d'|format(owner.id) }}</span>
                        <span>· {{ animals|length }} {{ t('owners.animals') }}</span>
                    </div>
                </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:0.75rem;">
                {% if owner.email %}
                <div class="flex items-center gap-2">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="color:var(--text-muted);flex-shrink:0;"><path stroke="currentColor" stroke-width="2" d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="22,6 12,13 2,6"/></svg>
                    <a href="mailto:{{ owner.email }}" class="text-sm" style="color:var(--accent);">{{ owner.email }}</a>
                </div>
                {% endif %}
                {% if owner.phone %}
                <div class="flex items-center gap-2">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="color:var(--text-muted);flex-shrink:0;"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.76a16 16 0 0 0 6 6l.95-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/></svg>
                    <a href="tel:{{ owner.phone }}" class="text-sm" style="color:var(--text-primary);">{{ owner.phone }}</a>
                </div>
                {% endif %}
                {% if owner.street or owner.city %}
                <div class="flex items-start gap-2">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="color:var(--text-muted);flex-shrink:0;margin-top:2px;"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2"/></svg>
                    <div class="text-sm text-secondary">
                        {% if owner.street %}<div>{{ owner.street }}</div>{% endif %}
                        {% if owner.zip or owner.city %}<div>{{ owner.zip }} {{ owner.city }}</div>{% endif %}
                    </div>
                </div>
                {% endif %}
                {% if owner.notes %}
                <div style="border-top:1px solid var(--glass-border);padding-top:0.75rem;">
                    <div class="text-xs text-muted mb-1">{{ t('owners.notes') }}</div>
                    <div class="text-sm text-secondary" style="line-height:1.5;">{{ owner.notes }}</div>
                </div>
                {% endif %}
            </div>
        </div>

        {% if current_user.role == 'admin' %}
        <form action="/tierhalter/{{ owner.id }}/loeschen" method="POST">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="btn btn-danger w-full" data-confirm="Tierhalter wirklich löschen? Alle verknüpften Daten werden gelöscht.">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m5 0V4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2"/></svg>
                {{ t('common.delete') }}
            </button>
        </form>
        {% endif %}
    </div>

    {# Right: Animals #}
    <div style="flex:1;min-width:0;">
        <div class="glass-card">
            <div class="flex items-center justify-between mb-4">
                <h2 class="font-semibold" style="font-size:1rem;">{{ t('owners.animals') }}</h2>
                <a href="/patienten" class="btn btn-primary btn-sm">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    {{ t('patients.new_patient') }}
                </a>
            </div>

            {% if animals %}
                <div class="patient-grid" style="grid-template-columns:repeat(auto-fill,minmax(200px,1fr));">
                    {% for animal in animals %}
                        <a href="/patienten/{{ animal.id }}" class="patient-card">
                            <div class="patient-card-image" style="height:100px;">
                                {% if animal.photo %}
                                    <img src="/patienten/{{ animal.id }}/foto/{{ animal.photo }}" alt="{{ animal.name }}">
                                {% else %}
                                    <div class="patient-card-image-placeholder"><svg width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="1.5" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
                                {% endif %}
                                <div style="position:absolute;top:0.4rem;right:0.4rem;"><span class="badge badge-aktiv" style="font-size:0.6rem;">{{ animal.status }}</span></div>
                            </div>
                            <div class="patient-card-body" style="padding:0.75rem;">
                                <div class="patient-card-name" style="font-size:0.9rem;">{{ animal.name }}</div>
                                <div class="patient-card-species" style="font-size:0.75rem;">{{ animal.species }}{% if animal.breed %} · {{ animal.breed }}{% endif %}</div>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <div class="empty-state" style="padding:2rem;">
                    <div class="empty-state-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="1.5" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
                    <div class="empty-state-title">Noch keine Tiere angelegt.</div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

{# Edit Owner Modal #}
<div class="modal fade" id="modal-edit-owner" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">{{ t('common.edit') }}: {{ owner.first_name }} {{ owner.last_name }}</h3>
            <button class="modal-close" data-bs-dismiss="modal" type="button"><svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></button>
        </div>
        <form action="/tierhalter/{{ owner.id }}" method="POST" class="modal-body">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="form-grid form-grid-2">
                <div class="form-group">
                    <label class="form-label">{{ t('owners.first_name') }} *</label>
                    <input type="text" name="first_name" class="form-control" value="{{ owner.first_name }}" required>
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('owners.last_name') }} *</label>
                    <input type="text" name="last_name" class="form-control" value="{{ owner.last_name }}" required>
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('owners.email') }}</label>
                    <input type="email" name="email" class="form-control" value="{{ owner.email }}">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('owners.phone') }}</label>
                    <input type="tel" name="phone" class="form-control" value="{{ owner.phone }}">
                </div>
                <div class="form-group">
                    <label class="form-label">{{ t('owners.street') }}</label>
                    <input type="text" name="street" class="form-control" value="{{ owner.street }}">
                </div>
                <div class="form-grid form-grid-2" style="gap:0.5rem;">
                    <div class="form-group">
                        <label class="form-label">{{ t('owners.zip') }}</label>
                        <input type="text" name="zip" class="form-control" value="{{ owner.zip }}" maxlength="10">
                    </div>
                    <div class="form-group">
                        <label class="form-label">{{ t('owners.city') }}</label>
                        <input type="text" name="city" class="form-control" value="{{ owner.city }}">
                    </div>
                </div>
            </div>
            <div class="form-group mt-3">
                <label class="form-label">{{ t('owners.notes') }}</label>
                <textarea name="notes" class="form-control" rows="3">{{ owner.notes }}</textarea>
            </div>
            <div class="modal-footer" style="padding:1rem 0 0;margin-top:1rem;border-top:1px solid var(--glass-border);">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ t('common.cancel') }}</button>
                <button type="submit" class="btn btn-primary">{{ t('common.save') }}</button>
            </div>
        </form>
    </div></div>
</div>
{% endblock %}
