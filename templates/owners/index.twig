{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}

{# -- Page Header (page-header class is visible in bridge.css) -- #}
<div class="page-header">
    <div>
        <h1 class="page-title">{{ t('owners.title') }}</h1>
        <p class="page-subtitle">{{ pagination.total }} {{ t('common.entries') }}</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modal-new-owner">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        {{ t('owners.new_owner') }}
    </button>
</div>

{# -- Panel -- #}
<div class="panel">

    {# Panel Header mit Suche #}
    <div class="panel-hdr">
        <h2>{{ t('owners.title') }} <span class="fw-300"><i>{{ pagination.total }} Einträge</i></span></h2>
        <div class="panel-toolbar">
            <form method="GET" action="{{ base_path }}/tierhalter" class="d-flex align-items-center gap-2 mb-0">
                <div class="input-group input-group-sm" style="width:240px;">
                    <span class="input-group-text">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/><line x1="21" y1="21" x2="16.65" y2="16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    </span>
                    <input type="text" name="search" class="form-control form-control-sm"
                           placeholder="{{ t('owners.search_placeholder') }}" value="{{ search }}">
                </div>
                <button type="submit" class="btn btn-sm btn-secondary">Suchen</button>
                {% if search %}<a href="{{ base_path }}/tierhalter" class="btn btn-sm btn-outline-secondary">?</a>{% endif %}
            </form>
        </div>
    </div>

    <div class="panel-container show">
        <div class="panel-content p-0">

        {% if owners %}
            <table class="table table-hover table-striped table-bordered mb-0">
                <thead>
                    <tr>
                        <th style="width:35%;">{{ t('owners.last_name') }}, {{ t('owners.first_name') }}</th>
                        <th>{{ t('owners.email') }}</th>
                        <th>{{ t('owners.phone') }}</th>
                        <th>{{ t('owners.city') }}</th>
                        <th class="text-center" style="width:70px;">Tiere</th>
                        <th class="text-end" style="width:130px;">{{ t('common.actions') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for owner in owners %}
                    <tr style="vertical-align:middle;">
                        <td>
                            <a href="{{ base_path }}/tierhalter/{{ owner.id }}" class="d-flex align-items-center gap-3 text-decoration-none text-body">
                                <span class="avatar-placeholder flex-shrink-0"
                                      style="width:36px;height:36px;font-size:0.78rem;">
                                    {{ owner.first_name|first|upper }}{{ owner.last_name|first|upper }}
                                </span>
                                <div>
                                    <div class="fw-500 d-flex align-items-center gap-2">
                                        {{ owner.last_name }}, {{ owner.first_name }}
                                        <span class="badge bg-primary fs-nano">#{{ '%04d'|format(owner.id) }}</span>
                                    </div>
                                    {% if owner.street %}
                                    <div class="fs-nano text-muted">{{ owner.street }}</div>
                                    {% endif %}
                                </div>
                            </a>
                        </td>
                        <td class="fs-sm">
                            {% if owner.email %}
                                <a href="mailto:{{ owner.email }}" class="text-primary">{{ owner.email }}</a>
                            {% else %}<span class="text-muted">—</span>{% endif %}
                        </td>
                        <td class="fs-sm">{{ owner.phone ?: '<span class="text-muted">—</span>' }}</td>
                        <td class="fs-sm">
                            {{ owner.zip ? owner.zip ~ ' ' ~ owner.city : (owner.city ?: '<span class="text-muted">—</span>') }}
                        </td>
                        <td class="text-center">
                            {% set cnt = owner.animal_count ?? 0 %}
                            <span class="badge {% if cnt > 0 %}bg-success{% else %}bg-secondary{% endif %}">{{ cnt }}</span>
                        </td>
                        <td class="text-end">
                            <div class="d-flex align-items-center justify-content-end gap-1">
                                <a href="{{ base_path }}/tierhalter/{{ owner.id }}" class="btn btn-xs btn-secondary" title="Ansehen">
                                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/></svg>
                                </a>
                                <a href="{{ base_path }}/rechnungen/erstellen?owner_id={{ owner.id }}" class="btn btn-xs btn-primary" title="Rechnung erstellen">
                                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
                                </a>
                                <div class="dropdown">
                                    <button class="btn btn-xs btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5" fill="currentColor"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/><circle cx="12" cy="19" r="1.5" fill="currentColor"/></svg>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-animated">
                                        <li><a class="dropdown-item" href="{{ base_path }}/tierhalter/{{ owner.id }}">
                                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" class="me-2 text-muted"><path stroke="currentColor" stroke-width="2" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/></svg>
                                            Profil anzeigen
                                        </a></li>
                                        <li><a class="dropdown-item" href="{{ base_path }}/rechnungen/erstellen?owner_id={{ owner.id }}">
                                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" class="me-2 text-muted"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
                                            Rechnung erstellen
                                        </a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" href="{{ base_path }}/einladungen?prefill_owner={{ owner.id }}">
                                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" class="me-2 text-muted"><line x1="22" y1="2" x2="11" y2="13" stroke="currentColor" stroke-width="2"/><polygon points="22 2 15 22 11 13 2 9 22 2" stroke="currentColor" stroke-width="2" fill="none"/></svg>
                                            Einladung senden
                                        </a></li>
                                    </ul>
                                </div>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>

            {# Pagination #}
            {% if pagination.last_page > 1 %}
            <div class="d-flex align-items-center justify-content-between px-3 py-2 border-top">
                <span class="fs-sm text-muted">Seite {{ pagination.page }} / {{ pagination.last_page }} &middot; {{ pagination.total }} Einträge</span>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item {% if not pagination.has_prev %}disabled{% endif %}">
                            <a class="page-link" href="?page={{ pagination.page - 1 }}&search={{ search }}">‹</a>
                        </li>
                        {% for p in 1..pagination.last_page %}
                            {% if p == pagination.page %}
                                <li class="page-item active"><span class="page-link">{{ p }}</span></li>
                            {% elseif p == 1 or p == pagination.last_page or (p >= pagination.page - 2 and p <= pagination.page + 2) %}
                                <li class="page-item"><a class="page-link" href="?page={{ p }}&search={{ search }}">{{ p }}</a></li>
                            {% elseif p == pagination.page - 3 or p == pagination.page + 3 %}
                                <li class="page-item disabled"><span class="page-link">…</span></li>
                            {% endif %}
                        {% endfor %}
                        <li class="page-item {% if not pagination.has_next %}disabled{% endif %}">
                            <a class="page-link" href="?page={{ pagination.page + 1 }}&search={{ search }}">›</a>
                        </li>
                    </ul>
                </nav>
            </div>
            {% endif %}

        {% else %}
            <div class="text-center py-5">
                <svg width="48" height="48" fill="none" viewBox="0 0 24 24" class="mb-3 text-muted" style="opacity:.3;"><path stroke="currentColor" stroke-width="1.5" d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path stroke="currentColor" stroke-width="1.5" d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <h5 class="text-muted fw-400">{{ t('owners.no_owners') }}</h5>
                <p class="text-muted fs-sm mb-4">{{ search ? 'Keine Ergebnisse für "' ~ search ~ '"' : 'Noch keine Tierhalter angelegt.' }}</p>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modal-new-owner">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    {{ t('owners.new_owner') }}
                </button>
            </div>
        {% endif %}

        </div>
    </div>

</div>{# end panel #}

{# New Owner Modal #}
<div class="modal fade" id="modal-new-owner" tabindex="-1" aria-labelledby="modal-new-owner-label" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h4 class="modal-title fw-500" id="modal-new-owner-label">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" class="me-2 text-primary" style="vertical-align:-2px;"><path stroke="currentColor" stroke-width="2" d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/><line x1="19" y1="8" x2="19" y2="14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="22" y1="11" x2="16" y2="11" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    {{ t('owners.new_owner') }}
                </h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form action="{{ base_path }}/tierhalter" method="POST">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">{{ t('owners.first_name') }} <span class="text-danger">*</span></label>
                            <input type="text" name="first_name" class="form-control" required autofocus>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">{{ t('owners.last_name') }} <span class="text-danger">*</span></label>
                            <input type="text" name="last_name" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">{{ t('owners.email') }}</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="sa sa-mail fs-xs"></i></span>
                                <input type="email" name="email" class="form-control">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">{{ t('owners.phone') }}</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="sa sa-phone fs-xs"></i></span>
                                <input type="tel" name="phone" class="form-control">
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">{{ t('owners.street') }}</label>
                            <input type="text" name="street" class="form-control">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">{{ t('owners.zip') }}</label>
                            <input type="text" name="zip" class="form-control" maxlength="10">
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">{{ t('owners.city') }}</label>
                            <input type="text" name="city" class="form-control">
                        </div>
                        <div class="col-12">
                            <label class="form-label">{{ t('owners.notes') }}</label>
                            <textarea name="notes" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <hr class="my-3">

                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" name="create_animal" value="1" id="create-animal-cb">
                        <label class="form-check-label fw-500" for="create-animal-cb">
                            {{ t('owners.create_animal') }}
                        </label>
                    </div>
                    <div id="animal-fields" style="display:none;">
                        <div class="row g-3 mt-1">
                            <div class="col-md-4">
                                <label class="form-label">{{ t('owners.animal_name') }}</label>
                                <input type="text" name="animal_name" class="form-control">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">{{ t('owners.animal_species') }}</label>
                                <input type="text" name="animal_species" class="form-control">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">{{ t('owners.animal_breed') }}</label>
                                <input type="text" name="animal_breed" class="form-control">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary waves-effect" data-bs-dismiss="modal">
                        {{ t('common.cancel') }}
                    </button>
                    <button type="submit" class="btn btn-primary waves-effect waves-themed">
                        <i class="sa sa-check me-1"></i> {{ t('common.create') }}
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
document.getElementById('create-animal-cb')?.addEventListener('change', function() {
    document.getElementById('animal-fields').style.display = this.checked ? 'block' : 'none';
});
</script>
{% endblock %}
