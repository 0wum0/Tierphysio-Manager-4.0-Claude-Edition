{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}

{# ── Page Header ── #}
<div class="subheader">
    <h1 class="subheader-title">
        <i class="sa sa-users me-2 text-primary"></i>
        {{ t('owners.title') }}
        <small>{{ pagination.total }} {{ t('common.entries') }}</small>
    </h1>
    <div class="subheader-action">
        <button class="btn btn-primary waves-effect waves-themed" data-bs-toggle="modal" data-bs-target="#modal-new-owner">
            <i class="sa sa-plus me-1"></i>
            {{ t('owners.new_owner') }}
        </button>
    </div>
</div>

{# ── Panel ── #}
<div class="row">
    <div class="col-xl-12">
        <div id="panel-owners" class="panel">

            {# Panel Toolbar #}
            <div class="panel-hdr">
                <h2>Tierhalter <span class="fw-300"><i>Übersicht</i></span></h2>
                <div class="panel-toolbar ms-auto d-flex align-items-center gap-2">
                    <form method="GET" action="/tierhalter" class="d-flex align-items-center gap-2 mb-0">
                        <div class="input-group input-group-sm" style="width:260px;">
                            <span class="input-group-text bg-transparent border-end-0">
                                <i class="sa sa-search text-muted" style="font-size:0.8rem;"></i>
                            </span>
                            <input type="text" name="search" class="form-control form-control-sm border-start-0 ps-0"
                                   placeholder="{{ t('owners.search_placeholder') }}" value="{{ search }}">
                            {% if search %}
                            <a href="/tierhalter" class="btn btn-sm btn-outline-secondary">
                                <i class="sa sa-x"></i>
                            </a>
                            {% endif %}
                        </div>
                        <button type="submit" class="btn btn-sm btn-secondary waves-effect">
                            {{ t('common.search') }}
                        </button>
                    </form>
                    <button class="btn btn-sm btn-primary waves-effect waves-themed" data-bs-toggle="modal" data-bs-target="#modal-new-owner">
                        <i class="sa sa-plus me-1"></i> Neu
                    </button>
                </div>
            </div>

            <div class="panel-container show">
                <div class="panel-content p-0">

                {% if owners %}
                    <table class="table table-hover table-striped mb-0">
                        <thead class="thead-themed">
                            <tr>
                                <th class="ps-4">Tierhalter</th>
                                <th>E-Mail</th>
                                <th>Telefon</th>
                                <th>Ort</th>
                                <th class="text-center">Tiere</th>
                                <th class="text-end pe-4">Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for owner in owners %}
                            <tr class="odd:bg-transparent even:bg-faded" style="vertical-align:middle;">
                                <td class="ps-4">
                                    <a href="/tierhalter/{{ owner.id }}" class="d-flex align-items-center gap-3 text-decoration-none">
                                        {# Avatar #}
                                        <span class="profile-image rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 fw-700 fs-sm"
                                              style="width:38px;height:38px;background:linear-gradient(135deg,var(--theme-primary,#4f7cff),var(--theme-secondary,#8b5cf6));color:#fff;font-size:0.8rem;">
                                            {{ owner.first_name|first|upper }}{{ owner.last_name|first|upper }}
                                        </span>
                                        <div class="d-flex flex-column">
                                            <span class="fw-500 fs-md text-body d-flex align-items-center gap-2">
                                                {{ owner.last_name }}, {{ owner.first_name }}
                                                <span class="badge bg-primary-500 badge-pill fs-nano fw-700">#{{ '%04d'|format(owner.id) }}</span>
                                            </span>
                                            {% if owner.street %}
                                            <span class="fs-nano text-muted">{{ owner.street }}</span>
                                            {% endif %}
                                        </div>
                                    </a>
                                </td>
                                <td>
                                    {% if owner.email %}
                                        <a href="mailto:{{ owner.email }}" class="text-primary fs-sm">
                                            <i class="sa sa-mail me-1 opacity-50"></i>{{ owner.email }}
                                        </a>
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td class="fs-sm">
                                    {% if owner.phone %}
                                        <i class="sa sa-phone me-1 opacity-50"></i>{{ owner.phone }}
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td class="fs-sm">
                                    {% if owner.city %}
                                        <i class="sa sa-map-pin me-1 opacity-50"></i>
                                        {{ owner.zip ? owner.zip ~ ' ' ~ owner.city : owner.city }}
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    {% set cnt = owner.animal_count ?? 0 %}
                                    <span class="badge {% if cnt > 0 %}bg-success{% else %}bg-secondary{% endif %} rounded-pill">
                                        {{ cnt }}
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex align-items-center justify-content-end gap-1">
                                        <a href="/tierhalter/{{ owner.id }}" class="btn btn-sm btn-outline-secondary waves-effect" title="Ansehen">
                                            <i class="sa sa-eye"></i>
                                        </a>
                                        <a href="/rechnungen/erstellen?owner_id={{ owner.id }}" class="btn btn-sm btn-outline-primary waves-effect" title="Rechnung erstellen">
                                            <i class="sa sa-file-text"></i>
                                        </a>
                                        <div class="dropdown d-inline-block">
                                            <button class="btn btn-sm btn-outline-secondary waves-effect dropdown-toggle no-arrow" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Mehr">
                                                <i class="sa sa-more-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-animated">
                                                <li>
                                                    <a class="dropdown-item" href="/tierhalter/{{ owner.id }}">
                                                        <i class="sa sa-eye me-2 text-muted"></i> Profil anzeigen
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" href="/rechnungen/erstellen?owner_id={{ owner.id }}">
                                                        <i class="sa sa-file-text me-2 text-muted"></i> Rechnung erstellen
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <a class="dropdown-item text-danger" href="/einladungen?prefill_owner={{ owner.id }}" title="Einladen">
                                                        <i class="sa sa-send me-2"></i> Einladung senden
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>

                    {# Pagination #}
                    {% if pagination.last_page > 1 %}
                    <div class="d-flex align-items-center justify-content-between px-4 py-3 border-top">
                        <span class="fs-sm text-muted">
                            Seite {{ pagination.page }} von {{ pagination.last_page }}
                            &middot; {{ pagination.total }} Einträge
                        </span>
                        <nav>
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item {% if not pagination.has_prev %}disabled{% endif %}">
                                    <a class="page-link" href="?page={{ pagination.page - 1 }}&search={{ search }}">
                                        <i class="sa sa-chevron-left"></i>
                                    </a>
                                </li>
                                {% for p in 1..pagination.last_page %}
                                    {% if p == pagination.page %}
                                        <li class="page-item active"><span class="page-link">{{ p }}</span></li>
                                    {% elseif p == 1 or p == pagination.last_page or (p >= pagination.page - 2 and p <= pagination.page + 2) %}
                                        <li class="page-item"><a class="page-link" href="?page={{ p }}&search={{ search }}">{{ p }}</a></li>
                                    {% elseif p == pagination.page - 3 or p == pagination.page + 3 %}
                                        <li class="page-item disabled"><span class="page-link">…</span></li>
                                    {% endif %}
                                {% endfor %}
                                <li class="page-item {% if not pagination.has_next %}disabled{% endif %}">
                                    <a class="page-link" href="?page={{ pagination.page + 1 }}&search={{ search }}">
                                        <i class="sa sa-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                    {% endif %}

                {% else %}
                    {# Empty State #}
                    <div class="d-flex flex-column align-items-center justify-content-center py-5 text-center">
                        <i class="sa sa-users sa-5x text-muted mb-3" style="opacity:0.25;font-size:3.5rem;"></i>
                        <h5 class="fw-400 text-muted">{{ t('owners.no_owners') }}</h5>
                        <p class="text-muted fs-sm mb-4">
                            {{ search ? 'Keine Ergebnisse für "' ~ search ~ '"' : 'Noch keine Tierhalter angelegt.' }}
                        </p>
                        <button class="btn btn-primary waves-effect waves-themed" data-bs-toggle="modal" data-bs-target="#modal-new-owner">
                            <i class="sa sa-plus me-1"></i> {{ t('owners.new_owner') }}
                        </button>
                    </div>
                {% endif %}

                </div>
            </div>{# end panel-container #}

        </div>{# end panel #}
    </div>
</div>

{# New Owner Modal #}
<div class="modal fade" id="modal-new-owner" tabindex="-1" aria-labelledby="modal-new-owner-label" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h4 class="modal-title fw-500" id="modal-new-owner-label">
                    <i class="sa sa-user-plus me-2 text-primary"></i>
                    {{ t('owners.new_owner') }}
                </h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form action="/tierhalter" method="POST">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">{{ t('owners.first_name') }} <span class="text-danger">*</span></label>
                            <input type="text" name="first_name" class="form-control" required autofocus>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">{{ t('owners.last_name') }} <span class="text-danger">*</span></label>
                            <input type="text" name="last_name" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">{{ t('owners.email') }}</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="sa sa-mail fs-xs"></i></span>
                                <input type="email" name="email" class="form-control">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">{{ t('owners.phone') }}</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="sa sa-phone fs-xs"></i></span>
                                <input type="tel" name="phone" class="form-control">
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">{{ t('owners.street') }}</label>
                            <input type="text" name="street" class="form-control">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">{{ t('owners.zip') }}</label>
                            <input type="text" name="zip" class="form-control" maxlength="10">
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">{{ t('owners.city') }}</label>
                            <input type="text" name="city" class="form-control">
                        </div>
                        <div class="col-12">
                            <label class="form-label">{{ t('owners.notes') }}</label>
                            <textarea name="notes" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <hr class="my-3">

                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" name="create_animal" value="1" id="create-animal-cb">
                        <label class="form-check-label fw-500" for="create-animal-cb">
                            {{ t('owners.create_animal') }}
                        </label>
                    </div>
                    <div id="animal-fields" style="display:none;">
                        <div class="row g-3 mt-1">
                            <div class="col-md-4">
                                <label class="form-label">{{ t('owners.animal_name') }}</label>
                                <input type="text" name="animal_name" class="form-control">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">{{ t('owners.animal_species') }}</label>
                                <input type="text" name="animal_species" class="form-control">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">{{ t('owners.animal_breed') }}</label>
                                <input type="text" name="animal_breed" class="form-control">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary waves-effect" data-bs-dismiss="modal">
                        {{ t('common.cancel') }}
                    </button>
                    <button type="submit" class="btn btn-primary waves-effect waves-themed">
                        <i class="sa sa-check me-1"></i> {{ t('common.create') }}
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
document.getElementById('create-animal-cb')?.addEventListener('change', function() {
    document.getElementById('animal-fields').style.display = this.checked ? 'block' : 'none';
});
</script>
{% endblock %}
