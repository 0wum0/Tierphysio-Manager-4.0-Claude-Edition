/* ── Open patient modal (global entry point) ──────────────── */
function openPatientModal(patientId) {
    resetModal();
    bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-patient-detail')).show();
    initQuill();

    fetch('/patienten/' + patientId + '/json')
        .then(function(r){ return r.json(); })
        .then(function(data) {
            var p = data.patient;
            var o = data.owner;
            pdName.textContent = p.name || '';
            if (p.status) {
                pdBadge.textContent  = p.status;
                pdBadge.className    = 'badge badge-' + p.status.toLowerCase().replace(/ /g,'_');
                pdBadge.style.display = '';
            }
            pdSpecies.textContent = [p.species,p.breed].filter(Boolean).join(' · ');
            if (p.photo) {
                var imgH = document.createElement('img');
                imgH.src = '/patienten/'+patientId+'/foto/'+p.photo;
                imgH.style.cssText = 'width:100%;height:100%;object-fit:cover;';
                pdPhoto.innerHTML = ''; pdPhoto.appendChild(imgH);
                var imgF = document.createElement('img');
                imgF.src = '/patienten/'+patientId+'/foto/'+p.photo;
                imgF.alt = p.name||'';
                pdPhotoFull.innerHTML = ''; pdPhotoFull.appendChild(imgF);
            }
            pdDetails.innerHTML =
                detail('Tierart', p.species) +
                detail('Rasse', p.breed) +
                detail('Geschlecht', p.gender) +
                detail('Geburtsdatum', p.birth_date ? fmtDate(p.birth_date) : null) +
                detail('Farbe', p.color) +
                detail('Chip-Nr.', p.chip_number) +
                (p.notes ? '<div style="grid-column:1/-1;border-top:1px solid var(--glass-border);padding-top:0.5rem;margin-top:0.1rem;"><span>Notizen</span><div style="line-height:1.5;">'+esc(p.notes)+'</div></div>' : '');
            if (o) {
                var kundenNr = 'Kunden-Nr. ' + String(o.id).padStart(4,'0');
                pdOwner.innerHTML = '<a href="{{ base_path }}/tierhalter/'+o.id+'" class="pd-owner-link"><div class="pd-owner-avatar">'+esc((o.first_name||'').charAt(0)+(o.last_name||'').charAt(0))+'</div><div class="pd-owner-info"><div class="pd-owner-name">'+esc(o.first_name+' '+o.last_name)+' <span style="font-size:0.7rem;font-weight:600;color:var(--accent);background:var(--accent-soft,rgba(99,102,241,0.1));padding:0.1rem 0.45rem;border-radius:999px;margin-left:4px;">'+kundenNr+'</span></div>'+(o.phone?'<div class="pd-owner-meta">'+esc(o.phone)+'</div>':'')+(o.email?'<div class="pd-owner-meta">'+esc(o.email)+'</div>':'')+(o.street?'<div class="pd-owner-meta">'+esc(o.street)+(o.zip||o.city?', '+esc((o.zip||'')+' '+(o.city||'')).trim():'')+'</div>':'')+'</div></a>';
            } else {
                pdOwner.innerHTML = '<span style="color:var(--text-muted);font-size:0.82rem;">Kein Besitzer</span>';
            }
            if (pdForm) { pdForm.action='/patienten/'+patientId+'/timeline'; pdForm.dataset.patientId=patientId; }
            var ttSel = document.getElementById('pd-treatment-type');
            if (ttSel && data.treatment_types) {
                ttSel.innerHTML = '<option value="">— keine —</option>';
                data.treatment_types.forEach(function(tt){
                    var opt=document.createElement('option'); opt.value=tt.id; opt.textContent=tt.name; opt.dataset.color=tt.color; ttSel.appendChild(opt);
                });
            }
            /* ── Rechnungs-Badge im Modal-Header (neben Name) ── */
            var existingBadge = document.getElementById('pd-invoice-badge');
            if (existingBadge) existingBadge.remove();
            if (data.invoice_stats && (data.invoice_stats.open_count > 0 || data.invoice_stats.paid_count > 0)) {
                var ib = document.createElement('a');
                ib.id = 'pd-invoice-badge';
                ib.style.cssText = 'flex-shrink:0;padding:0.2rem 0.5rem;border-radius:5px;font-size:0.68rem;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:0.25rem;white-space:nowrap;';
                if (data.invoice_stats.open_count > 0) {
                    ib.href = '/rechnungen?search=' + encodeURIComponent(p.name || '');
                    ib.style.background = 'rgba(220,53,69,0.18)';
                    ib.style.color = '#ff6b6b';
                    ib.style.border = '1.5px solid #dc3545';
                    ib.classList.add('invoice-badge-pulse');
                    ib.textContent = data.invoice_stats.open_count + ' Rechnung' + (data.invoice_stats.open_count !== 1 ? 'en' : '') + ' offen';
                } else {
                    ib.href = '/rechnungen?search=' + encodeURIComponent(p.name || '');
                    ib.style.background = 'rgba(25,135,84,0.15)';
                    ib.style.color = '#2dbe6c';
                    ib.style.border = '1.5px solid #198754';
                    ib.textContent = '✓ Bezahlt';
                }
                /* Insert after the status badge, inside the name row */
                var nameRow = document.querySelector('#pd-header #pd-badge');
                if (nameRow && nameRow.parentNode) {
                    nameRow.parentNode.insertBefore(ib, nameRow.nextSibling);
                }
            }

            currentPatientData = data;
            renderTimeline(data.timeline, patientId);
            pdLoading.style.display = 'none';
            pdBody.style.display    = 'flex';
        })
        .catch(function() {
            pdLoading.innerHTML = '<div style="color:var(--text-muted);font-size:0.85rem;">Fehler beim Laden.</div>';
        });
}

/* Export globally */
window._gsOpenPatient   = openPatientModal;
window.showPatientModal = openPatientModal;

})();
</script>