/* ── Delete patient ───────────────────────────────────────── */
window.deletePatient = function() {
    if (!currentPatientData) return;
    if (!confirm('Patient wirklich löschen? Alle Daten werden entfernt.')) return;
    var p    = currentPatientData.patient;
    var csrf = document.querySelector('meta[name="csrf-token"]')?.content
            || document.querySelector('input[name="_csrf_token"]')?.value || '';
    var fd = new FormData(); fd.append('_csrf_token', csrf);
    fetch('/patienten/'+p.id+'/loeschen', {method:'POST',body:fd})
        .then(function(){ window.location.href='/patienten'; });
};

