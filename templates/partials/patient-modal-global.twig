            </form>
        </div>

    </div></div>
</div>

{# ── Global Patient Modal JS ───────────────────────────────── #}
<script>
(function () {
'use strict';

/* Quill wird on-demand geladen */
var quillLoaded = false;
function loadQuill(cb) {
    if (window.Quill) { cb(); return; }
    if (quillLoaded) { var t = setInterval(function(){ if(window.Quill){ clearInterval(t); cb(); } }, 50); return; }
    quillLoaded = true;
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js';
    s.onload = cb;
    document.head.appendChild(s);
    var l = document.createElement('link');
    l.rel = 'stylesheet';
    l.href = 'https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css';
    document.head.appendChild(l);
}

/* ── DOM Refs ─────────────────────────────────────────────── */
var pdLoading    = document.getElementById('pd-loading');
var pdBody       = document.getElementById('pd-body');
var pdName       = document.getElementById('pd-name');
var pdBadge      = document.getElementById('pd-badge');
var pdSpecies    = document.getElementById('pd-species');
var pdPhoto      = document.getElementById('pd-photo');
var pdPhotoFull  = document.getElementById('pd-photo-full');
var pdDetails    = document.getElementById('pd-details');
var pdOwner      = document.getElementById('pd-owner');
var pdTimeline   = document.getElementById('pd-timeline');
var pdInvoiceBtn = document.getElementById('pd-invoice-btn');
var pdEditBtn    = document.getElementById('pd-edit-btn');
var pdForm       = document.getElementById('pd-timeline-form');
var pdSearchInput = document.getElementById('pd-timeline-search');
var currentPatientData = null;
var quillEditor  = null;
var teQuill      = null;
var imgExts      = ['jpg','jpeg','png','gif','webp'];

/* ── Spin keyframes ───────────────────────────────────────── */
if (!document.getElementById('pd-spin-style')) {
    var s = document.createElement('style');
    s.id = 'pd-spin-style';
    s.textContent = '@keyframes spin{to{transform:rotate(360deg)}}';
    document.head.appendChild(s);
}

/* ── Helpers ──────────────────────────────────────────────── */
function esc(str) {
    return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function fmtDate(str) {
    if (!str) return '—';
    var d = new Date(str.replace(' ', 'T'));
    return d.toLocaleDateString('de-DE', {day:'2-digit',month:'2-digit',year:'numeric'});
}
function fmtDateTime(str) {
    if (!str) return '—';
    var d = new Date(str.replace(' ', 'T'));
    return d.toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit',year:'numeric'}) + ' ' +
           d.toLocaleTimeString('de-DE',{hour:'2-digit',minute:'2-digit'});
}
function typeIcon(t) {
    return {note:'📝', treatment:'💊', photo:'📷', document:'📄', other:'📌'}[t] || '📌';
}
function detail(label, value) {
    if (!value) return '';
    return '<div><span>'+esc(label)+'</span><div>'+esc(value)+'</div></div>';
}

/* ── Quill init ───────────────────────────────────────────── */
function initQuill() {
    loadQuill(function() {
        if (quillEditor) return;
        var el = document.getElementById('pd-quill-editor');
        if (!el) return;
        quillEditor = new Quill(el, {
            theme: 'snow',
            placeholder: 'Notizen, Befunde, Behandlungsschritte...',
            modules: { toolbar: [['bold','italic','underline','strike'],[{list:'ordered'},{list:'bullet'}],['blockquote'],[{color:[]}],['clean']] }
        });
    });
}
function initTeQuill() {
    loadQuill(function() {
        if (teQuill) return;
        var el = document.getElementById('te-quill-editor');
        if (!el) return;
        teQuill = new Quill(el, {
            theme: 'snow',
            placeholder: 'Inhalt...',
            modules: { toolbar: [['bold','italic','underline','strike'],[{list:'ordered'},{list:'bullet'}],['blockquote'],[{color:[]}],['clean']] }
        });
    });
}

/* ── File Viewer ──────────────────────────────────────────── */
var fvOverlay = document.getElementById('fileviewer-overlay');
var fvBody2   = document.getElementById('fv-body');
var fvName    = document.getElementById('fv-filename');
var fvDl      = document.getElementById('fv-download');
var fvOpen    = document.getElementById('fv-open');
var fvClose   = document.getElementById('fv-close');

function isMobile() { return /Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent); }

function openViewer(src, filename) {
    fvName.textContent = filename;
    fvDl.href = src; fvDl.download = filename;
    if (fvOpen) fvOpen.href = src;
    fvBody2.innerHTML = '';
    var ext = (filename.split('.').pop() || '').toLowerCase();
    if (imgExts.includes(ext)) {
        var img = document.createElement('img');
        img.src = src; img.alt = filename;
        img.style.cssText = 'max-width:100%;max-height:100%;object-fit:contain;border-radius:4px;';
        fvBody2.appendChild(img);
    } else if (ext === 'pdf') {
        if (isMobile()) {
            fvBody2.innerHTML = '<div style="text-align:center;color:rgba(255,255,255,0.85);padding:2rem;"><div style="font-size:1rem;font-weight:600;margin-bottom:1rem;">'+esc(filename)+'</div><div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap;"><a href="'+src+'" target="_blank" rel="noopener" style="background:#4f7cff;color:#fff;padding:0.65rem 1.4rem;border-radius:8px;text-decoration:none;">Im Browser öffnen</a><a href="'+src+'" download="'+esc(filename)+'" style="background:rgba(255,255,255,0.15);color:#fff;padding:0.65rem 1.4rem;border-radius:8px;text-decoration:none;">Herunterladen</a></div></div>';
        } else {
            var fr = document.createElement('iframe');
            fr.src = src; fr.style.cssText = 'width:100%;height:100%;border:none;';
            fr.title = filename; fvBody2.appendChild(fr);
        }
    } else {
        fvBody2.innerHTML = '<div style="text-align:center;color:rgba(255,255,255,0.7);padding:3rem;"><div style="font-size:1rem;font-weight:600;margin-bottom:0.5rem;">'+esc(filename)+'</div><a href="'+src+'" download="'+esc(filename)+'" style="background:#4f7cff;color:#fff;padding:0.6rem 1.4rem;border-radius:8px;text-decoration:none;">Herunterladen</a></div>';
    }
    fvOverlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';
}
function closeViewer() {
    fvOverlay.style.display = 'none';
    fvBody2.innerHTML = '';
    document.body.style.overflow = '';
}
if (fvClose) fvClose.addEventListener('click', closeViewer);
if (fvOverlay) fvOverlay.addEventListener('click', function(e){ if(e.target===fvOverlay) closeViewer(); });

/* ── Reset Modal ──────────────────────────────────────────── */
function resetModal() {
    pdLoading.style.display = 'flex';
    pdBody.style.display    = 'none';
    pdName.textContent      = '';
    pdBadge.style.display   = 'none';
    pdSpecies.textContent   = '';
    pdPhoto.innerHTML       = '<svg width="24" height="24" fill="none" viewBox="0 0 24 24" style="opacity:0.3;"><path stroke="currentColor" stroke-width="1.5" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>';
    pdPhotoFull.innerHTML   = '<svg width="48" height="48" fill="none" viewBox="0 0 24 24" style="opacity:0.2;"><path stroke="currentColor" stroke-width="1.5" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>';
    pdDetails.innerHTML     = '';
    pdOwner.innerHTML       = '';
    pdTimeline.innerHTML    = '';
    if (pdSearchInput) pdSearchInput.value = '';
}

/* ── Timeline render ──────────────────────────────────────── */
function renderTimeline(timeline, patientId) {
    if (!timeline || !timeline.length) {
        pdTimeline.innerHTML = '<div style="text-align:center;padding:2rem 1rem;color:var(--text-muted);font-size:0.85rem;">Noch keine Einträge</div>';
        return;
    }
    var html = '<div class="timeline">';
    timeline.forEach(function (e) {
        var hasAttach = e.attachment;
        var ext = hasAttach ? (e.attachment.split('.').pop() || '').toLowerCase() : '';
        var isImg = imgExts.includes(ext);
        var src = hasAttach ? '/patienten/'+patientId+'/dokumente/'+encodeURIComponent(e.attachment) : '';
        var attachHtml = '';
        if (hasAttach) {
            if (isImg) {
                attachHtml = '<div class="mt-2"><a href="'+src+'" data-lightbox-modal="'+src+'" data-filename="'+esc(e.attachment)+'" style="cursor:pointer;display:inline-block;"><img src="'+src+'" alt="'+esc(e.attachment)+'" style="max-height:100px;max-width:100%;border-radius:6px;border:1px solid var(--glass-border);display:block;"></a></div>';
            } else {
                attachHtml = '<div class="mt-2"><a href="'+src+'" data-lightbox-modal="'+src+'" data-filename="'+esc(e.attachment)+'" class="btn btn-secondary btn-sm" style="font-size:0.78rem;">📎 '+esc(e.attachment)+'</a></div>';
            }
        }
        html += '<div class="timeline-item" data-entry-id="'+e.id+'">';
        html += '<div class="timeline-dot timeline-dot-'+esc(e.type)+'"></div>';
        html += '<div class="timeline-card">';
        html += '<div class="timeline-meta">';
        html += '<div style="display:flex;align-items:center;gap:0.4rem;flex-wrap:wrap;">';
        html += '<span class="text-xs">'+typeIcon(e.type)+'</span>';
        if (e.status_badge) html += '<span class="badge badge-primary" style="font-size:0.62rem;">'+esc(e.status_badge)+'</span>';
        html += '<span class="timeline-date">'+fmtDateTime(e.entry_date)+'</span>';
        if (e.treatment_type_name) html += '<span style="display:inline-block;padding:0.12rem 0.5rem;border-radius:999px;font-size:0.62rem;font-weight:600;background:'+esc(e.treatment_type_color)+'22;color:'+esc(e.treatment_type_color)+';border:1px solid '+esc(e.treatment_type_color)+'44;">'+esc(e.treatment_type_name)+'</span>';
        html += '</div>';
        html += '<div style="display:flex;align-items:center;gap:0.25rem;">';
        if (e.user_name) html += '<span class="timeline-author">'+esc(e.user_name)+'</span>';
        html += '<button type="button" class="tl-edit-btn" data-entry=\''+JSON.stringify(e)+'\' style="width:24px;height:24px;padding:0;color:var(--text-muted);border:none;background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;border-radius:4px;" title="Bearbeiten"><svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>';
        html += '<button type="button" class="tl-del-btn" data-entry-id="'+e.id+'" style="width:24px;height:24px;padding:0;color:var(--text-muted);border:none;background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;border-radius:4px;" title="Löschen"><svg width="12" height="12" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10 11v6M14 11v6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 6V4h6v2"/></svg></button>';
        html += '</div></div>';
        if (e.title) html += '<div class="timeline-title">'+esc(e.title)+'</div>';
        if (e.content) html += '<div class="timeline-content ql-view">'+e.content+'</div>';
        html += attachHtml;
        html += '</div></div>';
    });
    html += '</div>';
    pdTimeline.innerHTML = html;

    pdTimeline.querySelectorAll('[data-lightbox-modal]').forEach(function (el) {
        el.addEventListener('click', function (e) { e.preventDefault(); openViewer(el.dataset.lightboxModal, el.dataset.filename); });
    });
    pdTimeline.querySelectorAll('.tl-edit-btn').forEach(function (btn) {
        btn.addEventListener('click', function () { openTimelineEditModal(JSON.parse(btn.dataset.entry), btn.closest('[data-entry-id]')?.closest('.timeline-item')?.dataset.entryId || currentPatientData?.patient?.id); });
    });
    pdTimeline.querySelectorAll('.tl-del-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            if (!confirm('Eintrag wirklich löschen?')) return;
            var entryId = btn.dataset.entryId;
            var patId   = currentPatientData ? currentPatientData.patient.id : null;
            if (!patId) return;
            var csrf = document.getElementById('te-csrf')?.value || '';
            var fd = new FormData(); fd.append('_csrf_token', csrf);
            fetch('/patienten/'+patId+'/timeline/'+entryId+'/delete-json', {method:'POST',body:fd})
                .then(function(r){return r.json();})
                .then(function(data){ if(data.ok) renderTimeline(data.timeline, patId); })
                .catch(function(){ alert('Fehler beim Löschen.'); });
        });
    });
}

/* ── Timeline Edit Modal ─────────────────────────────────── */
function openTimelineEditModal(entry, patientId) {
    initTeQuill();
    setTimeout(function() {
        document.getElementById('te-entry-id').value   = entry.id;
        document.getElementById('te-patient-id').value = patientId || (currentPatientData ? currentPatientData.patient.id : '');
        var tySel = document.getElementById('te-type');
        for (var i=0;i<tySel.options.length;i++) tySel.options[i].selected = tySel.options[i].value === (entry.type||'note');
        var ttSel = document.getElementById('te-treatment-type');
        ttSel.innerHTML = '<option value="">— keine —</option>';
        if (currentPatientData && currentPatientData.treatment_types) {
            currentPatientData.treatment_types.forEach(function(tt){
                var o = document.createElement('option'); o.value=tt.id; o.textContent=tt.name;
                o.selected = parseInt(entry.treatment_type_id) === parseInt(tt.id);
                ttSel.appendChild(o);
            });
        }
        if (entry.entry_date) {
            var d = new Date(entry.entry_date.replace(' ','T'));
            var pad = function(n){return String(n).padStart(2,'0');};
            document.getElementById('te-date').value = d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate())+'T'+pad(d.getHours())+':'+pad(d.getMinutes());
        }
        var stSel = document.getElementById('te-status');
        for (var i=0;i<stSel.options.length;i++) stSel.options[i].selected = stSel.options[i].value === (entry.status_badge||'');
        document.getElementById('te-title').value = entry.title || '';
        if (teQuill) {
            if (entry.content) { teQuill.clipboard.dangerouslyPasteHTML(entry.content); }
            else { teQuill.setContents([]); }
        }
        bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-timeline-edit')).show();
    }, 100);
}

var teSaveBtn = document.getElementById('te-save-btn');
if (teSaveBtn) {
    teSaveBtn.addEventListener('click', function () {
        initTeQuill();
        var entryId   = document.getElementById('te-entry-id').value;
        var patientId = document.getElementById('te-patient-id').value;
        var csrf      = document.getElementById('te-csrf').value;
        if (!entryId || !patientId) return;
        if (teQuill) document.getElementById('te-content').value = teQuill.root.innerHTML;
        var fd = new FormData();
        fd.append('_csrf_token', csrf);
        fd.append('type',              document.getElementById('te-type').value);
        fd.append('treatment_type_id', document.getElementById('te-treatment-type').value);
        fd.append('title',             document.getElementById('te-title').value);
        fd.append('content',           document.getElementById('te-content').value);
        fd.append('status_badge',      document.getElementById('te-status').value);
        fd.append('entry_date',        document.getElementById('te-date').value);
        teSaveBtn.disabled = true; teSaveBtn.textContent = 'Speichern…';
        fetch('/patienten/'+patientId+'/timeline/'+entryId+'/update-json', {method:'POST',body:fd})
            .then(function(r){return r.json();})
            .then(function(data){
                if(data.ok){
                    bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-timeline-edit')).hide();
                    renderTimeline(data.timeline, patientId);
                }
            })
            .catch(function(){ alert('Fehler beim Speichern.'); })
            .finally(function(){ teSaveBtn.disabled=false; teSaveBtn.textContent='Speichern'; });
    });
}

