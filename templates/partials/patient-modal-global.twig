/* ── Open patient modal (global entry point) ──────────────── */
function openPatientModal(patientId) {
    resetModal();
    bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-patient-detail')).show();
    initQuill();

    fetch('/patienten/' + patientId + '/json')
        .then(function(r){ return r.json(); })
        .then(function(data) {
            var p = data.patient;
            var o = data.owner;
            pdName.textContent = p.name || '';
            if (p.status) {
                pdBadge.textContent  = p.status;
                pdBadge.className    = 'badge badge-' + p.status.toLowerCase().replace(/ /g,'_');
                pdBadge.style.display = '';
            }
            pdSpecies.textContent = [p.species,p.breed].filter(Boolean).join(' · ');
            if (p.photo) {
                var imgH = document.createElement('img');
                imgH.src = '/patienten/'+patientId+'/foto/'+p.photo;
                imgH.style.cssText = 'width:100%;height:100%;object-fit:cover;';
                pdPhoto.innerHTML = ''; pdPhoto.appendChild(imgH);
                var imgF = document.createElement('img');
                imgF.src = '/patienten/'+patientId+'/foto/'+p.photo;
                imgF.alt = p.name||'';
                pdPhotoFull.innerHTML = ''; pdPhotoFull.appendChild(imgF);
            }
            pdDetails.innerHTML =
                detail('Tierart', p.species) +
                detail('Rasse', p.breed) +
                detail('Geschlecht', p.gender) +
                detail('Geburtsdatum', p.birth_date ? fmtDate(p.birth_date) : null) +
                detail('Farbe', p.color) +
                detail('Chip-Nr.', p.chip_number) +
                (p.notes ? '<div style="grid-column:1/-1;border-top:1px solid var(--glass-border);padding-top:0.5rem;margin-top:0.1rem;"><span>Notizen</span><div style="line-height:1.5;">'+esc(p.notes)+'</div></div>' : '');
            if (o) {
                var kundenNr = 'Kunden-Nr. ' + String(o.id).padStart(4,'0');
                pdOwner.innerHTML = '<a href="/tierhalter/'+o.id+'" class="pd-owner-link"><div class="pd-owner-avatar">'+esc((o.first_name||'').charAt(0)+(o.last_name||'').charAt(0))+'</div><div class="pd-owner-info"><div class="pd-owner-name">'+esc(o.first_name+' '+o.last_name)+' <span style="font-size:0.7rem;font-weight:600;color:var(--accent);background:var(--accent-soft,rgba(99,102,241,0.1));padding:0.1rem 0.45rem;border-radius:999px;margin-left:4px;">'+kundenNr+'</span></div>'+(o.phone?'<div class="pd-owner-meta">'+esc(o.phone)+'</div>':'')+(o.email?'<div class="pd-owner-meta">'+esc(o.email)+'</div>':'')+(o.street?'<div class="pd-owner-meta">'+esc(o.street)+(o.zip||o.city?', '+esc((o.zip||'')+' '+(o.city||'')).trim():'')+'</div>':'')+'</div></a>';
            } else {
                pdOwner.innerHTML = '<span style="color:var(--text-muted);font-size:0.82rem;">Kein Besitzer</span>';
            }
            if (pdForm) { pdForm.action='/patienten/'+patientId+'/timeline'; pdForm.dataset.patientId=patientId; }
            var ttSel = document.getElementById('pd-treatment-type');
            if (ttSel && data.treatment_types) {
                ttSel.innerHTML = '<option value="">— keine —</option>';
                data.treatment_types.forEach(function(tt){
                    var opt=document.createElement('option'); opt.value=tt.id; opt.textContent=tt.name; opt.dataset.color=tt.color; ttSel.appendChild(opt);
                });
            }
            currentPatientData = data;
            renderTimeline(data.timeline, patientId);
            pdLoading.style.display = 'none';
            pdBody.style.display    = 'flex';
        })
        .catch(function() {
            pdLoading.innerHTML = '<div style="color:var(--text-muted);font-size:0.85rem;">Fehler beim Laden.</div>';
        });
}

/* Export globally */
window._gsOpenPatient   = openPatientModal;
window.showPatientModal = openPatientModal;

})();
</script>