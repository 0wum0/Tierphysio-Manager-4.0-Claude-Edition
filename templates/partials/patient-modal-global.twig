{# ═══════════════════════════════════════════════════════════
   GLOBAL PATIENT DETAIL MODAL
   Eingebunden in layout.twig — steht auf jeder Seite bereit.
   Geöffnet via: window._gsOpenPatient(id)
   ═══════════════════════════════════════════════════════════ #}

{# ── Patient Detail Modal ─────────────────────────────────── #}
<div class="modal fade" id="modal-patient-detail" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">

        <div id="pd-header" style="padding:0.6rem 1rem;border-bottom:1px solid var(--glass-border);flex-shrink:0;display:flex;align-items:center;gap:0.65rem;min-width:0;">
            <div id="pd-photo" style="width:38px;height:38px;border-radius:50%;overflow:hidden;flex-shrink:0;background:var(--bg-elevated);display:flex;align-items:center;justify-content:center;">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" style="opacity:0.3;"><path stroke="currentColor" stroke-width="1.5" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </div>
            <div style="min-width:0;flex-shrink:1;flex-grow:0;">
                <div style="display:flex;align-items:center;gap:0.35rem;">
                    <span id="pd-name" style="font-size:0.95rem;font-weight:700;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:160px;"></span>
                    <span id="pd-badge" class="badge" style="display:none;flex-shrink:0;"></span>
                </div>
                <div id="pd-species" style="font-size:0.72rem;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:160px;"></div>
            </div>
            <div style="display:flex;gap:0.35rem;align-items:center;overflow-x:auto;flex-shrink:0;-webkit-overflow-scrolling:touch;margin-left:auto;">
                <button id="pd-invoice-btn" type="button" class="btn btn-secondary btn-sm" style="flex-shrink:0;padding:0.3rem 0.6rem;">
                    <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
                    <span class="d-none d-sm-inline">Rechnung</span>
                </button>
                <button id="pd-pdf-btn" type="button" class="btn btn-secondary btn-sm" onclick="exportPatientPDF()" style="flex-shrink:0;padding:0.3rem 0.6rem;">
                    <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    <span class="d-none d-sm-inline">Akte als PDF</span>
                </button>
                <button id="pd-edit-btn" type="button" class="btn btn-primary btn-sm" style="flex-shrink:0;padding:0.3rem 0.6rem;">
                    <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    <span class="d-none d-sm-inline">Bearbeiten</span>
                </button>
                <button id="pd-delete-btn" type="button" class="btn btn-danger btn-sm" style="flex-shrink:0;padding:0.3rem 0.6rem;" onclick="deletePatient()">
                    <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10 11v6M14 11v6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 6V4h6v2"/></svg>
                    <span class="d-none d-sm-inline">Löschen</span>
                </button>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen" style="flex-shrink:0;"></button>
        </div>

        <div id="pd-loading" style="display:flex;align-items:center;justify-content:center;padding:3rem;flex:1;">
            <div style="width:32px;height:32px;border:3px solid var(--glass-border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.8s linear infinite;"></div>
        </div>

        <div id="pd-body" style="display:none;overflow-y:auto;flex:1;padding:1.5rem 1.25rem;flex-direction:column;gap:1.5rem;">

            <div class="pd-info-card" style="flex-shrink:0;">
                <div id="pd-photo-full" class="pd-info-photo">
                    <svg width="36" height="36" fill="none" viewBox="0 0 24 24" style="opacity:0.2;"><path stroke="currentColor" stroke-width="1.5" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </div>
                <div class="pd-info-divider"></div>
                <div class="pd-info-col">
                    <div class="pd-info-col-label">Patient</div>
                    <div id="pd-details" class="pd-info-grid"></div>
                </div>
                <div class="pd-info-divider"></div>
                <div class="pd-info-col">
                    <div class="pd-info-col-label">Besitzer</div>
                    <div id="pd-owner"></div>
                </div>
            </div>

            <div class="pd-entry-section">
                <div class="pd-section-label">Neuer Akte-Eintrag</div>
                <form id="pd-timeline-form" method="POST" enctype="multipart/form-data" class="pd-entry-form">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                    <div class="pd-form-grid4">
                        <div class="pd-field">
                            <label class="pd-label">Typ</label>
                            <select name="type" class="pd-select" data-no-cs>
                                <option value="note">📝 Notiz</option>
                                <option value="treatment">💊 Behandlung</option>
                                <option value="photo">📷 Foto</option>
                                <option value="document">📄 Dokument</option>
                                <option value="other">📌 Sonstiges</option>
                            </select>
                        </div>
                        <div class="pd-field">
                            <label class="pd-label">Behandlungsart</label>
                            <select name="treatment_type_id" id="pd-treatment-type" class="pd-select" data-no-cs>
                                <option value="">— keine —</option>
                            </select>
                        </div>
                        <div class="pd-field">
                            <label class="pd-label">Datum</label>
                            <input type="datetime-local" name="entry_date" class="pd-input" value="{{ 'now'|date('Y-m-d\\TH:i') }}">
                        </div>
                        <div class="pd-field">
                            <label class="pd-label">Status</label>
                            <select name="status_badge" class="pd-select" data-no-cs>
                                <option value="">— kein —</option>
                                <option value="Schmerzfrei">Schmerzfrei</option>
                                <option value="In Behandlung">In Behandlung</option>
                                <option value="Kontrolltermin">Kontrolltermin</option>
                                <option value="Notfall">Notfall</option>
                                <option value="Gebessert">Gebessert</option>
                                <option value="Entlassen">Entlassen</option>
                            </select>
                        </div>
                    </div>
                    <div class="pd-field">
                        <label class="pd-label">Titel</label>
                        <input type="text" name="title" class="pd-input" placeholder="Kurzer Titel...">
                    </div>
                    <div class="pd-field">
                        <label class="pd-label">Inhalt</label>
                        <div id="pd-quill-editor"></div>
                        <input type="hidden" name="content" id="pd-content-input">
                    </div>
                    <div class="pd-form-footer">
                        <div class="pd-field" style="flex:1;min-width:0;">
                            <label class="pd-label">Anhang</label>
                            <input type="file" name="attachment" id="pd-attachment" class="pd-file" accept="image/*,application/pdf,.doc,.docx">
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm pd-submit-btn">
                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            Speichern
                        </button>
                    </div>
                </form>
            </div>

            <div style="border-top:1px solid var(--glass-border);margin-top:0.5rem;"></div>

            <div style="display:flex;align-items:center;gap:0.5rem;margin-top:0.25rem;">
                <div style="position:relative;flex:1;">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="position:absolute;left:0.65rem;top:50%;transform:translateY(-50%);color:var(--text-muted);pointer-events:none;"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/><line x1="21" y1="21" x2="16.65" y2="16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    <input id="pd-timeline-search" type="text" class="form-control" placeholder="Timeline durchsuchen..." style="padding-left:2.1rem;font-size:0.83rem;">
                </div>
            </div>

            <div style="margin-top:0.25rem;">
                <div style="font-size:0.7rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.75rem;">Akte</div>
                <div id="pd-timeline" class="timeline"></div>
            </div>

        </div>

    </div></div>
</div>

{# ── Timeline-Eintrag bearbeiten Modal ─────────────────────── #}
<div class="modal fade" id="modal-timeline-edit" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">Eintrag bearbeiten</h3>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="te-csrf" value="{{ csrf_token }}">
            <input type="hidden" id="te-entry-id" value="">
            <input type="hidden" id="te-patient-id" value="">
            <div class="pd-form-grid4" style="margin-bottom:0.65rem;">
                <div class="pd-field">
                    <label class="pd-label">Typ</label>
                    <select id="te-type" class="pd-select">
                        <option value="note">📝 Notiz</option>
                        <option value="treatment">💊 Behandlung</option>
                        <option value="photo">📷 Foto</option>
                        <option value="document">📄 Dokument</option>
                        <option value="other">📌 Sonstiges</option>
                    </select>
                </div>
                <div class="pd-field">
                    <label class="pd-label">Behandlungsart</label>
                    <select id="te-treatment-type" class="pd-select">
                        <option value="">— keine —</option>
                    </select>
                </div>
                <div class="pd-field">
                    <label class="pd-label">Datum</label>
                    <input type="datetime-local" id="te-date" class="pd-input">
                </div>
                <div class="pd-field">
                    <label class="pd-label">Status</label>
                    <select id="te-status" class="pd-select">
                        <option value="">— kein —</option>
                        <option value="Schmerzfrei">Schmerzfrei</option>
                        <option value="In Behandlung">In Behandlung</option>
                        <option value="Kontrolltermin">Kontrolltermin</option>
                        <option value="Notfall">Notfall</option>
                        <option value="Gebessert">Gebessert</option>
                        <option value="Entlassen">Entlassen</option>
                    </select>
                </div>
            </div>
            <div class="pd-field" style="margin-bottom:0.65rem;">
                <label class="pd-label">Titel</label>
                <input type="text" id="te-title" class="pd-input" placeholder="Kurzer Titel...">
            </div>
            <div class="pd-field">
                <label class="pd-label">Inhalt</label>
                <div id="te-quill-editor"></div>
                <input type="hidden" id="te-content" value="">
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
            <button type="button" class="btn btn-primary" id="te-save-btn">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/></svg>
                Speichern
            </button>
        </div>
    </div></div>
</div>

{# ── Edit Patient Modal ─────────────────────────────────────── #}
<div class="modal fade" id="modal-edit-patient-inline" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title" id="edit-modal-title">Patient bearbeiten</h3>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
        </div>
        <form id="edit-patient-form" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="modal-body" style="overflow-y:auto;max-height:72vh;">
                <div class="form-group mb-4">
                    <label class="form-label">Profilbild</label>
                    <div class="flex items-center gap-3">
                        <div id="edit-photo-preview" style="width:64px;height:64px;border-radius:50%;overflow:hidden;background:var(--bg-elevated);display:flex;align-items:center;justify-content:center;flex-shrink:0;border:2px solid var(--glass-border);">
                            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" style="opacity:0.3;"><path stroke="currentColor" stroke-width="1.5" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/></svg>
                        </div>
                        <div style="flex:1;">
                            <input type="file" name="photo" id="edit-photo-input" accept="image/*" class="form-control" style="font-size:0.8rem;padding:0.4rem;">
                            <div class="form-hint">JPG, PNG, WEBP — max. 5 MB</div>
                        </div>
                    </div>
                </div>
                <div class="form-grid form-grid-2">
                    <div class="form-group">
                        <label class="form-label">Name *</label>
                        <input type="text" name="name" id="edit-name" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Tierart</label>
                        <input type="text" name="species" id="edit-species" class="form-control">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Rasse</label>
                        <input type="text" name="breed" id="edit-breed" class="form-control">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Geburtsdatum</label>
                        <input type="date" name="birth_date" id="edit-birth" class="form-control">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Geschlecht</label>
                        <select name="gender" id="edit-gender" class="form-control">
                            <option value="unbekannt">Unbekannt</option>
                            <option value="männlich">Männlich</option>
                            <option value="weiblich">Weiblich</option>
                            <option value="kastriert">Kastriert</option>
                            <option value="sterilisiert">Sterilisiert</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Farbe</label>
                        <input type="text" name="color" id="edit-color" class="form-control">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Chip-Nr.</label>
                        <input type="text" name="chip_number" id="edit-chip" class="form-control">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <select name="status" id="edit-status" class="form-control">
                            <option value="aktiv">Aktiv</option>
                            <option value="in_behandlung">In Behandlung</option>
                            <option value="schmerzfrei">Schmerzfrei</option>
                            <option value="kontrolltermin">Kontrolltermin</option>
                            <option value="inaktiv">Inaktiv</option>
                            <option value="verstorben">⚫ Verstorben</option>
                        </select>
                    </div>
                </div>
                <div class="form-group mt-3">
                    <label class="form-label">Tierhalter</label>
                    <select name="owner_id" id="edit-owner" class="form-control"></select>
                </div>
                <div class="form-group mt-3">
                    <label class="form-label">Notizen</label>
                    <textarea name="notes" id="edit-notes" class="form-control" rows="3"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <button type="submit" class="btn btn-primary">Speichern</button>
            </div>
        </form>
    </div></div>
</div>

{# ── Datei-Viewer ──────────────────────────────────────────── #}
<div id="fileviewer-overlay" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.88);align-items:center;justify-content:center;flex-direction:column;">
    <div style="position:relative;width:96vw;max-width:960px;height:92vh;display:flex;flex-direction:column;background:var(--bg-surface,#1a1a2e);border-radius:12px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.7);">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:0.6rem 0.85rem;border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;gap:0.5rem;">
            <span id="fv-filename" style="font-size:0.82rem;font-weight:600;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;min-width:0;flex:1;"></span>
            <div style="display:flex;gap:0.4rem;align-items:center;flex-shrink:0;">
                <a id="fv-open" href="" target="_blank" rel="noopener" style="background:rgba(255,255,255,0.12);color:#fff;border:none;padding:0.3rem 0.65rem;border-radius:6px;font-size:0.78rem;text-decoration:none;display:flex;align-items:center;gap:0.35rem;">Öffnen</a>
                <a id="fv-download" href="" download style="background:rgba(255,255,255,0.12);color:#fff;border:none;padding:0.3rem 0.65rem;border-radius:6px;font-size:0.78rem;text-decoration:none;display:flex;align-items:center;gap:0.35rem;">Laden</a>
                <button id="fv-close" style="background:rgba(255,255,255,0.12);border:none;color:#fff;width:32px;height:32px;border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                </button>
            </div>
        </div>
        <div id="fv-body" style="flex:1;overflow:auto;display:flex;align-items:center;justify-content:center;background:#111;"></div>
    </div>
</div>

{# ── Invoice Create Modal ──────────────────────────────────── #}
<div class="modal fade" id="modal-invoice-create" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">

        <div class="modal-header" style="padding:0.65rem 1rem;">
            <h5 class="modal-title" style="font-size:0.95rem;font-weight:700;">
                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" style="vertical-align:middle;margin-right:6px;"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg>
                Neue Rechnung erstellen
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
        </div>

        <div id="im-loading" style="display:flex;align-items:center;justify-content:center;padding:3rem;">
            <div style="width:28px;height:28px;border:3px solid var(--glass-border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.8s linear infinite;"></div>
        </div>

        <div id="im-body" class="modal-body" style="display:none;padding:1.25rem;overflow-y:auto;">
            <form action="{{ base_path }}/rechnungen" method="POST" id="im-form" style="display:contents;">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <input type="hidden" name="_send_email" id="im-send-email-flag" value="0">

                <div>
                    <div class="flex gap-4" style="align-items:flex-start;flex-wrap:wrap;">

                        {# Left: Form Fields #}
                        <div style="flex:1;min-width:280px;display:flex;flex-direction:column;gap:1rem;">

                            {# Header: Zahlungsart + Stammdaten #}
                            <div class="glass-card">
                                <h3 class="font-semibold mb-3" style="font-size:0.9rem;">Rechnung</h3>

                                {# Zahlungsart #}
                                <div class="form-group mb-3">
                                    <label class="form-label">Zahlungsart</label>
                                    <div class="flex gap-2">
                                        <label class="flex items-center gap-2 px-3 py-2 rounded" id="im-lbl-rechnung" style="cursor:pointer;border:2px solid var(--accent);background:rgba(99,102,241,0.08);flex:1;justify-content:center;">
                                            <input type="radio" name="payment_method" value="rechnung" checked style="display:none;">
                                            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg>
                                            <span class="font-semibold text-sm">Rechnung</span>
                                        </label>
                                        <label class="flex items-center gap-2 px-3 py-2 rounded" id="im-lbl-bar" style="cursor:pointer;border:2px solid var(--glass-border);flex:1;justify-content:center;">
                                            <input type="radio" name="payment_method" value="bar" style="display:none;">
