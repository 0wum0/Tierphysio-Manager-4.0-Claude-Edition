if (pdInvoiceBtn) {
    pdInvoiceBtn.addEventListener('click', function () {
        if (!currentPatientData) return;
        window.location.href = '/rechnungen/neu?patient_id=' + currentPatientData.patient.id;
    });
}

/* ── Edit button ──────────────────────────────────────────── */
if (pdEditBtn) {
    pdEditBtn.addEventListener('click', function () {
        if (!currentPatientData) return;
        var p = currentPatientData.patient;
        var o = currentPatientData.owner;
        var form = document.getElementById('edit-patient-form');
        form.action = '/patienten/' + p.id;
        document.getElementById('edit-modal-title').textContent = (p.name||'Patient') + ' bearbeiten';
        document.getElementById('edit-name').value    = p.name    || '';
        document.getElementById('edit-species').value = p.species || '';
        document.getElementById('edit-breed').value   = p.breed   || '';
        document.getElementById('edit-birth').value   = p.birth_date ? p.birth_date.slice(0,10) : '';
        document.getElementById('edit-color').value   = p.color   || '';
        document.getElementById('edit-chip').value    = p.chip_number || '';
        document.getElementById('edit-notes').value   = p.notes   || '';
        var gSel = document.getElementById('edit-gender');
        for (var i=0;i<gSel.options.length;i++) gSel.options[i].selected = gSel.options[i].value === (p.gender||'unbekannt');
        var sSel = document.getElementById('edit-status');
        for (var i=0;i<sSel.options.length;i++) sSel.options[i].selected = sSel.options[i].value === (p.status||'aktiv');
        /* Owner dropdown */
        var oSel = document.getElementById('edit-owner');
        if (oSel.options.length <= 1) {
            fetch('/api/tierhalter/suche?q=')
                .then(function(r){return r.json();})
                .then(function(owners){
                    oSel.innerHTML = '<option value="">— wählen —</option>';
                    owners.forEach(function(owner){
                        var opt = document.createElement('option');
                        opt.value = owner.id;
                        opt.textContent = owner.last_name + ', ' + owner.first_name;
                        opt.selected = parseInt(owner.id) === parseInt(p.owner_id||(o&&o.id));
                        oSel.appendChild(opt);
                    });
                });
        } else {
            for (var i=0;i<oSel.options.length;i++) oSel.options[i].selected = parseInt(oSel.options[i].value) === parseInt(p.owner_id||(o&&o.id));
        }
        var prev = document.getElementById('edit-photo-preview');
        if (p.photo) {
            prev.innerHTML = '<img src="/patienten/'+p.id+'/foto/'+encodeURIComponent(p.photo)+'" style="width:100%;height:100%;object-fit:cover;">';
        } else {
            prev.innerHTML = '<svg width="28" height="28" fill="none" viewBox="0 0 24 24" style="opacity:0.3;"><path stroke="currentColor" stroke-width="1.5" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/></svg>';
        }
        bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-edit-patient-inline')).show();
    });
}

/* ── Edit form AJAX ───────────────────────────────────────── */
var editForm = document.getElementById('edit-patient-form');
if (editForm) {
    editForm.addEventListener('submit', function (e) {
        e.preventDefault();
        var btn = editForm.querySelector('button[type="submit"]');
        if (btn) { btn.disabled=true; btn.textContent='Speichern…'; }
        var fd = new FormData(editForm);
        fetch(editForm.action, {method:'POST', headers:{'X-Requested-With':'XMLHttpRequest'}, body:fd})
            .then(function(r){return r.json();})
            .then(function(data){
                if (data.ok) {
                    if (currentPatientData && data.patient) {
                        currentPatientData.patient = data.patient;
                        pdName.textContent    = data.patient.name || '';
                        pdSpecies.textContent = [data.patient.species,data.patient.breed].filter(Boolean).join(' · ');
                    }
                    bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-edit-patient-inline')).hide();
                    bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-patient-detail')).show();
                }
            })
            .catch(function(){ alert('Fehler beim Speichern.'); })
            .finally(function(){ if(btn){btn.disabled=false;btn.textContent='Speichern';} });
    });
}

/* ── Edit photo preview ───────────────────────────────────── */
var editPhotoInput = document.getElementById('edit-photo-input');
if (editPhotoInput) {
    editPhotoInput.addEventListener('change', function () {
        var file = this.files && this.files[0];
        if (!file) return;
        var reader = new FileReader();
        reader.onload = function(ev) {
            document.getElementById('edit-photo-preview').innerHTML = '<img src="'+ev.target.result+'" style="width:100%;height:100%;object-fit:cover;">';
        };
        reader.readAsDataURL(file);
