{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}

<div class="page-header">
    <div class="d-flex align-items-center gap-2 min-width-0">
        <a href="/mailbox/posteingang" class="btn btn-outline-secondary btn-sm flex-shrink-0">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="15 18 9 12 15 6"/></svg>
        </a>
        <h1 class="page-title text-truncate mb-0" style="font-size:1.1rem;">{{ message.subject }}</h1>
    </div>
    <div class="d-flex gap-2">
        <a href="/mailbox/neu?to={{ message.from|url_encode }}&subject={{ ('Re: ' ~ message.subject)|url_encode }}&reply={{ message.uid }}&folder={{ folder|url_encode }}"
           class="btn btn-primary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" class="me-1"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="9 17 4 12 9 7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M20 18v-2a4 4 0 0 0-4-4H4"/></svg>
            Antworten
        </a>
        <form action="/mailbox/loeschen/{{ message.uid }}" method="POST" onsubmit="return confirm('Nachricht löschen?')">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <input type="hidden" name="folder" value="{{ folder }}">
            <button type="submit" class="btn btn-outline-danger btn-sm">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M10 11v6M14 11v6"/></svg>
            </button>
        </form>
    </div>
</div>

<div class="main-content">
<div class="row g-3">
<div class="col-12 col-xl-9">

    {# ── Message Header ── #}
    <div class="panel mb-0">
        <div class="panel-content p-4">

            <div class="d-flex align-items-start gap-3 mb-3">
                <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-circle"
                     style="width:46px;height:46px;background:rgba(79,124,255,0.12);color:#4f7cff;font-size:.95rem;font-weight:700;">
                    {{ message.from_name|slice(0,1)|upper ?: '?' }}
                </div>
                <div class="flex-grow-1 min-width-0">
                    <div class="fw-700 fs-md">{{ message.from_name ?: message.from }}</div>
                    <div class="text-muted" style="font-size:.8rem;">&lt;{{ message.from }}&gt;</div>
                    <div class="d-flex flex-wrap gap-3 mt-1" style="font-size:.78rem;color:var(--bs-secondary-color);">
                        <span>
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" class="me-1"><path stroke="currentColor" stroke-width="2" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2"/></svg>
                            An: {{ message.to }}
                        </span>
                        <span>
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" class="me-1"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="12 6 12 12 16 14"/></svg>
                            {% if message.date_ts > 0 %}{{ message.date_ts|date('d.m.Y, H:i') }} Uhr{% else %}{{ message.date }}{% endif %}
                        </span>
                    </div>
                </div>
            </div>

            <h5 class="fw-700 mb-3 pb-3 border-bottom">{{ message.subject }}</h5>

            {# ── Body ── #}
            <div id="mail-body" class="mail-body-content">
                {% if message.body_html %}
                <div class="mail-html-frame" style="width:100%;overflow:auto;">
                    <iframe id="mail-iframe" srcdoc="{{ message.body_html|e('html') }}"
                            style="width:100%;border:none;min-height:400px;background:#fff;"
                            sandbox="allow-same-origin"
                            onload="this.style.height=(this.contentWindow.document.body.scrollHeight+32)+'px'">
                    </iframe>
                </div>
                {% elseif message.body_text %}
                <pre style="white-space:pre-wrap;word-break:break-word;font-family:inherit;font-size:.875rem;line-height:1.6;">{{ message.body_text }}</pre>
                {% else %}
                <p class="text-muted fst-italic">Kein Nachrichteninhalt.</p>
                {% endif %}
            </div>

            {# ── Attachments ── #}
            {% if message.attachments is not empty %}
            <div class="mt-4 pt-3 border-top">
                <div class="fw-600 fs-sm mb-2">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" class="me-1"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                    {{ message.attachments|length }} Anhang/Anhänge
                </div>
                <div class="d-flex flex-wrap gap-2">
                    {% for att in message.attachments %}
                    <div class="d-flex align-items-center gap-2 px-3 py-2 rounded-2" style="background:var(--bs-tertiary-bg);border:1px solid var(--bs-border-color);font-size:.8rem;">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg>
                        <span>{{ att.name }}</span>
                        <span class="text-muted">({{ (att.size / 1024)|round(1) }} KB)</span>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

        </div>
    </div>

    {# ── Quick Reply ── #}
    <div class="panel mt-3">
        <div class="panel-hdr">
            <h2>
                <svg class="sa-icon me-2"><use href="/themes/smart-tierphysio/icons/sprite.svg#corner-up-left"></use></svg>
                Antworten
            </h2>
        </div>
        <div class="panel-container">
            <div class="panel-content p-3">
                <form action="/mailbox/senden" method="POST">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                    <input type="hidden" name="to" value="{{ message.from }}">
                    <input type="hidden" name="subject" value="Re: {{ message.subject }}">

                    <div class="mb-3">
                        <label class="form-label">An</label>
                        <input type="text" class="form-control" value="{{ message.from_name ? message.from_name ~ ' <' ~ message.from ~ '>' : message.from }}" readonly style="opacity:.7;">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Nachricht</label>
                        <textarea name="body" class="form-control" rows="5" placeholder="Ihre Antwort…"
                                  style="resize:vertical;"></textarea>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/mailbox/posteingang" class="btn btn-outline-secondary btn-sm">Abbrechen</a>
                        <button type="submit" class="btn btn-primary btn-sm">
                            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" class="me-1"><line x1="22" y1="2" x2="11" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><polygon stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="22 2 15 22 11 13 2 9 22 2"/></svg>
                            Antwort senden
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

</div>

{# ── Sidebar Info ── #}
<div class="col-12 col-xl-3">
    <div class="panel">
        <div class="panel-hdr">
            <h2>Details</h2>
        </div>
        <div class="panel-content p-0">
            <div class="list-group list-group-flush rounded-0">
                <div class="list-group-item px-3 py-2">
                    <div class="fs-nano text-muted mb-1">Von</div>
                    <div class="fw-600 fs-sm text-truncate">{{ message.from_name ?: message.from }}</div>
                    {% if message.from_name %}<div class="text-muted" style="font-size:.75rem;">{{ message.from }}</div>{% endif %}
                </div>
                <div class="list-group-item px-3 py-2">
                    <div class="fs-nano text-muted mb-1">Datum</div>
                    <div class="fw-500 fs-sm">
                        {% if message.date_ts > 0 %}{{ message.date_ts|date('d.m.Y') }}{% else %}—{% endif %}
                    </div>
                    <div class="text-muted" style="font-size:.75rem;">
                        {% if message.date_ts > 0 %}{{ message.date_ts|date('H:i') }} Uhr{% endif %}
                    </div>
                </div>
                <div class="list-group-item px-3 py-2">
                    <div class="fs-nano text-muted mb-1">Ordner</div>
                    <div class="fw-500 fs-sm">{{ folder }}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="panel mt-3">
        <div class="panel-content p-3 d-flex flex-column gap-2">
            <a href="/mailbox/neu?to={{ message.from|url_encode }}&subject={{ ('Re: ' ~ message.subject)|url_encode }}&reply={{ message.uid }}&folder={{ folder|url_encode }}"
               class="btn btn-outline-primary btn-sm w-100">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" class="me-1"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="9 17 4 12 9 7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M20 18v-2a4 4 0 0 0-4-4H4"/></svg>
                Antworten
            </a>
            <a href="/mailbox/neu?to={{ message.from|url_encode }}&subject={{ ('Fwd: ' ~ message.subject)|url_encode }}"
               class="btn btn-outline-secondary btn-sm w-100">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" class="me-1"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="15 17 20 12 15 7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M4 18v-2a4 4 0 0 1 4-4h12"/></svg>
                Weiterleiten
            </a>
            <form action="/mailbox/loeschen/{{ message.uid }}" method="POST" onsubmit="return confirm('Nachricht löschen?')">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <input type="hidden" name="folder" value="{{ folder }}">
                <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24" class="me-1"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                    Löschen
                </button>
            </form>
        </div>
    </div>
</div>

</div>
</div>

{% endblock %}
