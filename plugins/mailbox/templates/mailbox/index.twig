{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" style="vertical-align:-3px;margin-right:6px;"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="22,6 12,13 2,6"/></svg>
            Mailbox
        </h1>
        <p class="page-subtitle">E-Mails lesen und schreiben</p>
    </div>
    <div>
        <a href="/mailbox/neu" class="btn btn-primary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" class="me-1"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            Neue E-Mail
        </a>
    </div>
</div>

{% if not cfg_ok %}
{# ── Not configured ── #}
<div class="panel">
    <div class="panel-content p-5 text-center">
        <svg width="56" height="56" fill="none" viewBox="0 0 24 24" class="mb-3 opacity-40"><path stroke="currentColor" stroke-width="1.5" d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline stroke="currentColor" stroke-width="1.5" points="22,6 12,13 2,6"/></svg>
        <h4 class="mb-2">Mailbox nicht konfiguriert</h4>
        <p class="text-muted mb-4">Bitte IMAP-Einstellungen in den Systemeinstellungen hinterlegen.<br>Benötigt: IMAP-Host, Port, Verschlüsselung, Benutzername und Passwort.</p>
        <a href="/einstellungen" class="btn btn-primary">Zu den Einstellungen →</a>
    </div>
</div>

{% else %}

<div class="main-content p-0">
<div class="row g-0" style="min-height:calc(100vh - 160px);">

    {# ── Sidebar ── #}
    <div class="col-12 col-md-3 col-xl-2" style="border-right:1px solid var(--bs-border-color);">
        <div class="p-3">
            <a href="/mailbox/neu" class="btn btn-primary w-100 mb-3">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" class="me-1"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 20h9"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                Verfassen
            </a>

            <nav class="d-flex flex-column gap-1">
                <a href="/mailbox/posteingang"
                   class="d-flex align-items-center gap-2 px-3 py-2 rounded-2 text-decoration-none fw-500 fs-sm {{ active_folder == 'inbox' ? 'bg-primary text-white' : 'text-body' }}"
                   style="{{ active_folder == 'inbox' ? '' : 'transition:background .12s;' }}"
                   onmouseenter="{{ active_folder != 'inbox' ? 'this.style.background=\'var(--bs-tertiary-bg)\'' : '' }}"
                   onmouseleave="{{ active_folder != 'inbox' ? 'this.style.background=\'transparent\'' : '' }}">
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M22 12h-6l-2 3h-4l-2-3H2"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
                    Posteingang
                    {% if unread_count > 0 %}
                    <span class="badge ms-auto {{ active_folder == 'inbox' ? 'bg-white text-primary' : 'bg-primary' }}" style="font-size:.65rem;">{{ unread_count }}</span>
                    {% endif %}
                </a>

                <a href="/mailbox/gesendet"
                   class="d-flex align-items-center gap-2 px-3 py-2 rounded-2 text-decoration-none fw-500 fs-sm {{ active_folder == 'sent' ? 'bg-primary text-white' : 'text-body' }}"
                   onmouseenter="{{ active_folder != 'sent' ? 'this.style.background=\'var(--bs-tertiary-bg)\'' : '' }}"
                   onmouseleave="{{ active_folder != 'sent' ? 'this.style.background=\'transparent\'' : '' }}">
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><polygon stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    Gesendet
                </a>

                <a href="/mailbox/entwuerfe"
                   class="d-flex align-items-center gap-2 px-3 py-2 rounded-2 text-decoration-none fw-500 fs-sm {{ active_folder == 'drafts' ? 'bg-primary text-white' : 'text-body' }}"
                   onmouseenter="{{ active_folder != 'drafts' ? 'this.style.background=\'var(--bs-tertiary-bg)\'' : '' }}"
                   onmouseleave="{{ active_folder != 'drafts' ? 'this.style.background=\'transparent\'' : '' }}">
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 20h9"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                    Entwürfe
                </a>
            </nav>
        </div>
    </div>

    {# ── Message List ── #}
    <div class="col-12 col-md-9 col-xl-10">

        {% if error is defined and error %}
        <div class="alert alert-danger m-3">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" class="me-2"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            <strong>Verbindungsfehler:</strong> {{ error }}
            <div class="mt-2 fs-sm text-muted">Bitte IMAP-Einstellungen unter <a href="/einstellungen">Einstellungen</a> prüfen.</div>
        </div>
        {% endif %}

        {# Toolbar #}
        <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom gap-2 flex-wrap">
            <div class="d-flex align-items-center gap-2">
                <span class="fw-600 fs-sm">
                    {% if active_folder == 'inbox' %}Posteingang
                    {% elseif active_folder == 'sent' %}Gesendet
                    {% else %}Entwürfe{% endif %}
                </span>
                {% if total > 0 %}
                <span class="badge bg-secondary">{{ total }} Nachrichten</span>
                {% endif %}
            </div>
            <button class="btn btn-outline-secondary btn-sm" onclick="location.reload()">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="1 4 1 10 7 10"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M3.51 15a9 9 0 1 0 .49-4.95"/></svg>
                Aktualisieren
            </button>
        </div>

        {% if messages is empty %}
        <div class="d-flex flex-column align-items-center justify-content-center py-5 text-muted" style="min-height:300px;">
            <svg width="48" height="48" fill="none" viewBox="0 0 24 24" class="mb-3 opacity-30"><path stroke="currentColor" stroke-width="1.5" d="M22 12h-6l-2 3h-4l-2-3H2"/><path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
            <span class="fs-sm">Keine Nachrichten vorhanden</span>
        </div>
        {% else %}

        <div class="list-group list-group-flush rounded-0">
            {% for msg in messages %}
            <a href="/mailbox/nachricht/{{ msg.uid }}?folder={{ folder|url_encode }}"
               class="list-group-item list-group-item-action d-flex align-items-start gap-3 px-3 py-3 text-decoration-none {{ msg.unread ? 'fw-600' : '' }}"
               style="{{ msg.unread ? 'border-left:3px solid var(--bs-primary);' : 'border-left:3px solid transparent;' }}">

                {# Avatar #}
                <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-circle"
                     style="width:38px;height:38px;background:{% if msg.unread %}rgba(79,124,255,0.15){% else %}var(--bs-tertiary-bg){% endif %};font-size:.8rem;font-weight:700;color:{% if msg.unread %}#4f7cff{% else %}var(--bs-secondary-color){% endif %};">
                    {{ msg.from_name|slice(0,1)|upper ?: '?' }}
                </div>

                <div class="flex-grow-1 min-width-0">
                    <div class="d-flex justify-content-between align-items-baseline gap-2 mb-1">
                        <span class="text-truncate {{ msg.unread ? 'fw-700' : 'fw-500' }}" style="font-size:.875rem;">
                            {{ msg.from_name ?: msg.from }}
                        </span>
                        <span class="flex-shrink-0 text-muted" style="font-size:.72rem;white-space:nowrap;">
                            {% if msg.date_ts > 0 %}
                                {% set diff = 'now'|date('U') - msg.date_ts %}
                                {% if diff < 3600 %}{{ (diff / 60)|round }}m
                                {% elseif diff < 86400 %}{{ (diff / 3600)|round }}h
                                {% elseif diff < 604800 %}{{ msg.date_ts|date('D') }}
                                {% else %}{{ msg.date_ts|date('d.m.Y') }}{% endif %}
                            {% endif %}
                        </span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        {% if msg.unread %}
                        <span class="flex-shrink-0" style="width:6px;height:6px;border-radius:50%;background:#4f7cff;display:inline-block;"></span>
                        {% endif %}
                        <span class="text-truncate" style="font-size:.825rem;color:var(--bs-body-color);">{{ msg.subject }}</span>
                    </div>
                </div>

                {% if msg.flagged %}
                <div class="flex-shrink-0 text-warning" title="Markiert">
                    <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </div>
                {% endif %}
            </a>
            {% endfor %}
        </div>

        {# Pagination #}
        {% if total_pages > 1 %}
        <div class="d-flex justify-content-center align-items-center gap-2 p-3 border-top">
            {% if page > 1 %}
            <a href="?seite={{ page - 1 }}" class="btn btn-outline-secondary btn-sm">← Vorherige</a>
            {% endif %}
            <span class="text-muted fs-sm">Seite {{ page }} / {{ total_pages }}</span>
            {% if page < total_pages %}
            <a href="?seite={{ page + 1 }}" class="btn btn-outline-secondary btn-sm">Nächste →</a>
            {% endif %}
        </div>
        {% endif %}

        {% endif %}{# /messages empty #}
    </div>
</div>
</div>
{% endif %}

{% endblock %}
